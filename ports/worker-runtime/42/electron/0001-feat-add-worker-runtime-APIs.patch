+SharedWorkerMap& GetSharedWorkerMap() {
+  static base::NoDestructor<SharedWorkerMap> instance;
+  return *instance;
+}
+
+void SetConstructorPrototype(
+    v8::Isolate* isolate,
+    v8::Local<v8::Function> constructor,
+    const gin_helper::Handle<SharedWorkerMain>& handle) {
+  if (handle.IsEmpty() || !handle.ToV8()->IsObject())
+    return;
+
+  v8::Local<v8::Context> context = isolate->GetCurrentContext();
+  v8::Local<v8::Value> prototype;
+  if (!constructor->Get(context, gin::StringToV8(isolate, "prototype"))
+           .ToLocal(&prototype) ||
+      !prototype->IsObject()) {
+    return;
+  }
+
+  [[maybe_unused]] bool ok = handle.ToV8()
+                                 .As<v8::Object>()
+                                 ->SetPrototype(context,
+                                                prototype.As<v8::Object>())
+                                 .FromMaybe(false);
+}
+
+}  // namespace
+
+gin::DeprecatedWrapperInfo SharedWorkerMain::kWrapperInfo = {
+    gin::kEmbedderNativeGin};
+
+SharedWorkerMain::SharedWorkerMain(const blink::SharedWorkerToken& token)
+    : token_(token), id_(token.ToString()) {
+  GetSharedWorkerMap().emplace(token_, this);
+}
+
+SharedWorkerMain::~SharedWorkerMain() {
+  Destroy();
+}
+
+void SharedWorkerMain::Destroy() {
+  if (destroyed_)
+    return;
+  destroyed_ = true;
+  if (base::FindPtrOrNull(GetSharedWorkerMap(), token_) == this)
+    GetSharedWorkerMap().erase(token_);
+  Unpin();
+}
+
+// static
+void SharedWorkerMain::DestroyToken(const blink::SharedWorkerToken& token) {
+  if (auto* worker = FromToken(token))
+    worker->Destroy();
+}
+
+content::SharedWorkerHost* SharedWorkerMain::GetHost() const {
+  if (destroyed_)
+    return nullptr;
+  return ElectronApiWorkerIPCHandlerImpl::GetSharedWorkerHost(token_);
+}
+
+mojom::ElectronRenderer* SharedWorkerMain::GetRendererApi() const {
+  if (destroyed_)
+    return nullptr;
+  return ElectronApiWorkerIPCHandlerImpl::GetSharedWorkerRenderer(token_);
+}
+
+bool SharedWorkerMain::IsDestroyed() const {
+  return destroyed_ || !GetHost();
+}
+
+std::string SharedWorkerMain::ID() const {
+  return id_;
+}
+
+int SharedWorkerMain::ProcessID() const {
+  auto* host = GetHost();
+  return host ? host->GetProcessHost()->GetID().GetUnsafeValue() : -1;
+}
+
+GURL SharedWorkerMain::URL() const {
+  auto* host = GetHost();
+  if (!host)
+    return {};
+  if (host->final_response_url().is_valid())
+    return host->final_response_url();
+  return host->instance().url();
+}
+
+std::string SharedWorkerMain::Name() const {
+  auto* host = GetHost();
+  return host ? host->instance().name() : std::string();
+}
+
+api::Session* SharedWorkerMain::Session() const {
+  auto* host = GetHost();
+  if (!host)
+    return nullptr;
+  auto* cell = api::Session::FromBrowserContext(
+      host->GetProcessHost()->GetBrowserContext());
+  return cell ? cell->Get() : nullptr;
+}
+
+std::vector<content::RenderFrameHost*> SharedWorkerMain::GetClientFrames()
+    const {
+  std::vector<content::RenderFrameHost*> frames;
+  auto* host = GetHost();
+  if (!host)
+    return frames;
+
+  for (const auto& id : host->GetRenderFrameIDsForWorker()) {
+    if (auto* frame = content::RenderFrameHost::FromID(id))
+      frames.push_back(frame);
+  }
+  return frames;
+}
+
+void SharedWorkerMain::Send(v8::Isolate* isolate,
+                            bool internal,
+                            const std::string& channel,
+                            v8::Local<v8::Value> args) {
+  blink::CloneableMessage message;
+  if (!gin::ConvertFromV8(isolate, args, &message)) {
+    isolate->ThrowException(v8::Exception::Error(
+        gin::StringToV8(isolate, "Failed to serialize arguments")));
+    return;
+  }
+
+  auto* renderer_api = GetRendererApi();
+  if (!renderer_api)
+    return;
+
+  renderer_api->Message(internal, channel, std::move(message));
+}
+
+v8::Local<v8::Promise> SharedWorkerMain::ExecuteJavaScript(
+    v8::Isolate* isolate,
+    const std::string& code) {
+  auto promise =
+      std::make_shared<gin_helper::Promise<v8::Local<v8::Value>>>(isolate);
+  v8::Local<v8::Promise> handle = promise->GetHandle();
+
+  auto* renderer_api = GetRendererApi();
+  if (!renderer_api) {
+    promise->RejectWithErrorMessage(
+        "Shared worker is no longer running or has been destroyed");
+    return handle;
+  }
+
+  renderer_api->ExecuteJavaScript(
+      code, base::BindOnce(&ResolveWorkerExecuteJavaScript, promise));
+  return handle;
+}
+
+// static
+gin_helper::Handle<SharedWorkerMain> SharedWorkerMain::New(
+    v8::Isolate* isolate) {
+  return {};
+}
+
+// static
+gin_helper::Handle<SharedWorkerMain> SharedWorkerMain::From(
+    v8::Isolate* isolate,
+    content::SharedWorkerHost* host) {
+  if (!host)
+    return {};
+  return FromToken(isolate, host->token());
+}
+
+// static
+gin_helper::Handle<SharedWorkerMain> SharedWorkerMain::FromToken(
+    v8::Isolate* isolate,
+    const blink::SharedWorkerToken& token) {
+  v8::Local<v8::Function> constructor =
+      GetConstructor(isolate, isolate->GetCurrentContext());
+
+  if (auto* worker = FromToken(token)) {
+    auto handle = gin_helper::CreateHandle(isolate, worker);
+    SetConstructorPrototype(isolate, constructor, handle);
+    return handle;
+  }
+
+  if (!ElectronApiWorkerIPCHandlerImpl::GetSharedWorkerHost(token))
+    return {};
+
+  auto handle = gin_helper::CreateHandle(isolate, new SharedWorkerMain(token));
+  handle->Pin(isolate);
+  SetConstructorPrototype(isolate, constructor, handle);
+  return handle;
+}
+
+// static
+SharedWorkerMain* SharedWorkerMain::FromToken(
+    const blink::SharedWorkerToken& token) {
+  return base::FindPtrOrNull(GetSharedWorkerMap(), token);
+}
+
+// static
+void SharedWorkerMain::FillObjectTemplate(v8::Isolate* isolate,
+                                          v8::Local<v8::ObjectTemplate> templ) {
+  gin_helper::ObjectTemplateBuilder(isolate, templ)
+      .SetMethod("_send", &SharedWorkerMain::Send)
+      .SetMethod("executeJavaScript", &SharedWorkerMain::ExecuteJavaScript)
+      .SetMethod("isDestroyed", &SharedWorkerMain::IsDestroyed)
+      .SetMethod("getClientFrames", &SharedWorkerMain::GetClientFrames)
+      .SetProperty("id", &SharedWorkerMain::ID)
+      .SetProperty("processId", &SharedWorkerMain::ProcessID)
+      .SetProperty("url", &SharedWorkerMain::URL)
+      .SetProperty("name", &SharedWorkerMain::Name)
+      .SetProperty("session", &SharedWorkerMain::Session)
+      .Build();
+}
+
+const char* SharedWorkerMain::GetTypeName() {
+  return GetClassName();
+}
+
+}  // namespace electron::api
+
+namespace {
+
+using electron::api::SharedWorkerMain;
+
+void Initialize(v8::Local<v8::Object> exports,
+                v8::Local<v8::Value> unused,
+                v8::Local<v8::Context> context,
+                void* priv) {
+  v8::Isolate* const isolate = electron::JavascriptEnvironment::GetIsolate();
+  gin_helper::Dictionary dict{isolate, exports};
+  dict.Set("SharedWorkerMain",
+           SharedWorkerMain::GetConstructor(isolate, context));
+}
+
+}  // namespace
+
+NODE_LINKED_BINDING_CONTEXT_AWARE(electron_browser_shared_worker_main,
+                                  Initialize)
