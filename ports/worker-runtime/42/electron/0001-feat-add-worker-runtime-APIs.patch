+
+namespace electron::renderer_util {
+
+namespace {
+
+std::string ToErrorString(v8::Isolate* isolate, v8::Local<v8::Value> value) {
+  if (value.IsEmpty())
+    return "JavaScript execution failed";
+  return gin::V8ToString(isolate, value);
+}
+
+}  // namespace
+
+void EmitIPCMessageInContext(v8::Isolate* isolate,
+                             v8::Local<v8::Context> context,
+                             bool internal,
+                             const std::string& channel,
+                             const blink::CloneableMessage& arguments) {
+  if (context.IsEmpty())
+    return;
+
+  v8::Context::Scope context_scope(context);
+  v8::Local<v8::Value> args = gin::ConvertToV8(isolate, arguments);
+  ipc_native::EmitIPCEvent(isolate, context, internal, channel, {}, args);
+}
+
+void EmitIPCPostMessageInContext(v8::Isolate* isolate,
+                                 v8::Local<v8::Context> context,
+                                 const std::string& channel,
+                                 blink::TransferableMessage message) {
+  if (context.IsEmpty())
+    return;
+
+  v8::Context::Scope context_scope(context);
+  v8::Local<v8::Value> message_value = DeserializeV8Value(isolate, message);
+
+  std::vector<v8::Local<v8::Value>> ports;
+  for (auto& port : message.ports) {
+    ports.emplace_back(
+        blink::WebMessagePortConverter::EntangleAndInjectMessagePortChannel(
+            isolate, context, std::move(port)));
+  }
+
+  std::vector<v8::Local<v8::Value>> args = {message_value};
+  ipc_native::EmitIPCEvent(isolate, context, false, channel, ports,
+                           gin::ConvertToV8(isolate, args));
+}
+
+void ExecuteJavaScriptInContext(
+    v8::Isolate* isolate,
+    v8::Local<v8::Context> context,
+    const std::string& code,
+    mojom::ElectronRenderer::ExecuteJavaScriptCallback callback) {
+  if (context.IsEmpty()) {
+    std::move(callback).Run({}, "JavaScript context was released");
+    return;
+  }
+
+  v8::Context::Scope context_scope(context);
+  v8::TryCatch try_catch(isolate);
+
+  v8::Local<v8::String> source = gin::StringToV8(isolate, code);
+  v8::Local<v8::Script> script;
+  if (!v8::Script::Compile(context, source).ToLocal(&script)) {
+    std::move(callback).Run({}, ToErrorString(isolate, try_catch.Exception()));
+    return;
+  }
+
+  v8::Local<v8::Value> value;
+  if (!script->Run(context).ToLocal(&value)) {
+    std::move(callback).Run({}, ToErrorString(isolate, try_catch.Exception()));
+    return;
+  }
+
+  blink::CloneableMessage result;
+  if (!SerializeV8Value(isolate, value, &result)) {
+    std::move(callback).Run({}, "Failed to serialize JavaScript result");
+    return;
+  }
+
+  std::move(callback).Run(std::move(result), {});
+}
+
+void TakeHeapSnapshot(
+    v8::Isolate* isolate,
+    mojo::ScopedHandle file,
+    mojom::ElectronRenderer::TakeHeapSnapshotCallback callback) {
+  ScopedAllowBlockingForElectron allow_blocking;
+
+  base::ScopedPlatformFile platform_file;
+  if (mojo::UnwrapPlatformFile(std::move(file), &platform_file) !=
+      MOJO_RESULT_OK) {
+    LOG(ERROR) << "Unable to get the file handle from mojo.";
+    std::move(callback).Run(false);
+    return;
+  }
+
+  base::File base_file(std::move(platform_file));
+  std::move(callback).Run(electron::TakeHeapSnapshot(isolate, &base_file));
+}
+
+}  // namespace electron::renderer_util
