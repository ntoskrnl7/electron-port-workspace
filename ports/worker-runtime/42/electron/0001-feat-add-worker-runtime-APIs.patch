+  it('does not run default dedicated worker preloads before debugger wait-for-start evaluation', async () => {
+    const result = await inspectDedicatedWorkerPreloadDuringDebuggerWait();
+
+    expect(result).to.deep.equal({
+      beforeContinue: false,
+      afterContinue: true
