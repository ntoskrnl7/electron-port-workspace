+namespace electron::api {
+
+namespace {
+
+content::SharedWorkerServiceImpl* AsImpl(
+    content::SharedWorkerService* shared_worker_service) {
+  return static_cast<content::SharedWorkerServiceImpl*>(shared_worker_service);
+}
+
+class SharedWorkerCollector final
+    : public content::SharedWorkerService::Observer {
+ public:
+  std::vector<blink::SharedWorkerToken> tokens;
+
+  void OnWorkerCreated(const blink::SharedWorkerToken& token,
+                       content::ChildProcessId worker_process_id,
+                       const url::Origin& security_origin,
+                       const base::UnguessableToken& dev_tools_token) override {
+    tokens.push_back(token);
+  }
+  void OnBeforeWorkerDestroyed(const blink::SharedWorkerToken& token) override {
+  }
+  void OnFinalResponseURLDetermined(const blink::SharedWorkerToken& token,
+                                    const GURL& url) override {}
+  void OnClientAdded(
+      const blink::SharedWorkerToken& token,
+      content::GlobalRenderFrameHostId render_frame_host_id) override {}
+  void OnClientRemoved(
+      const blink::SharedWorkerToken& token,
+      content::GlobalRenderFrameHostId render_frame_host_id) override {}
+};
+
+v8::Local<v8::Value> SharedWorkerInfoToDict(v8::Isolate* isolate,
+                                            content::SharedWorkerHost* host) {
+  if (!host)
+    return v8::Undefined(isolate);
+
+  const GURL& script_url = host->final_response_url().is_valid()
+                               ? host->final_response_url()
+                               : host->instance().url();
+  return gin::DataObjectBuilder(isolate)
+      .Set("id", host->token().ToString())
+      .Set("name", host->instance().name())
+      .Set("url", host->instance().url().spec())
+      .Set("scriptURL", script_url.spec())
+      .Set("renderProcessId", host->GetProcessHost()->GetID().GetUnsafeValue())
+      .Build();
+}
+
+}  // namespace
+
+const gin::WrapperInfo SharedWorkerContext::kWrapperInfo = {
+    {gin::kEmbedderNativeGin},
+    gin::kElectronSharedWorkerContext};
+
+SharedWorkerContext::SharedWorkerContext(
+    v8::Isolate* isolate,
+    ElectronBrowserContext* browser_context)
+    : shared_worker_service_{browser_context->GetDefaultStoragePartition()
+                                 ->GetSharedWorkerService()} {
+  shared_worker_service_->AddObserver(this);
+}
+
+SharedWorkerContext::~SharedWorkerContext() {
+  if (shared_worker_service_)
+    shared_worker_service_->RemoveObserver(this);
+}
+
+v8::Local<v8::Value> SharedWorkerContext::GetAllRunning(v8::Isolate* isolate) {
+  gin::DataObjectBuilder builder(isolate);
+  SharedWorkerCollector collector;
+  shared_worker_service_->EnumerateSharedWorkers(&collector);
+  auto* service = AsImpl(shared_worker_service_);
+  for (const auto& token : collector.tokens) {
+    builder.Set(token.ToString(),
+                SharedWorkerInfoToDict(
+                    isolate, service->GetSharedWorkerHostFromToken(token)));
+  }
+  return builder.Build();
+}
+
+v8::Local<v8::Value> SharedWorkerContext::GetWorkerFromID(
+    gin_helper::ErrorThrower thrower,
+    const std::string& worker_id) {
+  SharedWorkerCollector collector;
+  shared_worker_service_->EnumerateSharedWorkers(&collector);
+  auto* service = AsImpl(shared_worker_service_);
+  for (const auto& token : collector.tokens) {
+    if (token.ToString() == worker_id) {
+      return SharedWorkerMain::From(
+                 thrower.isolate(),
+                 service->GetSharedWorkerHostFromToken(token))
+          .ToV8();
+    }
+  }
+  return v8::Undefined(thrower.isolate());
+}
+
+void SharedWorkerContext::OnWorkerCreated(
+    const blink::SharedWorkerToken& token,
+    content::ChildProcessId worker_process_id,
+    const url::Origin& security_origin,
+    const base::UnguessableToken& dev_tools_token) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  EmitWithoutEvent(
+      "created", gin::DataObjectBuilder(isolate)
+                     .Set("id", token.ToString())
+                     .Set("renderProcessId", worker_process_id.GetUnsafeValue())
+                     .Set("origin", security_origin.Serialize())
+                     .Set("devToolsToken", dev_tools_token.ToString())
+                     .Build());
+}
+
+void SharedWorkerContext::OnBeforeWorkerDestroyed(
+    const blink::SharedWorkerToken& token) {
+  SharedWorkerMain::DestroyToken(token);
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  EmitWithoutEvent(
+      "destroyed",
+      gin::DataObjectBuilder(isolate).Set("id", token.ToString()).Build());
+}
+
+void SharedWorkerContext::OnFinalResponseURLDetermined(
+    const blink::SharedWorkerToken& token,
+    const GURL& url) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  EmitWithoutEvent("final-response-url-determined",
+                   gin::DataObjectBuilder(isolate)
+                       .Set("id", token.ToString())
+                       .Set("url", url.spec())
+                       .Build());
+}
+
+void SharedWorkerContext::OnClientAdded(
+    const blink::SharedWorkerToken& token,
+    content::GlobalRenderFrameHostId render_frame_host_id) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  auto details = gin_helper::Dictionary::CreateEmpty(isolate);
+  details.Set("id", token.ToString());
+  details.SetGetter("frame",
+                    content::RenderFrameHost::FromID(render_frame_host_id));
+  EmitWithoutEvent("client-added", details.GetHandle());
+}
+
+void SharedWorkerContext::OnClientRemoved(
+    const blink::SharedWorkerToken& token,
+    content::GlobalRenderFrameHostId render_frame_host_id) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  auto details = gin_helper::Dictionary::CreateEmpty(isolate);
+  details.Set("id", token.ToString());
+  details.SetGetter("frame",
+                    content::RenderFrameHost::FromID(render_frame_host_id));
+  EmitWithoutEvent("client-removed", details.GetHandle());
+}
+
+// static
+SharedWorkerContext* SharedWorkerContext::Create(
+    v8::Isolate* isolate,
+    ElectronBrowserContext* browser_context) {
+  return cppgc::MakeGarbageCollected<SharedWorkerContext>(
+      isolate->GetCppHeap()->GetAllocationHandle(), isolate, browser_context);
+}
+
+gin::ObjectTemplateBuilder SharedWorkerContext::GetObjectTemplateBuilder(
+    v8::Isolate* isolate) {
+  return gin_helper::EventEmitterMixin<
+             SharedWorkerContext>::GetObjectTemplateBuilder(isolate)
+      .SetMethod("getAllRunning", &SharedWorkerContext::GetAllRunning)
+      .SetMethod("getWorkerFromID", &SharedWorkerContext::GetWorkerFromID);
+}
+
+void SharedWorkerContext::Trace(cppgc::Visitor* visitor) const {
+  gin::Wrappable<SharedWorkerContext>::Trace(visitor);
+  visitor->Trace(weak_factory_);
+}
+
+const gin::WrapperInfo* SharedWorkerContext::wrapper_info() const {
+  return &kWrapperInfo;
+}
+
+const char* SharedWorkerContext::GetHumanReadableName() const {
+  return "Electron / SharedWorkerContext";
+}
+
+}  // namespace electron::api
