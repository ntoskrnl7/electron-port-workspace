+namespace electron {
+
+namespace {
+
+using DedicatedWorkerHandlerMap =
+    base::flat_map<blink::DedicatedWorkerToken,
+                   ElectronApiWorkerIPCHandlerImpl*>;
+using SharedWorkerHandlerMap =
+    base::flat_map<blink::SharedWorkerToken, ElectronApiWorkerIPCHandlerImpl*>;
+
+DedicatedWorkerHandlerMap& GetDedicatedWorkerHandlerMap() {
+  static base::NoDestructor<DedicatedWorkerHandlerMap> instance;
+  return *instance;
+}
+
+SharedWorkerHandlerMap& GetSharedWorkerHandlerMap() {
+  static base::NoDestructor<SharedWorkerHandlerMap> instance;
+  return *instance;
+}
+
+ElectronApiWorkerIPCHandlerImpl* FromDedicatedWorkerToken(
+    const blink::DedicatedWorkerToken& token) {
+  return base::FindPtrOrNull(GetDedicatedWorkerHandlerMap(), token);
+}
+
+ElectronApiWorkerIPCHandlerImpl* FromSharedWorkerToken(
+    const blink::SharedWorkerToken& token) {
+  return base::FindPtrOrNull(GetSharedWorkerHandlerMap(), token);
+}
+
+content::DedicatedWorkerServiceImpl* GetDedicatedWorkerService(
+    content::RenderProcessHost* render_process_host) {
+  if (!render_process_host)
+    return nullptr;
+  auto* storage_partition = render_process_host->GetStoragePartition();
+  if (!storage_partition)
+    return nullptr;
+  return static_cast<content::DedicatedWorkerServiceImpl*>(
+      storage_partition->GetDedicatedWorkerService());
+}
+
+content::SharedWorkerServiceImpl* GetSharedWorkerService(
+    content::RenderProcessHost* render_process_host) {
+  if (!render_process_host)
+    return nullptr;
+  auto* storage_partition = render_process_host->GetStoragePartition();
+  if (!storage_partition)
+    return nullptr;
+  return static_cast<content::SharedWorkerServiceImpl*>(
+      storage_partition->GetSharedWorkerService());
+}
+
+content::WebContents* GetDedicatedWorkerWebContents(
+    const blink::DedicatedWorkerToken& token) {
+  auto* host = ElectronApiWorkerIPCHandlerImpl::GetDedicatedWorkerHost(token);
+  if (!host)
+    return nullptr;
+  auto* ancestor =
+      content::RenderFrameHost::FromID(host->GetAncestorRenderFrameHostId());
+  return ancestor ? content::WebContents::FromRenderFrameHost(ancestor)
+                  : nullptr;
+}
+
+}  // namespace
+
+ElectronApiWorkerIPCHandlerImpl::ElectronApiWorkerIPCHandlerImpl(
+    content::RenderProcessHost* render_process_host,
+    Type type,
+    blink::WorkerToken token,
+    mojo::PendingRemote<mojom::ElectronRenderer> renderer)
+    : render_process_host_(render_process_host),
+      type_(type),
+      token_(std::move(token)) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (type_ == Type::kDedicatedWorker) {
+    const auto& dedicated_token =
+        token_.GetAs<blink::DedicatedWorkerToken>();
+    GetDedicatedWorkerHandlerMap()[dedicated_token] = this;
+  } else {
+    const auto& shared_token = token_.GetAs<blink::SharedWorkerToken>();
+    GetSharedWorkerHandlerMap()[shared_token] = this;
+  }
+
+  renderer_.Bind(std::move(renderer));
+  renderer_.set_disconnect_handler(
+      base::BindOnce(&ElectronApiWorkerIPCHandlerImpl::RendererDisconnected,
+                     weak_factory_.GetWeakPtr()));
+
+  render_process_host_->AddObserver(this);
+}
+
+ElectronApiWorkerIPCHandlerImpl::~ElectronApiWorkerIPCHandlerImpl() {
+  if (render_process_host_)
+    render_process_host_->RemoveObserver(this);
+  if (type_ == Type::kDedicatedWorker) {
+    const auto& dedicated_token =
+        token_.GetAs<blink::DedicatedWorkerToken>();
+    if (base::FindPtrOrNull(GetDedicatedWorkerHandlerMap(), dedicated_token) ==
+        this)
+      GetDedicatedWorkerHandlerMap().erase(dedicated_token);
+  } else {
+    const auto& shared_token = token_.GetAs<blink::SharedWorkerToken>();
+    if (base::FindPtrOrNull(GetSharedWorkerHandlerMap(), shared_token) == this)
+      GetSharedWorkerHandlerMap().erase(shared_token);
+  }
+}
+
+void ElectronApiWorkerIPCHandlerImpl::RegisterDedicatedWorker(
+    content::RenderProcessHost* render_process_host,
+    const blink::DedicatedWorkerToken& token,
+    mojo::PendingRemote<mojom::ElectronRenderer> renderer) {
+  if (auto* existing = FromDedicatedWorkerToken(token))
+    existing->Destroy();
+  new ElectronApiWorkerIPCHandlerImpl(
+      render_process_host, Type::kDedicatedWorker, blink::WorkerToken(token),
+      std::move(renderer));
+}
+
+void ElectronApiWorkerIPCHandlerImpl::RegisterSharedWorker(
+    content::RenderProcessHost* render_process_host,
+    const blink::SharedWorkerToken& token,
+    mojo::PendingRemote<mojom::ElectronRenderer> renderer) {
+  if (auto* existing = FromSharedWorkerToken(token))
+    existing->Destroy();
+  new ElectronApiWorkerIPCHandlerImpl(render_process_host, Type::kSharedWorker,
+                                      blink::WorkerToken(token),
+                                      std::move(renderer));
+}
+
+void ElectronApiWorkerIPCHandlerImpl::BindDedicatedWorkerIPC(
+    const blink::DedicatedWorkerToken& token,
+    mojo::PendingReceiver<mojom::ElectronApiIPC> receiver) {
+  if (auto* handler = FromDedicatedWorkerToken(token))
+    handler->BindIPCReceiver(std::move(receiver));
+}
+
+void ElectronApiWorkerIPCHandlerImpl::BindSharedWorkerIPC(
+    const blink::SharedWorkerToken& token,
+    mojo::PendingReceiver<mojom::ElectronApiIPC> receiver) {
+  if (auto* handler = FromSharedWorkerToken(token))
+    handler->BindIPCReceiver(std::move(receiver));
+}
+
+mojom::ElectronRenderer*
+ElectronApiWorkerIPCHandlerImpl::GetDedicatedWorkerRenderer(
+    const blink::DedicatedWorkerToken& token) {
+  auto* handler = FromDedicatedWorkerToken(token);
+  return handler && handler->renderer_.is_bound() ? handler->renderer_.get()
+                                                  : nullptr;
+}
+
+mojom::ElectronRenderer*
+ElectronApiWorkerIPCHandlerImpl::GetSharedWorkerRenderer(
+    const blink::SharedWorkerToken& token) {
+  auto* handler = FromSharedWorkerToken(token);
+  return handler && handler->renderer_.is_bound() ? handler->renderer_.get()
+                                                  : nullptr;
+}
+
+content::DedicatedWorkerHost*
+ElectronApiWorkerIPCHandlerImpl::GetDedicatedWorkerHost(
+    const blink::DedicatedWorkerToken& token) {
+  auto* handler = FromDedicatedWorkerToken(token);
+  if (!handler)
+    return nullptr;
+  auto* service = GetDedicatedWorkerService(handler->render_process_host_);
+  return service ? service->GetDedicatedWorkerHostFromToken(token) : nullptr;
+}
+
+content::SharedWorkerHost* ElectronApiWorkerIPCHandlerImpl::GetSharedWorkerHost(
+    const blink::SharedWorkerToken& token) {
+  auto* handler = FromSharedWorkerToken(token);
+  if (!handler)
+    return nullptr;
+  auto* service = GetSharedWorkerService(handler->render_process_host_);
+  return service ? service->GetSharedWorkerHostFromToken(token) : nullptr;
+}
+
+void ElectronApiWorkerIPCHandlerImpl::BindIPCReceiver(
+    mojo::PendingReceiver<mojom::ElectronApiIPC> receiver) {
+  if (receiver_.is_bound())
+    receiver_.reset();
+
+  receiver_.Bind(std::move(receiver));
+  receiver_.set_disconnect_handler(
+      base::BindOnce(&ElectronApiWorkerIPCHandlerImpl::IPCDisconnected,
+                     weak_factory_.GetWeakPtr()));
+}
+
+void ElectronApiWorkerIPCHandlerImpl::RendererDisconnected() {
+  Destroy();
+}
+
+void ElectronApiWorkerIPCHandlerImpl::IPCDisconnected() {
+  receiver_.reset();
+}
+
+void ElectronApiWorkerIPCHandlerImpl::Message(
+    bool internal,
+    const std::string& channel,
+    blink::CloneableMessage arguments) {
+  gin::WeakCell<api::Session>* session = GetSession();
+  if (session && session->Get()) {
+    v8::Isolate* isolate = electron::JavascriptEnvironment::GetIsolate();
+    v8::HandleScope handle_scope(isolate);
+    auto* event = MakeIPCEvent(isolate, session->Get(), internal);
+    if (!event)
+      return;
+    v8::Local<v8::Object> event_object =
+        event->GetWrapper(isolate).ToLocalChecked();
+    session->Get()->Message(event_object, channel, std::move(arguments));
+  }
+}
+
+void ElectronApiWorkerIPCHandlerImpl::Invoke(bool internal,
+                                             const std::string& channel,
+                                             blink::CloneableMessage arguments,
+                                             InvokeCallback callback) {
+  v8::Isolate* isolate = electron::JavascriptEnvironment::GetIsolate();
+  gin::WeakCell<api::Session>* session = GetSession();
+  if (!session || !session->Get()) {
+    gin_helper::internal::ReplyChannel::SendError(isolate, std::move(callback),
+                                                  "Session does not exist");
+    return;
+  }
+
+  v8::HandleScope handle_scope(isolate);
+  auto* event =
+      MakeIPCEvent(isolate, session->Get(), internal, std::move(callback));
+  if (!event)
+    return;
+  v8::Local<v8::Object> event_object =
+      event->GetWrapper(isolate).ToLocalChecked();
+  session->Get()->Invoke(event_object, channel, std::move(arguments));
+}
+
+void ElectronApiWorkerIPCHandlerImpl::ReceivePostMessage(
+    const std::string& channel,
+    blink::TransferableMessage message) {
+  gin::WeakCell<api::Session>* session = GetSession();
+  if (session && session->Get()) {
+    v8::Isolate* isolate = electron::JavascriptEnvironment::GetIsolate();
+    v8::HandleScope handle_scope(isolate);
+    auto* event = MakeIPCEvent(isolate, session->Get(), false);
+    if (!event)
+      return;
+    v8::Local<v8::Object> event_object =
+        event->GetWrapper(isolate).ToLocalChecked();
+    session->Get()->ReceivePostMessage(event_object, channel,
+                                       std::move(message));
+  }
+}
+
+void ElectronApiWorkerIPCHandlerImpl::MessageSync(
+    bool internal,
+    const std::string& channel,
+    blink::CloneableMessage arguments,
+    MessageSyncCallback callback) {
+  v8::Isolate* isolate = electron::JavascriptEnvironment::GetIsolate();
+  gin::WeakCell<api::Session>* session = GetSession();
+  if (!session || !session->Get()) {
+    gin_helper::internal::ReplyChannel::SendError(isolate, std::move(callback),
+                                                  "Session does not exist");
+    return;
+  }
+
+  v8::HandleScope handle_scope(isolate);
+  auto* event =
+      MakeIPCEvent(isolate, session->Get(), internal, std::move(callback));
+  if (!event)
+    return;
+  v8::Local<v8::Object> event_object =
+      event->GetWrapper(isolate).ToLocalChecked();
+  session->Get()->MessageSync(event_object, channel, std::move(arguments));
+}
+
+void ElectronApiWorkerIPCHandlerImpl::MessageHost(
+    const std::string& channel,
+    blink::CloneableMessage arguments) {
+  // Workers have no <webview> host channel.
+}
+
+gin::WeakCell<api::Session>* ElectronApiWorkerIPCHandlerImpl::GetSession() {
+  if (!render_process_host_)
+    return nullptr;
+  return api::Session::FromBrowserContext(
+      render_process_host_->GetBrowserContext());
+}
+
+gin_helper::internal::Event* ElectronApiWorkerIPCHandlerImpl::MakeIPCEvent(
+    v8::Isolate* isolate,
+    api::Session* session,
+    bool internal,
+    electron::mojom::ElectronApiIPC::InvokeCallback callback) {
+  if (!session) {
+    gin_helper::internal::ReplyChannel::SendError(isolate, std::move(callback),
+                                                  "Session does not exist");
+    return {};
+  }
+
+  gin_helper::internal::Event* event =
+      gin_helper::internal::Event::New(isolate);
+  v8::Local<v8::Object> event_object =
+      event->GetWrapper(isolate).ToLocalChecked();
+  gin_helper::Dictionary dict(isolate, event_object);
+
+  dict.Set("processId", render_process_host_->GetID().GetUnsafeValue());
+
+  if (internal)
+    dict.SetHidden("internal", internal);
+
+  if (type_ == Type::kDedicatedWorker) {
+    dict.Set("type", "dedicated-worker");
+    const auto& token = token_.GetAs<blink::DedicatedWorkerToken>();
+    content::WebContents* web_contents = GetDedicatedWorkerWebContents(token);
+    if (!web_contents) {
+      gin_helper::internal::ReplyChannel::SendError(
+          isolate, std::move(callback), "WebContents does not exist");
+      return {};
+    }
+    auto* api_web_contents = api::WebContents::From(web_contents);
+    if (!api_web_contents) {
+      gin_helper::internal::ReplyChannel::SendError(
+          isolate, std::move(callback), "WebContents does not exist");
+      return {};
+    }
+    v8::Local<v8::Object> wrapper;
+    if (!api_web_contents->GetWrapper(isolate).ToLocal(&wrapper)) {
+      gin_helper::internal::ReplyChannel::SendError(
+          isolate, std::move(callback), "WebContents was destroyed");
+      return {};
+    }
+    dict.Set("sender", web_contents);
+    dict.Set("senderDedicatedWorker",
+             api::DedicatedWorkerMain::FromToken(isolate, token).ToV8());
+  } else {
+    dict.Set("type", "shared-worker");
+    const auto& token = token_.GetAs<blink::SharedWorkerToken>();
+    dict.Set("session", session);
+    dict.Set("sharedWorker",
+             api::SharedWorkerMain::FromToken(isolate, token).ToV8());
+  }
+
+  if (callback)
+    dict.Set("_replyChannel", gin_helper::internal::ReplyChannel::Create(
+                                  isolate, std::move(callback)));
+
+  return event;
+}
+
+void ElectronApiWorkerIPCHandlerImpl::RenderProcessExited(
+    content::RenderProcessHost* host,
+    const content::ChildProcessTerminationInfo& info) {
+  CHECK_EQ(host, render_process_host_);
+  Destroy();
+}
+
+void ElectronApiWorkerIPCHandlerImpl::Destroy() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  weak_factory_.InvalidateWeakPtrs();
+  if (type_ == Type::kDedicatedWorker) {
+    api::DedicatedWorkerMain::DestroyToken(
+        token_.GetAs<blink::DedicatedWorkerToken>());
+  } else {
+    api::SharedWorkerMain::DestroyToken(
+        token_.GetAs<blink::SharedWorkerToken>());
+  }
+  delete this;
+}
+
+ElectronWorkerAPIImpl::ElectronWorkerAPIImpl(
+    content::RenderProcessHost* render_process_host)
+    : render_process_host_(render_process_host) {}
+
+ElectronWorkerAPIImpl::~ElectronWorkerAPIImpl() = default;
+
+void ElectronWorkerAPIImpl::Create(
+    content::RenderProcessHost* render_process_host,
+    mojo::PendingReceiver<mojom::ElectronWorkerAPI> receiver) {
+  mojo::MakeSelfOwnedReceiver(
+      std::make_unique<ElectronWorkerAPIImpl>(render_process_host),
+      std::move(receiver));
+}
+
+void ElectronWorkerAPIImpl::RegisterDedicatedWorker(
+    const blink::DedicatedWorkerToken& token,
+    mojo::PendingRemote<mojom::ElectronRenderer> renderer) {
+  ElectronApiWorkerIPCHandlerImpl::RegisterDedicatedWorker(
+      render_process_host_, token, std::move(renderer));
+}
+
+void ElectronWorkerAPIImpl::RegisterSharedWorker(
+    const blink::SharedWorkerToken& token,
+    mojo::PendingRemote<mojom::ElectronRenderer> renderer) {
+  ElectronApiWorkerIPCHandlerImpl::RegisterSharedWorker(
+      render_process_host_, token, std::move(renderer));
+}
+
+void ElectronWorkerAPIImpl::BindDedicatedWorkerIPC(
+    const blink::DedicatedWorkerToken& token,
+    mojo::PendingReceiver<mojom::ElectronApiIPC> receiver) {
+  ElectronApiWorkerIPCHandlerImpl::BindDedicatedWorkerIPC(token,
+                                                          std::move(receiver));
+}
+
+void ElectronWorkerAPIImpl::BindSharedWorkerIPC(
+    const blink::SharedWorkerToken& token,
+    mojo::PendingReceiver<mojom::ElectronApiIPC> receiver) {
+  ElectronApiWorkerIPCHandlerImpl::BindSharedWorkerIPC(token,
+                                                       std::move(receiver));
+}
+
+}  // namespace electron
