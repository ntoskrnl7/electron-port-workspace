+    } finally {
+      worker.ipc.removeHandler(`${channel}:invoke-scoped`);
+      w!.webContents.ipc.removeHandler(`${channel}:invoke-owner`);
+      ipcMain.removeHandler(`${channel}:invoke-main`);
