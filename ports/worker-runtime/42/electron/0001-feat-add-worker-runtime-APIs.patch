@@ -0,0 +1,112 @@
+// Copyright (c) 2026 Electron Port Workspace contributors
+// Use of this source code is governed by the MIT license that can be
+// found in the LICENSE file.
+
+#include "shell/renderer/worker_data.h"
+
+#include <utility>
+
+#include "shell/renderer/electron_renderer_v8_util.h"
+#include "third_party/blink/public/common/thread_safe_browser_interface_broker_proxy.h"
+#include "third_party/blink/public/platform/platform.h"
+
+namespace electron {
+namespace {
+
+constinit thread_local WorkerData* g_current_worker_data = nullptr;
+
+}  // namespace
+
+WorkerData::WorkerData(v8::Isolate* isolate,
+                       v8::Local<v8::Context> context,
+                       Type type,
+                       blink::WorkerToken token)
+    : isolate_(isolate),
+      context_(isolate, context),
+      type_(type),
+      token_(std::move(token)),
+      metrics_(base::ProcessMetrics::CreateCurrentProcessMetrics()) {
+  DCHECK(!g_current_worker_data);
+  g_current_worker_data = this;
+
+  blink::Platform::Current()->GetBrowserInterfaceBroker()->GetInterface(
+      worker_api_.BindNewPipeAndPassReceiver());
+
+  mojo::PendingRemote<mojom::ElectronRenderer> renderer;
+  receiver_.Bind(renderer.InitWithNewPipeAndPassReceiver());
+
+  if (type_ == Type::kDedicatedWorker) {
+    worker_api_->RegisterDedicatedWorker(
+        token_.GetAs<blink::DedicatedWorkerToken>(), std::move(renderer));
+  } else {
+    worker_api_->RegisterSharedWorker(token_.GetAs<blink::SharedWorkerToken>(),
+                                      std::move(renderer));
+  }
+}
+
+WorkerData::~WorkerData() {
+  if (g_current_worker_data == this)
+    g_current_worker_data = nullptr;
+}
+
+// static
+WorkerData* WorkerData::GetCurrent() {
+  return g_current_worker_data;
+}
+
+void WorkerData::UpdateContext(v8::Local<v8::Context> context) {
+  context_.Reset(isolate_, context);
+}
+
+void WorkerData::BindIPCReceiver(
+    mojo::PendingReceiver<mojom::ElectronApiIPC> receiver) {
+  if (type_ == Type::kDedicatedWorker) {
+    worker_api_->BindDedicatedWorkerIPC(
+        token_.GetAs<blink::DedicatedWorkerToken>(), std::move(receiver));
+  } else {
+    worker_api_->BindSharedWorkerIPC(token_.GetAs<blink::SharedWorkerToken>(),
+                                     std::move(receiver));
+  }
+}
+
+void WorkerData::Message(bool internal,
+                         const std::string& channel,
+                         blink::CloneableMessage arguments) {
+  v8::Isolate* isolate = isolate_.get();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Context> context = context_.Get(isolate);
+  renderer_util::EmitIPCMessageInContext(isolate, context, internal, channel,
+                                         std::move(arguments));
+}
+
+void WorkerData::ReceivePostMessage(const std::string& channel,
+                                    blink::TransferableMessage message) {
+  v8::Isolate* isolate = isolate_.get();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Context> context = context_.Get(isolate);
+  renderer_util::EmitIPCPostMessageInContext(isolate, context, channel,
+                                             std::move(message));
+}
+
+void WorkerData::ExecuteJavaScript(const std::string& code,
+                                   ExecuteJavaScriptCallback callback) {
+  v8::Isolate* isolate = isolate_.get();
+  v8::HandleScope handle_scope(isolate);
+
+  v8::Local<v8::Context> context = context_.Get(isolate);
+  if (context.IsEmpty()) {
+    std::move(callback).Run({}, "Worker context was released");
+    return;
+  }
+
+  renderer_util::ExecuteJavaScriptInContext(isolate, context, code,
+                                            std::move(callback));
+}
+
+void WorkerData::TakeHeapSnapshot(mojo::ScopedHandle file,
+                                  TakeHeapSnapshotCallback callback) {
+  renderer_util::TakeHeapSnapshot(isolate_, std::move(file),
+                                  std::move(callback));
+}
+
+}  // namespace electron
