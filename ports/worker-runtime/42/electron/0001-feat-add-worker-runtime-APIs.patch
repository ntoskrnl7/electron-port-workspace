 namespace {

+std::string StartExternalRequestErrorToString(
+    content::ServiceWorkerExternalRequestResult result) {
+  switch (result) {
+    case content::ServiceWorkerExternalRequestResult::kOk:
+      return {};
+    case content::ServiceWorkerExternalRequestResult::kWorkerNotRunning:
+      return "Service worker is not running or has been destroyed";
+    case content::ServiceWorkerExternalRequestResult::kWorkerNotFound:
+      return "Service worker was not found";
+    case content::ServiceWorkerExternalRequestResult::kNullContext:
+    case content::ServiceWorkerExternalRequestResult::kBadRequestId:
+    default:
+      return "Service worker context is unavailable and may be shutting down";
+  }
+}
+
 // Use private API to get the live version of the service worker. This will
 // exist while in starting, stopping, or stopped running status.
 content::ServiceWorkerVersion* GetLiveVersion(
@@ -144,6 +162,57 @@ void ServiceWorkerMain::Send(v8::Isolate* isolate,
   renderer_api_remote->Message(internal, channel, std::move(message));
 }

+v8::Local<v8::Promise> ServiceWorkerMain::ExecuteJavaScript(
+    v8::Isolate* isolate,
+    const std::string& code) {
+  auto promise =
+      std::make_shared<gin_helper::Promise<v8::Local<v8::Value>>>(isolate);
+  v8::Local<v8::Promise> handle = promise->GetHandle();
+
+  if (!service_worker_context_->IsLiveRunningServiceWorker(version_id_)) {
+    promise->RejectWithErrorMessage(
+        "Service worker is not running or has been destroyed");
+    return handle;
+  }
+
+  auto request_uuid = base::Uuid::GenerateRandomV4();
+  auto start_result = service_worker_context_->StartingExternalRequest(
+      version_id_, content::ServiceWorkerExternalRequestTimeoutType::
+                       kDoesNotTimeout,
+      request_uuid);
+  if (start_result != content::ServiceWorkerExternalRequestResult::kOk) {
+    promise->RejectWithErrorMessage(
+        StartExternalRequestErrorToString(start_result));
+    return handle;
+  }
+
+  if (!service_worker_context_->ExecuteScriptForTest(
+          code, version_id_,
+          base::BindOnce(&ServiceWorkerMain::OnExecuteJavaScriptComplete,
+                         base::Unretained(this), promise, request_uuid))) {
+    service_worker_context_->FinishedExternalRequest(version_id_, request_uuid);
+    promise->RejectWithErrorMessage(
+        "Service worker is not running or has been destroyed");
+  }
+  return handle;
+}
+
+void ServiceWorkerMain::OnExecuteJavaScriptComplete(
+    std::shared_ptr<gin_helper::Promise<v8::Local<v8::Value>>> promise,
+    base::Uuid request_uuid,
+    base::Value result,
+    const std::optional<std::string>& error) {
+  service_worker_context_->FinishedExternalRequest(version_id_, request_uuid);
+  if (error) {
+    promise->RejectWithErrorMessage(*error);
+    return;
+  }
+
+  v8::Isolate* isolate = promise->isolate();
+  v8::HandleScope handle_scope(isolate);
+  promise->Resolve(gin::ConvertToV8(isolate, result));
+}
