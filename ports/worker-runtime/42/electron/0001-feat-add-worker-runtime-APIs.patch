+
+const dedicatedNodeWorkerScript = `
+const { ipcRenderer } = require('electron');
+
+self.onmessage = async ({ data }) => {
+  if (!data || data.type !== 'run-ipc') return;
+
+  const { channel } = data;
+  try {
+    ipcRenderer.on(\`\${channel}:from-main\`, (_event, value) => {
+      ipcRenderer.send(\`\${channel}:from-main-received\`, value);
+    });
+
+    ipcRenderer.send(\`\${channel}:ping\`, 'payload');
+    const scoped = await ipcRenderer.invoke(\`\${channel}:invoke-scoped\`, 'payload');
+    const owner = await ipcRenderer.invoke(\`\${channel}:invoke-owner\`, 'payload');
+    const main = await ipcRenderer.invoke(\`\${channel}:invoke-main\`, 'payload');
+    const sync = ipcRenderer.sendSync(\`\${channel}:sync\`, 'payload');
+    ipcRenderer.send(\`\${channel}:invoke-results\`, { scoped, owner, main, sync });
+  } catch (error) {
+    ipcRenderer.send(\`\${channel}:invoke-results\`, {
+      error: error instanceof Error ? error.message : String(error)
+    });
+  }
+};
+
+postMessage({ type: 'ready' });
+`;
+
+const dedicatedBasicWorkerScript = `
+postMessage({ type: 'ready' });
+`;
+
+const sharedWorkerScript = `
+self.onconnect = event => {
+  const port = event.ports[0];
+  port.onmessage = event => {
+    port.postMessage({ type: 'echo', value: event.data });
+  };
+  port.start();
+  port.postMessage({ type: 'ready' });
+};
+`;
+
+describe('WorkerMain module', () => {
+  const workerPreload = path.resolve(__dirname, 'fixtures', 'workers', 'worker-ipc-preload.js');
+  const workerInjectionPointPreload = path.resolve(__dirname, 'fixtures', 'workers', 'worker-injection-point-preload.js');
+
+  let server: http.Server;
+  let serverUrl: string;
+  let ses: Electron.Session;
+  let w: BrowserWindow | null = null;
+
+  beforeEach(async () => {
+    ses = session.fromPartition(`worker-main-spec-${crypto.randomUUID()}`);
+    server = http.createServer((req, res) => {
+      const url = new URL(req.url!, `http://${req.headers.host}`);
+      switch (url.pathname) {
+        case '/index.html':
+          res.setHeader('Content-Type', 'text/html');
+          res.end('<!doctype html><title>worker-main-spec</title>');
+          break;
+        case '/dedicated-node-worker.js':
+          res.setHeader('Content-Type', 'application/javascript');
+          res.end(dedicatedNodeWorkerScript);
+          break;
+        case '/dedicated-basic-worker.js':
+          res.setHeader('Content-Type', 'application/javascript');
+          res.end(dedicatedBasicWorkerScript);
+          break;
+        case '/shared-worker.js':
+          res.setHeader('Content-Type', 'application/javascript');
+          res.end(sharedWorkerScript);
+          break;
+        default:
+          res.statusCode = 404;
+          res.end();
+      }
+    });
+    ({ url: serverUrl } = await listen(server));
+  });
+
+  afterEach(async () => {
+    await closeWindow(w);
+    w = null;
+    server.close();
+    for (const { id } of ses.getPreloadScripts()) {
+      ses.unregisterPreloadScript(id);
+    }
+  });
+
+  const createWindow = async (webPreferences: Electron.BrowserWindowConstructorOptions['webPreferences'] = {}) => {
+    w = new BrowserWindow({
+      show: false,
+      webPreferences: {
+        session: ses,
+        ...webPreferences
+      }
+    });
+    await w.loadURL(`${serverUrl}/index.html`);
+    return w;
+  };
+
+  const createDedicatedWorker = async (scriptPath: string, channel?: string) => {
+    const workerUrl = `${scriptPath}${channel ? `?channel=${channel}` : ''}`;
+    await w!.webContents.executeJavaScript(`
+      new Promise((resolve, reject) => {
+        const worker = new Worker(${JSON.stringify(workerUrl)});
+        globalThis.workerForTest = worker;
+        worker.onmessage = event => resolve(event.data);
+        worker.onerror = event => reject(event.message);
+      })
+    `);
+  };
+
+  const createSharedWorker = async (channel: string) => {
+    const workerUrl = `/shared-worker.js?channel=${channel}`;
+    await w!.webContents.executeJavaScript(`
+      new Promise((resolve, reject) => {
+        const worker = new SharedWorker(${JSON.stringify(workerUrl)}, 'worker-main-spec');
+        globalThis.sharedWorkerForTest = worker;
+        worker.onerror = event => reject(event.message);
+        worker.port.onmessage = event => resolve(event.data);
+        worker.port.start();
+      })
+    `);
+  };
+
+  const inspectDedicatedWorkerPreloadDuringDebuggerWait = async (
+    injectionPoint?: 'worker-script-ready' | 'context-created'
+  ) => {
+    ses.registerPreloadScript({
+      type: 'dedicated-worker',
+      filePath: workerInjectionPointPreload,
+      ...(injectionPoint ? { injectionPoint } : {})
+    });
+
+    await createWindow();
+
+    const dbg = w!.webContents.debugger;
+    dbg.attach('1.3');
+
+    const expression = 'globalThis.__electronWorkerInjectionPointPreload === true';
+    let workerSessionId = '';
+    let handledWorkerTarget = false;
+    let onMessage: ((event: Electron.Event, method: string, params: any) => void) | undefined;
+
+    const waitForWorkerTarget = new Promise<boolean>((resolve, reject) => {
+      onMessage = (_event: Electron.Event, method: string, params: any) => {
+        if (method !== 'Target.attachedToTarget' || params.targetInfo?.type !== 'worker' || handledWorkerTarget) {
+          return;
+        }
+
+        handledWorkerTarget = true;
+        workerSessionId = params.sessionId;
+        (async () => {
+          try {
+            await dbg.sendCommand('Runtime.enable', {}, workerSessionId);
+            const evaluationPromise = dbg.sendCommand('Runtime.evaluate', {
+              expression,
+              returnByValue: true
+            }, workerSessionId);
+            const beforeContinue = await Promise.race([
+              evaluationPromise,
+              delay(3000).then(() => ({ timedOut: true }))
+            ]);
+            await dbg.sendCommand('Runtime.runIfWaitingForDebugger', {}, workerSessionId);
+            if ('timedOut' in beforeContinue) {
+              throw new Error('timed out evaluating worker preload state before debugger continue');
+            }
+            resolve(Boolean(beforeContinue.result?.value));
+          } catch (error) {
+            try {
+              await dbg.sendCommand('Runtime.runIfWaitingForDebugger', {}, workerSessionId);
+            } catch {
+              // The worker may already have continued or exited.
+            }
+            reject(error);
+          }
+        })();
+      };
+
+      dbg.on('message', onMessage);
+    });
+
+    try {
+      await dbg.sendCommand('Target.setAutoAttach', {
+        autoAttach: true,
+        waitForDebuggerOnStart: true,
+        flatten: true
+      });
+
+      const gonePromise = once(w!.webContents, 'render-process-gone').then(([, details]) => {
+        throw new Error(`renderer process gone while starting dedicated worker: ${JSON.stringify(details)}`);
+      });
+      const workerReadyPromise = createDedicatedWorker('/dedicated-basic-worker.js');
+      const beforeContinue = await Promise.race([
+        waitForWorkerTarget,
+        gonePromise,
+        delay(10000).then(() => {
+          throw new Error('timed out waiting for debugger worker target');
+        })
+      ]);
+
+      await Promise.race([
+        workerReadyPromise,
+        gonePromise,
+        delay(10000).then(() => {
+          throw new Error('timed out waiting for dedicated worker to continue');
+        })
+      ]);
+
+      const afterContinue = await dbg.sendCommand('Runtime.evaluate', {
+        expression,
+        returnByValue: true
+      }, workerSessionId);
+
+      return {
+        beforeContinue,
+        afterContinue: Boolean(afterContinue.result?.value)
+      };
+    } finally {
+      if (onMessage) {
+        dbg.off('message', onMessage);
+      }
+      if (dbg.isAttached()) {
+        dbg.detach();
+      }
+    }
+  };
+
+  const verifyPreloadIpc = async (
+    worker: Electron.DedicatedWorkerMain | Electron.SharedWorkerMain,
+    ownerIpc: Electron.IpcMain | Electron.IpcMainSession | Electron.IpcMainWebContents,
+    channel: string
+  ) => {
+    const workerIpc = worker.ipc as any;
+    const owner = ownerIpc as any;
+    try {
+      workerIpc.handle(`${channel}:invoke-scoped`, (event: Electron.IpcMainDedicatedWorkerInvokeEvent | Electron.IpcMainSharedWorkerInvokeEvent, value: string) => {
+        expect(event.type).to.be.oneOf(['dedicated-worker', 'shared-worker']);
+        return `scoped:${value}`;
+      });
+      owner.handle(`${channel}:invoke-owner`, (_event: Electron.IpcMainDedicatedWorkerInvokeEvent | Electron.IpcMainSharedWorkerInvokeEvent, value: string) => `owner:${value}`);
+      ipcMain.handle(`${channel}:invoke-main`, (_event, value) => `main:${value}`);
+      workerIpc.once(`${channel}:sync`, (event: Electron.IpcMainDedicatedWorkerEvent | Electron.IpcMainSharedWorkerEvent, value: string) => {
+        expect(event.isReturnValueSet).to.equal(false);
+        event.returnValue = `sync:${value}`;
+        expect(event.isReturnValueSet).to.equal(true);
+      });
+      owner.once(`${channel}:sync`, (event: Electron.IpcMainDedicatedWorkerEvent | Electron.IpcMainSharedWorkerEvent) => {
+        expect(event.isReturnValueSet).to.equal(true);
+        event.returnValue = 'ignored-owner-sync-reply';
+        expect(event.isReturnValueSet).to.equal(true);
+      });
+      ipcMain.once(`${channel}:sync`, (event: Electron.IpcMainMessageEvent) => {
+        expect(event.isReturnValueSet).to.equal(true);
+        event.returnValue = 'ignored-main-sync-reply';
+        expect(event.isReturnValueSet).to.equal(true);
+      });
+
+      const fromMainPromise = once(workerIpc, `${channel}:from-main-received`);
+      worker.send(`${channel}:from-main`, 'from-main');
+      const [, fromMainValue] = await fromMainPromise;
+      expect(fromMainValue).to.equal('from-main');
+
+      const resultsPromise = once(workerIpc, `${channel}:invoke-results`);
+      worker.send(`${channel}:run-invoke`);
+      const [, results] = await resultsPromise;
+      expect(results).to.deep.equal({
+        scoped: 'scoped:payload',
+        owner: 'owner:payload',
+        main: 'main:payload',
+        sync: 'sync:payload'
+      });
+    } finally {
+      workerIpc.removeHandler(`${channel}:invoke-scoped`);
+      owner.removeHandler(`${channel}:invoke-owner`);
+      ipcMain.removeHandler(`${channel}:invoke-main`);
+    }
+  };
+
+  it('exposes dedicated worker properties and dispatches IPC through worker, WebContents, and ipcMain', async () => {
+    await createWindow({ nodeIntegrationInWorker: true });
+    const dedicatedWorkers = w!.webContents.dedicatedWorkers;
+    const createdPromise = once(dedicatedWorkers, 'created');
+    const contentsCreatedPromise = once(w!.webContents, 'dedicated-worker-created');
+    await createDedicatedWorker('/dedicated-node-worker.js');
+
+    const [[created], [, contentsCreated]] = await Promise.all([createdPromise, contentsCreatedPromise]);
+    expect(contentsCreated).to.deep.equal(created);
+    expect(created).to.include({
+      origin: new URL(serverUrl).origin
+    });
+
+    await waitUntil(() => !!dedicatedWorkers.getWorkerFromID(created.id));
+    const running = dedicatedWorkers.getAllRunning();
+    expect(running).to.have.property(created.id).that.includes({
+      id: created.id,
+      url: `${serverUrl}/dedicated-node-worker.js`,
+      scriptURL: `${serverUrl}/dedicated-node-worker.js`
+    });
+
+    const worker = dedicatedWorkers.getWorkerFromID(created.id)!;
+    expect(worker).to.have.property('id').that.is.a('string');
+    expect(worker.id).to.equal(created.id);
+    expect(dedicatedWorkers.getWorkerFromID(worker.id)).to.equal(worker);
+    expect(worker.sender).to.equal(w!.webContents);
+    expect(worker.ownerFrame).to.not.equal(null);
+    expect(worker.parentWorker).to.equal(null);
+    expect(worker.url).to.equal(`${serverUrl}/dedicated-node-worker.js`);
+    expect(await worker.executeJavaScript('globalThis.workerValue = 42; globalThis.workerValue')).to.equal(42);
+
+    const channel = `dedicated-${crypto.randomUUID()}`;
+    try {
+      worker.ipc.handle(`${channel}:invoke-scoped`, (event, value) => {
+        expect(event.type).to.equal('dedicated-worker');
+        expect(event.senderDedicatedWorker).to.equal(worker);
+        return `scoped:${value}`;
+      });
+      w!.webContents.ipc.handle(`${channel}:invoke-owner`, (event, value) => {
+        expect(event.type).to.equal('dedicated-worker');
+        if (event.type !== 'dedicated-worker') {
+          throw new Error(`Unexpected IPC event type: ${event.type}`);
+        }
+        expect(event.senderDedicatedWorker).to.equal(worker);
+        return `owner:${value}`;
+      });
+      ipcMain.handle(`${channel}:invoke-main`, (event: Electron.IpcMainInvokeEventUnion, value) => {
+        expect(event.type).to.equal('dedicated-worker');
+        if (event.type !== 'dedicated-worker') {
+          throw new Error(`Unexpected IPC event type: ${event.type}`);
+        }
+        expect(event.senderDedicatedWorker).to.equal(worker);
+        return `main:${value}`;
+      });
+      worker.ipc.once(`${channel}:sync`, (event, value) => {
+        expect(event.type).to.equal('dedicated-worker');
+        event.returnValue = `sync:${value}`;
+      });
+
+      const pingPromises = [
+        once(worker.ipc, `${channel}:ping`),
+        once(w!.webContents.ipc, `${channel}:ping`),
+        once(ipcMain, `${channel}:ping`)
+      ];
+      const resultsPromise = once(worker.ipc, `${channel}:invoke-results`);
+
+      await w!.webContents.executeJavaScript(`
+        globalThis.workerForTest.postMessage(${JSON.stringify({ type: 'run-ipc', channel })});
+      `);
+
+      const [[workerEvent, workerPayload], [contentsEvent, contentsPayload], [mainEvent, mainPayload]] =
+        await Promise.all(pingPromises);
+      for (const event of [workerEvent, contentsEvent, mainEvent]) {
+        expect(event.type).to.equal('dedicated-worker');
+        expect(event.senderDedicatedWorker).to.equal(worker);
+        expect(event).to.not.have.property('workerId');
+      }
+      expect([workerPayload, contentsPayload, mainPayload]).to.deep.equal(['payload', 'payload', 'payload']);
+
+      const [, results] = await resultsPromise;
+      expect(results).to.deep.equal({
+        scoped: 'scoped:payload',
+        owner: 'owner:payload',
+        main: 'main:payload',
+        sync: 'sync:payload'
