+
+namespace electron::api {
+
+namespace {
+
+using DedicatedWorkerMap =
+    base::flat_map<blink::DedicatedWorkerToken, DedicatedWorkerMain*>;
+
+DedicatedWorkerMap& GetDedicatedWorkerMap() {
+  static base::NoDestructor<DedicatedWorkerMap> instance;
+  return *instance;
+}
+
+content::RenderFrameHost* GetAncestorFrame(content::DedicatedWorkerHost* host) {
+  return host ? content::RenderFrameHost::FromID(
+                    host->GetAncestorRenderFrameHostId())
+              : nullptr;
+}
+
+void SetConstructorPrototype(
+    v8::Isolate* isolate,
+    v8::Local<v8::Function> constructor,
+    const gin_helper::Handle<DedicatedWorkerMain>& handle) {
+  if (handle.IsEmpty() || !handle.ToV8()->IsObject())
+    return;
+
+  v8::Local<v8::Context> context = isolate->GetCurrentContext();
+  v8::Local<v8::Value> prototype;
+  if (!constructor->Get(context, gin::StringToV8(isolate, "prototype"))
+           .ToLocal(&prototype) ||
+      !prototype->IsObject()) {
+    return;
+  }
+
+  [[maybe_unused]] bool ok = handle.ToV8()
+                                 .As<v8::Object>()
+                                 ->SetPrototype(context,
+                                                prototype.As<v8::Object>())
+                                 .FromMaybe(false);
+}
+
+}  // namespace
+
+gin::DeprecatedWrapperInfo DedicatedWorkerMain::kWrapperInfo = {
+    gin::kEmbedderNativeGin};
+
+DedicatedWorkerMain::DedicatedWorkerMain(
+    const blink::DedicatedWorkerToken& token)
+    : token_(token), id_(token.ToString()) {
+  GetDedicatedWorkerMap().emplace(token_, this);
+}
+
+DedicatedWorkerMain::~DedicatedWorkerMain() {
+  Destroy();
+}
+
+void DedicatedWorkerMain::Destroy() {
+  if (destroyed_)
+    return;
+  destroyed_ = true;
+  if (base::FindPtrOrNull(GetDedicatedWorkerMap(), token_) == this)
+    GetDedicatedWorkerMap().erase(token_);
+  Unpin();
+}
+
+// static
+void DedicatedWorkerMain::DestroyToken(
+    const blink::DedicatedWorkerToken& token) {
+  if (auto* worker = FromToken(token))
+    worker->Destroy();
+}
+
+content::DedicatedWorkerHost* DedicatedWorkerMain::GetHost() const {
+  if (destroyed_)
+    return nullptr;
+  return ElectronApiWorkerIPCHandlerImpl::GetDedicatedWorkerHost(token_);
+}
+
+mojom::ElectronRenderer* DedicatedWorkerMain::GetRendererApi() const {
+  if (destroyed_)
+    return nullptr;
+  return ElectronApiWorkerIPCHandlerImpl::GetDedicatedWorkerRenderer(token_);
+}
+
+bool DedicatedWorkerMain::IsDestroyed() const {
+  return destroyed_ || !GetHost();
+}
+
+std::string DedicatedWorkerMain::ID() const {
+  return id_;
+}
+
+int DedicatedWorkerMain::ProcessID() const {
+  auto* host = GetHost();
+  return host ? host->GetProcessHost()->GetID().GetUnsafeValue() : -1;
+}
+
+GURL DedicatedWorkerMain::URL() const {
+  auto* host = GetHost();
+  if (!host || !host->GetFinalResponseURL())
+    return {};
+  return *host->GetFinalResponseURL();
+}
+
+content::WebContents* DedicatedWorkerMain::Sender() const {
+  auto* frame = GetAncestorFrame(GetHost());
+  return frame ? content::WebContents::FromRenderFrameHost(frame) : nullptr;
+}
+
+content::RenderFrameHost* DedicatedWorkerMain::OwnerFrame() const {
+  auto* host = GetHost();
+  if (!host)
+    return nullptr;
+  const auto& creator = host->GetCreator();
+  if (!std::holds_alternative<content::GlobalRenderFrameHostId>(creator))
+    return nullptr;
+  return content::RenderFrameHost::FromID(
+      std::get<content::GlobalRenderFrameHostId>(creator));
+}
+
+v8::Local<v8::Value> DedicatedWorkerMain::ParentWorker(
+    v8::Isolate* isolate) const {
+  auto* host = GetHost();
+  if (!host)
+    return v8::Null(isolate);
+  const auto& creator = host->GetCreator();
+  if (!std::holds_alternative<blink::DedicatedWorkerToken>(creator))
+    return v8::Null(isolate);
+  return DedicatedWorkerMain::FromToken(
+             isolate, std::get<blink::DedicatedWorkerToken>(creator))
+      .ToV8();
+}
+
+void DedicatedWorkerMain::Send(v8::Isolate* isolate,
+                               bool internal,
+                               const std::string& channel,
+                               v8::Local<v8::Value> args) {
+  blink::CloneableMessage message;
+  if (!gin::ConvertFromV8(isolate, args, &message)) {
+    isolate->ThrowException(v8::Exception::Error(
+        gin::StringToV8(isolate, "Failed to serialize arguments")));
+    return;
+  }
+
+  auto* renderer_api = GetRendererApi();
+  if (!renderer_api)
+    return;
+
+  renderer_api->Message(internal, channel, std::move(message));
+}
+
+v8::Local<v8::Promise> DedicatedWorkerMain::ExecuteJavaScript(
+    v8::Isolate* isolate,
+    const std::string& code) {
+  auto promise =
+      std::make_shared<gin_helper::Promise<v8::Local<v8::Value>>>(isolate);
+  v8::Local<v8::Promise> handle = promise->GetHandle();
+
+  auto* renderer_api = GetRendererApi();
+  if (!renderer_api) {
+    promise->RejectWithErrorMessage(
+        "Dedicated worker is no longer running or has been destroyed");
+    return handle;
+  }
+
+  renderer_api->ExecuteJavaScript(
+      code, base::BindOnce(&ResolveWorkerExecuteJavaScript, promise));
+  return handle;
+}
+
+// static
+gin_helper::Handle<DedicatedWorkerMain> DedicatedWorkerMain::New(
+    v8::Isolate* isolate) {
+  return {};
+}
+
+// static
+gin_helper::Handle<DedicatedWorkerMain> DedicatedWorkerMain::From(
+    v8::Isolate* isolate,
+    content::DedicatedWorkerHost* host) {
+  if (!host)
+    return {};
+  return FromToken(isolate, host->GetToken());
+}
+
+// static
+gin_helper::Handle<DedicatedWorkerMain> DedicatedWorkerMain::FromToken(
+    v8::Isolate* isolate,
+    const blink::DedicatedWorkerToken& token) {
+  v8::Local<v8::Function> constructor =
+      GetConstructor(isolate, isolate->GetCurrentContext());
+
+  if (auto* worker = FromToken(token)) {
+    auto handle = gin_helper::CreateHandle(isolate, worker);
+    SetConstructorPrototype(isolate, constructor, handle);
+    return handle;
+  }
+
+  if (!ElectronApiWorkerIPCHandlerImpl::GetDedicatedWorkerHost(token))
+    return {};
+
+  auto handle =
+      gin_helper::CreateHandle(isolate, new DedicatedWorkerMain(token));
+  handle->Pin(isolate);
+  SetConstructorPrototype(isolate, constructor, handle);
+  return handle;
+}
+
+// static
+DedicatedWorkerMain* DedicatedWorkerMain::FromToken(
+    const blink::DedicatedWorkerToken& token) {
+  return base::FindPtrOrNull(GetDedicatedWorkerMap(), token);
+}
+
+// static
+void DedicatedWorkerMain::FillObjectTemplate(
+    v8::Isolate* isolate,
+    v8::Local<v8::ObjectTemplate> templ) {
+  gin_helper::ObjectTemplateBuilder(isolate, templ)
+      .SetMethod("_send", &DedicatedWorkerMain::Send)
+      .SetMethod("executeJavaScript", &DedicatedWorkerMain::ExecuteJavaScript)
+      .SetMethod("isDestroyed", &DedicatedWorkerMain::IsDestroyed)
+      .SetProperty("id", &DedicatedWorkerMain::ID)
+      .SetProperty("processId", &DedicatedWorkerMain::ProcessID)
+      .SetProperty("url", &DedicatedWorkerMain::URL)
+      .SetProperty("sender", &DedicatedWorkerMain::Sender)
+      .SetProperty("ownerFrame", &DedicatedWorkerMain::OwnerFrame)
+      .SetProperty("parentWorker", &DedicatedWorkerMain::ParentWorker)
+      .Build();
+}
+
+const char* DedicatedWorkerMain::GetTypeName() {
+  return GetClassName();
+}
+
+}  // namespace electron::api
+
+namespace {
+
+using electron::api::DedicatedWorkerMain;
+
+void Initialize(v8::Local<v8::Object> exports,
+                v8::Local<v8::Value> unused,
+                v8::Local<v8::Context> context,
+                void* priv) {
+  v8::Isolate* const isolate = electron::JavascriptEnvironment::GetIsolate();
+  gin_helper::Dictionary dict{isolate, exports};
+  dict.Set("DedicatedWorkerMain",
+           DedicatedWorkerMain::GetConstructor(isolate, context));
+}
+
+}  // namespace
+
+NODE_LINKED_BINDING_CONTEXT_AWARE(electron_browser_dedicated_worker_main,
+                                  Initialize)
