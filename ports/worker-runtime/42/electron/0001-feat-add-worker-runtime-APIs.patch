+#include "shell/common/gin_helper/handle.h"
+#include "v8/include/cppgc/allocation.h"
+
+namespace electron::api {
+
+namespace {
+
+content::DedicatedWorkerServiceImpl* AsImpl(
+    content::DedicatedWorkerService* dedicated_worker_service) {
+  return static_cast<content::DedicatedWorkerServiceImpl*>(
+      dedicated_worker_service);
+}
+
+content::DedicatedWorkerService* GetDedicatedWorkerService(
+    WebContents* web_contents) {
+  if (!web_contents || !web_contents->GetWebContents())
+    return nullptr;
+
+  auto* main_frame = web_contents->GetWebContents()->GetPrimaryMainFrame();
+  if (main_frame && main_frame->GetProcess()) {
+    auto* storage_partition = main_frame->GetProcess()->GetStoragePartition();
+    if (storage_partition)
+      return storage_partition->GetDedicatedWorkerService();
+  }
+
+  auto* browser_context = web_contents->GetWebContents()->GetBrowserContext();
+  auto* storage_partition =
+      browser_context ? browser_context->GetDefaultStoragePartition()
+                      : nullptr;
+  return storage_partition ? storage_partition->GetDedicatedWorkerService()
+                           : nullptr;
+}
+
+class DedicatedWorkerCollector final
+    : public content::DedicatedWorkerService::Observer {
+ public:
+  std::vector<blink::DedicatedWorkerToken> tokens;
+
+  void OnWorkerCreated(const blink::DedicatedWorkerToken& worker_token,
+                       content::ChildProcessId worker_process_id,
+                       const url::Origin& security_origin,
+                       content::DedicatedWorkerCreator creator) override {
+    tokens.push_back(worker_token);
+  }
+  void OnBeforeWorkerDestroyed(
+      const blink::DedicatedWorkerToken& worker_token,
+      content::DedicatedWorkerCreator creator) override {}
+  void OnFinalResponseURLDetermined(
+      const blink::DedicatedWorkerToken& worker_token,
+      const GURL& url) override {}
+};
+
+bool BelongsToWebContents(content::DedicatedWorkerHost* host,
+                          content::WebContents* web_contents) {
+  if (!host || !web_contents)
+    return false;
+  auto* ancestor =
+      content::RenderFrameHost::FromID(host->GetAncestorRenderFrameHostId());
+  return ancestor &&
+         content::WebContents::FromRenderFrameHost(ancestor) == web_contents;
+}
+
+bool CreatorBelongsToWebContents(content::DedicatedWorkerService* service,
+                                 const content::DedicatedWorkerCreator& creator,
+                                 content::WebContents* web_contents) {
+  if (!service || !web_contents)
+    return false;
+
+  if (std::holds_alternative<content::GlobalRenderFrameHostId>(creator)) {
+    auto* frame = content::RenderFrameHost::FromID(
+        std::get<content::GlobalRenderFrameHostId>(creator));
+    return frame && content::WebContents::FromRenderFrameHost(frame) ==
+                        web_contents;
+  }
+
+  auto* parent_host = AsImpl(service)->GetDedicatedWorkerHostFromToken(
+      std::get<blink::DedicatedWorkerToken>(creator));
+  return BelongsToWebContents(parent_host, web_contents);
+}
+
+v8::Local<v8::Value> DedicatedWorkerInfoToDict(
+    v8::Isolate* isolate,
+    content::DedicatedWorkerHost* host) {
+  if (!host)
+    return v8::Undefined(isolate);
+
+  const std::string script_url =
+      host->GetFinalResponseURL() ? host->GetFinalResponseURL()->spec() : "";
+  return gin::DataObjectBuilder(isolate)
+      .Set("id", host->GetToken().ToString())
+      .Set("url", script_url)
+      .Set("scriptURL", script_url)
+      .Set("renderProcessId", host->GetProcessHost()->GetID().GetUnsafeValue())
+      .Build();
+}
+
+}  // namespace
+
+const gin::WrapperInfo DedicatedWorkerContext::kWrapperInfo = {
+    {gin::kEmbedderNativeGin},
+    gin::kElectronDedicatedWorkerContext};
+
+DedicatedWorkerContext::DedicatedWorkerContext(v8::Isolate* isolate,
+                                               WebContents* web_contents)
+    : web_contents_{web_contents},
+      dedicated_worker_service_{GetDedicatedWorkerService(web_contents)} {
+  if (dedicated_worker_service_)
+    dedicated_worker_service_->AddObserver(this);
+}
+
+DedicatedWorkerContext::~DedicatedWorkerContext() {
+  if (dedicated_worker_service_)
+    dedicated_worker_service_->RemoveObserver(this);
+}
+
+v8::Local<v8::Value> DedicatedWorkerContext::GetAllRunning(
+    v8::Isolate* isolate) {
+  gin::DataObjectBuilder builder(isolate);
+  if (!dedicated_worker_service_ || !web_contents_)
+    return builder.Build();
+
+  DedicatedWorkerCollector collector;
+  dedicated_worker_service_->EnumerateDedicatedWorkers(&collector);
+  auto* service = AsImpl(dedicated_worker_service_);
+  auto* owner = web_contents_->GetWebContents();
+  for (const auto& token : collector.tokens) {
+    auto* host = service->GetDedicatedWorkerHostFromToken(token);
+    if (BelongsToWebContents(host, owner))
+      builder.Set(token.ToString(), DedicatedWorkerInfoToDict(isolate, host));
+  }
+  return builder.Build();
+}
+
+v8::Local<v8::Value> DedicatedWorkerContext::GetWorkerFromID(
+    gin_helper::ErrorThrower thrower,
+    const std::string& worker_id) {
+  if (!dedicated_worker_service_ || !web_contents_)
+    return v8::Undefined(thrower.isolate());
+
+  DedicatedWorkerCollector collector;
+  dedicated_worker_service_->EnumerateDedicatedWorkers(&collector);
+  auto* service = AsImpl(dedicated_worker_service_);
+  auto* owner = web_contents_->GetWebContents();
+  for (const auto& token : collector.tokens) {
+    auto* host = service->GetDedicatedWorkerHostFromToken(token);
+    if (token.ToString() == worker_id && BelongsToWebContents(host, owner)) {
+      return DedicatedWorkerMain::From(thrower.isolate(), host).ToV8();
+    }
+  }
+  return v8::Undefined(thrower.isolate());
+}
+
+void DedicatedWorkerContext::OnWorkerCreated(
+    const blink::DedicatedWorkerToken& worker_token,
+    content::ChildProcessId worker_process_id,
+    const url::Origin& security_origin,
+    content::DedicatedWorkerCreator creator) {
+  if (!dedicated_worker_service_ || !web_contents_)
+    return;
+
+  auto* host = AsImpl(dedicated_worker_service_)
+                   ->GetDedicatedWorkerHostFromToken(worker_token);
+  if (!BelongsToWebContents(host, web_contents_->GetWebContents()))
+    return;
+
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Value> details =
+      gin::DataObjectBuilder(isolate)
+          .Set("id", worker_token.ToString())
+          .Set("renderProcessId", worker_process_id.GetUnsafeValue())
+          .Set("origin", security_origin.Serialize())
+          .Build();
+  EmitWithoutEvent("created", details);
+  web_contents_->Emit("dedicated-worker-created", details);
+}
+
+void DedicatedWorkerContext::OnBeforeWorkerDestroyed(
+    const blink::DedicatedWorkerToken& worker_token,
+    content::DedicatedWorkerCreator creator) {
+  if (!dedicated_worker_service_ || !web_contents_)
+    return;
+
+  if (!CreatorBelongsToWebContents(dedicated_worker_service_, creator,
+                                   web_contents_->GetWebContents())) {
+    return;
+  }
+
+  DedicatedWorkerMain::DestroyToken(worker_token);
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Value> details =
+      gin::DataObjectBuilder(isolate)
+          .Set("id", worker_token.ToString())
+          .Build();
+  EmitWithoutEvent("destroyed", details);
+  web_contents_->Emit("dedicated-worker-destroyed", details);
+}
+
+void DedicatedWorkerContext::OnFinalResponseURLDetermined(
+    const blink::DedicatedWorkerToken& worker_token,
+    const GURL& url) {
+  if (!dedicated_worker_service_ || !web_contents_)
+    return;
+
+  auto* host = AsImpl(dedicated_worker_service_)
+                   ->GetDedicatedWorkerHostFromToken(worker_token);
+  if (!BelongsToWebContents(host, web_contents_->GetWebContents()))
+    return;
+
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  EmitWithoutEvent("final-response-url-determined",
+                   gin::DataObjectBuilder(isolate)
+                       .Set("id", worker_token.ToString())
+                       .Set("url", url.spec())
+                       .Build());
+}
+
+// static
+DedicatedWorkerContext* DedicatedWorkerContext::Create(
+    v8::Isolate* isolate,
+    WebContents* web_contents) {
+  return cppgc::MakeGarbageCollected<DedicatedWorkerContext>(
+      isolate->GetCppHeap()->GetAllocationHandle(), isolate, web_contents);
+}
+
+gin::ObjectTemplateBuilder DedicatedWorkerContext::GetObjectTemplateBuilder(
+    v8::Isolate* isolate) {
+  return gin_helper::EventEmitterMixin<
+             DedicatedWorkerContext>::GetObjectTemplateBuilder(isolate)
+      .SetMethod("getAllRunning", &DedicatedWorkerContext::GetAllRunning)
+      .SetMethod("getWorkerFromID", &DedicatedWorkerContext::GetWorkerFromID);
+}
+
+void DedicatedWorkerContext::Trace(cppgc::Visitor* visitor) const {
+  gin::Wrappable<DedicatedWorkerContext>::Trace(visitor);
+  visitor->Trace(weak_factory_);
+}
+
+const gin::WrapperInfo* DedicatedWorkerContext::wrapper_info() const {
+  return &kWrapperInfo;
+}
+
+const char* DedicatedWorkerContext::GetHumanReadableName() const {
+  return "Electron / DedicatedWorkerContext";
+}
+
+}  // namespace electron::api
