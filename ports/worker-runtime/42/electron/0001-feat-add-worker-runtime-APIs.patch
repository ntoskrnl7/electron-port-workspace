+
+#ifndef ELECTRON_SHELL_RENDERER_WORKER_DATA_H_
+#define ELECTRON_SHELL_RENDERER_WORKER_DATA_H_
+
+#include <memory>
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "base/process/process_metrics.h"
+#include "electron/shell/common/api/api.mojom.h"
+#include "mojo/public/cpp/bindings/receiver.h"
+#include "mojo/public/cpp/bindings/remote.h"
+#include "third_party/blink/public/common/tokens/tokens.h"
+#include "v8/include/v8-context.h"
+#include "v8/include/v8-forward.h"
+
+namespace electron {
+
+// Per dedicated/shared worker data in the worker thread.
+class WorkerData : public mojom::ElectronRenderer {
+ public:
+  enum class Type {
+    kDedicatedWorker,
+    kSharedWorker,
+  };
+
+  WorkerData(v8::Isolate* isolate,
+             v8::Local<v8::Context> context,
+             Type type,
+             blink::WorkerToken token);
+  ~WorkerData() override;
+
+  WorkerData(const WorkerData&) = delete;
+  WorkerData& operator=(const WorkerData&) = delete;
+
+  static WorkerData* GetCurrent();
+
+  Type type() const { return type_; }
+  const blink::WorkerToken& token() const { return token_; }
+  base::ProcessMetrics* process_metrics() const { return metrics_.get(); }
+
+  void UpdateContext(v8::Local<v8::Context> context);
+
+  void BindIPCReceiver(
+      mojo::PendingReceiver<mojom::ElectronApiIPC> receiver);
+
+  // mojom::ElectronRenderer
+  void Message(bool internal,
+               const std::string& channel,
+               blink::CloneableMessage arguments) override;
+  void ReceivePostMessage(const std::string& channel,
+                          blink::TransferableMessage message) override;
+  void ExecuteJavaScript(const std::string& code,
+                         ExecuteJavaScriptCallback callback) override;
+  void TakeHeapSnapshot(mojo::ScopedHandle file,
+                        TakeHeapSnapshotCallback callback) override;
+
+ private:
+  raw_ptr<v8::Isolate> isolate_;
+  v8::Global<v8::Context> context_;
+
+  Type type_;
+  blink::WorkerToken token_;
+
+  std::unique_ptr<base::ProcessMetrics> metrics_;
+
+  mojo::Remote<mojom::ElectronWorkerAPI> worker_api_;
+  mojo::Receiver<mojom::ElectronRenderer> receiver_{this};
+};
+
+}  // namespace electron
+
+#endif  // ELECTRON_SHELL_RENDERER_WORKER_DATA_H_
