From 126dd3c25f82984df5cad325677d0401f75745cf Mon Sep 17 00:00:00 2001
From: Jung-Kwang Lee <ntoskrnl7@gmail.com>
Date: Mon, 8 Jun 2026 17:28:06 +0900
Subject: [PATCH] feat: allow focused editable text password inputs

---
 docs/api/web-contents.md                      | 25 +++---
 .../browser/api/electron_api_web_contents.cc  | 25 +++---
 spec/api-web-contents-spec.ts                 | 87 ++++++++++++++++---
 3 files changed, 105 insertions(+), 32 deletions(-)

diff --git a/docs/api/web-contents.md b/docs/api/web-contents.md
index 5552a4c519..aa4507eed9 100644
--- a/docs/api/web-contents.md
+++ b/docs/api/web-contents.md
@@ -1265,10 +1265,11 @@ returned `text` string. The selected text can be read with:
 const selectedText = info.text.slice(info.selection.start, info.selection.end)
 ```
 
-Password inputs return `null`. Custom editors backed by DOM-editable content are
-handled on a best-effort basis. Editors backed by canvas, virtual documents, or
-application-internal models may only expose the focused DOM control.
-Empty text controls resolve with `text: ''` rather than `null`.
+Password inputs are returned with `inputType: 'password'`. Custom editors backed
+by DOM-editable content are handled on a best-effort basis. Editors backed by
+canvas, virtual documents, or application-internal models may only expose the
+focused DOM control. Empty text controls resolve with `text: ''` rather than
+`null`.
 
 #### `contents.watchFocusedEditableText([options, ]callback)` _Experimental_
 
@@ -1299,10 +1300,11 @@ The watcher coalesces changes while an asynchronous snapshot is in flight and
 uses `throttleMs` to limit callback frequency. It reports the latest snapshot
 after coalescing rather than queueing every intermediate input state.
 
-Password inputs report `null`. Custom editors backed by DOM-editable content
-are handled on a best-effort basis. The watcher is not a general DOM mutation
-observer; editors backed by canvas, virtual documents, or application-internal
-models may only expose the focused DOM control.
+Password inputs are reported with `inputType: 'password'`. Custom editors
+backed by DOM-editable content are handled on a best-effort basis. The watcher
+is not a general DOM mutation observer; editors backed by canvas, virtual
+documents, or application-internal models may only expose the focused DOM
+control.
 
 #### `contents.editFocusedEditableText(edit)` _Experimental_
 
@@ -1328,9 +1330,10 @@ completed, the edit itself is not rolled back. The returned
 [`FocusedEditableText`](structures/focused-editable-text.md) contains the
 actual final selection.
 
-Password inputs return `null`. Custom editors backed by DOM-editable content are
-handled on a best-effort basis. Editors backed by canvas, virtual documents, or
-application-internal models may only expose the focused DOM control.
+Password inputs are editable through this API. Custom editors backed by
+DOM-editable content are handled on a best-effort basis. Editors backed by
+canvas, virtual documents, or application-internal models may only expose the
+focused DOM control.
 
 #### `contents.isLoading()`
 
diff --git a/shell/browser/api/electron_api_web_contents.cc b/shell/browser/api/electron_api_web_contents.cc
index c94755af5e..160fd0bd4b 100644
--- a/shell/browser/api/electron_api_web_contents.cc
+++ b/shell/browser/api/electron_api_web_contents.cc
@@ -2358,10 +2358,6 @@ std::string_view FocusedEditableTextModeToString(FocusedEditableTextMode mode) {
   return "full";
 }
 
-bool IsPasswordTextInputType(ui::TextInputType type) {
-  return type == ui::TEXT_INPUT_TYPE_PASSWORD;
-}
-
 FocusedEditableTextInputState CaptureFocusedEditableTextInputState(
     const ui::mojom::TextInputState& state) {
   FocusedEditableTextInputState result;
@@ -2445,9 +2441,8 @@ CreateFocusedEditableTextSnapshotFromInputState(
     uint32_t max_length) {
   FocusedEditableTextSnapshot snapshot;
   // Blink can expose an initially empty text control as a null WebString.
-  // Password and non-editable contexts are filtered before this point, so a
-  // missing value here represents empty editable text rather than unreadable
-  // text.
+  // Non-editable contexts are filtered before this point, so a missing value
+  // here represents empty editable text rather than unreadable text.
   if (state.value)
     snapshot.text = *state.value;
   snapshot.selection = state.selection;
@@ -2741,8 +2736,7 @@ content::RenderFrameHost* GetFocusedEditableTextFrame(
 
   const ui::mojom::TextInputState* text_input_state =
       text_input_manager->GetTextInputState();
-  if (!text_input_state || text_input_state->type == ui::TEXT_INPUT_TYPE_NONE ||
-      IsPasswordTextInputType(text_input_state->type)) {
+  if (!text_input_state || text_input_state->type == ui::TEXT_INPUT_TYPE_NONE) {
     return nullptr;
   }
 
@@ -2888,7 +2882,6 @@ std::u16string CreateFocusedEditableTextDomScript(uint32_t max_length) {
   const tag = active.localName;
   if (tag === 'input' || tag === 'textarea') {
     const type = (active.getAttribute('type') || 'text').toLowerCase();
-    if (tag === 'input' && type === 'password') return { ok: false };
     const value = String(active.value ?? '');
     const start = typeof active.selectionStart === 'number' ? active.selectionStart : value.length;
     const end = typeof active.selectionEnd === 'number' ? active.selectionEnd : start;
@@ -3003,6 +2996,18 @@ void RequestFocusedEditableTextSnapshot(
 
   content::GlobalRenderFrameHostId frame_id = render_frame_host->GetGlobalId();
   if (options.mode == FocusedEditableTextMode::kSurrounding) {
+    if (input_state.type == ui::TEXT_INPUT_TYPE_PASSWORD) {
+      std::optional<FocusedEditableTextSnapshot> snapshot =
+          CreateFocusedEditableTextSnapshotFromInputState(*text_input_state,
+                                                          options.max_length);
+      if (!snapshot) {
+        std::move(callback).Run(v8::Null(isolate));
+        return;
+      }
+      std::move(callback).Run(CreateFocusedEditableTextValue(
+          isolate, render_frame_host, input_state, options.mode, *snapshot));
+      return;
+    }
     render_frame_host->RequestTextSurroundingSelection(
         base::BindOnce(&OnFocusedEditableTextSurroundingSelection,
                        std::move(callback), contents->GetWeakPtr(), frame_id,
diff --git a/spec/api-web-contents-spec.ts b/spec/api-web-contents-spec.ts
index c3e7b29a45..cabe2e9109 100644
--- a/spec/api-web-contents-spec.ts
+++ b/spec/api-web-contents-spec.ts
@@ -1454,7 +1454,7 @@ describe('webContents module', () => {
       expect(await w.webContents.getFocusedEditableText()).to.equal(null);
     });
 
-    it('returns null for password inputs', async () => {
+    it('returns password input text', async () => {
       const w = new BrowserWindow({ show: false, width: 400, height: 300 });
       await w.loadURL(
         `data:text/html;charset=utf-8,${encodeURIComponent(`
@@ -1464,10 +1464,41 @@ describe('webContents module', () => {
       );
 
       await w.webContents.executeJavaScript(`
-        document.getElementById('field').focus();
+        const field = document.getElementById('field');
+        field.focus();
+        field.setSelectionRange(1, 4);
       `);
 
-      expect(await w.webContents.getFocusedEditableText()).to.equal(null);
+      await waitUntil(async () => {
+        const info = await w.webContents.getFocusedEditableText({ mode: 'value' });
+        return info?.inputType === 'password' && info.text === 'secret';
+      });
+
+      const valueInfo = await w.webContents.getFocusedEditableText({ mode: 'value' });
+      expect(valueInfo).to.not.equal(null);
+      if (valueInfo === null) {
+        throw new Error('Expected focused editable text');
+      }
+      expect(valueInfo.inputType).to.equal('password');
+      expect(valueInfo.text).to.equal('secret');
+      expect(valueInfo.selection).to.deep.equal({
+        isCollapsed: false,
+        start: 1,
+        end: 4
+      });
+      expect(valueInfo.source).to.equal('text-input-state');
+      expect(valueInfo.mode).to.equal('value');
+
+      const fullInfo = await w.webContents.getFocusedEditableText();
+      expect(fullInfo).to.not.equal(null);
+      if (fullInfo === null) {
+        throw new Error('Expected focused editable text');
+      }
+      expect(fullInfo.inputType).to.equal('password');
+      expect(fullInfo.text).to.equal('secret');
+      expect(fullInfo.text.slice(fullInfo.selection.start, fullInfo.selection.end)).to.equal('ecr');
+      expect(fullInfo.source).to.equal('dom');
+      expect(fullInfo.mode).to.equal('full');
     });
 
     it('returns input text with selection offsets relative to text', async () => {
@@ -1696,7 +1727,7 @@ describe('webContents module', () => {
       })).to.equal(null);
     });
 
-    it('returns null for password inputs', async () => {
+    it('edits password inputs', async () => {
       const w = new BrowserWindow({ show: false, width: 400, height: 300 });
       await w.loadURL(
         `data:text/html;charset=utf-8,${encodeURIComponent(`
@@ -1706,13 +1737,44 @@ describe('webContents module', () => {
       );
 
       await w.webContents.executeJavaScript(`
-        document.getElementById('field').focus();
+        const field = document.getElementById('field');
+        field.focus();
+        field.setSelectionRange(6, 6);
       `);
+      await waitUntil(async () => {
+        const info = await w.webContents.getFocusedEditableText();
+        return info?.inputType === 'password' && info.text === 'secret';
+      });
 
-      expect(await w.webContents.editFocusedEditableText({
+      const info = await w.webContents.editFocusedEditableText({
         kind: 'insertText',
-        text: 'ignored'
-      })).to.equal(null);
+        text: '!'
+      });
+
+      expect(info).to.not.equal(null);
+      if (info === null) {
+        throw new Error('Expected focused editable text');
+      }
+      expect(info.inputType).to.equal('password');
+      expect(info.text).to.equal('secret!');
+      expect(info.selection).to.deep.equal({
+        isCollapsed: true,
+        start: 7,
+        end: 7
+      });
+
+      const domState = await w.webContents.executeJavaScript(`
+        ({
+          value: document.getElementById('field').value,
+          selectionStart: document.getElementById('field').selectionStart,
+          selectionEnd: document.getElementById('field').selectionEnd
+        })
+      `);
+      expect(domState).to.deep.equal({
+        value: 'secret!',
+        selectionStart: 7,
+        selectionEnd: 7
+      });
     });
 
     it('inserts text and clamps selectionAfter to the final text', async () => {
@@ -2167,7 +2229,7 @@ describe('webContents module', () => {
       expect(fullInfo.text.slice(fullInfo.selection.start, fullInfo.selection.end)).to.equal('5');
     });
 
-    it('reports null for password inputs and when editable focus is lost', async () => {
+    it('reports password inputs and null when editable focus is lost', async () => {
       const w = new BrowserWindow({ show: false, width: 400, height: 300 });
       await w.loadURL(
         `data:text/html;charset=utf-8,${encodeURIComponent(`
@@ -2196,11 +2258,14 @@ describe('webContents module', () => {
       });
 
       await sawText;
-      const sawPasswordNull = waitUntil(() => snapshots.length > 0 && snapshots[snapshots.length - 1] === null);
+      const sawPassword = waitUntil(() => {
+        const snapshot = snapshots[snapshots.length - 1];
+        return snapshot?.inputType === 'password' && snapshot.text === 'secret';
+      });
       await w.webContents.executeJavaScript(`
         document.getElementById('password').focus();
       `);
-      await sawPasswordNull;
+      await sawPassword;
       watcher?.close();
 
       snapshots.length = 0;
