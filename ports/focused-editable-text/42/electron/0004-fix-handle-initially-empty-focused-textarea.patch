+      expect(iframeInfo.inputType).to.equal('textArea');
+      expect(iframeInfo.text).to.equal('');
+      expect(iframeInfo.selection).to.deep.equal({
+        isCollapsed: true,
+        start: 0,
+        end: 0
+      });
+    });
