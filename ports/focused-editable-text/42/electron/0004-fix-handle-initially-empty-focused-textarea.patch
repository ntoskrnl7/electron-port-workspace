+      expect(mainInfo.isMainFrame).to.be.true();
+      expect(mainInfo.inputType).to.equal('textArea');
+      expect(mainInfo.text).to.equal('');
+      expect(mainInfo.selection).to.deep.equal({
+        isCollapsed: true,
+        start: 0,
+        end: 0
+      });
+
+      await focusInitiallyEmptyTextarea(w.webContents, true);
+
+      await waitUntil(async () => {
+        const info = await w.webContents.getFocusedEditableText({ mode: 'value' });
+        return info?.inputType === 'textArea' && info.text === '' && !info.isMainFrame;
