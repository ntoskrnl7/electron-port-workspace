@@ -1380,6 +1380,42 @@ describe('webContents module', () => {
     });
   });
 
+  const focusInitiallyEmptyTextarea = async (contents: WebContents, inIframe = false) => {
+    const result = await contents.executeJavaScript(`
+      (() => {
+        try {
+          const body = document.body || document.documentElement.appendChild(document.createElement('body'));
+          if (${inIframe ? 'true' : 'false'}) {
+            body.innerHTML = '<iframe id="child"></iframe>';
+            const iframe = document.getElementById('child');
+            const doc = iframe && iframe.contentDocument;
+            if (!doc) return { ok: false, message: 'iframe contentDocument is not available' };
+            doc.open();
+            doc.write('<!DOCTYPE html><textarea id="field"></textarea>');
+            doc.close();
+            const field = doc.getElementById('field');
+            if (!field) return { ok: false, message: 'textarea was not created' };
+            iframe.contentWindow.focus();
+            field.focus();
+          } else {
+            body.innerHTML = '<textarea id="field"></textarea>';
+            const field = document.getElementById('field');
+            if (!field) return { ok: false, message: 'textarea was not created' };
+            field.focus();
+          }
+          return { ok: true };
+        } catch (error) {
+          return {
+            ok: false,
+            message: String(error && error.message || error),
+            html: document.documentElement?.outerHTML || ''
+          };
+        }
+      })()
+    `);
+    expect(result, JSON.stringify(result)).to.deep.equal({ ok: true });
+  };
+
   describe('getFocusedEditableText() API', () => {
     afterEach(closeAllWindows);
 
