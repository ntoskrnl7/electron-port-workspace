+  describe('editFocusedEditableText() API', () => {
+    afterEach(closeAllWindows);
+
+    it('returns null when no focused editable text is available', async () => {
+      const w = new BrowserWindow({ show: false, width: 400, height: 300 });
+      await w.loadURL('data:text/html;charset=utf-8,<p>no editable element</p>');
+
+      expect(await w.webContents.editFocusedEditableText({
+        kind: 'insertText',
+        text: 'ignored'
