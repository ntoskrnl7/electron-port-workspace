+v8::Local<v8::Promise> WebContents::EditFocusedEditableText(
+    gin::Arguments* args) {
+  v8::Isolate* isolate = args->isolate();
+  gin_helper::Promise<v8::Local<v8::Value>> promise(isolate);
+  v8::Local<v8::Promise> handle = promise.GetHandle();
+
+  FocusedEditableTextEdit edit;
+  std::string error;
+  if (!ParseFocusedEditableTextEdit(args, &edit, &error)) {
+    promise.RejectWithErrorMessage(error);
+    return handle;
+  }
+
+  FocusedEditableTextInputState input_state;
+  const ui::mojom::TextInputState* text_input_state = nullptr;
+  content::RenderWidgetHostImpl* active_widget = nullptr;
+  content::RenderFrameHost* render_frame_host = GetFocusedEditableTextFrame(
+      web_contents(), &input_state, &text_input_state, &active_widget);
+  if (!render_frame_host || !active_widget || !text_input_state) {
+    v8::Local<v8::Value> null_value = v8::Null(isolate);
+    promise.Resolve(null_value);
+    return handle;
+  }
+
+  std::optional<size_t> text_length;
+  if (text_input_state->value)
+    text_length = text_input_state->value->length();
+
+  const bool needs_text_length =
+      edit.kind == FocusedEditableTextEditKind::kReplaceText ||
+      edit.selection_after.has_value();
+  if (needs_text_length && !text_length) {
+    v8::Local<v8::Value> null_value = v8::Null(isolate);
+    promise.Resolve(null_value);
+    return handle;
+  }
+
+  std::optional<gfx::Range> replacement_range;
+  size_t replaced_length = 0;
+  if (edit.kind == FocusedEditableTextEditKind::kReplaceText) {
+    replacement_range =
+        ResolveFocusedEditableTextEditReplacementRange(edit, *text_length,
+                                                       &error);
+    if (!error.empty()) {
+      promise.RejectWithErrorMessage(error);
+      return handle;
+    }
+    if (replacement_range) {
+      replaced_length = replacement_range->length();
+    } else {
+      gfx::Range current = GetFocusedEditableTextEditCurrentReplacementRange(
+          input_state, *text_length);
+      replaced_length = current.length();
+    }
+  } else if (text_length) {
+    gfx::Range current = GetFocusedEditableTextEditCurrentReplacementRange(
+        input_state, *text_length);
+    replaced_length = current.length();
+  }
+
+  std::optional<gfx::Range> selection_after;
+  const size_t final_text_length =
+      text_length ? *text_length - replaced_length + edit.text.length() : 0;
+  if (edit.selection_after) {
+    selection_after = ClampFocusedEditableTextSelectionAfter(
+        *edit.selection_after, final_text_length);
+  } else if (replacement_range) {
+    const size_t offset = std::min<size_t>(
+        replacement_range->start() + edit.text.length(), final_text_length);
+    selection_after = gfx::Range(offset, offset);
+  }
+
+  auto* request = new FocusedEditableTextEditRequest(GetWeakPtr(),
+                                                     std::move(promise));
+  request->Start(active_widget, std::move(edit.text), replacement_range,
+                 selection_after);
+  return handle;
+}
