+class FocusedEditableTextEditRequest {
+ public:
+  FocusedEditableTextEditRequest(
+      base::WeakPtr<WebContents> owner,
+      gin_helper::Promise<v8::Local<v8::Value>> promise)
+      : owner_(std::move(owner)), promise_(std::move(promise)) {}
+
+  FocusedEditableTextEditRequest(const FocusedEditableTextEditRequest&) =
+      delete;
+  FocusedEditableTextEditRequest& operator=(
+      const FocusedEditableTextEditRequest&) = delete;
+
+  void Start(content::RenderWidgetHostImpl* target_widget,
+             std::u16string text,
+             std::optional<gfx::Range> replacement_range,
+             std::optional<gfx::Range> selection_after) {
+    if (!target_widget) {
+      ResolveNull();
+      return;
+    }
+
+    target_widget_ = target_widget->GetWeakPtr();
+    selection_after_ = selection_after;
+    target_widget->Focus();
+    if (!target_widget->GetWidgetInputHandler()) {
+      ResolveNull();
+      return;
+    }
+    StartTimeout();
+    target_widget->GetWidgetInputHandler()->ImeCommitText(
+        std::move(text), std::vector<ui::ImeTextSpan>(),
+        replacement_range.value_or(gfx::Range::InvalidRange()), 0,
+        base::BindOnce(&FocusedEditableTextEditRequest::OnCommitComplete,
+                       weak_factory_.GetWeakPtr()));
+  }
+
+ private:
+  void StartTimeout() {
+    base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+        FROM_HERE,
+        base::BindOnce(&FocusedEditableTextEditRequest::ResolveNullIfPending,
+                       weak_factory_.GetWeakPtr()),
+        base::Seconds(5));
+  }
+
+  void ResolveNullIfPending() {
+    if (settled_)
+      return;
+    ResolveNull();
+  }
+
+  void OnCommitComplete() {
+    if (settled_)
+      return;
+    if (!owner_ || !owner_->GetWebContents() || !target_widget_) {
+      ResolveNull();
+      return;
+    }
+
+    if (selection_after_) {
+      auto* frame_input_handler = target_widget_->GetFrameWidgetInputHandler();
+      if (!frame_input_handler) {
+        ResolveNull();
+        return;
+      }
+      frame_input_handler->SetEditableSelectionOffsets(
+          static_cast<int>(selection_after_->start()),
+          static_cast<int>(selection_after_->end()));
+    }
+
+    target_widget_->InsertVisualStateCallback(base::BindOnce(
+        &FocusedEditableTextEditRequest::AfterVisualState,
+        weak_factory_.GetWeakPtr()));
+  }
+
+  void AfterVisualState(bool) {
+    if (settled_)
+      return;
+    if (!owner_ || !owner_->GetWebContents()) {
+      ResolveNull();
+      return;
+    }
+
+    FocusedEditableTextOptions options;
+    options.mode = FocusedEditableTextMode::kFull;
+    RequestFocusedEditableTextSnapshot(
+        owner_->GetWebContents(), options,
+        base::BindOnce(&FocusedEditableTextEditRequest::OnSnapshot,
+                       weak_factory_.GetWeakPtr()));
+  }
+
+  void OnSnapshot(v8::Local<v8::Value> value) {
+    if (settled_)
+      return;
+    settled_ = true;
+    v8::HandleScope handle_scope(promise_.isolate());
+    v8::Context::Scope context_scope(promise_.GetContext());
+    promise_.Resolve(value);
+    delete this;
+  }
+
+  void ResolveNull() {
+    if (settled_)
+      return;
+    settled_ = true;
+    v8::HandleScope handle_scope(promise_.isolate());
+    v8::Context::Scope context_scope(promise_.GetContext());
+    v8::Local<v8::Value> null_value = v8::Null(promise_.isolate());
+    promise_.Resolve(null_value);
+    delete this;
+  }
+
+  base::WeakPtr<WebContents> owner_;
+  gin_helper::Promise<v8::Local<v8::Value>> promise_;
+  base::WeakPtr<content::RenderWidgetHostImpl> target_widget_;
+  std::optional<gfx::Range> selection_after_;
+  bool settled_ = false;
+  base::WeakPtrFactory<FocusedEditableTextEditRequest> weak_factory_{this};
+};
