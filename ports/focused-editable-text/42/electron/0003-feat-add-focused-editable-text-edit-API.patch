+bool GetOptionalFocusedEditableTextEditOffset(
+    const gin_helper::Dictionary& dict,
+    std::string_view key,
+    std::optional<int>* offset,
+    std::string* error) {
+  if (!dict.Has(std::string(key)))
+    return true;
+
+  int value = 0;
+  if (!dict.Get(std::string(key), &value)) {
+    *error = base::StringPrintf("%s must be an integer",
+                                std::string(key).c_str());
+    return false;
+  }
+
+  *offset = value;
+  return true;
+}
+
+bool ParseFocusedEditableTextEditSelection(
+    const gin_helper::Dictionary& dict,
+    FocusedEditableTextEditSelection* selection,
+    std::string* error) {
+  if (!dict.Get("start", &selection->start)) {
+    *error = "selectionAfter.start must be an integer";
+    return false;
+  }
+  if (!dict.Get("end", &selection->end)) {
+    *error = "selectionAfter.end must be an integer";
+    return false;
+  }
+  return true;
+}
+
+bool ParseFocusedEditableTextEdit(gin::Arguments* args,
+                                  FocusedEditableTextEdit* edit,
+                                  std::string* error) {
+  gin_helper::Dictionary dict;
+  if (!args->GetNext(&dict)) {
+    *error = "edit must be an object";
+    return false;
+  }
+
+  std::string kind;
+  if (!dict.Get("kind", &kind)) {
+    *error = "kind must be a string";
+    return false;
+  }
+  if (kind == "insertText") {
+    edit->kind = FocusedEditableTextEditKind::kInsertText;
+  } else if (kind == "replaceText") {
+    edit->kind = FocusedEditableTextEditKind::kReplaceText;
+  } else {
+    *error = "kind must be 'insertText' or 'replaceText'";
+    return false;
+  }
+
+  std::string text;
+  if (!dict.Get("text", &text)) {
+    *error = "text must be a string";
+    return false;
+  }
+  edit->text = base::UTF8ToUTF16(text);
+
+  if (!GetOptionalFocusedEditableTextEditOffset(dict, "start", &edit->start,
+                                                error) ||
+      !GetOptionalFocusedEditableTextEditOffset(dict, "end", &edit->end,
+                                                error)) {
+    return false;
+  }
+
+  if ((edit->start || edit->end) &&
+      edit->kind != FocusedEditableTextEditKind::kReplaceText) {
+    *error = "start and end are only valid for replaceText";
+    return false;
+  }
+
+  if (dict.Has("selectionAfter")) {
+    gin_helper::Dictionary selection_dict;
+    if (!dict.Get("selectionAfter", &selection_dict)) {
+      *error = "selectionAfter must be an object";
+      return false;
+    }
+    FocusedEditableTextEditSelection selection;
+    if (!ParseFocusedEditableTextEditSelection(selection_dict, &selection,
+                                               error)) {
+      return false;
+    }
+    edit->selection_after = selection;
+  }
+
+  return true;
+}
+
+std::optional<gfx::Range> ResolveFocusedEditableTextEditReplacementRange(
+    const FocusedEditableTextEdit& edit,
+    size_t text_length,
+    std::string* error) {
+  if (edit.kind == FocusedEditableTextEditKind::kInsertText ||
+      (!edit.start && !edit.end)) {
+    return std::nullopt;
+  }
+
+  const int start = edit.start.value_or(0);
+  if (text_length > static_cast<size_t>(std::numeric_limits<int>::max())) {
+    *error = "focused editable text is too long to edit by range";
+    return std::nullopt;
+  }
+  const int end = edit.end.value_or(static_cast<int>(text_length));
+  if (start < 0 || end < 0) {
+    *error = "start and end must be non-negative";
+    return std::nullopt;
+  }
+  if (static_cast<size_t>(start) > text_length ||
+      static_cast<size_t>(end) > text_length) {
+    *error = "start and end must be within the focused editable text";
+    return std::nullopt;
+  }
+  if (start > end) {
+    *error = "start must be less than or equal to end";
+    return std::nullopt;
+  }
+  return gfx::Range(start, end);
+}
+
+gfx::Range GetFocusedEditableTextEditCurrentReplacementRange(
+    const FocusedEditableTextInputState& input_state,
+    size_t text_length) {
+  if (input_state.composition)
+    return ClampRangeToText(*input_state.composition, text_length);
+  return ClampRangeToText(input_state.selection, text_length);
+}
+
+gfx::Range ClampFocusedEditableTextSelectionAfter(
+    const FocusedEditableTextEditSelection& selection,
+    size_t final_text_length) {
+  const int max_offset = static_cast<int>(std::min<size_t>(
+      final_text_length, static_cast<size_t>(std::numeric_limits<int>::max())));
+  int start = std::clamp(selection.start, 0, max_offset);
+  int end = std::clamp(selection.end, 0, max_offset);
+  if (start <= end)
+    return gfx::Range(start, end);
+  return gfx::Range(end, start);
+}
