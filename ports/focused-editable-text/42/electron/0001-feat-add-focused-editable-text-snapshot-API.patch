+v8::Local<v8::Promise> WebContents::GetFocusedEditableText(
+    gin::Arguments* args) {
+  v8::Isolate* isolate = args->isolate();
+  gin_helper::Promise<v8::Local<v8::Value>> promise(isolate);
+  v8::Local<v8::Promise> handle = promise.GetHandle();
+
+  FocusedEditableTextOptions options;
+  std::string error;
+  if (!ParseFocusedEditableTextOptions(args, &options, &error)) {
+    promise.RejectWithErrorMessage(error);
+    return handle;
+  }
+
+  FocusedEditableTextInputState input_state;
+  const ui::mojom::TextInputState* text_input_state = nullptr;
+  content::RenderFrameHost* render_frame_host = GetFocusedEditableTextFrame(
+      web_contents(), &input_state, &text_input_state);
+  if (!render_frame_host) {
+    v8::Local<v8::Value> null_value = v8::Null(isolate);
+    promise.Resolve(null_value);
+    return handle;
+  }
+
+  if (options.mode == FocusedEditableTextMode::kValue) {
+    std::optional<FocusedEditableTextSnapshot> snapshot =
+        CreateFocusedEditableTextSnapshotFromInputState(*text_input_state,
+                                                        options.max_length);
+    if (!snapshot) {
+      v8::Local<v8::Value> null_value = v8::Null(isolate);
+      promise.Resolve(null_value);
+      return handle;
+    }
+    promise.Resolve(CreateFocusedEditableTextValue(
+        isolate, render_frame_host, input_state, options.mode, *snapshot));
+    return handle;
+  }
+
+  content::GlobalRenderFrameHostId frame_id = render_frame_host->GetGlobalId();
+  if (options.mode == FocusedEditableTextMode::kSurrounding) {
+    render_frame_host->RequestTextSurroundingSelection(
+        base::BindOnce(&OnFocusedEditableTextSurroundingSelection,
+                       std::move(promise), web_contents()->GetWeakPtr(),
+                       frame_id, input_state, options.mode,
+                       options.max_length),
+        options.max_length);
+    return handle;
+  }
+
+  render_frame_host->ExecuteJavaScriptForTests(
+      CreateFocusedEditableTextDomScript(options.max_length),
+      base::BindOnce(&OnFocusedEditableTextDomResult, std::move(promise),
+                     web_contents()->GetWeakPtr(), frame_id, input_state,
+                     options.mode),
+      content::ISOLATED_WORLD_ID_GLOBAL);
+  return handle;
+}
