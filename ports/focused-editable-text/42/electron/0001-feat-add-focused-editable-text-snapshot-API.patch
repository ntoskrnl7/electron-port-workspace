+constexpr uint32_t kDefaultFocusedEditableTextMaxLength = 100000;
+constexpr uint32_t kMaxFocusedEditableTextMaxLength = 1000000;
+
+enum class FocusedEditableTextMode {
+  kValue,
+  kSurrounding,
+  kFull,
+};
+
+struct FocusedEditableTextOptions {
+  FocusedEditableTextMode mode = FocusedEditableTextMode::kFull;
+  uint32_t max_length = kDefaultFocusedEditableTextMaxLength;
+};
+
+struct FocusedEditableTextInputState {
+  ui::TextInputType type = ui::TEXT_INPUT_TYPE_NONE;
+  ui::TextInputMode mode = ui::TEXT_INPUT_MODE_DEFAULT;
+  ui::TextInputAction action = ui::TextInputAction::kDefault;
+  gfx::Range selection;
+  std::optional<gfx::Range> composition;
+};
+
+struct FocusedEditableTextSnapshot {
+  std::u16string text;
+  gfx::Range selection;
+  std::optional<gfx::Range> composition;
+  std::string source;
+  bool is_partial = false;
+};
+
+std::string_view FocusedEditableTextModeToString(
+    FocusedEditableTextMode mode) {
+  switch (mode) {
+    case FocusedEditableTextMode::kValue:
+      return "value";
+    case FocusedEditableTextMode::kSurrounding:
+      return "surrounding";
+    case FocusedEditableTextMode::kFull:
+      return "full";
+  }
+  return "full";
+}
+
+bool IsPasswordTextInputType(ui::TextInputType type) {
+  return type == ui::TEXT_INPUT_TYPE_PASSWORD;
+}
+
+FocusedEditableTextInputState CaptureFocusedEditableTextInputState(
+    const ui::mojom::TextInputState& state) {
+  FocusedEditableTextInputState result;
+  result.type = state.type;
+  result.mode = state.mode;
+  result.action = state.action;
+  result.selection = state.selection;
+  if (state.composition && state.composition->IsValid())
+    result.composition = *state.composition;
+  return result;
+}
+
+gfx::Range ClampRangeToText(const gfx::Range& range, size_t text_length) {
+  if (!range.IsValid())
+    return gfx::Range(0, 0);
+
+  const size_t start = std::min<size_t>(range.start(), text_length);
+  const size_t end = std::min<size_t>(range.end(), text_length);
+  if (start <= end)
+    return gfx::Range(start, end);
+  return gfx::Range(end, start);
+}
+
+std::optional<gfx::Range> ClampCompositionToText(
+    const std::optional<gfx::Range>& composition,
+    size_t text_length) {
+  if (!composition || !composition->IsValid())
+    return std::nullopt;
+  return ClampRangeToText(*composition, text_length);
+}
+
+void ClampFocusedEditableTextSnapshot(FocusedEditableTextSnapshot* snapshot,
+                                      uint32_t max_length) {
+  // The public API promises offsets relative to the returned `text`. Keep that
+  // invariant even when a large editable value must be truncated.
+  snapshot->selection =
+      ClampRangeToText(snapshot->selection, snapshot->text.length());
+  snapshot->composition =
+      ClampCompositionToText(snapshot->composition, snapshot->text.length());
+
+  if (snapshot->text.length() <= max_length)
+    return;
+
+  const size_t text_length = snapshot->text.length();
+  const size_t selection_start = snapshot->selection.start();
+  const size_t selection_end = snapshot->selection.end();
+  const size_t selection_length = selection_end - selection_start;
+
+  size_t window_start = 0;
+  size_t window_end = max_length;
+  if (selection_length >= max_length) {
+    window_start = selection_start;
+    window_end = std::min(text_length, window_start + max_length);
+  } else {
+    const size_t remaining = max_length - selection_length;
+    size_t before = std::min(selection_start, remaining / 2);
+    size_t after = std::min(text_length - selection_end, remaining - before);
+    before = std::min(selection_start, remaining - after);
+    window_start = selection_start - before;
+    window_end = selection_end + after;
+  }
+
+  snapshot->text =
+      snapshot->text.substr(window_start, window_end - window_start);
+  snapshot->selection = gfx::Range(selection_start - window_start,
+                                  selection_end - window_start);
+  if (snapshot->composition && snapshot->composition->start() >= window_start &&
+      snapshot->composition->end() <= window_end) {
+    snapshot->composition =
+        gfx::Range(snapshot->composition->start() - window_start,
+                   snapshot->composition->end() - window_start);
+  } else {
+    snapshot->composition = std::nullopt;
+  }
+  snapshot->is_partial = true;
+}
+
+std::optional<FocusedEditableTextSnapshot>
+CreateFocusedEditableTextSnapshotFromInputState(
+    const ui::mojom::TextInputState& state,
+    uint32_t max_length) {
+  if (!state.value)
+    return std::nullopt;
+
+  FocusedEditableTextSnapshot snapshot;
+  snapshot.text = *state.value;
+  snapshot.selection = state.selection;
+  snapshot.composition = ClampCompositionToText(
+      state.composition ? std::make_optional(*state.composition) : std::nullopt,
+      snapshot.text.length());
+  snapshot.source = "text-input-state";
+  ClampFocusedEditableTextSnapshot(&snapshot, max_length);
+  return snapshot;
+}
+
+v8::Local<v8::Value> CreateFocusedEditableTextValue(
+    v8::Isolate* isolate,
+    content::RenderFrameHost* render_frame_host,
+    const FocusedEditableTextInputState& input_state,
+    FocusedEditableTextMode mode,
+    const FocusedEditableTextSnapshot& snapshot) {
+  auto details = gin_helper::Dictionary::CreateEmpty(isolate);
+  details.SetGetter("frame", render_frame_host);
+  details.Set("url", render_frame_host->GetLastCommittedURL().spec());
+  details.Set("isMainFrame", render_frame_host->GetParent() == nullptr);
+  details.Set("inputType", std::string(TextInputTypeToString(input_state.type)));
+  details.Set("inputMode", std::string(TextInputModeToString(input_state.mode)));
+  details.Set("inputAction",
+              std::string(TextInputActionToString(input_state.action)));
+  details.Set("text", snapshot.text);
+
+  auto selection = gin_helper::Dictionary::CreateEmpty(isolate);
+  SetRangeDetails(&selection, snapshot.selection);
+  details.Set("selection", selection);
+
+  auto composition = gin_helper::Dictionary::CreateEmpty(isolate);
+  composition.Set("isComposing", snapshot.composition.has_value());
+  if (snapshot.composition) {
+    composition.Set("start",
+                    static_cast<uint32_t>(snapshot.composition->start()));
+    composition.Set("end", static_cast<uint32_t>(snapshot.composition->end()));
+  }
+  details.Set("composition", composition);
+
+  details.Set("source", snapshot.source);
+  details.Set("mode", std::string(FocusedEditableTextModeToString(mode)));
+  details.Set("isPartial", snapshot.is_partial);
+  return details.GetHandle();
+}
+
+bool ParseFocusedEditableTextOptions(gin::Arguments* args,
+                                     FocusedEditableTextOptions* options,
+                                     std::string* error) {
+  gin_helper::Dictionary dict =
+      gin_helper::Dictionary::CreateEmpty(args->isolate());
+  if (args->Length() >= 1 && !args->PeekNext()->IsNullOrUndefined() &&
+      !args->GetNext(&dict)) {
+    *error = "options must be an object when provided";
+    return false;
+  }
+
+  if (dict.Has("mode")) {
+    std::string mode;
+    if (!dict.Get("mode", &mode)) {
+      *error = "mode must be a string";
+      return false;
+    }
+    if (mode == "value") {
+      options->mode = FocusedEditableTextMode::kValue;
+    } else if (mode == "surrounding") {
+      options->mode = FocusedEditableTextMode::kSurrounding;
+    } else if (mode == "full") {
+      options->mode = FocusedEditableTextMode::kFull;
+    } else {
+      *error = "mode must be 'value', 'surrounding', or 'full'";
+      return false;
+    }
+  }
+
+  if (dict.Has("maxLength")) {
+    int max_length = 0;
+    if (!dict.Get("maxLength", &max_length)) {
+      *error = "maxLength must be an integer";
+      return false;
+    }
+    if (max_length < 1 ||
+        static_cast<uint32_t>(max_length) > kMaxFocusedEditableTextMaxLength) {
+      *error = base::StringPrintf(
+          "maxLength must be between 1 and %u",
+          kMaxFocusedEditableTextMaxLength);
+      return false;
+    }
+    options->max_length = static_cast<uint32_t>(max_length);
+  }
+
+  return true;
+}
+
+content::RenderFrameHost* GetFocusedEditableTextFrame(
+    content::WebContents* contents,
+    FocusedEditableTextInputState* input_state,
+    const ui::mojom::TextInputState** text_input_state_out = nullptr) {
+  auto* web_contents_impl = static_cast<content::WebContentsImpl*>(contents);
+  auto* text_input_manager = web_contents_impl->GetTextInputManager();
+  if (!text_input_manager)
+    return nullptr;
+
+  content::RenderWidgetHostImpl* active_widget =
+      text_input_manager->GetActiveWidget();
+  content::RenderWidgetHostViewBase* active_view =
+      active_widget ? active_widget->GetView() : nullptr;
+  if (!active_view || !text_input_manager->IsRegistered(active_view))
+    return nullptr;
+
+  const ui::mojom::TextInputState* text_input_state =
+      text_input_manager->GetTextInputState();
+  if (!text_input_state ||
+      text_input_state->type == ui::TEXT_INPUT_TYPE_NONE ||
+      IsPasswordTextInputType(text_input_state->type)) {
+    return nullptr;
+  }
+
+  content::RenderFrameHost* render_frame_host =
+      GetRenderFrameHostForView(contents, active_view);
+  if (!render_frame_host)
+    return nullptr;
+
+  *input_state = CaptureFocusedEditableTextInputState(*text_input_state);
+  if (text_input_state_out)
+    *text_input_state_out = text_input_state;
+  return render_frame_host;
+}
+
+void ResolveFocusedEditableTextNull(
+    gin_helper::Promise<v8::Local<v8::Value>> promise) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Value> null_value = v8::Null(isolate);
+  promise.Resolve(null_value);
+}
+
+void ResolveFocusedEditableTextSnapshot(
+    gin_helper::Promise<v8::Local<v8::Value>> promise,
+    base::WeakPtr<content::WebContents> contents,
+    content::GlobalRenderFrameHostId frame_id,
+    FocusedEditableTextInputState input_state,
+    FocusedEditableTextMode mode,
+    FocusedEditableTextSnapshot snapshot) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  auto* web_contents = contents.get();
+  auto* render_frame_host = content::RenderFrameHost::FromID(frame_id);
+  if (!web_contents || !render_frame_host) {
+    v8::Local<v8::Value> null_value = v8::Null(isolate);
+    promise.Resolve(null_value);
+    return;
+  }
+
+  promise.Resolve(CreateFocusedEditableTextValue(
+      isolate, render_frame_host, input_state, mode, snapshot));
+}
+
+void OnFocusedEditableTextSurroundingSelection(
+    gin_helper::Promise<v8::Local<v8::Value>> promise,
+    base::WeakPtr<content::WebContents> contents,
+    content::GlobalRenderFrameHostId frame_id,
+    FocusedEditableTextInputState input_state,
+    FocusedEditableTextMode mode,
+    uint32_t max_length,
+    const std::u16string& text,
+    uint32_t start_offset,
+    uint32_t end_offset) {
+  if (text.empty()) {
+    ResolveFocusedEditableTextNull(std::move(promise));
+    return;
+  }
+
+  FocusedEditableTextSnapshot snapshot;
+  snapshot.text = text;
+  snapshot.selection = ClampRangeToText(gfx::Range(start_offset, end_offset),
+                                        snapshot.text.length());
+  snapshot.composition =
+      ClampCompositionToText(input_state.composition, snapshot.text.length());
+  snapshot.source = "surrounding-selection";
+  snapshot.is_partial = true;
+  ClampFocusedEditableTextSnapshot(&snapshot, max_length);
+  ResolveFocusedEditableTextSnapshot(std::move(promise), std::move(contents),
+                                      frame_id, input_state, mode,
+                                      std::move(snapshot));
+}
+
+std::u16string CreateFocusedEditableTextDomScript(uint32_t max_length) {
+  // DOM extraction is intentionally best-effort. Contenteditable hosts can be
+  // represented as DOM text, while application-model editors backed by canvas
+  // or hidden controls can only expose the focused DOM control.
+  return base::UTF8ToUTF16(base::StringPrintf(R"JS(
+(() => {
+  const maxLength = %u;
+  const clamp = (text, start, end) => {
+    start = Math.max(0, Math.min(start, text.length));
+    end = Math.max(0, Math.min(end, text.length));
+    if (start > end) [start, end] = [end, start];
+    if (text.length <= maxLength) {
+      return { ok: true, text, selectionStart: start, selectionEnd: end, isPartial: false };
+    }
+    const selectionLength = end - start;
+    let windowStart = 0;
+    let windowEnd = maxLength;
+    if (selectionLength >= maxLength) {
+      windowStart = start;
+      windowEnd = Math.min(text.length, windowStart + maxLength);
+    } else {
+      const remaining = maxLength - selectionLength;
+      let before = Math.min(start, Math.floor(remaining / 2));
+      let after = Math.min(text.length - end, remaining - before);
+      before = Math.min(start, remaining - after);
+      windowStart = start - before;
+      windowEnd = end + after;
+    }
+    return {
+      ok: true,
+      text: text.slice(windowStart, windowEnd),
+      selectionStart: start - windowStart,
+      selectionEnd: end - windowStart,
+      isPartial: true
+    };
+  };
+
+  const activeElementDeep = (doc) => {
+    let active = doc.activeElement;
+    while (active && active.shadowRoot && active.shadowRoot.activeElement) {
+      active = active.shadowRoot.activeElement;
+    }
+    return active;
+  };
+
+  const parentElementOrHost = (node) => {
+    if (!node) return null;
+    if (node.parentElement) return node.parentElement;
+    const root = node.getRootNode && node.getRootNode();
+    return root && root.host instanceof Element ? root.host : null;
+  };
+
+  const isInside = (node, host) => {
+    let current = node && (node.nodeType === Node.ELEMENT_NODE ? node : node.parentNode);
+    while (current) {
+      if (current === host) return true;
+      if (current.parentNode) {
+        current = current.parentNode;
+        continue;
+      }
+      const root = current.getRootNode && current.getRootNode();
+      current = root && root.host instanceof Element ? root.host : null;
+    }
+    return false;
+  };
+
+  const active = activeElementDeep(document);
+  if (!active) return { ok: false };
+
+  const tag = active.localName;
+  if (tag === 'input' || tag === 'textarea') {
+    const type = (active.getAttribute('type') || 'text').toLowerCase();
+    if (tag === 'input' && type === 'password') return { ok: false };
+    const value = String(active.value ?? '');
+    const start = typeof active.selectionStart === 'number' ? active.selectionStart : value.length;
+    const end = typeof active.selectionEnd === 'number' ? active.selectionEnd : start;
+    return clamp(value, start, end);
+  }
+
+  let host = null;
+  for (let element = active; element; element = parentElementOrHost(element)) {
+    if (element.isContentEditable) {
+      host = element;
+      for (let parent = parentElementOrHost(element); parent && parent.isContentEditable; parent = parentElementOrHost(parent)) {
+        host = parent;
+      }
+      break;
+    }
+  }
+  if (!host && String(document.designMode).toLowerCase() === 'on') {
+    host = document.body || document.documentElement;
+  }
+  if (!host) return { ok: false };
+
+  const selection = document.getSelection();
+  if (!selection || selection.rangeCount === 0) return { ok: false };
+  const range = selection.getRangeAt(0);
+  if (!isInside(range.startContainer, host) || !isInside(range.endContainer, host)) {
+    return { ok: false };
+  }
+
+  const fullRange = document.createRange();
+  fullRange.selectNodeContents(host);
+  const text = fullRange.toString();
+  const beforeStart = document.createRange();
+  beforeStart.selectNodeContents(host);
+  beforeStart.setEnd(range.startContainer, range.startOffset);
+  const beforeEnd = document.createRange();
+  beforeEnd.selectNodeContents(host);
+  beforeEnd.setEnd(range.endContainer, range.endOffset);
+  return clamp(text, beforeStart.toString().length, beforeEnd.toString().length);
+})()
+)JS",
+                                          max_length));
+}
+
+void OnFocusedEditableTextDomResult(
+    gin_helper::Promise<v8::Local<v8::Value>> promise,
+    base::WeakPtr<content::WebContents> contents,
+    content::GlobalRenderFrameHostId frame_id,
+    FocusedEditableTextInputState input_state,
+    FocusedEditableTextMode mode,
+    base::Value value) {
+  if (!value.is_dict()) {
+    ResolveFocusedEditableTextNull(std::move(promise));
+    return;
+  }
+
+  const base::DictValue& dict = value.GetDict();
+  if (!dict.FindBool("ok").value_or(false)) {
+    ResolveFocusedEditableTextNull(std::move(promise));
+    return;
+  }
+
+  const std::string* text = dict.FindString("text");
+  std::optional<int> selection_start = dict.FindInt("selectionStart");
