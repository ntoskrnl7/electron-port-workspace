+bool ParseFocusedEditableTextWatchOptionsDictionary(
+    const gin_helper::Dictionary& dict,
+    FocusedEditableTextWatchOptions* options,
+    std::string* error) {
+  if (!ParseFocusedEditableTextOptionsDictionary(dict, &options->text_options,
+                                                 error)) {
+    return false;
+  }
+
+  if (dict.Has("throttleMs")) {
+    int throttle_ms = 0;
+    if (!dict.Get("throttleMs", &throttle_ms)) {
+      *error = "throttleMs must be an integer";
+      return false;
+    }
+    if (throttle_ms < 0 ||
+        throttle_ms > kMaxFocusedEditableTextWatchThrottleMs) {
+      *error = base::StringPrintf("throttleMs must be between 0 and %d",
+                                  kMaxFocusedEditableTextWatchThrottleMs);
+      return false;
+    }
+    options->throttle_interval = base::Milliseconds(throttle_ms);
+  }
+
+  return true;
+}
