+TextCaretFrameObserver::TextCaretFrameObserver(
+    content::WebContents* web_contents,
+    base::WeakPtr<WebContents> api_web_contents)
+    : content::WebContentsObserver(web_contents),
+      api_web_contents_(api_web_contents) {
+  auto* web_contents_impl =
+      static_cast<content::WebContentsImpl*>(web_contents);
+  text_input_manager_ = web_contents_impl->GetTextInputManager();
+  if (text_input_manager_)
+    text_input_manager_->AddObserver(this);
+}
+
+TextCaretFrameObserver::~TextCaretFrameObserver() {
+  CloseFocusedEditableTextWatchers();
+  StopObservingTextInputManager();
+}
+
+TextCaretFrameObserver* TextCaretFrameObserver::FromOrCreate(
+    content::WebContents* web_contents,
+    base::WeakPtr<WebContents> api_web_contents) {
+  if (!web_contents)
+    return nullptr;
+
+  if (auto* observer = static_cast<TextCaretFrameObserver*>(
+          web_contents->GetUserData(kTextCaretFrameObserverKey))) {
+    return observer;
+  }
+
+  auto observer =
+      std::make_unique<TextCaretFrameObserver>(web_contents, api_web_contents);
+  auto* observer_ptr = observer.get();
+  web_contents->SetUserData(kTextCaretFrameObserverKey, std::move(observer));
+  return observer_ptr;
+}
+
+void TextCaretFrameObserver::CreateForWebContents(
+    content::WebContents* web_contents,
+    base::WeakPtr<WebContents> api_web_contents) {
+  FromOrCreate(web_contents, std::move(api_web_contents));
+}
+
+void TextCaretFrameObserver::RegisterFocusedEditableTextWatcher(
+    FocusedEditableTextWatcher* watcher) {
+  focused_editable_text_watchers_.insert(watcher);
+}
+
+void TextCaretFrameObserver::UnregisterFocusedEditableTextWatcher(
+    FocusedEditableTextWatcher* watcher) {
+  focused_editable_text_watchers_.erase(watcher);
+}
+
+void TextCaretFrameObserver::WebContentsDestroyed() {
+  CloseFocusedEditableTextWatchers();
+  StopObservingTextInputManager();
+  Observe(nullptr);
+}
+
+void TextCaretFrameObserver::OnUpdateTextInputStateCalled(
+    content::TextInputManager* text_input_manager,
+    content::RenderWidgetHostViewBase* updated_view,
+    bool did_update_state) {
+  if (!did_update_state)
+    return;
+
+  EmitCaretInfoChanged(text_input_manager, updated_view, "focus");
+  NotifyFocusedEditableTextWatchers();
+}
+
+void TextCaretFrameObserver::OnSelectionBoundsChanged(
+    content::TextInputManager* text_input_manager,
+    content::RenderWidgetHostViewBase* updated_view) {
+  EmitCaretInfoChanged(text_input_manager, updated_view, "caret-move");
+  NotifyFocusedEditableTextWatchers();
+}
+
+void TextCaretFrameObserver::OnTextSelectionChanged(
+    content::TextInputManager* text_input_manager,
+    content::RenderWidgetHostViewBase* updated_view) {
+  EmitCaretInfoChanged(text_input_manager, updated_view, "caret-move");
+  NotifyFocusedEditableTextWatchers();
+}
+
+void TextCaretFrameObserver::StopObservingTextInputManager() {
+  if (text_input_manager_ && text_input_manager_->HasObserver(this))
+    text_input_manager_->RemoveObserver(this);
+  text_input_manager_ = nullptr;
+}
+
+void TextCaretFrameObserver::NotifyFocusedEditableTextWatchers() {
+  std::vector<FocusedEditableTextWatcher*> watchers(
+      focused_editable_text_watchers_.begin(),
+      focused_editable_text_watchers_.end());
+  for (auto* watcher : watchers) {
+    if (focused_editable_text_watchers_.contains(watcher))
+      watcher->NotifyTextInputChanged();
+  }
+}
+
+void TextCaretFrameObserver::CloseFocusedEditableTextWatchers() {
+  std::vector<FocusedEditableTextWatcher*> watchers(
+      focused_editable_text_watchers_.begin(),
+      focused_editable_text_watchers_.end());
+  focused_editable_text_watchers_.clear();
+  for (auto* watcher : watchers)
+    watcher->CloseFromObserver();
+}
+
+void TextCaretFrameObserver::EmitCaretInfoChanged(
+    content::TextInputManager* text_input_manager,
+    content::RenderWidgetHostViewBase* updated_view,
+    const char* reason) {
+  if (!api_web_contents_)
+    return;
+
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Value> details = CreateTextCaretInfo(
+      isolate, web_contents(), text_input_manager, updated_view, reason);
+  if (!details->IsNull())
+    api_web_contents_->Emit("text-caret-info-changed", details);
+}
