+      await expect(
+        w.webContents.getFocusedEditableText({ html: { inlineStyles: 'yes' } } as any)
+      ).to.eventually.be.rejectedWith('html.inlineStyles must be a boolean');
       await expect(
         w.webContents.getFocusedEditableText({ html: 'yes' } as any)
