@@ -2884,6 +2896,7 @@ std::u16string CreateFocusedEditableTextDomScript(
   const maxLength = %u;
   const includeHtml = %s;
   const maxHtmlLength = %u;
+  const inlineHtmlStyles = %s;
 
   const clampHtml = (html) => {
     if (!includeHtml || typeof html !== 'string') return {};
@@ -2896,6 +2909,38 @@ std::u16string CreateFocusedEditableTextDomScript(
     };
   };
 
+  const inlineComputedStyles = (source, target) => {
+    if (!(source instanceof Element) || !(target instanceof Element)) return;
+    const style = getComputedStyle(source);
+    const declarations = [];
+    for (const property of style) {
+      const value = style.getPropertyValue(property);
+      if (!value) continue;
+      const priority = style.getPropertyPriority(property);
+      declarations.push(`${property}: ${value}${priority ? ' !important' : ''};`);
+    }
+    if (declarations.length > 0) {
+      target.setAttribute('style', declarations.join(' '));
+    }
+  };
+
+  const createHtmlSnapshot = (host) => {
+    if (!(host instanceof Element)) return undefined;
+    if (!inlineHtmlStyles) return host.innerHTML;
+
+    const clone = host.cloneNode(true);
+    inlineComputedStyles(host, clone);
+    const sourceWalker = document.createTreeWalker(host, NodeFilter.SHOW_ELEMENT);
+    const cloneWalker = document.createTreeWalker(clone, NodeFilter.SHOW_ELEMENT);
+    while (true) {
+      const source = sourceWalker.nextNode();
+      const target = cloneWalker.nextNode();
+      if (!source || !target) break;
+      inlineComputedStyles(source, target);
+    }
+    return clone.innerHTML;
+  };
+
   const clamp = (text, start, end, extra = {}) => {
     start = Math.max(0, Math.min(start, text.length));
     end = Math.max(0, Math.min(end, text.length));
@@ -2978,8 +3023,9 @@ std::u16string CreateFocusedEditableTextDomScript(
     'table-header-group', 'table-footer-group'
   ]);
 
