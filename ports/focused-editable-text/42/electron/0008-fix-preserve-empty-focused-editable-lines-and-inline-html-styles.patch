diff --git a/spec/api-web-contents-spec.ts b/spec/api-web-contents-spec.ts
index 0814e9297d..1e3de2ac60 100644
--- a/spec/api-web-contents-spec.ts
+++ b/spec/api-web-contents-spec.ts
@@ -1692,6 +1692,102 @@ describe('webContents module', () => {
       expect(truncated.isHtmlPartial).to.be.true();
     });
 
+    it('preserves empty contenteditable block lines in full text', async () => {
+      const w = new BrowserWindow({ show: false, width: 400, height: 300 });
+      const html = [
+        '<!DOCTYPE html>',
+        '<div id="editor" contenteditable="true">',
+        '<p>aaa</p><p></p><p>bbb</p><p><br></p><p>ccc</p>',
+        '<div>ddd<br><br>eee</div>',
+        '</div>'
+      ].join('');
+      await w.loadURL(
+        `data:text/html;charset=utf-8,${encodeURIComponent(html)}`
+      );
+
+      await w.webContents.executeJavaScript(`
+        const editor = document.getElementById('editor');
+        const bbb = editor.querySelectorAll('p')[2].firstChild;
+        const range = document.createRange();
+        range.setStart(bbb, 1);
+        range.collapse(true);
+        const selection = getSelection();
+        selection.removeAllRanges();
+        selection.addRange(range);
+        editor.focus();
+      `);
+
+      await waitUntil(async () => {
+        const info = await w.webContents.getFocusedEditableText();
+        return info?.text === 'aaa\n\nbbb\n\nccc\nddd\n\neee';
+      });
+
+      const info = await w.webContents.getFocusedEditableText();
+      expect(info).to.not.equal(null);
+      if (info === null) {
+        throw new Error('Expected focused editable text');
+      }
+
+      expect(info.text).to.equal('aaa\n\nbbb\n\nccc\nddd\n\neee');
+      expect(info.selection).to.deep.equal({
+        isCollapsed: true,
+        start: 'aaa\n\nb'.length,
+        end: 'aaa\n\nb'.length
+      });
+    });
+
+    it('can inline computed styles in contenteditable html snapshots', async () => {
+      const w = new BrowserWindow({ show: false, width: 400, height: 300 });
+      await w.loadURL(
+        `data:text/html;charset=utf-8,${encodeURIComponent(`
+        <!DOCTYPE html>
+        <style>
+          #editor .important {
+            color: rgb(255, 0, 0);
+            font-weight: 700;
+          }
+        </style>
+        <div id="editor" contenteditable="true"><p class="important">alpha</p></div>
+      `)}`
+      );
+
+      await w.webContents.executeJavaScript(`
+        const editor = document.getElementById('editor');
+        const text = editor.querySelector('p').firstChild;
+        const range = document.createRange();
+        range.setStart(text, 0);
+        range.collapse(true);
+        const selection = getSelection();
+        selection.removeAllRanges();
+        selection.addRange(range);
+        editor.focus();
+      `);
+
+      await waitUntil(async () => {
+        const info = await w.webContents.getFocusedEditableText({
+          html: {
+            inlineStyles: true
+          }
+        });
+        return info?.html?.includes('style=') ?? false;
+      });
+
+      const info = await w.webContents.getFocusedEditableText({
+        html: {
+          inlineStyles: true
+        }
+      });
+      expect(info).to.not.equal(null);
+      if (info === null) {
+        throw new Error('Expected focused editable text');
+      }
+
+      expect(info.html).to.include('class="important"');
+      expect(info.html).to.include('style=');
+      expect(info.html).to.include('color: rgb(255, 0, 0)');
+      expect(info.html).to.include('font-weight: 700');
+    });
+
     it('keeps selection offsets relative to truncated text', async () => {
       const w = new BrowserWindow({ show: false, width: 400, height: 300 });
       await w.loadURL(
@@ -1781,6 +1877,9 @@ describe('webContents module', () => {
       await expect(
         w.webContents.getFocusedEditableText({ html: { maxLength: 0 } } as any)
