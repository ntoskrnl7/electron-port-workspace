+  const appendNewline = (state, force = false) => {
+    if (!force && (!state.text || state.text.endsWith('\n'))) return;
+    state.text += '\n';
   };
 
   const isHiddenElement = (element) => {
@@ -3012,13 +3058,17 @@ std::u16string CreateFocusedEditableTextDomScript(
       if (node.nodeType === Node.ELEMENT_NODE) {
         if (isHiddenElement(node)) return;
         if (node.localName === 'br') {
-          appendNewline(state);
+          appendNewline(state, true);
           return;
         }
 
         const isBlock = !isRoot && isBlockElement(node);
         if (isBlock) appendNewline(state);
+        const textLengthAfterBlockStart = state.text.length;
         for (const child of node.childNodes) visit(child);
+        if (isBlock && state.text.length === textLengthAfterBlockStart) {
+          appendNewline(state, true);
+        }
         if (isBlock) appendNewline(state);
         return;
       }
@@ -3070,7 +3120,7 @@ std::u16string CreateFocusedEditableTextDomScript(
   beforeEnd.selectNodeContents(host);
   beforeEnd.setEnd(range.endContainer, range.endOffset);
 
-  const html = host instanceof Element ? host.innerHTML : undefined;
+  const html = createHtmlSnapshot(host);
   return clamp(
     serializeRendered(host),
     serializeRendered(beforeStart.cloneContents()).length,
@@ -3082,7 +3132,10 @@ std::u16string CreateFocusedEditableTextDomScript(
                                               options.max_length,
                                               options.include_html ? "true"
                                                                    : "false",
-                                              options.max_html_length));
+                                              options.max_html_length,
+                                              options.inline_html_styles
+                                                  ? "true"
+                                                  : "false"));
 }
 
