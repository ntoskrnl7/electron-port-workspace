+void SetConstructorPrototype(
+    v8::Isolate* isolate,
+    v8::Local<v8::Function> constructor,
+    const gin_helper::Handle<WebNotification>& handle) {
+  if (handle.IsEmpty() || !handle.ToV8()->IsObject())
+    return;
+
+  v8::Local<v8::Context> context = isolate->GetCurrentContext();
+  v8::Local<v8::Value> prototype;
+  if (!constructor->Get(context, gin::StringToV8(isolate, "prototype"))
+           .ToLocal(&prototype) ||
+      !prototype->IsObject()) {
+    return;
+  }
+
+  [[maybe_unused]] bool ok = handle.ToV8()
+                                 .As<v8::Object>()
+                                 ->SetPrototype(context,
+                                                prototype.As<v8::Object>())
+                                 .FromMaybe(false);
+}
