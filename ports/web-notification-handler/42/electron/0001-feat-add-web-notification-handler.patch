+  auto notification = api::WebNotification::Create(
+      isolate, this, browser_context_, render_frame_host,
+      std::move(notification_id), std::move(origin), std::move(document_url),
+      std::move(service_worker_scope), std::move(notification_data),
+      std::move(notification_resources));
