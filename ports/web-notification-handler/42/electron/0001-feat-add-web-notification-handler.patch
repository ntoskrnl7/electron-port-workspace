+void WebNotification::ShowNative() {
+  if (displayed_ || closed_ || destroyed_)
+    return;
+
+  auto* presenter = ElectronBrowserClient::Get()->GetNotificationPresenter();
+  if (!presenter) {
+    OnNativeFailed("Notification presenter is not available");
+    return;
+  }
+
+  presenter->CloseNotificationWithId(notification_id_);
+  native_action_to_web_action_index_.clear();
+
+  electron::NotificationOptions options;
+  options.title = notification_data_.title;
+  options.msg = notification_data_.body;
+  options.tag = notification_data_.tag;
+  options.icon_url = notification_data_.icon;
+  options.icon = notification_resources_.notification_icon;
+  options.silent = notification_data_.silent;
+  options.has_reply = false;
+  if (notification_data_.require_interaction)
+    options.timeout_type = u"never";
+
+  for (size_t i = 0; i < notification_data_.actions.size(); ++i) {
+    const auto& action = notification_data_.actions[i];
+    if (action->type == blink::mojom::NotificationActionType::BUTTON) {
+      electron::NotificationAction native_action;
+      native_action.type = u"button";
+      native_action.text = action->title;
+      options.actions.push_back(std::move(native_action));
+      native_action_to_web_action_index_.push_back(static_cast<int>(i));
+    } else if (!options.has_reply) {
+      options.has_reply = true;
+      if (action->placeholder)
+        options.reply_placeholder = *action->placeholder;
+    }
+  }
+
+  auto* delegate = new Delegate(this);
+  auto notification = presenter->CreateNotification(delegate, notification_id_);
+  if (!notification) {
+    delete delegate;
+    OnNativeFailed("Failed to create notification");
+    return;
+  }
+
+  native_notification_ = notification.get();
+  notification->Show(options);
+}
+
+void WebNotification::Destroy(bool emit_close) {
+  if (destroyed_)
+    return;
+
+  destroyed_ = true;
+  if (service_) {
+    service_->UntrackNotification(this);
+    service_ = nullptr;
+  }
+  if (native_notification_) {
+    native_notification_->Destroy();
+    native_notification_ = nullptr;
+  }
+  if (emit_close)
+    EmitClose(false, "destroyed");
+  Unpin();
+}
