+v8::Local<v8::Value> WebNotification::Actions(v8::Isolate* isolate) const {
+  v8::EscapableHandleScope handle_scope(isolate);
+  v8::Local<v8::Array> actions =
+      v8::Array::New(isolate, notification_data_.actions.size());
+  v8::Local<v8::Context> context = isolate->GetCurrentContext();
+  for (size_t i = 0; i < notification_data_.actions.size(); ++i) {
+    actions->Set(context, i, ActionDetails(isolate, static_cast<int>(i))).Check();
+  }
+  return handle_scope.Escape(actions);
+}
