+v8::Local<v8::Promise> WebNotification::GetServiceWorker(v8::Isolate* isolate) {
+  auto shared_promise =
+      std::make_shared<gin_helper::Promise<v8::Local<v8::Value>>>(isolate);
+  v8::Local<v8::Promise> handle = shared_promise->GetHandle();
+
+  if (!service_worker_scope_) {
+    shared_promise->RejectWithErrorMessage(
+        "Notification was not created by a service worker.");
+    return handle;
+  }
+
+  auto* storage_partition = browser_context_->GetDefaultStoragePartition();
+  auto* service_worker_context = storage_partition->GetServiceWorkerContext();
+  blink::StorageKey storage_key =
+      blink::StorageKey::CreateFirstParty(url::Origin::Create(origin_));
+  service_worker_context->StartWorkerForScope(
+      *service_worker_scope_, storage_key,
+      base::BindOnce(&WebNotification::DidStartWorkerForScope,
+                     weak_factory_.GetWeakPtr(), shared_promise),
+      base::BindOnce(&WebNotification::DidFailToStartWorkerForScope,
+                     weak_factory_.GetWeakPtr(), shared_promise));
+
+  return handle;
+}
