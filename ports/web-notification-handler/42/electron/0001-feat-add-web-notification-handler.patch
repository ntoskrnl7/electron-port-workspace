+v8::Local<v8::Value> WebNotification::WebContents(v8::Isolate* isolate) const {
+  if (persistent())
+    return ToUndefined(isolate);
+  content::RenderFrameHost* rfh = content::RenderFrameHost::FromID(frame_id_);
+  content::WebContents* web_contents =
+      rfh ? content::WebContents::FromRenderFrameHost(rfh) : nullptr;
+  if (!web_contents)
+    return ToUndefined(isolate);
+  auto handle = api::WebContents::FromOrCreate(isolate, web_contents);
+  if (handle.IsEmpty())
+    return ToUndefined(isolate);
+  return handle.ToV8();
