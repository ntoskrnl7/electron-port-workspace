+void WebNotification::Close(gin::Arguments* args) {
+  bool by_user = true;
+  v8::Local<v8::Value> value;
+  if (args->GetNext(&value) && !value->IsNullOrUndefined()) {
+    gin_helper::Dictionary options;
+    if (!gin::ConvertFromV8(args->isolate(), value, &options)) {
+      args->ThrowTypeError("close options must be an object");
+      return;
+    }
+    options.Get("byUser", &by_user);
+  }
+
+  if (closed_ || destroyed_)
+    return;
+
+  closed_ = true;
+  if (native_notification_) {
+    closing_native_ = true;
+    native_notification_->Dismiss();
+    closing_native_ = false;
+  }
+  DispatchClose(by_user);
+  EmitClose(by_user, by_user ? "user" : "programmatic");
+  Destroy(false);
+}
+
+void WebNotification::Click(gin::Arguments* args) {
+  if (closed_ || destroyed_)
+    return;
+
+  EmitWithoutEvent("click");
+  DispatchClick(std::nullopt, std::nullopt);
+}
+
+void WebNotification::ClickAction(gin::Arguments* args) {
+  v8::Local<v8::Value> value;
+  if (!args->GetNext(&value)) {
+    args->ThrowTypeError("action must be an index or action string");
+    return;
+  }
+
+  std::optional<int> action_index = ResolveAction(args, value);
+  if (!action_index)
+    return;
+
+  EmitWithoutEvent("action", ActionDetails(args->isolate(), *action_index));
+  DispatchClick(action_index, std::nullopt);
+}
+
+void WebNotification::Reply(gin::Arguments* args) {
+  std::u16string reply;
+  if (!args->GetNext(&reply)) {
+    args->ThrowTypeError("reply text must be a string");
+    return;
+  }
+
+  std::optional<int> action_index;
+  v8::Local<v8::Value> value;
+  if (args->GetNext(&value) && !value->IsNullOrUndefined()) {
+    action_index = ResolveAction(args, value);
+    if (!action_index)
+      return;
+  } else {
+    action_index = FirstTextActionIndex();
+  }
+
+  EmitWithoutEvent("reply", ReplyDetails(args->isolate(), reply, action_index));
+  DispatchClick(action_index, reply);
+}
