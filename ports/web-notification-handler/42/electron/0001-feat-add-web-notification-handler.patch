diff --git a/script/fix-web-notification-typescript-definitions.mjs b/script/fix-web-notification-typescript-definitions.mjs
new file mode 100644
index 0000000000..19cba7a5c2
--- /dev/null
+++ b/script/fix-web-notification-typescript-definitions.mjs
@@ -0,0 +1,239 @@
+import fs from 'node:fs';
+import path from 'node:path';
+
+const definitionsPath = path.resolve('electron.d.ts');
+let definitions = fs.readFileSync(definitionsPath, 'utf8');
+
+const replacement = `  type WebNotification = WebFrameNotification | WebWorkerNotification | WebServiceWorkerNotification;
+
+  interface WebNotificationBase extends NodeJS.EventEmitter {
+
+    // Docs: https://electronjs.org/docs/api/web-notification
+
+    /**
+     * Emitted when an action button is clicked.
+     *
+     * For persistent service worker notifications, this dispatches the web
+     * \`notificationclick\` event to the service worker with the matching action.
+     */
+    on(event: 'action', listener: (details: WebNotificationActionEvent) => void): this;
+    off(event: 'action', listener: (details: WebNotificationActionEvent) => void): this;
+    once(event: 'action', listener: (details: WebNotificationActionEvent) => void): this;
+    addListener(event: 'action', listener: (details: WebNotificationActionEvent) => void): this;
+    removeListener(event: 'action', listener: (details: WebNotificationActionEvent) => void): this;
+    /**
+     * Emitted when the notification body is clicked.
+     *
+     * For persistent service worker notifications, this dispatches the web
+     * \`notificationclick\` event to the service worker.
+     */
+    on(event: 'click', listener: () => void): this;
+    off(event: 'click', listener: () => void): this;
+    once(event: 'click', listener: () => void): this;
+    addListener(event: 'click', listener: () => void): this;
+    removeListener(event: 'click', listener: () => void): this;
+    /**
+     * Emitted when the notification is closed.
+     */
+    on(event: 'close', listener: (details: WebNotificationCloseEvent) => void): this;
+    off(event: 'close', listener: (details: WebNotificationCloseEvent) => void): this;
+    once(event: 'close', listener: (details: WebNotificationCloseEvent) => void): this;
+    addListener(event: 'close', listener: (details: WebNotificationCloseEvent) => void): this;
+    removeListener(event: 'close', listener: (details: WebNotificationCloseEvent) => void): this;
+    /**
+     * Emitted when Electron fails to show the native notification.
+     */
+    on(event: 'failed', listener: (details: WebNotificationFailedEvent) => void): this;
+    off(event: 'failed', listener: (details: WebNotificationFailedEvent) => void): this;
+    once(event: 'failed', listener: (details: WebNotificationFailedEvent) => void): this;
+    addListener(event: 'failed', listener: (details: WebNotificationFailedEvent) => void): this;
+    removeListener(event: 'failed', listener: (details: WebNotificationFailedEvent) => void): this;
+    /**
+     * Emitted when the user submits text for a text action.
+     *
+     * For persistent service worker notifications, this dispatches the web
+     * \`notificationclick\` event to the service worker with the reply text.
+     */
+    on(event: 'reply', listener: (details: WebNotificationReplyEvent) => void): this;
+    off(event: 'reply', listener: (details: WebNotificationReplyEvent) => void): this;
+    once(event: 'reply', listener: (details: WebNotificationReplyEvent) => void): this;
+    addListener(event: 'reply', listener: (details: WebNotificationReplyEvent) => void): this;
+    removeListener(event: 'reply', listener: (details: WebNotificationReplyEvent) => void): this;
+    /**
+     * Emitted when Electron's native notification presenter displays the notification.
+     */
+    on(event: 'show', listener: () => void): this;
+    off(event: 'show', listener: () => void): this;
+    once(event: 'show', listener: () => void): this;
+    addListener(event: 'show', listener: () => void): this;
+    removeListener(event: 'show', listener: () => void): this;
+    /**
+     * Dispatches a notification body click.
+     */
+    click(): void;
+    /**
+     * Dispatches an action button click.
+     */
+    clickAction(action: (number) | (string)): void;
+    /**
+     * Closes the notification. For persistent service worker notifications, this
+     * dispatches \`notificationclose\` when \`byUser\` is \`true\`.
+     */
+    close(options?: WebNotificationCloseOptions): void;
+    /**
+     * Whether the notification object has been destroyed.
+     */
+    isDestroyed(): boolean;
+    /**
+     * Dispatches a text reply.
+     */
+    reply(text: string, action?: (number) | (string)): void;
+    /**
+     * Shows the notification using Electron's native notification presenter.
+     */
+    show(): void;
+    /**
+     * Prevents Electron from automatically showing the notification after the
+     * \`setWebNotificationHandler\` callback returns.
+     *
+     * The notification remains valid and can still be controlled later with
+     * \`notification.click()\`, \`notification.clickAction(action)\`,
+     * \`notification.reply(text[, action])\`, and \`notification.close([options])\`.
+     */
+    suppress(): void;
+    /**
+     * A \`WebNotificationAction[]\` containing the web notification actions.
+     *
+     */
+    readonly actions: WebNotificationAction[];
+    /**
+     * A \`string\` containing the notification body.
+     *
+     */
+    readonly body: string;
+    /**
+     * A \`string\` identifying this notification.
+     *
+     */
+    readonly id: string;
+    /**
+     * A \`string\` containing the notification origin.
+     *
+     */
+    readonly origin: string;
+    /**
+     * A \`string\` containing the notification tag.
+     *
+     */
+    readonly tag: string;
+    /**
+     * A \`string\` containing the notification title.
+     *
+     */
+    readonly title: string;
+  }
+
+  interface WebFrameNotification extends WebNotificationBase {
+    /**
+     * The notification was created by a frame with \`new Notification()\`.
+     */
+    readonly persistent: false;
+    /**
+     * The document URL for the frame notification.
+     */
+    readonly documentUrl: string;
+    /**
+     * The frame that created the notification.
+     */
+    readonly frame: WebFrameMain;
+    /**
+     * Persistent service worker notifications only.
+     */
+    readonly serviceWorker: undefined;
+    /**
+     * Persistent service worker notifications only.
+     */
+    readonly serviceWorkerScope: undefined;
+    /**
+     * The \`WebContents\` that owns the creating frame.
+     */
+    readonly webContents: WebContents;
+  }
+
+  interface WebWorkerNotification extends WebNotificationBase {
+    /**
+     * The notification was created by a dedicated worker or shared worker with
+     * \`new Notification()\`.
+     */
+    readonly persistent: false;
+    /**
+     * Frame document notifications only.
+     */
+    readonly documentUrl: undefined;
+    /**
+     * The ancestor frame for dedicated worker notifications. This is
+     * \`undefined\` for shared worker notifications.
+     */
+    readonly frame: (WebFrameMain) | (undefined);
+    /**
+     * Persistent service worker notifications only.
+     */
+    readonly serviceWorker: undefined;
+    /**
+     * Persistent service worker notifications only.
+     */
+    readonly serviceWorkerScope: undefined;
+    /**
+     * The \`WebContents\` that owns the ancestor frame for dedicated worker
+     * notifications. This is \`undefined\` for shared worker notifications.
+     */
+    readonly webContents: (WebContents) | (undefined);
+  }
+
+  interface WebServiceWorkerNotification extends WebNotificationBase {
+    /**
+     * The notification was created by
+     * \`ServiceWorkerRegistration.showNotification()\`.
+     */
+    readonly persistent: true;
+    /**
+     * Non-persistent notifications only.
+     */
+    readonly documentUrl: undefined;
+    /**
+     * Non-persistent notifications only.
+     */
+    readonly frame: undefined;
+    /**
+     * Resolves with the service worker for this persistent notification's scope.
+     */
+    getServiceWorker(): Promise<Electron.ServiceWorkerMain>;
+    /**
+     * The running service worker associated with this persistent notification, when
+     * it is currently running.
+     */
+    readonly serviceWorker: (ServiceWorkerMain) | (undefined);
+    /**
+     * The service worker scope for this persistent notification.
+     */
+    readonly serviceWorkerScope: string;
+    /**
+     * Non-persistent notifications only.
+     */
+    readonly webContents: undefined;
+  }
+`;
+
+if (!definitions.includes('type WebNotification = WebFrameNotification | WebWorkerNotification | WebServiceWorkerNotification;')) {
+  const startMarker = '  class WebNotification extends NodeEventEmitter {';
+  const endMarker = '\n  interface WebNotificationAction {';
+  const start = definitions.indexOf(startMarker);
+  const end = definitions.indexOf(endMarker, start);
+
+  if (start === -1 || end === -1) {
+    throw new Error('Unable to find generated WebNotification class in electron.d.ts');
+  }
+
+  definitions = definitions.slice(0, start) + replacement + definitions.slice(end);
+  fs.writeFileSync(definitionsPath, definitions);
+}
diff --git a/shell/browser/api/electron_api_session.cc b/shell/browser/api/electron_api_session.cc
index d018d72a51..c7f2f1c4b7 100644
--- a/shell/browser/api/electron_api_session.cc
+++ b/shell/browser/api/electron_api_session.cc
@@ -971,6 +971,26 @@ void Session::SetBluetoothPairingHandler(v8::Local<v8::Value> val,
   permission_manager->SetBluetoothPairingHandler(handler);
 }

+void Session::SetWebNotificationHandler(gin::Arguments* args) {
+  v8::Local<v8::Value> value;
+  WebNotificationHandler handler;
+  if (!args->GetNext(&value) ||
+      !(value->IsNull() ||
+        gin::ConvertFromV8(args->isolate(), value, &handler))) {
+    args->ThrowTypeError("Must pass null or function");
+    return;
+  }
+
+  web_notification_handler_ = std::move(handler);
+}
+
+bool Session::HandleWebNotification(v8::Local<v8::Value> notification) {
+  if (web_notification_handler_.is_null())
+    return false;
+  web_notification_handler_.Run(notification);
+  return true;
+}
+
