+v8::Local<v8::Value> WebNotification::ServiceWorkerScope(
+    v8::Isolate* isolate) const {
+  if (!service_worker_scope_)
+    return ToUndefined(isolate);
+  return gin::ConvertToV8(isolate, *service_worker_scope_);
+}
+
+v8::Local<v8::Value> WebNotification::ServiceWorker(v8::Isolate* isolate) const {
+  if (!service_worker_scope_)
+    return ToUndefined(isolate);
+
+  auto* storage_partition = browser_context_->GetDefaultStoragePartition();
+  auto* service_worker_context = storage_partition->GetServiceWorkerContext();
+  const auto& workers = service_worker_context->GetRunningServiceWorkerInfos();
+  for (const auto& [version_id, info] : workers) {
+    if (info.scope == *service_worker_scope_) {
+      auto handle = ServiceWorkerMain::From(
+          isolate, service_worker_context, browser_context_->UniqueId(),
+          storage_partition->GetConfig(), version_id);
+      if (handle.IsEmpty())
+        return ToUndefined(isolate);
+      return handle.ToV8();
+    }
+  }
+  return ToUndefined(isolate);
+}
