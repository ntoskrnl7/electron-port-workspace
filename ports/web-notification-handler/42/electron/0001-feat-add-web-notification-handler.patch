+class WebNotification::Delegate final : public electron::NotificationDelegate {
+ public:
+  explicit Delegate(WebNotification* owner) : owner_(owner) {}
+
+  Delegate(const Delegate&) = delete;
+  Delegate& operator=(const Delegate&) = delete;
+
+  void NotificationDestroyed() override {
+    if (owner_)
+      owner_->OnNativeDestroyed();
+    delete this;
+  }
+
+  void NotificationFailed(const std::string& error) override {
+    if (owner_)
+      owner_->OnNativeFailed(error);
+  }
+
+  void NotificationReplied(const std::string& reply) override {
+    if (owner_)
+      owner_->OnNativeReplied(reply);
+  }
+
+  void NotificationAction(int action_index, int selection_index) override {
+    if (owner_)
+      owner_->OnNativeAction(action_index, selection_index);
+  }
+
+  void NotificationClick() override {
+    if (owner_)
+      owner_->OnNativeClicked();
+  }
+
+  void NotificationClosed(const std::string& reason) override {
+    if (owner_)
+      owner_->OnNativeClosed(reason);
+  }
+
+  void NotificationDisplayed() override {
+    if (owner_)
+      owner_->OnNativeDisplayed();
+  }
+
+ private:
+  raw_ptr<WebNotification> owner_;
+};
