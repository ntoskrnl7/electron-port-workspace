+    v8::Isolate* isolate,
+    bool by_user,
+    const std::string& reason) const {
+  return gin::DataObjectBuilder(isolate)
+      .Set("byUser", by_user)
+      .Set("reason", reason)
+      .Build();
+}
+
+std::optional<int> WebNotification::ResolveAction(
+    gin::Arguments* args,
+    v8::Local<v8::Value> value) const {
+  int index = -1;
+  if (gin::ConvertFromV8(args->isolate(), value, &index)) {
+    if (index >= 0 &&
+        static_cast<size_t>(index) < notification_data_.actions.size()) {
+      return index;
+    }
+    args->ThrowTypeError("action index is out of range");
+    return std::nullopt;
+  }
+
+  std::string action_name;
+  if (gin::ConvertFromV8(args->isolate(), value, &action_name)) {
+    for (size_t i = 0; i < notification_data_.actions.size(); ++i) {
+      if (notification_data_.actions[i]->action == action_name)
+        return static_cast<int>(i);
+    }
+    args->ThrowTypeError("action string does not match any notification action");
+    return std::nullopt;
+  }
+
+  args->ThrowTypeError("action must be an index or action string");
+  return std::nullopt;
+}
+
+v8::Local<v8::Value> WebNotification::ActionDetails(v8::Isolate* isolate,
+                                                    int action_index) const {
+  if (action_index < 0 ||
+      static_cast<size_t>(action_index) >= notification_data_.actions.size()) {
+    return ToUndefined(isolate);
+  }
+
+  const auto& action = notification_data_.actions[action_index];
+  gin::DataObjectBuilder builder(isolate);
+  builder.Set("index", action_index)
+      .Set("type", NotificationActionTypeToString(action->type))
+      .Set("action", action->action)
+      .Set("title", action->title)
+      .Set("icon", action->icon.spec());
+  if (action->placeholder)
+    builder.Set("placeholder", *action->placeholder);
+  return builder.Build();
+}
+
+std::optional<int> WebNotification::FirstTextActionIndex() const {
+  for (size_t i = 0; i < notification_data_.actions.size(); ++i) {
+    if (notification_data_.actions[i]->type ==
+        blink::mojom::NotificationActionType::TEXT) {
+      return static_cast<int>(i);
+    }
+  }
+  return std::nullopt;
+}
+
+void WebNotification::EmitClose(bool by_user, const std::string& reason) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  EmitWithoutEvent("close", CloseDetails(isolate, by_user, reason));
+}
+
+void WebNotification::OnNativeDisplayed() {
+  displayed_ = true;
+  EmitWithoutEvent("show");
+}
+
+void WebNotification::OnNativeClicked() {
+  if (closed_ || destroyed_)
+    return;
+  EmitWithoutEvent("click");
+  DispatchClick(std::nullopt, std::nullopt);
+}
+
+void WebNotification::OnNativeAction(int native_action_index,
+                                     int selection_index) {
+  if (native_action_index < 0 ||
+      static_cast<size_t>(native_action_index) >=
+          native_action_to_web_action_index_.size()) {
+    return;
+  }
+
+  int action_index = native_action_to_web_action_index_[native_action_index];
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  EmitWithoutEvent("action", ActionDetails(isolate, action_index));
+  DispatchClick(action_index, std::nullopt);
+}
+
+void WebNotification::OnNativeReplied(const std::string& reply) {
+  std::optional<int> action_index = FirstTextActionIndex();
+  std::u16string reply_text = base::UTF8ToUTF16(reply);
+
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  EmitWithoutEvent("reply", ReplyDetails(isolate, reply_text, action_index));
+  DispatchClick(action_index, reply_text);
+}
+
+void WebNotification::OnNativeClosed(const std::string& reason) {
+  if (closing_native_ || closed_ || destroyed_)
+    return;
+
+  closed_ = true;
+  DispatchClose(true);
+  EmitClose(true, reason.empty() ? "user" : reason);
+  Destroy(false);
+}
+
+void WebNotification::OnNativeFailed(const std::string& error) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  EmitWithoutEvent("failed",
+                   gin::DataObjectBuilder(isolate).Set("error", error).Build());
+  Destroy(false);
+}
+
+void WebNotification::OnNativeDestroyed() {
+  native_notification_ = nullptr;
+  if (!destroyed_ && closed_) {
+    Destroy(false);
+  }
+}
+
+void WebNotification::DidStartWorkerForScope(
+    std::shared_ptr<gin_helper::Promise<v8::Local<v8::Value>>> shared_promise,
+    int64_t version_id,
+    content::ChildProcessId process_id,
+    int thread_id,
+    const blink::ServiceWorkerToken& token) {
+  v8::Isolate* isolate = shared_promise->isolate();
+  v8::HandleScope handle_scope(isolate);
+  auto* storage_partition = browser_context_->GetDefaultStoragePartition();
+  auto* service_worker_context = storage_partition->GetServiceWorkerContext();
+  auto service_worker = ServiceWorkerMain::From(
+      isolate, service_worker_context, browser_context_->UniqueId(),
+      storage_partition->GetConfig(), version_id);
+  shared_promise->Resolve(service_worker.ToV8());
+}
+
+void WebNotification::DidFailToStartWorkerForScope(
+    std::shared_ptr<gin_helper::Promise<v8::Local<v8::Value>>> shared_promise,
+    content::StatusCodeResponse status) {
+  shared_promise->RejectWithErrorMessage("Failed to start service worker.");
+}
