+v8::Local<v8::Value> WebNotification::ReplyDetails(
+    v8::Isolate* isolate,
+    const std::u16string& reply,
+    std::optional<int> action_index) const {
+  gin::DataObjectBuilder builder(isolate);
+  builder.Set("text", reply).Set("index", action_index.value_or(-1));
+  if (action_index)
+    builder.Set("action", ActionDetails(isolate, *action_index));
+  return builder.Build();
