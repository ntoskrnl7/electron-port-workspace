+void WebNotification::CloseFromService(bool dispatch_event) {
+  if (closed_ || destroyed_)
+    return;
+
+  closed_ = true;
+  if (native_notification_) {
+    closing_native_ = true;
+    native_notification_->Dismiss();
+    closing_native_ = false;
+  }
+  if (dispatch_event)
+    DispatchClose(false);
+  EmitClose(false, "programmatic");
+  Destroy(false);
+}
