+std::string NotificationActionTypeToString(
+    blink::mojom::NotificationActionType type) {
+  switch (type) {
+    case blink::mojom::NotificationActionType::BUTTON:
+      return "button";
+    case blink::mojom::NotificationActionType::TEXT:
