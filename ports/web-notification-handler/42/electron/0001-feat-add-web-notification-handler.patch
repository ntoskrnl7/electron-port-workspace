+gin_helper::Handle<WebNotification> WebNotification::Create(
+    v8::Isolate* isolate,
+    PlatformNotificationService* service,
+    ElectronBrowserContext* browser_context,
+    content::RenderFrameHost* render_frame_host,
+    std::string notification_id,
+    GURL origin,
+    GURL document_url,
+    std::optional<GURL> service_worker_scope,
+    blink::PlatformNotificationData notification_data,
+    blink::NotificationResources notification_resources) {
+  v8::Local<v8::Function> constructor =
+      GetConstructor(isolate, isolate->GetCurrentContext());
+  auto handle = gin_helper::CreateHandle(
+      isolate,
+      new WebNotification(service, browser_context, render_frame_host,
+                          std::move(notification_id), std::move(origin),
+                          std::move(document_url),
+                          std::move(service_worker_scope),
+                          std::move(notification_data),
+                          std::move(notification_resources)));
+  if (!handle.IsEmpty()) {
+    SetConstructorPrototype(isolate, constructor, handle);
+    handle->Pin(isolate);
+  }
+  return handle;
+}
