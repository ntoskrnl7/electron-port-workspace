++        {VAEncPictureParameterBufferType, sizeof(pic_param), &pic_param},
++        {VAEncSliceParameterBufferType, sizeof(slice_param), &slice_param},
++    };
++
++    std::array<VAEncPackedHeaderParameterBuffer, 3> packed_header_params = {};
