++    for (VAPictureHEVC& ref_pic : slice_param.ref_pic_list0) {
++      InitVAPictureHEVC(&ref_pic);
++    }
++    for (VAPictureHEVC& ref_pic : slice_param.ref_pic_list1) {
++      InitVAPictureHEVC(&ref_pic);
++    }
++
++    std::vector<VaapiWrapper::VABufferDescriptor> va_buffers = {
