+index 37001b947a9fa..a2be205da4f97 100644
+--- a/media/gpu/vaapi/vaapi_wrapper.h
++++ b/media/gpu/vaapi/vaapi_wrapper.h
+@@ -103,6 +103,7 @@ enum class VAImplementation {
+   kMesaGallium,
+   kIntelI965,
+   kIntelIHD,
++  kNvidia,
+   kChromiumFakeDriver,
+   kOther,
+   kInvalid,
diff --git a/patches/chromium/media_allow_webcodecs_hevc_main10_and_4_4_4_encode_configs.patch b/patches/chromium/media_allow_webcodecs_hevc_main10_and_4_4_4_encode_configs.patch
