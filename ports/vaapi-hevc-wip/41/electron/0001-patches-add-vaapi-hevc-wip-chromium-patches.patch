+From a5786aafff4595c39189b7805568e119651aae1e Mon Sep 17 00:00:00 2001
+From: Jung-Kwang Lee <ntoskrnl7@gmail.com>
+Date: Mon, 23 Mar 2026 14:47:52 +0900
+Subject: media/gpu: add VA-API HEVC Main10 and 4:4:4 encode support
+
+Add the H.265 VA-API encoder delegate and wire the Linux VA-API encode path to support HEVC Main10, Main444, and Main444 10 profiles.
+
+Teach the frame conversion, packed-header generation, upload, and VEA adapter paths to handle P010, I444, and YUV444P10 input for these profiles.
+
+Patch-Dir: src/electron/patches/chromium
+Patch-Filename: media_gpu_add_va-api_hevc_main10_and_4_4_4_encode_support.patch
+(cherry picked from commit 6a79ad798c74fa4ef2e7078c3c70e38ee8eca846)
+---
+ media/base/video_frame_converter.cc           | 263 ++++++++
+ media/base/video_frame_converter.h            |   9 +
+ media/gpu/h265_builder.cc                     |  11 +-
+ media/gpu/h265_builder_unittest.cc            | 120 ++++
+ media/gpu/vaapi/BUILD.gn                      |   2 +
+ .../h265_vaapi_video_encoder_delegate.cc      | 549 ++++++++++++++++
+ .../vaapi/h265_vaapi_video_encoder_delegate.h |  59 ++
+ .../vaapi/vaapi_video_encode_accelerator.cc   | 221 ++++++-
+ .../vaapi/vaapi_video_encode_accelerator.h    |   8 +
+ ...vaapi_video_encode_accelerator_unittest.cc |  13 +-
+ media/gpu/vaapi/vaapi_wrapper.cc              | 588 ++++++++++++++++--
+ media/gpu/vaapi/vaapi_wrapper.h               |  16 +-
+ .../video/video_encode_accelerator_adapter.cc | 150 ++++-
+ .../video/video_encode_accelerator_adapter.h  |   9 +
+ .../video_encode_accelerator_adapter_test.cc  |  80 +++
+ 15 files changed, 1991 insertions(+), 107 deletions(-)
+ create mode 100644 media/gpu/vaapi/h265_vaapi_video_encoder_delegate.cc
+ create mode 100644 media/gpu/vaapi/h265_vaapi_video_encoder_delegate.h
+
+diff --git a/media/base/video_frame_converter.cc b/media/base/video_frame_converter.cc
+index 5759bca54bae7..e94626c4eb355 100644
+--- a/media/base/video_frame_converter.cc
++++ b/media/base/video_frame_converter.cc
+@@ -5,6 +5,7 @@
+ 
+ #include "media/base/video_frame_converter.h"
+ 
++#include "base/numerics/safe_conversions.h"
+ #include "base/trace_event/trace_event.h"
+ #include "media/base/video_frame_converter_internals.h"
+ #include "third_party/libyuv/include/libyuv.h"
+@@ -14,6 +15,7 @@ namespace media {
+ namespace {
+ 
+ constexpr auto kDefaultFiltering = libyuv::kFilterBox;
++constexpr int kConvert8To10BitScale = 1024;
+ 
+ std::optional<VideoPixelFormat> GetSourceFormatOverrideForABGRToARGB(
+     VideoPixelFormat src_format,
+@@ -73,6 +75,9 @@ EncoderStatus VideoFrameConverter::ConvertAndScale(const VideoFrame& src_frame,
+     case PIXEL_FORMAT_I444A:
+       return ConvertAndScaleI4xxx(&src_frame, dest_frame);
+ 
++    case PIXEL_FORMAT_YUV444P10:
++      return ConvertAndScaleYUV444P10(&src_frame, dest_frame);
++
+     case PIXEL_FORMAT_NV12:
+     case PIXEL_FORMAT_NV12A:
+       return ConvertAndScaleNV12x(&src_frame, dest_frame);
+@@ -222,6 +227,49 @@ EncoderStatus VideoFrameConverter::ConvertAndScaleRGB(
+                  ? OkStatus()
+                  : EncoderStatus(EncoderStatus::Codes::kFormatConversionError);
+ 
++    case PIXEL_FORMAT_P010LE: {
++      auto tmp_i420_frame =
++          CreateTempFrame(PIXEL_FORMAT_I420, dest_frame.coded_size(),
++                          dest_frame.visible_rect(), dest_frame.natural_size());
++      if (!tmp_i420_frame ||
++          !internals::ARGBToI420x(*src_frame, *tmp_i420_frame)) {
++        return EncoderStatus::Codes::kFormatConversionError;
++      }
++      return ConvertI420xToP010(*tmp_i420_frame, dest_frame);
++    }
++
++    case PIXEL_FORMAT_YUV444P10: {
++      auto tmp_i444_frame =
++          CreateTempFrame(PIXEL_FORMAT_I444, dest_frame.coded_size(),
++                          dest_frame.visible_rect(), dest_frame.natural_size());
++      if (!tmp_i444_frame) {
++        return EncoderStatus::Codes::kScalingError;
++      }
++
++      scoped_refptr<VideoFrame> argb_tmp_frame;
++      if (auto src_format_override = GetSourceFormatOverrideForABGRToARGB(
++              src_frame->format(), PIXEL_FORMAT_I444)) {
++        if (tmp_frame) {
++          argb_tmp_frame =
++              WrapTempFrameForABGRToARGB(*src_format_override, tmp_frame);
++        } else {
++          argb_tmp_frame = CreateTempFrame(
++              *src_format_override, dest_frame.coded_size(),
++              dest_frame.visible_rect(), dest_frame.natural_size());
