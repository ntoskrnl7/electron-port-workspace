+void AppendExplicitShortTermRefPicSet(H26xAnnexBBitstreamBuilder& builder,
+                                      const H265StRefPicSet& st_ref_pic_set) {
+  // Keep packed non-IDR slice headers constrained to the single backward
+  // reference pattern used by the current VAAPI encoder path.
+  CHECK_LE(st_ref_pic_set.num_negative_pics, 1);
+  CHECK_EQ(st_ref_pic_set.num_positive_pics, 0);
+
+  builder.AppendUE(st_ref_pic_set.num_negative_pics);
+  builder.AppendUE(st_ref_pic_set.num_positive_pics);
+
+  if (st_ref_pic_set.num_negative_pics == 1) {
+    CHECK_EQ(st_ref_pic_set.delta_poc_s0[0], -1);
+    builder.AppendUE(0);  // delta_poc_s0_minus1
+    builder.AppendBool(st_ref_pic_set.used_by_curr_pic_s0[0]);
+  }
+}
