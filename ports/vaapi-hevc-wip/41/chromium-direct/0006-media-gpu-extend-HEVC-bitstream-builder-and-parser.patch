+void BuildPackedH265SliceHeader(H26xAnnexBBitstreamBuilder& builder,
+                                const H265SPS& sps,
+                                const H265PPS& pps,
+                                const H265SliceHeader& slice_header,
+                                bool add_rbsp_trailing_bits) {
+  // 7.3.6 Slice segment header syntax.
+  DCHECK(slice_header.first_slice_segment_in_pic_flag);
+  DCHECK(!slice_header.dependent_slice_segment_flag);
+
+  builder.BeginNALU(static_cast<H265NALU::Type>(slice_header.nal_unit_type));
+
+  builder.AppendBool(slice_header.first_slice_segment_in_pic_flag);
+  if (slice_header.irap_pic) {
+    builder.AppendBool(slice_header.no_output_of_prior_pics_flag);
+  }
+  builder.AppendUE(slice_header.slice_pic_parameter_set_id);
+
+  if (pps.num_extra_slice_header_bits > 0) {
+    builder.AppendBits(pps.num_extra_slice_header_bits, 0);
+  }
+  builder.AppendUE(slice_header.slice_type);
+
+  if (pps.output_flag_present_flag) {
+    builder.AppendBool(slice_header.pic_output_flag);
+  }
+  if (sps.separate_colour_plane_flag) {
+    builder.AppendBits(2, slice_header.colour_plane_id);
+  }
+
+  if (slice_header.nal_unit_type != H265NALU::IDR_W_RADL &&
+      slice_header.nal_unit_type != H265NALU::IDR_N_LP) {
+    builder.AppendBits(sps.log2_max_pic_order_cnt_lsb_minus4 + 4,
+                       slice_header.slice_pic_order_cnt_lsb);
+    builder.AppendBool(slice_header.short_term_ref_pic_set_sps_flag);
+    if (slice_header.short_term_ref_pic_set_sps_flag) {
+      CHECK_LE(sps.num_short_term_ref_pic_sets, 1);
+    } else {
+      AppendExplicitShortTermRefPicSet(builder, slice_header.st_ref_pic_set);
+    }
+    if (sps.sps_temporal_mvp_enabled_flag) {
+      builder.AppendBool(slice_header.slice_temporal_mvp_enabled_flag);
+    }
+  }
+
+  CHECK(!slice_header.IsBSlice());
+  if (sps.sample_adaptive_offset_enabled_flag) {
+    const int chroma_array_type =
+        sps.separate_colour_plane_flag ? 0 : sps.chroma_format_idc;
+    builder.AppendBool(slice_header.slice_sao_luma_flag);
+    if (chroma_array_type != 0) {
+      builder.AppendBool(slice_header.slice_sao_chroma_flag);
+    }
+  }
+
+  if (!slice_header.IsISlice()) {
+    builder.AppendBool(slice_header.num_ref_idx_active_override_flag);
+    if (slice_header.num_ref_idx_active_override_flag) {
+      builder.AppendUE(slice_header.num_ref_idx_l0_active_minus1);
+      CHECK(!slice_header.IsPSlice());
+      builder.AppendUE(slice_header.num_ref_idx_l1_active_minus1);
+    }
+    CHECK(!pps.lists_modification_present_flag);
+    if (pps.cabac_init_present_flag) {
+      builder.AppendBool(slice_header.cabac_init_flag);
+    }
+    if (slice_header.slice_temporal_mvp_enabled_flag) {
+      if (slice_header.IsBSlice()) {
+        builder.AppendBool(slice_header.collocated_from_l0_flag);
+      }
+      builder.AppendUE(slice_header.collocated_ref_idx);
+    }
+    CHECK(!pps.weighted_pred_flag);
+    CHECK(!pps.weighted_bipred_flag);
+    builder.AppendUE(slice_header.five_minus_max_num_merge_cand);
+  }
+
+  builder.AppendSE(slice_header.slice_qp_delta);
+
+  if (pps.pps_slice_chroma_qp_offsets_present_flag) {
+    builder.AppendSE(slice_header.slice_cb_qp_offset);
+    builder.AppendSE(slice_header.slice_cr_qp_offset);
+  }
+
+  if (pps.chroma_qp_offset_list_enabled_flag) {
+    builder.AppendBool(false);  // cu_chroma_qp_offset_enabled_flag
+  }
+
+  const bool deblocking_filter_disabled =
+      pps.deblocking_filter_override_enabled_flag
+          ? slice_header.slice_deblocking_filter_disabled_flag
+          : pps.pps_deblocking_filter_disabled_flag;
+  if (pps.deblocking_filter_override_enabled_flag) {
+    CHECK_EQ(slice_header.slice_deblocking_filter_disabled_flag,
+             pps.pps_deblocking_filter_disabled_flag);
+    builder.AppendBool(false);  // deblocking_filter_override_flag
+  }
+
+  if (pps.pps_loop_filter_across_slices_enabled_flag &&
+      (slice_header.slice_sao_luma_flag || slice_header.slice_sao_chroma_flag ||
+       !deblocking_filter_disabled)) {
+    builder.AppendBool(slice_header.slice_loop_filter_across_slices_enabled_flag);
+  }
+
+  if (add_rbsp_trailing_bits) {
+    builder.FinishNALU();
+    return;
+  }
+
+  // Some packed-header paths want only the header bits without a terminating
+  // RBSP stop bit so the caller can control exact bit length explicitly.
+  builder.Flush();
+}
