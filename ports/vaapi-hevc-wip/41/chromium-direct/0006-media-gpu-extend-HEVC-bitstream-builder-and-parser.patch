+TEST_F(H265BuilderTest, BuildVPSWithTimingInfo) {
+  H265VPS vps = MakeTestVPS();
+  vps.vps_timing_info_present_flag = true;
+  vps.vps_num_units_in_tick = 1;
+  vps.vps_time_scale = 30;
+  vps.vps_poc_proportional_to_timing_flag = true;
+  vps.vps_num_ticks_poc_diff_one_minus1 = 0;
+  vps.vps_num_hrd_parameters = 0;
+
+  H26xAnnexBBitstreamBuilder builder;
+  BuildPackedH265VPS(builder, vps);
+  builder.Flush();
+
+  parser_->SetStream(builder.data());
+  H265NALU nalu;
+  ASSERT_EQ(H265Parser::kOk, parser_->AdvanceToNextNALU(&nalu));
+  ASSERT_EQ(H265NALU::VPS_NUT, nalu.nal_unit_type);
+
+  int vps_id = -1;
+  ASSERT_EQ(H265Parser::kOk, parser_->ParseVPS(&vps_id));
+
+  const H265VPS* parsed_vps = parser_->GetVPS(vps_id);
+  ASSERT_TRUE(parsed_vps);
+  EXPECT_TRUE(parsed_vps->vps_timing_info_present_flag);
+  EXPECT_EQ(vps.vps_num_units_in_tick, parsed_vps->vps_num_units_in_tick);
+  EXPECT_EQ(vps.vps_time_scale, parsed_vps->vps_time_scale);
+  EXPECT_TRUE(parsed_vps->vps_poc_proportional_to_timing_flag);
+  EXPECT_EQ(vps.vps_num_ticks_poc_diff_one_minus1,
+            parsed_vps->vps_num_ticks_poc_diff_one_minus1);
+  EXPECT_EQ(vps.vps_num_hrd_parameters, parsed_vps->vps_num_hrd_parameters);
+}
