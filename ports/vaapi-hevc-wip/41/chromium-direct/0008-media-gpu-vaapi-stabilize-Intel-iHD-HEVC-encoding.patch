+void H265VaapiVideoEncoderDelegate::ApplyInputColorSpaceToParameterSets(
+    H265SPS& sps) const {
+  // Match the FFmpeg VAAPI HEVC stream layout more closely: keep HEVC colour
+  // description unspecified unless the end-to-end RGB->YUV conversion and
+  // signalling path has been validated. The current SHMEM capture path already
+  // uploads limited-range NV12 correctly, so forcing primaries/matrix/transfer
+  // here is more likely to tint the output than to help it.
+  sps.vui_parameters.colour_description_present_flag = false;
+  sps.vui_parameters.colour_primaries = 0;
+  sps.vui_parameters.transfer_characteristics = 0;
+  sps.vui_parameters.matrix_coeffs = 0;
+  sps.vui_parameters.video_full_range_flag = false;
+}
