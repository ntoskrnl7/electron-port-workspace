+scoped_refptr<VideoFrame> WrapP010UploadImageAsVideoFrame(
+    const VAImage& image,
+    const gfx::Size& visible_size,
+    uint8_t* image_ptr,
+    base::TimeDelta timestamp) {
+  CHECK_EQ(image.format.fourcc, base::checked_cast<uint32_t>(VA_FOURCC_P010));
+
+  // Treat the mapped VAImage memory as an unowned P010 frame so the upload
+  // path can reuse VideoFrameConverter's scratch/pool logic instead of keeping
+  // a separate ad-hoc conversion cache in VaapiWrapper.
+  const gfx::Size coded_size(image.width, image.height);
+  const size_t y_plane_bytes =
+      base::checked_cast<size_t>(image.pitches[0]) *
+      VideoFrame::Rows(VideoFrame::Plane::kY, PIXEL_FORMAT_P010LE,
+                       coded_size.height());
+  const size_t uv_plane_bytes =
+      base::checked_cast<size_t>(image.pitches[1]) *
+      VideoFrame::Rows(VideoFrame::Plane::kUV, PIXEL_FORMAT_P010LE,
+                       coded_size.height());
+  auto image_data =
+      UNSAFE_BUFFERS(base::span(image_ptr, image.data_size));
+
+  return VideoFrame::WrapExternalYuvData(
+      PIXEL_FORMAT_P010LE, coded_size, gfx::Rect(visible_size), visible_size,
+      base::checked_cast<size_t>(image.pitches[0]),
+      base::checked_cast<size_t>(image.pitches[1]),
+      image_data.subspan(image.offsets[0], y_plane_bytes),
+      image_data.subspan(image.offsets[1], uv_plane_bytes),
+      timestamp);
+}
