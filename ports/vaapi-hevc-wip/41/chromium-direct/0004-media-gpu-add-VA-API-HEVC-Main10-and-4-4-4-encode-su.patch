+VideoPixelFormat GetCpuInputPixelFormatForProfile(VideoCodecProfile profile) {
+#if BUILDFLAG(IS_LINUX) || BUILDFLAG(IS_CHROMEOS)
+  // This returns the CPU-upload fallback format for the current platform path,
+  // not the ideal hardware-native format in the abstract.
+  switch (profile) {
+    case HEVCPROFILE_MAIN10:
+      return PIXEL_FORMAT_I420;
+    case HEVCPROFILE_REXT:
+      return PIXEL_FORMAT_I444;
+    case HEVCPROFILE_HIGH_THROUGHPUT:
+      return PIXEL_FORMAT_YUV444P10;
+    default:
+      break;
+  }
+#endif
+#if BUILDFLAG(IS_FUCHSIA)
+  return PIXEL_FORMAT_I420;
+#else
+  return PIXEL_FORMAT_NV12;
+#endif
+}
+
+std::optional<VideoPixelFormat> GetGpuInputPixelFormatForProfile(
+    VideoCodecProfile profile) {
+#if BUILDFLAG(IS_LINUX) || BUILDFLAG(IS_CHROMEOS)
+  switch (profile) {
+    case HEVCPROFILE_MAIN10:
+      return PIXEL_FORMAT_P010LE;
+    case HEVCPROFILE_REXT:
+      return PIXEL_FORMAT_I444;
+    case HEVCPROFILE_HIGH_THROUGHPUT:
+      return PIXEL_FORMAT_YUV444P10;
+    default:
+      return std::nullopt;
+  }
+#else
+  return std::nullopt;
+#endif
+}
+
+VideoPixelFormat GetInputPixelFormatForProfile(
+    VideoCodecProfile profile,
+    const std::vector<VideoPixelFormat>& gpu_supported_pixel_formats,
+    bool supports_gpu_shared_images) {
+#if BUILDFLAG(IS_LINUX) || BUILDFLAG(IS_CHROMEOS)
+  if (supports_gpu_shared_images) {
+    const auto gpu_input_format = GetGpuInputPixelFormatForProfile(profile);
+    if (gpu_input_format &&
+        std::ranges::find(gpu_supported_pixel_formats, *gpu_input_format) !=
+            gpu_supported_pixel_formats.end()) {
+      return *gpu_input_format;
+    }
+  }
+#endif
+  return GetCpuInputPixelFormatForProfile(profile);
+}
+
+bool UsesGpuInputBuffers(
+    VideoCodecProfile profile,
+    const std::vector<VideoPixelFormat>& gpu_supported_pixel_formats,
+    bool supports_gpu_shared_images) {
+  if (!supports_gpu_shared_images) {
+    return false;
+  }
+
+  const auto gpu_input_format = GetGpuInputPixelFormatForProfile(profile);
+  return gpu_input_format &&
+         std::ranges::find(gpu_supported_pixel_formats, *gpu_input_format) !=
+             gpu_supported_pixel_formats.end();
+}
