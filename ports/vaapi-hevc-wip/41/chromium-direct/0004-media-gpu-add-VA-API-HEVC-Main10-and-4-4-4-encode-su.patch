+// coded size stays implicit inside the encoder/upload path instead of
+// materializing as input-frame padding. Other CPU-uploaded HEVC profiles keep
+// the aligned coded size contract until they demonstrate the same artifact.
+bool UsesVisibleSizeCpuFrames(VideoCodecProfile profile,
+                              bool uses_cpu_input_buffers) {
+  return profile == HEVCPROFILE_MAIN10 && uses_cpu_input_buffers;
+}
