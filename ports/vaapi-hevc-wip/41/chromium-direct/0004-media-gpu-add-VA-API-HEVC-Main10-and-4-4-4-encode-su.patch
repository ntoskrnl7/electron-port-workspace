+// and a P010-preferred encoder backend.
+bool UseVisibleSizeMain10ShmemPath(VideoCodecProfile output_profile,
+                                   uint32_t preferred_image_fourcc,
+                                   bool native_input_mode) {
+  return output_profile == HEVCPROFILE_MAIN10 && !native_input_mode &&
+         preferred_image_fourcc == VA_FOURCC_P010;
+}
+
+std::optional<VideoPixelFormat> GetNativeInputFormatForProfile(
+    VideoCodecProfile profile) {
+  switch (profile) {
+    case HEVCPROFILE_MAIN10:
