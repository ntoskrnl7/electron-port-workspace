+EncoderStatus VideoFrameConverter::ConvertI420xToP010(
+    const VideoFrame& src_frame,
+    VideoFrame& dest_frame) {
+  DCHECK(src_frame.format() == PIXEL_FORMAT_I420 ||
+         src_frame.format() == PIXEL_FORMAT_I420A);
+  DCHECK_EQ(dest_frame.format(), PIXEL_FORMAT_P010LE);
+  DCHECK_EQ(src_frame.visible_rect().size(), dest_frame.visible_rect().size());
+
+  // Keep the 10-bit intermediate on a plain owned frame. The reusable scratch
+  // pool still covers the surrounding I420 staging, while this path gives
+  // libyuv a conventional writable I010 layout for the final 10-bit step.
+  auto tmp_i010 =
+      VideoFrame::CreateFrame(PIXEL_FORMAT_YUV420P10, dest_frame.coded_size(),
+                              dest_frame.visible_rect(),
+                              dest_frame.natural_size(),
+                              dest_frame.timestamp());
+  if (!tmp_i010) {
+    return EncoderStatus::Codes::kScalingError;
+  }
+
+  if (libyuv::I420ToI010(
+          src_frame.visible_data(VideoFrame::Plane::kY),
+          src_frame.stride(VideoFrame::Plane::kY),
+          src_frame.visible_data(VideoFrame::Plane::kU),
+          src_frame.stride(VideoFrame::Plane::kU),
+          src_frame.visible_data(VideoFrame::Plane::kV),
+          src_frame.stride(VideoFrame::Plane::kV),
+          reinterpret_cast<uint16_t*>(
+              tmp_i010->GetWritableVisibleData(VideoFrame::Plane::kY)),
+          tmp_i010->stride(VideoFrame::Plane::kY) /
+              base::checked_cast<int>(sizeof(uint16_t)),
+          reinterpret_cast<uint16_t*>(
+              tmp_i010->GetWritableVisibleData(VideoFrame::Plane::kU)),
+          tmp_i010->stride(VideoFrame::Plane::kU) /
+              base::checked_cast<int>(sizeof(uint16_t)),
+          reinterpret_cast<uint16_t*>(
+              tmp_i010->GetWritableVisibleData(VideoFrame::Plane::kV)),
+          tmp_i010->stride(VideoFrame::Plane::kV) /
+              base::checked_cast<int>(sizeof(uint16_t)),
+          dest_frame.visible_rect().width(), dest_frame.visible_rect().height()) !=
+      0) {
+    return EncoderStatus::Codes::kFormatConversionError;
+  }
+
+  if (libyuv::I010ToP010(
+          reinterpret_cast<const uint16_t*>(
+              tmp_i010->visible_data(VideoFrame::Plane::kY)),
+          tmp_i010->stride(VideoFrame::Plane::kY) /
+              base::checked_cast<int>(sizeof(uint16_t)),
+          reinterpret_cast<const uint16_t*>(
+              tmp_i010->visible_data(VideoFrame::Plane::kU)),
+          tmp_i010->stride(VideoFrame::Plane::kU) /
+              base::checked_cast<int>(sizeof(uint16_t)),
+          reinterpret_cast<const uint16_t*>(
+              tmp_i010->visible_data(VideoFrame::Plane::kV)),
+          tmp_i010->stride(VideoFrame::Plane::kV) /
+              base::checked_cast<int>(sizeof(uint16_t)),
+          reinterpret_cast<uint16_t*>(
+              dest_frame.GetWritableVisibleData(VideoFrame::Plane::kY)),
+          dest_frame.stride(VideoFrame::Plane::kY) /
+              base::checked_cast<int>(sizeof(uint16_t)),
+          reinterpret_cast<uint16_t*>(
+              dest_frame.GetWritableVisibleData(VideoFrame::Plane::kUV)),
+          dest_frame.stride(VideoFrame::Plane::kUV) /
+              base::checked_cast<int>(sizeof(uint16_t)),
+          dest_frame.visible_rect().width(),
+          dest_frame.visible_rect().height()) != 0) {
+    return EncoderStatus::Codes::kFormatConversionError;
+  }
+
+  return OkStatus();
+}
+
+EncoderStatus VideoFrameConverter::ConvertAndScaleYUV444P10(
+    const VideoFrame* src_frame,
+    VideoFrame& dest_frame) {
+  DCHECK_EQ(src_frame->format(), PIXEL_FORMAT_YUV444P10);
+
+  dest_frame.set_color_space(src_frame->ColorSpace());
+
+  switch (dest_frame.format()) {
+    case PIXEL_FORMAT_YUV444P10: {
+      const auto filtering =
+          src_frame->visible_rect() == dest_frame.visible_rect()
+              ? libyuv::kFilterNone
+              : libyuv::kFilterBox;
+      for (size_t i = 0; i < VideoFrame::NumPlanes(dest_frame.format()); ++i) {
+        if (libyuv::ScalePlane_16(
+                reinterpret_cast<const uint16_t*>(src_frame->visible_data(i)),
+                src_frame->stride(i) /
+                    base::checked_cast<int>(sizeof(uint16_t)),
+                VideoFrame::Columns(i, src_frame->format(),
+                                    src_frame->visible_rect().width()),
+                VideoFrame::Rows(i, src_frame->format(),
+                                 src_frame->visible_rect().height()),
+                reinterpret_cast<uint16_t*>(
+                    dest_frame.GetWritableVisibleData(i)),
+                dest_frame.stride(i) /
+                    base::checked_cast<int>(sizeof(uint16_t)),
+                VideoFrame::Columns(i, dest_frame.format(),
+                                    dest_frame.visible_rect().width()),
+                VideoFrame::Rows(i, dest_frame.format(),
+                                 dest_frame.visible_rect().height()),
+                filtering) != 0) {
+          return EncoderStatus::Codes::kScalingError;
+        }
+      }
+      return OkStatus();
+    }
+
+    default:
+      return EncoderStatus(EncoderStatus::Codes::kUnsupportedFrameFormat)
+          .WithData("src", src_frame->AsHumanReadableString())
+          .WithData("dst", dest_frame.AsHumanReadableString());
+  }
+}
+
+EncoderStatus VideoFrameConverter::ConvertI444xToYUV444P10(
+    const VideoFrame& src_frame,
+    VideoFrame& dest_frame) {
+  DCHECK(src_frame.format() == PIXEL_FORMAT_I444 ||
+         src_frame.format() == PIXEL_FORMAT_I444A);
+  DCHECK_EQ(dest_frame.format(), PIXEL_FORMAT_YUV444P10);
+  DCHECK_EQ(src_frame.visible_rect().size(), dest_frame.visible_rect().size());
+
+  for (size_t i = 0; i < VideoFrame::NumPlanes(dest_frame.format()); ++i) {
+    libyuv::Convert8To16Plane(
+        src_frame.visible_data(i), src_frame.stride(i),
+        reinterpret_cast<uint16_t*>(dest_frame.GetWritableVisibleData(i)),
+        dest_frame.stride(i) / base::checked_cast<int>(sizeof(uint16_t)),
+        kConvert8To10BitScale,
+        VideoFrame::Columns(i, dest_frame.format(),
+                            dest_frame.visible_rect().width()),
+        VideoFrame::Rows(i, dest_frame.format(),
+                         dest_frame.visible_rect().height()));
+  }
+
+  return OkStatus();
+}
