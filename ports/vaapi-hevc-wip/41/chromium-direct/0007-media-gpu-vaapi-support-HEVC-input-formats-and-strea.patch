diff --git a/media/gpu/vaapi/test/hevc_vaapi_smoke_test.py b/media/gpu/vaapi/test/hevc_vaapi_smoke_test.py
new file mode 100644
index 0000000000000..a562a31f43a92
--- /dev/null
+++ b/media/gpu/vaapi/test/hevc_vaapi_smoke_test.py
@@ -0,0 +1,235 @@
+#!/usr/bin/env python3
+
+"""Minimal VAAPI HEVC encoder smoke test.
+
+This script verifies three things:
+1. `vainfo` advertises HEVC encode support.
+2. `ffmpeg` can encode a short synthetic stream with `hevc_vaapi`.
+3. `ffprobe` can parse the generated elementary stream as HEVC.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import shutil
+import subprocess
+import sys
+import tempfile
+from pathlib import Path
+
+
+def run_command(cmd: list[str]) -> subprocess.CompletedProcess[str]:
+    return subprocess.run(
+        cmd,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.STDOUT,
+        text=True,
+        check=False,
+    )
+
+
+def require_tool(name: str) -> str:
+    tool_path = shutil.which(name)
+    if not tool_path:
+        raise RuntimeError(f"Required tool not found in PATH: {name}")
+    return tool_path
+
+
+def advertised_hevc_encode(vainfo_output: str, profile: str) -> bool:
+    target_profile = "VAProfileHEVCMain10" if profile == "main10" else "VAProfileHEVCMain"
+    for line in vainfo_output.splitlines():
+        if target_profile not in line:
+            continue
+        if "VAEntrypointEncSlice" in line or "VAEntrypointEncSliceLP" in line:
+            return True
+    return False
+
+
+def encode_with_ffmpeg(
+    ffmpeg: str,
+    device: str,
+    profile: str,
+    width: int,
+    height: int,
+    fps: int,
+    frames: int,
+    qp: int,
+    output_path: Path,
+) -> subprocess.CompletedProcess[str]:
+    upload_format = "p010le" if profile == "main10" else "nv12"
+    cmd = [
+        ffmpeg,
+        "-hide_banner",
+        "-loglevel",
+        "info",
+        "-y",
+        "-vaapi_device",
+        device,
+        "-f",
+        "lavfi",
+        "-i",
+        f"testsrc2=size={width}x{height}:rate={fps}",
+        "-frames:v",
+        str(frames),
+        "-vf",
+        f"format={upload_format},hwupload",
+        "-c:v",
+        "hevc_vaapi",
+        "-profile:v",
+        profile,
+        "-rc_mode",
+        "CQP",
+        "-qp",
+        str(qp),
+        "-bf",
+        "0",
+        "-f",
+        "hevc",
+        str(output_path),
+    ]
+    return run_command(cmd)
+
+
+def probe_stream(ffprobe: str, input_path: Path) -> dict:
+    cmd = [
+        ffprobe,
+        "-v",
+        "error",
+        "-count_frames",
+        "-show_entries",
+        "stream=codec_name,profile,width,height,pix_fmt,nb_read_frames",
+        "-of",
+        "json",
+        str(input_path),
+    ]
+    proc = run_command(cmd)
+    if proc.returncode != 0:
+        raise RuntimeError(f"ffprobe failed:\n{proc.stdout}")
+    return json.loads(proc.stdout)
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--device", default="/dev/dri/renderD128", help="VAAPI render node")
+    parser.add_argument("--width", type=int, default=128, help="Frame width")
+    parser.add_argument("--height", type=int, default=128, help="Frame height")
+    parser.add_argument("--fps", type=int, default=30, help="Frame rate")
+    parser.add_argument("--frames", type=int, default=8, help="Number of frames to encode")
+    parser.add_argument("--qp", type=int, default=24, help="CQP value")
+    parser.add_argument(
+        "--profile",
+        choices=("main", "main10"),
+        default="main",
+        help="HEVC profile to test",
+    )
+    parser.add_argument(
+        "--output",
+        type=Path,
+        help="Optional output .hevc path. If omitted, a temporary file is used.",
+    )
+    parser.add_argument(
+        "--keep-output",
+        action="store_true",
+        help="Keep the temporary output file instead of deleting it.",
+    )
+    parser.add_argument(
+        "--show-logs",
+        action="store_true",
+        help="Print full vainfo and ffmpeg logs.",
+    )
+    return parser.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+
+    try:
+        vainfo = require_tool("vainfo")
+        ffmpeg = require_tool("ffmpeg")
+        ffprobe = require_tool("ffprobe")
+    except RuntimeError as exc:
+        print(f"ERROR: {exc}", file=sys.stderr)
+        return 1
+
+    vainfo_proc = run_command([vainfo])
+    if vainfo_proc.returncode != 0:
+        print("ERROR: vainfo failed", file=sys.stderr)
+        print(vainfo_proc.stdout, file=sys.stderr)
+        return 1
+
+    supports_hevc = advertised_hevc_encode(vainfo_proc.stdout, args.profile)
+    if not supports_hevc:
+        print(
+            f"ERROR: vainfo did not advertise HEVC {args.profile} encode support",
+            file=sys.stderr,
+        )
+        print(vainfo_proc.stdout, file=sys.stderr)
+        return 1
+
+    temp_dir_path: Path | None = None
+    output_path: Path
+    if args.output:
+        output_path = args.output.resolve()
+        output_path.parent.mkdir(parents=True, exist_ok=True)
+    else:
+        temp_dir_path = Path(tempfile.mkdtemp(prefix="hevc-vaapi-smoke-"))
+        output_path = temp_dir_path / "smoke_test.hevc"
+
+    ffmpeg_proc = encode_with_ffmpeg(
+        ffmpeg=ffmpeg,
+        device=args.device,
+        profile=args.profile,
+        width=args.width,
+        height=args.height,
+        fps=args.fps,
+        frames=args.frames,
+        qp=args.qp,
+        output_path=output_path,
+    )
+    if ffmpeg_proc.returncode != 0:
+        print("ERROR: ffmpeg encode failed", file=sys.stderr)
+        print(ffmpeg_proc.stdout, file=sys.stderr)
+        if temp_dir_path is not None and not args.keep_output:
+            shutil.rmtree(temp_dir_path, ignore_errors=True)
+        return 1
+
+    if not output_path.exists() or output_path.stat().st_size == 0:
+        print("ERROR: ffmpeg returned success but output file is missing or empty", file=sys.stderr)
+        if temp_dir_path is not None and not args.keep_output:
+            shutil.rmtree(temp_dir_path, ignore_errors=True)
+        return 1
+
+    try:
+        probe = probe_stream(ffprobe, output_path)
+    except RuntimeError as exc:
+        print(f"ERROR: {exc}", file=sys.stderr)
+        if temp_dir_path is not None and not args.keep_output:
+            shutil.rmtree(temp_dir_path, ignore_errors=True)
+        return 1
+
+    stream = probe.get("streams", [{}])[0]
+    summary = {
+        "device": args.device,
+        "profile_requested": args.profile,
+        "output_path": str(output_path),
+        "output_size_bytes": output_path.stat().st_size,
+        "stream": stream,
+    }
+
+    print("HEVC VAAPI smoke test passed.")
+    print(json.dumps(summary, indent=2, sort_keys=True))
+
+    if args.show_logs:
+        print("\n=== vainfo ===")
+        print(vainfo_proc.stdout)
+        print("=== ffmpeg ===")
+        print(ffmpeg_proc.stdout)
+
+    if temp_dir_path is not None and not args.keep_output:
+        shutil.rmtree(temp_dir_path, ignore_errors=True)
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
