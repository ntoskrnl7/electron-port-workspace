From 4bbf96cd755b91e49dc293a613d00d15ef38f3a4 Mon Sep 17 00:00:00 2001
From: Jung-Kwang Lee <ntoskrnl7@gmail.com>
Date: Mon, 23 Mar 2026 14:43:24 +0900
Subject: media: allow WebCodecs HEVC Main10 and 4:4:4 encode configs

Accept HEVC Main10, REXT, and High Throughput profiles in WebCodecs static validation and hardware config checks.

Also keep bare REXT codec strings without constraint bytes unspecified instead of inferring a stricter profile variant, and guard VideoEncoderFallback completion after teardown.

Patch-Dir: src/electron/patches/chromium
Patch-Filename: media_allow_webcodecs_hevc_main10_and_4_4_4_encode_configs.patch
(cherry picked from commit 44f91b71b449e5bcce918ac61416c53729881878)
---
 media/base/video_codec_string_parsers.cc      |  2 +-
 .../video_codec_string_parsers_unittest.cc    |  8 +++++++
 media/video/video_encoder_fallback.cc         |  1 +
 .../modules/webcodecs/video_encoder.cc        | 22 ++++++++++++++-----
 4 files changed, 27 insertions(+), 6 deletions(-)

diff --git a/media/base/video_codec_string_parsers.cc b/media/base/video_codec_string_parsers.cc
index d5ed519c3eafc..d395b423e6b96 100644
--- a/media/base/video_codec_string_parsers.cc
+++ b/media/base/video_codec_string_parsers.cc
@@ -706,7 +706,7 @@ std::optional<VideoType> ParseHEVCCodecId(std::string_view codec_id) {
   // monochrome constraint flags, which we use to determine the bit depth and
   // chroma subsampling formats.
   if (base::FeatureList::IsEnabled(kHEVCRextCodecStringParsing) &&
-      out_profile == HEVCPROFILE_REXT) {
+      out_profile == HEVCPROFILE_REXT && elem.size() > 4) {
     uint8_t max_bits_flag = (constraint_flags[0] >> 1) & 0b111;
     bool max_422_flag = constraint_flags[0] & 0b1;
     bool max_420_flag = constraint_flags[1] >> 7;
diff --git a/media/base/video_codec_string_parsers_unittest.cc b/media/base/video_codec_string_parsers_unittest.cc
index 011ab3eb91c8b..2b4584aa0284a 100644
--- a/media/base/video_codec_string_parsers_unittest.cc
+++ b/media/base/video_codec_string_parsers_unittest.cc
@@ -631,6 +631,14 @@ TEST(ParseHEVCCodecIdTest, InvalidHEVCCodecIds) {
   }
 
   if (base::FeatureList::IsEnabled(kHEVCRextCodecStringParsing)) {
+    {
+      auto result = ParseHEVCCodecId("hvc1.4.0.L93");
+      ASSERT_TRUE(result);
+      EXPECT_EQ(HEVCPROFILE_REXT, result->profile);
+      EXPECT_FALSE(result->bit_depth.has_value());
+      EXPECT_FALSE(result->subsampling.has_value());
+    }
+
     // HEVC range extension 8b444
     for (const auto* codec_id :
          {"hvc1.4.10.L93.9E.28", "hvc1.4.10.L93.9E.20", "hvc1.4.10.L93.9E.8"}) {
diff --git a/media/video/video_encoder_fallback.cc b/media/video/video_encoder_fallback.cc
index d7d1e0af8d74b..e20ead2e18325 100644
--- a/media/video/video_encoder_fallback.cc
+++ b/media/video/video_encoder_fallback.cc
@@ -162,6 +162,7 @@ void VideoEncoderFallback::FallbackInitialize(EncoderStatusCB init_done_cb) {
 
   auto complete_cb = [](base::WeakPtr<VideoEncoderFallback> self,
                         EncoderStatusCB init_done_cb, EncoderStatus status) {
+    if (!self) return;
     DCHECK_CALLED_ON_VALID_SEQUENCE(self->sequence_checker_);
     DCHECK(self->encoder_);
     std::move(init_done_cb).Run(std::move(status));
diff --git a/third_party/blink/renderer/modules/webcodecs/video_encoder.cc b/third_party/blink/renderer/modules/webcodecs/video_encoder.cc
index 95e98d3f1075a..6b29dd464353d 100644
--- a/third_party/blink/renderer/modules/webcodecs/video_encoder.cc
+++ b/third_party/blink/renderer/modules/webcodecs/video_encoder.cc
@@ -189,16 +189,24 @@ media::EncoderStatus IsAcceleratedConfigurationSupported(
     return media::EncoderStatus::Codes::kEncoderAccelerationSupportMissing;
   }
 
-  // Hardware encoders don't currently support high bit depths or subsamplings
-  // other than 4:2:0, except for AV1 profile 1 we require 4:4:4.
+  // Most hardware encoders currently support 4:2:0 input. AV1 profile 1 uses
+  // 4:4:4, and the HEVC 4:4:4 profiles we expose through VEA also require
+  // 4:4:4 input. HEVC Main10 and High Throughput use 10-bit input.
   media::VideoChromaSampling required_sampling =
-      (profile == media::AV1PROFILE_PROFILE_HIGH)
+      (profile == media::AV1PROFILE_PROFILE_HIGH ||
+       profile == media::HEVCPROFILE_REXT ||
+       profile == media::HEVCPROFILE_HIGH_THROUGHPUT)
           ? media::VideoChromaSampling::k444
           : media::VideoChromaSampling::k420;
+  const uint8_t required_bit_depth =
+      (profile == media::HEVCPROFILE_MAIN10 ||
+       profile == media::HEVCPROFILE_HIGH_THROUGHPUT)
+          ? 10
+          : 8;
 
   if ((options.subsampling.has_value() &&
        options.subsampling.value() != required_sampling) ||
-      options.bit_depth.value_or(8) != 8) {
+      options.bit_depth.value_or(required_bit_depth) != required_bit_depth) {
     return media::EncoderStatus::Codes::kEncoderUnsupportedConfig;
   }
 
@@ -472,7 +480,11 @@ bool VerifyCodecSupportStatic(VideoEncoderTraits::ParsedConfig* config,
       break;
 #if BUILDFLAG(ENABLE_PLATFORM_HEVC)
     case media::VideoCodec::kHEVC:
-      if (config->profile != media::VideoCodecProfile::HEVCPROFILE_MAIN) {
+      if (config->profile != media::VideoCodecProfile::HEVCPROFILE_MAIN &&
+          config->profile != media::VideoCodecProfile::HEVCPROFILE_MAIN10 &&
+          config->profile != media::VideoCodecProfile::HEVCPROFILE_REXT &&
+          config->profile !=
+              media::VideoCodecProfile::HEVCPROFILE_HIGH_THROUGHPUT) {
         *js_error_message = "Unsupported hevc profile.";
         return false;
       }
