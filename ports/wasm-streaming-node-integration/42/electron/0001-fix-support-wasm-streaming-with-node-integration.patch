diff --git a/lib/node/asar-fs-wrapper.ts b/lib/node/asar-fs-wrapper.ts
index af19733ea6..56011933e0 100644
--- a/lib/node/asar-fs-wrapper.ts
+++ b/lib/node/asar-fs-wrapper.ts
@@ -15,7 +15,7 @@ const Promise: PromiseConstructor = global.Promise;
 const envNoAsar = process.env.ELECTRON_NO_ASAR && process.type !== 'browser' && process.type !== 'renderer';
 const isAsarDisabled = () => process.noAsar || envNoAsar;
 
-const internalBinding = process.internalBinding!;
+export const internalBinding = process.internalBinding!;
 delete process.internalBinding;
 
 const nextTick = (functionToCall: Function, args: any[] = []) => {
diff --git a/lib/node/init.ts b/lib/node/init.ts
index b9ef80900f..896e563a77 100644
--- a/lib/node/init.ts
+++ b/lib/node/init.ts
@@ -1,9 +1,16 @@
 /* eslint-disable import/newline-after-import */
 /* eslint-disable import/order */
 // Initialize ASAR support in fs module.
-import { wrapFsWithAsar } from './asar-fs-wrapper';
+import { internalBinding, wrapFsWithAsar } from './asar-fs-wrapper';
 wrapFsWithAsar(require('fs'));
 
+interface WasmStreamingState {
+  setURL: (url: string) => void;
+  push: (chunk: ArrayBuffer | ArrayBufferView) => void;
+  finish: () => void;
+  abort: (error: unknown) => void;
+}
+
 // See ElectronRendererClient::DidCreateScriptContext.
 if ((globalThis as any).blinkfetch) {
   const keys = ['fetch', 'Response', 'FormData', 'Request', 'Headers', 'EventSource'];
@@ -11,6 +18,54 @@ if ((globalThis as any).blinkfetch) {
     (globalThis as any)[key] = (globalThis as any)[`blink${key}`];
     delete (globalThis as any)[`blink${key}`];
   }
+
+  const BlinkResponse = Response;
+  const resolvePromise = Promise.resolve.bind(Promise) as <T>(
+    value: T | PromiseLike<T>
+  ) => Promise<Awaited<T>>;
+
+  internalBinding('wasm_web_api').setImplementation(
+    (streamState: WasmStreamingState, source: Response | Promise<Response>) => {
+      (async () => {
+        const response = await resolvePromise(source);
+        if (!(response instanceof BlinkResponse)) {
+          throw new TypeError('WebAssembly response must be a Response or a Promise resolving to a Response');
+        }
+
+        const contentType = response.headers.get('Content-Type');
+        if (contentType?.toLowerCase() !== 'application/wasm') {
+          throw new TypeError(`WebAssembly response has unsupported MIME type '${contentType}'`);
+        }
+
+        if (!response.ok) {
+          throw new TypeError(`WebAssembly response has status code ${response.status}`);
+        }
+
+        if (response.bodyUsed) {
+          throw new TypeError('WebAssembly response body has already been used');
+        }
+
+        if (response.url) {
+          streamState.setURL(response.url);
+        }
+
+        const reader = response.body?.getReader();
+        if (reader) {
+          while (true) {
+            const { done, value } = await reader.read();
+            if (done) {
+              break;
+            }
+            streamState.push(value);
+          }
+        }
+      })().then(() => {
+        streamState.finish();
+      }, error => {
+        streamState.abort(error);
+      });
+    }
+  );
 }
 
