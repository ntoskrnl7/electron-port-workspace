+    async function withRenderProcessGoneGuard<T> (
+      window: BrowserWindow,
+      action: () => Promise<T>,
+      message: string
+    ) {
+      return await new Promise<T>((resolve, reject) => {
+        const onRenderProcessGone = (_event: Electron.Event, details: Electron.RenderProcessGoneDetails) => {
+          reject(new Error(`${message}: ${details.reason}`));
+        };
+        window.webContents.once('render-process-gone', onRenderProcessGone);
+        action().then(resolve, reject).finally(() => {
+          window.webContents.removeListener('render-process-gone', onRenderProcessGone);
+        });
+      });
+    }
+
+    it('supports wasm streaming compilation with nodeIntegration enabled', async () => {
+      const w = new BrowserWindow({
+        show: false,
+        webPreferences: {
+          nodeIntegration: true,
+          contextIsolation: false
+        }
+      });
+
+      await w.loadURL('data:text/html;charset=utf-8,<p>wasm streaming</p>');
+      const result = await withRenderProcessGoneGuard(
+        w,
+        () => w.webContents.executeJavaScript(wasmStreamingTestScript),
+        'renderer exited while compiling streaming wasm'
+      );
+      expect(result).to.equal(true);
+    });
+
