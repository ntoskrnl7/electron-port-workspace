+type JavaScriptDialogType = 'alert' | 'confirm' | 'prompt' | 'beforeunload';
+
+interface JavaScriptDialogInfo {
+  frame: Electron.WebFrameMain;
+  dialogType: JavaScriptDialogType;
+  messageText: string;
+  defaultPromptText: string;
+  isReload?: boolean;
+}
+
+type JavaScriptDialogCallback = (success: boolean, userInput: string) => void;
+type JavaScriptDialog =
+  Electron.AlertJavaScriptDialog |
+  Electron.ConfirmJavaScriptDialog |
+  Electron.PromptJavaScriptDialog |
+  Electron.BeforeUnloadJavaScriptDialog;
+type JavaScriptDialogHandler = (details: Electron.JavaScriptDialogHandlerDetails, dialog: JavaScriptDialog) => void | Promise<void>;
+type PendingJavaScriptDialog = { cancel: () => void };
+type JavaScriptDialogController = PendingJavaScriptDialog & { response: JavaScriptDialog };
+
+const MAX_PENDING_JAVASCRIPT_DIALOGS = 32;
+const javaScriptDialogHandlers = new WeakMap<Electron.WebContents, JavaScriptDialogHandler>();
+const pendingJavaScriptDialogs = new WeakMap<Electron.WebContents, Set<PendingJavaScriptDialog>>();
+
+const getJavaScriptDialogOrigin = (info: JavaScriptDialogInfo) => {
+  return info.frame.origin === 'file://' ? info.frame.url : info.frame.origin;
+};
+
+const createJavaScriptDialogDetails = (info: JavaScriptDialogInfo): Electron.JavaScriptDialogHandlerDetails => {
+  return {
+    frame: info.frame,
+    type: info.dialogType,
+    messageText: info.messageText,
+    defaultPromptText: info.defaultPromptText,
+    url: info.frame.url,
+    isMainFrame: info.frame.parent === null,
+    ...(info.dialogType === 'beforeunload' ? { isReload: !!info.isReload } : {})
+  };
+};
+
+const createJavaScriptDialog = (
+  type: JavaScriptDialogType,
+  callback: JavaScriptDialogCallback,
+  onDone: () => void
+): JavaScriptDialogController => {
+  let handled = false;
+
+  const respond = (success: boolean, userInput = '') => {
+    if (handled) return false;
+    handled = true;
+    onDone();
+    callback(success, userInput);
+    return true;
+  };
+
+  const cancel = () => {
+    if (handled) return;
+    handled = true;
+    onDone();
+  };
+
+  switch (type) {
+    case 'alert':
+      return {
+        response: {
+          type,
+          ok: () => respond(true)
+        },
+        cancel
+      };
+    case 'confirm':
+      return {
+        response: {
+          type,
+          confirm: () => respond(true),
+          cancel: () => respond(false)
+        },
+        cancel
+      };
+    case 'prompt':
+      return {
+        response: {
+          type,
+          submit: (value: string) => respond(true, `${value}`),
+          cancel: () => respond(false)
+        },
+        cancel
+      };
+    case 'beforeunload':
+      return {
+        response: {
+          type,
+          leave: () => respond(true),
+          stay: () => respond(false)
+        },
+        cancel
+      };
+  }
+};
+
+const cancelJavaScriptDialog = (dialog: JavaScriptDialog) => {
+  switch (dialog.type) {
+    case 'alert':
+      dialog.ok();
+      break;
+    case 'confirm':
+      dialog.cancel();
+      break;
+    case 'prompt':
+      dialog.cancel();
+      break;
+    case 'beforeunload':
+      dialog.stay();
+      break;
+  }
+};
+
+const runJavaScriptDialogHandler = (
+  contents: Electron.WebContents,
+  info: JavaScriptDialogInfo,
+  callback: JavaScriptDialogCallback
+) => {
+  const handler = javaScriptDialogHandlers.get(contents);
+  if (!handler) return false;
+
+  const pending = pendingJavaScriptDialogs.get(contents) ?? new Set<PendingJavaScriptDialog>();
+  pendingJavaScriptDialogs.set(contents, pending);
+  if (pending.size >= MAX_PENDING_JAVASCRIPT_DIALOGS) {
+    callback(false, '');
+    return true;
+  }
+
+  let dialog: JavaScriptDialogController | undefined;
+  const onDone = () => {
+    if (dialog) pending.delete(dialog);
+  };
+  dialog = createJavaScriptDialog(info.dialogType, callback, onDone);
+  pending.add(dialog);
+
+  try {
+    Promise.resolve(handler(createJavaScriptDialogDetails(info), dialog.response)).catch(error => {
+      cancelJavaScriptDialog(dialog.response);
+      process.nextTick(() => {
+        throw error;
+      });
+    });
+  } catch (error) {
+    cancelJavaScriptDialog(dialog.response);
+    throw error;
+  }
+
+  return true;
+};
+
+WebContents.prototype.setJavaScriptDialogHandler = function (handler) {
+  if (handler === null) {
+    javaScriptDialogHandlers.delete(this);
+    this._setJavaScriptDialogHandlerInstalled(false);
+    return;
+  }
+
+  if (typeof handler !== 'function') {
+    throw new TypeError('JavaScript dialog handler must be null or a function');
+  }
+
+  javaScriptDialogHandlers.set(this, handler);
+  this._setJavaScriptDialogHandlerInstalled(true);
+};
