From 2996b6bc0050b62cc054f6e9f29284c590037d5d Mon Sep 17 00:00:00 2001
From: Codex <codex@localhost>
Date: Wed, 20 May 2026 20:09:37 +0900
Subject: [PATCH] fix: expose localized beforeunload dialog text

---
 BUILD.gn                                      |  1 +
 .../before-unload-javascript-dialog.md        |  3 +-
 lib/browser/api/web-contents.ts               |  2 ++
 .../browser/api/electron_api_web_contents.cc  | 12 +++++++-
 spec/api-web-contents-spec.ts                 | 28 +++++++++++++++++++
 spec/ts-smoke/electron/main.ts                |  2 +-
 typings/internal-electron.d.ts                |  2 +-
 7 files changed, 46 insertions(+), 4 deletions(-)

diff --git a/BUILD.gn b/BUILD.gn
index 4dbc16cc7f..333d815456 100644
--- a/BUILD.gn
+++ b/BUILD.gn
@@ -497,6 +497,7 @@ source_set("electron_lib") {
     "//components/pref_registry",
     "//components/prefs",
     "//components/security_state/content",
+    "//components/strings:components_strings",
     "//components/tracing:tracing_metrics",
     "//components/upload_list",
     "//components/user_prefs",
diff --git a/docs/api/structures/before-unload-javascript-dialog.md b/docs/api/structures/before-unload-javascript-dialog.md
index 4bdb71d7e4..917b107807 100644
--- a/docs/api/structures/before-unload-javascript-dialog.md
+++ b/docs/api/structures/before-unload-javascript-dialog.md
@@ -3,7 +3,8 @@
 * `type` string - Can be `beforeunload`.
 * `frame` [WebFrameMain](../web-frame-main.md) - The frame that requested the
   JavaScript dialog.
-* `messageText` string - The dialog message text.
+* `title` string - The localized Chromium dialog title.
+* `messageText` string - The localized Chromium dialog message text.
 * `url` string - The last committed URL of the frame that requested the dialog.
 * `isMainFrame` boolean - Whether the frame that requested the dialog is the
   main frame.
diff --git a/lib/browser/api/web-contents.ts b/lib/browser/api/web-contents.ts
index a3aeefc262..34dca2f1d4 100644
--- a/lib/browser/api/web-contents.ts
+++ b/lib/browser/api/web-contents.ts
@@ -434,6 +434,7 @@ type JavaScriptDialogType = 'alert' | 'confirm' | 'prompt' | 'beforeunload';
 interface JavaScriptDialogInfo {
   frame: Electron.WebFrameMain;
   dialogType: JavaScriptDialogType;
+  title?: string;
   messageText: string;
   defaultPromptText: string;
   isReload?: boolean;
@@ -520,6 +521,7 @@ const createJavaScriptDialog = (
         response: {
           ...details,
           type: 'beforeunload',
+          title: info.title ?? '',
           isReload: !!info.isReload,
           leave: () => respond(true),
           stay: () => respond(false)
diff --git a/shell/browser/api/electron_api_web_contents.cc b/shell/browser/api/electron_api_web_contents.cc
index f34ca4cdb1..b90607261c 100644
--- a/shell/browser/api/electron_api_web_contents.cc
+++ b/shell/browser/api/electron_api_web_contents.cc
@@ -50,6 +50,7 @@
 #include "components/prefs/scoped_user_pref_update.h"
 #include "components/security_state/content/content_utils.h"
 #include "components/security_state/core/security_state.h"
+#include "components/strings/grit/components_strings.h"
 #include "content/browser/renderer_host/frame_tree_node.h"  // nogncheck
 #include "content/browser/renderer_host/input/touch_emulator_impl.h"  // nogncheck
 #include "content/browser/renderer_host/navigation_controller_impl.h"  // nogncheck
@@ -179,6 +180,7 @@
 #include "ui/base/ime/text_input_action.h"
 #include "ui/base/ime/text_input_mode.h"
 #include "ui/base/ime/text_input_type.h"
+#include "ui/base/l10n/l10n_util.h"
 #include "ui/display/screen.h"
 #include "ui/events/base_event_utils.h"
 #include "ui/events/blink/web_input_event_traits.h"
@@ -6217,12 +6219,20 @@ void WebContents::RunBeforeUnloadDialog(content::WebContents* web_contents,
                                         bool is_reload,
                                         DialogClosedCallback callback) {
   if (has_javascript_dialog_handler_) {
+    const std::u16string title =
+        l10n_util::GetStringUTF16(is_reload
+                                      ? IDS_BEFORERELOAD_MESSAGEBOX_TITLE
+                                      : IDS_BEFOREUNLOAD_MESSAGEBOX_TITLE);
+    const std::u16string message_text =
+        l10n_util::GetStringUTF16(IDS_BEFOREUNLOAD_MESSAGEBOX_MESSAGE);
+
     auto* isolate = JavascriptEnvironment::GetIsolate();
     v8::HandleScope scope(isolate);
     auto info = gin::DataObjectBuilder(isolate)
                     .Set("frame", rfh)
                     .Set("dialogType", "beforeunload")
-                    .Set("messageText", std::u16string())
+                    .Set("title", title)
+                    .Set("messageText", message_text)
                     .Set("defaultPromptText", std::u16string())
                     .Set("isReload", is_reload)
                     .Build();
diff --git a/spec/api-web-contents-spec.ts b/spec/api-web-contents-spec.ts
index 209a8c8672..7d14440a31 100644
--- a/spec/api-web-contents-spec.ts
+++ b/spec/api-web-contents-spec.ts
@@ -214,6 +214,8 @@ describe('webContents module', () => {
         if (dialog.type === 'beforeunload') {
           expect(dialog.frame).to.equal(w.webContents.mainFrame);
           expect(dialog.isMainFrame).to.equal(true);
+          expect(dialog.title).to.not.equal('');
+          expect(dialog.messageText).to.not.equal('');
           expect(dialog.isReload).to.equal(false);
           setImmediate(() => {
             expect(dialog.stay()).to.equal(true);
@@ -242,6 +244,8 @@ describe('webContents module', () => {
       });
       w.webContents.setJavaScriptDialogHandler((dialog) => {
         if (dialog.type === 'beforeunload') {
+          expect(dialog.title).to.not.equal('');
+          expect(dialog.messageText).to.not.equal('');
           expect(dialog.isReload).to.equal(false);
           setImmediate(() => {
             expect(dialog.leave()).to.equal(true);
@@ -257,6 +261,30 @@ describe('webContents module', () => {
       expect(pageTitle).to.equal('test');
       expect(legacyEventFired).to.equal(false);
     });
+
+    it('reports reload beforeunload title and message with setJavaScriptDialogHandler', async () => {
+      const w = new BrowserWindow({ show: false });
+      let beforeUnloadTitle = '';
+      let beforeUnloadMessage = '';
+      w.webContents.setJavaScriptDialogHandler((dialog) => {
+        if (dialog.type === 'beforeunload') {
+          expect(dialog.isReload).to.equal(true);
+          beforeUnloadTitle = dialog.title;
+          beforeUnloadMessage = dialog.messageText;
+          setImmediate(() => {
+            expect(dialog.leave()).to.equal(true);
+          });
+        }
+      });
+
+      await w.loadFile(path.join(__dirname, 'fixtures', 'api', 'beforeunload-false.html'));
+      await w.webContents.executeJavaScript("console.log('gesture')", true);
+      const didFinishLoad = once(w.webContents, 'did-finish-load');
+      w.webContents.reload();
+      await didFinishLoad;
+      expect(beforeUnloadTitle).to.not.equal('');
+      expect(beforeUnloadMessage).to.not.equal('');
+    });
   });
 
   describe('webContents.send(channel, args...)', () => {
diff --git a/spec/ts-smoke/electron/main.ts b/spec/ts-smoke/electron/main.ts
index 169e8af282..b27738de6a 100644
--- a/spec/ts-smoke/electron/main.ts
+++ b/spec/ts-smoke/electron/main.ts
@@ -149,7 +149,7 @@ app.whenReady().then(() => {
         console.log(dialog.isReload);
         break;
       case 'beforeunload':
-        console.log(dialog.isReload);
+        console.log(dialog.title, dialog.isReload);
         dialog.leave();
         break;
     }
diff --git a/typings/internal-electron.d.ts b/typings/internal-electron.d.ts
index 1088fe1fbb..0032a8fee9 100644
--- a/typings/internal-electron.d.ts
+++ b/typings/internal-electron.d.ts
@@ -284,7 +284,7 @@ declare namespace Electron {
     on(event: '-ipc-message-sync', listener: (event: Electron.IpcMainEvent, internal: boolean, channel: string, args: any[]) => void): this;
     on(event: '-ipc-invoke', listener: (event: Electron.IpcMainInvokeEvent, internal: boolean, channel: string, args: any[]) => void): this;
     on(event: '-ipc-ports', listener: (event: Electron.IpcMainEvent, internal: boolean, channel: string, message: any, ports: any[]) => void): this;
-    on(event: '-run-dialog', listener: (info: {frame: WebFrameMain, dialogType: 'prompt' | 'confirm' | 'alert' | 'beforeunload', messageText: string, defaultPromptText: string, isReload?: boolean}, callback: (success: boolean, user_input: string) => void) => void): this;
+    on(event: '-run-dialog', listener: (info: {frame: WebFrameMain, dialogType: 'prompt' | 'confirm' | 'alert' | 'beforeunload', title?: string, messageText: string, defaultPromptText: string, isReload?: boolean}, callback: (success: boolean, user_input: string) => void) => void): this;
     on(event: '-cancel-dialogs', listener: () => void): this;
     on(event: 'ready-to-show', listener: () => void): this;
     on(event: '-before-unload-fired', listener: (event: Electron.Event, proceed: boolean) => void): this;
