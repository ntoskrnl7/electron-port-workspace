+base::expected<ui::ImeTextSpan::UnderlineStyle, std::string>
+GetDispatchCompositionUnderlineStyle(const std::string& style) {
+  using UnderlineStyle = ui::ImeTextSpan::UnderlineStyle;
+  static constexpr auto Lookup =
+      base::MakeFixedFlatMap<std::string_view, UnderlineStyle>({
+          {"none", UnderlineStyle::kNone},
+          {"solid", UnderlineStyle::kSolid},
+          {"dot", UnderlineStyle::kDot},
+          {"dash", UnderlineStyle::kDash},
+          {"squiggle", UnderlineStyle::kSquiggle},
+      });
+  const auto* value = base::FindOrNull(Lookup, style);
+  if (!value)
+    return base::unexpected("Invalid 'highlight.underlineStyle' parameter");
+  return *value;
+}
+
+base::expected<ui::ImeTextSpan::Thickness, std::string>
+GetDispatchCompositionThickness(const std::string& thickness) {
+  using Thickness = ui::ImeTextSpan::Thickness;
+  static constexpr auto Lookup =
+      base::MakeFixedFlatMap<std::string_view, Thickness>({
+          {"none", Thickness::kNone},
+          {"thin", Thickness::kThin},
+          {"thick", Thickness::kThick},
+      });
+  const auto* value = base::FindOrNull(Lookup, thickness);
+  if (!value)
+    return base::unexpected("Invalid 'highlight.thickness' parameter");
+  return *value;
+}
+
+base::expected<SkColor, std::string> GetDispatchCompositionHighlightColor(
+    const gin_helper::Dictionary& dict,
+    std::string_view key) {
+  std::string color_string;
+  if (!dict.Get(key, &color_string)) {
+    return base::unexpected(
+        base::StringPrintf("Invalid 'highlight.%s' parameter",
+                           std::string(key).c_str()));
+  }
+
+  const std::optional<SkColor> color = ParseCSSColor(color_string);
+  if (!color.has_value()) {
+    return base::unexpected(
+        base::StringPrintf("Invalid 'highlight.%s' parameter",
+                           std::string(key).c_str()));
+  }
+  return color.value();
+}
+
+base::expected<ui::ImeTextSpan, std::string>
+CreateDispatchCompositionHighlightSpan(
+    const gin_helper::Dictionary& highlight_options,
+    size_t text_length) {
+  SkColor background_color = SK_ColorTRANSPARENT;
+  SkColor underline_color = SK_ColorTRANSPARENT;
+  SkColor text_color = SK_ColorTRANSPARENT;
+  ui::ImeTextSpan::Thickness thickness = ui::ImeTextSpan::Thickness::kNone;
+  ui::ImeTextSpan::UnderlineStyle underline_style =
+      ui::ImeTextSpan::UnderlineStyle::kNone;
+
+  const bool has_underline_options =
+      highlight_options.Has("underlineColor") ||
+      highlight_options.Has("underlineStyle") ||
+      highlight_options.Has("thickness");
+  if (has_underline_options) {
+    thickness = ui::ImeTextSpan::Thickness::kThin;
+    underline_style = ui::ImeTextSpan::UnderlineStyle::kSolid;
+  }
+
+  if (highlight_options.Has("backgroundColor")) {
+    auto parsed =
+        GetDispatchCompositionHighlightColor(highlight_options,
+                                             "backgroundColor");
+    if (!parsed.has_value())
+      return base::unexpected(parsed.error());
+    background_color = parsed.value();
+  }
+
+  if (highlight_options.Has("underlineColor")) {
+    auto parsed =
+        GetDispatchCompositionHighlightColor(highlight_options,
+                                             "underlineColor");
+    if (!parsed.has_value())
+      return base::unexpected(parsed.error());
+    underline_color = parsed.value();
+  }
+
+  if (highlight_options.Has("textColor")) {
+    auto parsed =
+        GetDispatchCompositionHighlightColor(highlight_options, "textColor");
+    if (!parsed.has_value())
+      return base::unexpected(parsed.error());
+    text_color = parsed.value();
+  }
+
+  if (highlight_options.Has("underlineStyle")) {
+    std::string style;
+    if (!highlight_options.Get("underlineStyle", &style)) {
+      return base::unexpected("Invalid 'highlight.underlineStyle' parameter");
+    }
+    auto parsed = GetDispatchCompositionUnderlineStyle(style);
+    if (!parsed.has_value())
+      return base::unexpected(parsed.error());
+    underline_style = parsed.value();
+  }
+
+  if (highlight_options.Has("thickness")) {
+    std::string value;
+    if (!highlight_options.Get("thickness", &value)) {
+      return base::unexpected("Invalid 'highlight.thickness' parameter");
+    }
+    auto parsed = GetDispatchCompositionThickness(value);
+    if (!parsed.has_value())
+      return base::unexpected(parsed.error());
+    thickness = parsed.value();
+  }
+
+  ui::ImeTextSpan span(ui::ImeTextSpan::Type::kComposition, 0, text_length,
+                       thickness, underline_style, background_color,
+                       SK_ColorTRANSPARENT, std::vector<std::string>(),
+                       text_color);
+  span.underline_color = underline_color;
+  return span;
+}
+
+base::expected<std::vector<ui::ImeTextSpan>, std::string>
+CreateDispatchCompositionHighlightSpans(
+    v8::Isolate* isolate,
+    const gin_helper::Dictionary& input_event,
+    size_t text_length) {
+  std::vector<ui::ImeTextSpan> spans;
+
+  v8::Local<v8::Value> value;
+  if (!input_event.GetHandle()
+           ->GetRealNamedProperty(
+               isolate->GetCurrentContext(),
+               gin::StringToV8(isolate, "highlight").As<v8::String>())
+           .ToLocal(&value))
+    return spans;
+
+  if (value->IsBoolean()) {
+    if (value.As<v8::Boolean>()->Value())
+      return spans;
+
+    auto span =
+        CreateDispatchCompositionHighlightSpan(
+            gin_helper::Dictionary::CreateEmpty(isolate), text_length);
+    if (!span.has_value())
+      return base::unexpected(span.error());
+    spans.push_back(span.value());
+    return spans;
+  }
+
+  if (!value->IsObject() || value->IsArray()) {
+    return base::unexpected("'highlight' must be a boolean or an object");
+  }
+
+  gin_helper::Dictionary highlight_options;
+  if (!gin::ConvertFromV8(isolate, value, &highlight_options)) {
+    return base::unexpected("'highlight' must be a boolean or an object");
+  }
+
+  auto span =
+      CreateDispatchCompositionHighlightSpan(highlight_options, text_length);
+  if (!span.has_value())
+    return base::unexpected(span.error());
+  spans.push_back(span.value());
+  return spans;
+}
