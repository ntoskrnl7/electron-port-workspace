+    const countPixels = (image: Electron.NativeImage, matches: (r: number, g: number, b: number, a: number) => boolean) => {
+      const bitmap = image.toBitmap();
+      let count = 0;
+      for (let i = 0; i < bitmap.length; i += 4) {
+        const b = bitmap[i];
+        const g = bitmap[i + 1];
+        const r = bitmap[i + 2];
+        const a = bitmap[i + 3];
+        if (matches(r, g, b, a)) count++;
+      }
+      return count;
+    };
