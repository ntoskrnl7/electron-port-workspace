+const { app, BrowserWindow } = require('electron');
+const http = require('node:http');
+
+const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
+let progress = 'initializing';
+
+function createServer() {
+  const server = http.createServer((req, res) => {
+    res.setHeader('Content-Type', 'text/html');
+
+    if (req.url.startsWith('/a')) {
+      res.end(`
+        <!doctype html>
+        <html>
+        <head>
+          <meta charset="utf-8">
+          <style>
+            body { margin: 0; font: 14px sans-serif; }
+            #source {
+              position: absolute;
+              left: 20px;
+              top: 20px;
+              width: 140px;
+              height: 32px;
+              border: 1px solid #222;
+              user-select: none;
+            }
+            #button {
+              position: absolute;
+              left: 20px;
+              top: 90px;
+              width: 120px;
+              height: 32px;
+            }
+          </style>
+        </head>
+        <body>
+          <div id="source" draggable="true">dragged-text</div>
+          <button id="button">click me</button>
+          <script>
+            const post = type => parent.postMessage({ frame: 'a', type }, '*');
+            const source = document.getElementById('source');
+            const button = document.getElementById('button');
+
+            source.addEventListener('dragstart', event => {
+              event.dataTransfer.setData('text/plain', 'dragged-text');
+              event.dataTransfer.effectAllowed = 'copyMove';
+              post('dragstart');
+            });
+            source.addEventListener('dragend', () => post('dragend'));
+
+            button.addEventListener('mouseover', () => post('mouseover'));
+            button.addEventListener('mousedown', () => post('mousedown'));
+            button.addEventListener('mouseup', () => post('mouseup'));
+            button.addEventListener('click', () => post('click'));
+
+            window.addEventListener('load', () => post('ready'));
+          </script>
+        </body>
+        </html>
+      `);
+      return;
+    }
+
+    if (req.url.startsWith('/b')) {
+      res.end(`
+        <!doctype html>
+        <html>
+        <head>
+          <meta charset="utf-8">
+          <style>
+            body { margin: 0; }
+            #target {
+              position: absolute;
+              left: 20px;
+              top: 40px;
+              width: 150px;
+              height: 70px;
+            }
+          </style>
+        </head>
+        <body>
+          <textarea id="target"></textarea>
+          <script>
+            const target = document.getElementById('target');
+            const post = (type, extra = {}) => parent.postMessage({ frame: 'b', type, ...extra }, '*');
+            target.addEventListener('drop', () => {
+              setTimeout(() => post('drop', { value: target.value }), 0);
+            });
+            window.addEventListener('load', () => post('ready'));
+          </script>
+        </body>
+        </html>
+      `);
+      return;
+    }
+
+    const host = req.headers.host;
+    const aUrl = `http://${host}/a`;
+    const bUrl = `http://${host.replace('127.0.0.1', 'localhost')}/b`;
+    res.end(`
+      <!doctype html>
+      <html>
+      <head>
+        <meta charset="utf-8">
+        <style>
+          body { margin: 0; }
+          iframe {
+            position: absolute;
+            top: 20px;
+            width: 220px;
+            height: 160px;
+            border: 0;
+          }
+          #a { left: 20px; }
+          #b { left: 280px; }
+        </style>
+      </head>
+      <body>
+        <iframe id="a" src="${aUrl}"></iframe>
+        <iframe id="b" src="${bUrl}"></iframe>
+        <script>
+          window.messages = [];
+          window.readyFrames = {};
+          window.addEventListener('message', event => {
+            window.messages.push(event.data);
+            if (event.data?.type === 'ready') {
+              window.readyFrames[event.data.frame] = true;
+            }
+          });
+        </script>
+      </body>
+      </html>
+    `);
+  });
+
+  return new Promise((resolve) => {
+    server.listen(0, '127.0.0.1', () => {
+      const { port } = server.address();
+      resolve({ server, url: `http://127.0.0.1:${port}` });
+    });
+  });
+}
+
+async function waitFor(webContents, expression, timeout = 5000) {
+  const started = Date.now();
+  while (Date.now() - started < timeout) {
+    if (await webContents.executeJavaScript(expression)) {
+      return;
+    }
+    await delay(50);
+  }
+  throw new Error(`Timed out waiting for ${expression}`);
+}
+
+async function dispatchCrossFrameDrag(webContents) {
+  progress = 'drag mousePressed';
+  await webContents.dispatchInputEvent({
+    kind: 'mouse',
+    type: 'mousePressed',
+    x: 90,
+    y: 56,
+    button: 'left',
+    buttons: 1,
+    clickCount: 1
+  });
+  await delay(100);
+
+  for (const [x, y] of [
+    [140, 56],
+    [220, 56],
+    [270, 70],
+    [300, 80],
+    [340, 88],
+    [370, 92]
+  ]) {
+    progress = `drag mouseMoved ${x},${y}`;
+    await webContents.dispatchInputEvent({
+      kind: 'mouse',
+      type: 'mouseMoved',
+      x,
+      y,
+      button: 'left',
+      buttons: 1
+    });
+    await delay(100);
+  }
+
+  await delay(150);
+  progress = 'drag mouseReleased';
+  await webContents.dispatchInputEvent({
+    kind: 'mouse',
+    type: 'mouseReleased',
+    x: 370,
+    y: 92,
+    button: 'left',
+    buttons: 0,
+    clickCount: 1
+  });
+}
+
+async function dispatchSourceFrameClick(webContents) {
+  await delay(200);
+  progress = 'source mouseMoved';
+  await webContents.dispatchInputEvent({
+    kind: 'mouse',
+    type: 'mouseMoved',
+    x: 90,
+    y: 126,
+    button: 'none',
+    buttons: 0
+  });
+  await delay(50);
+  progress = 'source mousePressed';
+  await webContents.dispatchInputEvent({
+    kind: 'mouse',
+    type: 'mousePressed',
+    x: 90,
+    y: 126,
+    button: 'left',
+    buttons: 1,
+    clickCount: 1
+  });
+  await delay(50);
+  progress = 'source mouseReleased';
+  await webContents.dispatchInputEvent({
+    kind: 'mouse',
+    type: 'mouseReleased',
+    x: 90,
+    y: 126,
+    button: 'left',
+    buttons: 0,
+    clickCount: 1
+  });
+}
+
+async function main() {
+  const timeout = setTimeout(() => {
+    console.error(`dispatch-input-cross-frame-drag fixture timed out at ${progress}`);
+    app.exit(124);
+  }, 12000);
+
+  const { server, url } = await createServer();
+  progress = 'creating window';
+  const window = new BrowserWindow({
+    show: true,
+    width: 560,
+    height: 240,
+    webPreferences: {
+      sandbox: false
+    }
+  });
+
+  try {
+    progress = 'loading parent page';
+    await window.loadURL(url);
+    progress = 'waiting for frames';
+    await waitFor(window.webContents, 'window.readyFrames.a && window.readyFrames.b');
+    window.focus();
+    await delay(200);
+
+    await dispatchCrossFrameDrag(window.webContents);
+    progress = 'waiting for drop';
+    await waitFor(window.webContents, 'window.messages.some(message => message.frame === "b" && message.type === "drop")');
+    await dispatchSourceFrameClick(window.webContents);
+    await delay(300);
+
+    progress = 'collecting result';
+    const result = await window.webContents.executeJavaScript(`(() => {
+      const events = window.messages.map(message => message.frame + ':' + message.type);
+      const drop = window.messages.find(message => message.frame === 'b' && message.type === 'drop');
+      return { events, droppedText: drop?.value || '' };
+    })()`);
+
+    await new Promise((resolve) => process.stdout.write(`RESULT:${JSON.stringify(result)}\n`, resolve));
+
+    if (
+      result.droppedText !== 'dragged-text' ||
+      !result.events.includes('a:dragstart') ||
+      !result.events.includes('a:dragend') ||
+      !result.events.includes('b:drop') ||
+      !result.events.includes('a:mouseover') ||
+      !result.events.includes('a:click')
+    ) {
+      await new Promise((resolve) => process.stderr.write(`FAIL:${JSON.stringify(result)}\n`, resolve));
+      app.exitCode = 1;
+    }
+  } finally {
+    clearTimeout(timeout);
+    window.close();
+    server.close(() => app.quit());
+  }
+}
+
+app
+  .whenReady()
+  .then(main)
+  .catch((error) => {
+    console.error(error);
+    app.exit(1);
+  });
