+base::expected<std::vector<blink::WebTouchEvent>, std::string>
+CreateDispatchTouchEvents(WebContents* contents,
+                          const gin_helper::Dictionary& dict,
+                          float scale_factor) {
+  std::string event_type;
+  if (!dict.Get("type", &event_type))
+    return base::unexpected("Missing required option 'type'");
+
+  blink::WebInputEvent::Type type = GetDispatchTouchEventType(event_type);
+  if (type == blink::WebInputEvent::Type::kUndefined) {
+    return base::unexpected(base::StringPrintf(
+        "Unexpected touch event type '%s'", event_type.c_str()));
+  }
+
+  std::vector<gin_helper::Dictionary> touch_points;
+  dict.Get("touchPoints", &touch_points);
+  if ((type == blink::WebInputEvent::Type::kTouchStart ||
+       type == blink::WebInputEvent::Type::kTouchMove) &&
+      touch_points.empty()) {
+    return base::unexpected(
+        "touchStart and touchMove require at least one touch point");
+  }
+  if (type == blink::WebInputEvent::Type::kTouchCancel &&
+      !touch_points.empty()) {
+    return base::unexpected("touchCancel must not include touch points");
+  }
+
+  DispatchTouchPointMap& current_points =
+      GetDispatchInputTouchPoints()[contents];
+  if (type != blink::WebInputEvent::Type::kTouchStart &&
+      current_points.empty()) {
+    return base::unexpected(
+        "Must send touchStart before touchMove/touchEnd/touchCancel");
+  }
+
+  int modifiers = 0;
+  dict.Get("modifiers", &modifiers);
+  std::optional<double> timestamp;
+  double timestamp_value = 0;
+  if (dict.Get("timestamp", &timestamp_value))
+    timestamp = timestamp_value;
+  const int event_modifiers =
+      GetDispatchInputEventModifiers(modifiers, false, false, 0, 0);
+  const base::TimeTicks event_timestamp =
+      GetDispatchInputEventTimeTicks(timestamp);
+
+  DispatchTouchPointMap incoming_points;
+  size_t with_id = 0;
+  for (size_t i = 0; i < touch_points.size(); ++i) {
+    gin_helper::Dictionary point = touch_points[i];
+    int id = static_cast<int>(i);
+    if (point.Get("id", &id))
+      with_id++;
+
+    double x = 0;
+    double y = 0;
+    if (!point.Get("x", &x) || !point.Get("y", &y))
+      return base::unexpected("Touch points require 'x' and 'y'");
+
+    double radius_x = 1.0;
+    point.Get("radiusX", &radius_x);
+    double radius_y = 1.0;
+    point.Get("radiusY", &radius_y);
+    double rotation_angle = 0.0;
+    point.Get("rotationAngle", &rotation_angle);
+    double force = 1.0;
+    point.Get("force", &force);
+    double tangential_pressure = 0.0;
+    point.Get("tangentialPressure", &tangential_pressure);
+    double tilt_x = 0.0;
+    point.Get("tiltX", &tilt_x);
+    double tilt_y = 0.0;
+    point.Get("tiltY", &tilt_y);
+    int twist = 0;
+    point.Get("twist", &twist);
+
+    std::string validation_error = ValidatePointerEventProperties(
+        force, tangential_pressure, tilt_x, tilt_y, twist);
+    if (!validation_error.empty())
+      return base::unexpected(validation_error);
+
+    blink::WebTouchPoint web_point;
+    web_point.id = id;
+    web_point.radius_x = radius_x;
+    web_point.radius_y = radius_y;
+    web_point.rotation_angle = rotation_angle;
+    web_point.force = force;
+    web_point.pointer_type = blink::WebPointerProperties::PointerType::kTouch;
+    web_point.SetPositionInWidget(CssPixelsToPointF(x, y, scale_factor));
+    web_point.SetPositionInScreen(web_point.PositionInWidget());
+    web_point.tilt_x = tilt_x;
+    web_point.tilt_y = tilt_y;
+    web_point.tangential_pressure = tangential_pressure;
+    web_point.twist = twist;
+    incoming_points[id] = web_point;
+  }
+
+  if (with_id > 0 && with_id < touch_points.size()) {
+    return base::unexpected(
+        "All or none of the provided touch points must supply ids");
+  }
+
+  std::vector<blink::WebTouchEvent> events;
+  bool ok = true;
+  for (auto& id_point : incoming_points) {
+    if (current_points.contains(id_point.first) &&
+        type == blink::WebInputEvent::Type::kTouchMove &&
+        current_points[id_point.first].PositionInWidget() ==
+            id_point.second.PositionInWidget()) {
+      continue;
+    }
+
+    events.emplace_back(type, event_modifiers, event_timestamp);
+    ok &= GenerateDispatchTouchPoints(&events.back(), type, current_points,
+                                      id_point.second);
+    if (type == blink::WebInputEvent::Type::kTouchStart ||
+        type == blink::WebInputEvent::Type::kTouchMove) {
+      current_points[id_point.first] = id_point.second;
+    } else if (type == blink::WebInputEvent::Type::kTouchEnd) {
+      current_points.erase(id_point.first);
+    }
+  }
+
+  if (touch_points.empty() && !current_points.empty()) {
+    if (type == blink::WebInputEvent::Type::kTouchCancel) {
+      events.emplace_back(type, event_modifiers, event_timestamp);
+      ok &= GenerateDispatchTouchPoints(&events.back(), type, current_points,
+                                        current_points.begin()->second);
+      current_points.clear();
+    } else if (type == blink::WebInputEvent::Type::kTouchEnd) {
+      for (auto it = current_points.begin(); it != current_points.end();) {
+        events.emplace_back(type, event_modifiers, event_timestamp);
+        ok &= GenerateDispatchTouchPoints(&events.back(), type, current_points,
+                                          it->second);
+        it = current_points.erase(it);
+      }
+    }
+  }
+
+  if (!ok) {
+    return base::unexpected(
+        base::StringPrintf("Exceeded maximum touch points limit of %d",
+                           blink::WebTouchEvent::kTouchesLengthCap));
+  }
+
+  return events;
+}
