+base::TimeTicks GetDispatchInputEventTimeTicks(
+    const std::optional<double>& timestamp) {
+  return timestamp.has_value()
+             ? base::Seconds(timestamp.value()) + base::TimeTicks::UnixEpoch()
+             : ui::EventTimeForNow();
+}
+
+int GetDispatchInputEventModifiers(int modifiers,
+                                   bool auto_repeat,
+                                   bool is_keypad,
+                                   int location,
+                                   int buttons) {
+  int result = blink::WebInputEvent::kFromDebugger;
+  if (auto_repeat)
+    result |= blink::WebInputEvent::kIsAutoRepeat;
+  if (is_keypad)
+    result |= blink::WebInputEvent::kIsKeyPad;
+
+  if (modifiers & 1)
+    result |= blink::WebInputEvent::kAltKey;
+  if (modifiers & 2)
+    result |= blink::WebInputEvent::kControlKey;
+  if (modifiers & 4)
+    result |= blink::WebInputEvent::kMetaKey;
+  if (modifiers & 8)
+    result |= blink::WebInputEvent::kShiftKey;
+
+  if (location & 1)
+    result |= blink::WebInputEvent::kIsLeft;
+  if (location & 2)
+    result |= blink::WebInputEvent::kIsRight;
+
+  if (buttons & 1)
+    result |= blink::WebMouseEvent::kLeftButtonDown;
+  if (buttons & 2)
+    result |= blink::WebInputEvent::kRightButtonDown;
+  if (buttons & 4)
+    result |= blink::WebInputEvent::kMiddleButtonDown;
+  if (buttons & 8)
+    result |= blink::WebInputEvent::kBackButtonDown;
+  if (buttons & 16)
+    result |= blink::WebInputEvent::kForwardButtonDown;
+  return result;
+}
+
+bool SetKeyboardEventText(
+    base::span<char16_t, blink::WebKeyboardEvent::kTextLengthCap> to,
+    const std::optional<std::string>& from) {
+  if (!from.has_value())
+    return true;
+
+  std::u16string text16 = base::UTF8ToUTF16(from.value());
+  if (text16.size() >= to.size())
+    return false;
+
+  std::ranges::fill(to, 0);
+  for (size_t i = 0; i < text16.size(); ++i)
+    to[i] = text16[i];
+  return true;
+}
+
+ui::KeyboardCode InferWindowsVirtualKeyCode(ui::DomCode dom_code,
+                                            ui::DomKey dom_key) {
+  if (dom_code != ui::DomCode::NONE) {
+    ui::KeyboardCode code = ui::DomCodeToUsLayoutKeyboardCode(dom_code);
+    if (code != ui::VKEY_UNKNOWN)
+      return code;
+  }
+
+  if (dom_key != ui::DomKey::NONE) {
+    ui::KeyboardCode code = ui::NonPrintableDomKeyToKeyboardCode(dom_key);
+    if (code != ui::VKEY_UNKNOWN)
+      return code;
+  }
+
+  return ui::VKEY_UNKNOWN;
+}
+
+blink::WebInputEvent::Type GetDispatchKeyEventType(const std::string& type) {
+  if (type == "keyDown")
+    return blink::WebInputEvent::Type::kKeyDown;
+  if (type == "keyUp")
+    return blink::WebInputEvent::Type::kKeyUp;
+  if (type == "char")
+    return blink::WebInputEvent::Type::kChar;
+  if (type == "rawKeyDown")
+    return blink::WebInputEvent::Type::kRawKeyDown;
+  return blink::WebInputEvent::Type::kUndefined;
+}
+
+base::expected<input::NativeWebKeyboardEvent, std::string>
+CreateDispatchKeyEvent(const gin_helper::Dictionary& dict) {
+  std::string type;
+  if (!dict.Get("type", &type))
+    return base::unexpected("Missing required option 'type'");
+
+  blink::WebInputEvent::Type web_event_type = GetDispatchKeyEventType(type);
+  if (web_event_type == blink::WebInputEvent::Type::kUndefined)
+    return base::unexpected(
+        base::StringPrintf("Unexpected key event type '%s'", type.c_str()));
+
+  int modifiers = 0;
+  dict.Get("modifiers", &modifiers);
+  bool auto_repeat = false;
+  dict.Get("autoRepeat", &auto_repeat);
+  bool is_keypad = false;
+  dict.Get("isKeypad", &is_keypad);
+  int location = 0;
+  dict.Get("location", &location);
+  std::optional<double> timestamp;
+  double timestamp_value = 0;
+  if (dict.Get("timestamp", &timestamp_value))
+    timestamp = timestamp_value;
+
+  input::NativeWebKeyboardEvent event(
+      web_event_type,
+      GetDispatchInputEventModifiers(modifiers, auto_repeat, is_keypad,
+                                     location, 0),
+      GetDispatchInputEventTimeTicks(timestamp));
+
+  std::optional<std::string> text;
+  std::string text_value;
+  if (dict.Get("text", &text_value))
+    text = text_value;
+  if (!SetKeyboardEventText(event.text, text))
+    return base::unexpected("Invalid 'text' parameter");
+
+  std::optional<std::string> unmodified_text;
+  std::string unmodified_text_value;
+  if (dict.Get("unmodifiedText", &unmodified_text_value))
+    unmodified_text = unmodified_text_value;
+  if (!SetKeyboardEventText(event.unmodified_text, unmodified_text))
+    return base::unexpected("Invalid 'unmodifiedText' parameter");
+
+  ui::DomCode dom_code = ui::DomCode::NONE;
+  std::string code;
+  if (dict.Get("code", &code)) {
+    dom_code = ui::KeycodeConverter::CodeStringToDomCode(code);
+    event.dom_code = static_cast<int>(dom_code);
+  }
+
+  ui::DomKey dom_key = ui::DomKey::NONE;
+  std::string key;
+  if (dict.Get("key", &key)) {
+    dom_key = ui::KeycodeConverter::KeyStringToDomKey(key);
+    event.dom_key = static_cast<int>(dom_key);
+  }
+
+  int windows_virtual_key_code = 0;
+  if (dict.Get("windowsVirtualKeyCode", &windows_virtual_key_code)) {
+    event.windows_key_code = windows_virtual_key_code;
+  } else {
+    event.windows_key_code = InferWindowsVirtualKeyCode(dom_code, dom_key);
+  }
+
+  int native_virtual_key_code = 0;
+  if (dict.Get("nativeVirtualKeyCode", &native_virtual_key_code)) {
+    event.native_key_code = native_virtual_key_code;
+  } else {
+    event.native_key_code = event.windows_key_code;
+  }
+
+  bool is_system_key = false;
+  if (dict.Get("isSystemKey", &is_system_key))
+    event.is_system_key = is_system_key;
+
+  return event;
+}
+
+blink::WebInputEvent::Type GetDispatchMouseEventType(const std::string& type) {
+  if (type == "mousePressed")
+    return blink::WebInputEvent::Type::kMouseDown;
+  if (type == "mouseReleased")
+    return blink::WebInputEvent::Type::kMouseUp;
+  if (type == "mouseMoved")
+    return blink::WebInputEvent::Type::kMouseMove;
+  if (type == "mouseWheel")
+    return blink::WebInputEvent::Type::kMouseWheel;
+  return blink::WebInputEvent::Type::kUndefined;
+}
+
+bool GetDispatchMouseButton(const std::string& button,
+                            blink::WebPointerProperties::Button* event_button,
+                            int* event_modifiers) {
+  *event_modifiers = blink::WebInputEvent::kFromDebugger;
+  if (button.empty())
+    return true;
+
+  if (button == "none") {
+    *event_button = blink::WebMouseEvent::Button::kNoButton;
+  } else if (button == "left") {
+    *event_button = blink::WebMouseEvent::Button::kLeft;
+    *event_modifiers |= blink::WebInputEvent::kLeftButtonDown;
+  } else if (button == "middle") {
+    *event_button = blink::WebMouseEvent::Button::kMiddle;
+    *event_modifiers |= blink::WebInputEvent::kMiddleButtonDown;
+  } else if (button == "right") {
+    *event_button = blink::WebMouseEvent::Button::kRight;
+    *event_modifiers |= blink::WebInputEvent::kRightButtonDown;
+  } else if (button == "back") {
+    *event_button = blink::WebMouseEvent::Button::kBack;
+    *event_modifiers |= blink::WebInputEvent::kBackButtonDown;
+  } else if (button == "forward") {
+    *event_button = blink::WebMouseEvent::Button::kForward;
+    *event_modifiers |= blink::WebInputEvent::kForwardButtonDown;
+  } else {
+    return false;
+  }
+  return true;
+}
+
+blink::WebPointerProperties::PointerType GetDispatchPointerType(
+    const std::string& pointer_type) {
+  if (pointer_type == "pen")
+    return blink::WebPointerProperties::PointerType::kPen;
+  return blink::WebPointerProperties::PointerType::kMouse;
+}
+
+std::string ValidatePointerEventProperties(double force,
+                                           double tangential_pressure,
+                                           double tilt_x,
+                                           double tilt_y,
+                                           int twist) {
+  if (force < 0.0 || force > 1.0)
+    return "'force' should be in the range of [0,1]";
+  if (tangential_pressure < -1.0 || tangential_pressure > 1.0)
+    return "'tangentialPressure' should be in the range of [-1,1]";
+  if (tilt_x < -90.0 || tilt_x > 90.0)
+    return "'tiltX' should be in the range of [-90,90]";
+  if (tilt_y < -90.0 || tilt_y > 90.0)
+    return "'tiltY' should be in the range of [-90,90]";
+  if (twist < 0 || twist > 359)
+    return "'twist' should be in the range of [0,359]";
+  return "";
+}
