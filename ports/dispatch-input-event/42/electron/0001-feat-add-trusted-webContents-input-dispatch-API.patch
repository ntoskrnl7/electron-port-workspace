+class DispatchInputDevToolsClient : public base::SupportsUserData::Data,
+                                    public content::DevToolsAgentHostClient,
+                                    public content::WebContentsObserver {
+ public:
+  using CommandCallback =
+      base::OnceCallback<void(std::optional<std::string> error_message)>;
+
+  explicit DispatchInputDevToolsClient(content::WebContents* web_contents)
+      : content::WebContentsObserver(web_contents),
+        web_contents_(web_contents) {}
+
+  DispatchInputDevToolsClient(const DispatchInputDevToolsClient&) = delete;
+  DispatchInputDevToolsClient& operator=(const DispatchInputDevToolsClient&) =
+      delete;
+
+  ~DispatchInputDevToolsClient() override {
+    if (agent_host_)
+      agent_host_->DetachClient(this);
+  }
+
+  void SendCommand(std::string method,
+                   base::DictValue params,
+                   CommandCallback callback) {
+    if (!EnsureAttached()) {
+      std::move(callback).Run("No target available");
+      return;
+    }
+
+    base::DictValue request;
+    int request_id = ++previous_request_id_;
+    pending_requests_.emplace(request_id, std::move(callback));
+    request.Set("id", request_id);
+    request.Set("method", std::move(method));
+    request.Set("params", std::move(params));
+
+    std::string json_args = base::WriteJson(request).value_or("");
+    agent_host_->DispatchProtocolMessage(this, base::as_byte_span(json_args));
+  }
+
+  void DispatchProtocolMessage(content::DevToolsAgentHost* agent_host,
+                               base::span<const uint8_t> message) override {
+    DCHECK(agent_host == agent_host_);
+
+    std::optional<base::Value> parsed_message = base::JSONReader::Read(
+        base::as_string_view(message), base::JSON_REPLACE_INVALID_CHARACTERS);
+    if (!parsed_message || !parsed_message->is_dict())
+      return;
+
+    base::DictValue& dict = parsed_message->GetDict();
+    std::optional<int> id = dict.FindInt("id");
+    if (!id)
+      return;
+
+    auto it = pending_requests_.find(*id);
+    if (it == pending_requests_.end())
+      return;
+
+    CommandCallback callback = std::move(it->second);
+    pending_requests_.erase(it);
+
+    base::DictValue* error = dict.FindDict("error");
+    if (error) {
+      std::string* error_message = error->FindString("message");
+      std::move(callback).Run(error_message
+                                  ? std::optional<std::string>(*error_message)
+                                  : std::optional<std::string>(""));
+      return;
+    }
+
+    std::move(callback).Run(std::nullopt);
+  }
+
+  void AgentHostClosed(content::DevToolsAgentHost* agent_host) override {
+    DCHECK(agent_host == agent_host_);
+    agent_host_ = nullptr;
+    for (auto& it : pending_requests_)
+      std::move(it.second).Run("target closed while handling command");
+    pending_requests_.clear();
+  }
+
+  void RenderFrameHostChanged(content::RenderFrameHost* old_rfh,
+                              content::RenderFrameHost* new_rfh) override {
+    if (agent_host_ && new_rfh && new_rfh->IsInPrimaryMainFrame()) {
+      agent_host_->DisconnectWebContents();
+      agent_host_->ConnectWebContents(web_contents_);
+    }
+  }
+
+ private:
+  bool EnsureAttached() {
+    if (agent_host_)
+      return true;
+
+    agent_host_ = content::DevToolsAgentHost::GetOrCreateFor(web_contents_);
+    if (!agent_host_)
+      return false;
+
+    if (!agent_host_->AttachClient(this)) {
+      agent_host_ = nullptr;
+      return false;
+    }
+
+    return true;
+  }
+
+  raw_ptr<content::WebContents> web_contents_;
+  scoped_refptr<content::DevToolsAgentHost> agent_host_;
+  int previous_request_id_ = 0;
+  std::map<int, CommandCallback> pending_requests_;
+};
+
+const void* kDispatchInputDevToolsClientKey = &kDispatchInputDevToolsClientKey;
+
+DispatchInputDevToolsClient* GetDispatchInputDevToolsClient(
+    content::WebContents* web_contents) {
+  auto* client = static_cast<DispatchInputDevToolsClient*>(
+      web_contents->GetUserData(kDispatchInputDevToolsClientKey));
+  if (client)
+    return client;
+
+  auto owned_client =
+      std::make_unique<DispatchInputDevToolsClient>(web_contents);
+  client = owned_client.get();
+  web_contents->SetUserData(kDispatchInputDevToolsClientKey,
+                            std::move(owned_client));
+  return client;
+}
