+const { app, BrowserWindow } = require('electron');
+
+const page = `
+<!doctype html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <style>
+    html,
+    body {
+      height: 100%;
+      margin: 0;
+    }
+
+    #source,
+    #target {
+      box-sizing: border-box;
+      position: absolute;
+      width: 120px;
+      height: 80px;
+      border: 1px solid #222;
+      font: 14px sans-serif;
+      user-select: none;
+    }
+
+    #source {
+      left: 20px;
+      top: 20px;
+      background: #cfe8ff;
+    }
+
+    #target {
+      left: 170px;
+      top: 20px;
+      background: #d8f5d0;
+    }
+  </style>
+</head>
+<body>
+  <div id="source" draggable="true">drag me</div>
+  <div id="target">drop here</div>
+  <script>
+    window.dragEvents = [];
+
+    const record = event => {
+      const dragEvent = {
+        type: event.type,
+        clientX: event.clientX,
+        clientY: event.clientY,
+        isTrusted: event.isTrusted
+      };
+      window.dragEvents.push(dragEvent);
+      console.log('DRAG_EVENT:' + JSON.stringify(dragEvent));
+    };
+
+    const source = document.getElementById('source');
+    const target = document.getElementById('target');
+
+    source.addEventListener('dragstart', event => {
+      record(event);
+      event.dataTransfer.setData('text/plain', 'dragged-text');
+      event.dataTransfer.effectAllowed = 'copyMove';
+    });
+
+    source.addEventListener('dragend', record);
+
+    target.addEventListener('dragenter', event => {
+      record(event);
+      event.preventDefault();
+    });
+
+    target.addEventListener('dragover', event => {
+      record(event);
+      event.preventDefault();
+    });
+
+    target.addEventListener('drop', event => {
+      record(event);
+      window.droppedText = event.dataTransfer.getData('text/plain');
+      event.preventDefault();
+    });
+  </script>
+</body>
+</html>
+`;
+
+const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
+
+async function dispatchDragSequence(webContents) {
+  await webContents.dispatchInputEvent({
+    kind: 'mouse',
+    type: 'mousePressed',
+    x: 60,
+    y: 50,
+    button: 'left',
+    buttons: 1,
+    clickCount: 1
+  });
+
+  await delay(50);
+
+  for (const [x, y] of [
+    [90, 50],
+    [130, 50],
+    [180, 50],
+    [210, 50]
+  ]) {
+    await webContents.dispatchInputEvent({
+      kind: 'mouse',
+      type: 'mouseMoved',
+      x,
+      y,
+      button: 'left',
+      buttons: 1
+    });
+    await delay(50);
+  }
+
+  await webContents.dispatchInputEvent({
+    kind: 'mouse',
+    type: 'mouseReleased',
+    x: 210,
+    y: 50,
+    button: 'left',
+    buttons: 0,
+    clickCount: 1
+  });
+}
+
+async function main() {
+  const timeout = setTimeout(() => {
+    console.error('dispatch-input-drag-hang fixture timed out');
+    app.exit(124);
+  }, 5000);
+
+  const window = new BrowserWindow({
+    show: true,
+    width: 360,
+    height: 180,
+    webPreferences: {
+      sandbox: false
+    }
+  });
+
+  window.webContents.on('console-message', ({ message }) => {
+    if (message.startsWith('DRAG_EVENT:')) {
+      console.log(message);
+    }
+  });
+
+  await window.loadURL(`data:text/html,${encodeURIComponent(page)}`);
+  window.focus();
+  await delay(200);
+
+  await dispatchDragSequence(window.webContents);
+  await delay(300);
+
+  const result = await window.webContents.executeJavaScript(`({
+    events: window.dragEvents.map(event => event.type),
+    droppedText: window.droppedText || ''
+  })`);
+
+  console.log(`RESULT:${JSON.stringify(result)}`);
+
+  if (
+    !result.events.includes('dragstart') ||
+    !result.events.includes('dragover') ||
+    !result.events.includes('drop') ||
+    !result.events.includes('dragend') ||
+    result.droppedText !== 'dragged-text'
+  ) {
+    app.exitCode = 1;
+  }
+
+  clearTimeout(timeout);
+  window.close();
+  app.quit();
+}
+
+app
+  .whenReady()
+  .then(main)
+  .catch((error) => {
+    console.error(error);
+    app.exit(1);
+  });
