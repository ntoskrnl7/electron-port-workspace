+v8::Local<v8::Promise> WebContents::DispatchInputEvent(
+    v8::Isolate* isolate,
+    const gin_helper::Dictionary& input_event) {
+  gin_helper::Promise<gin_helper::Dictionary> promise(isolate);
+  v8::Local<v8::Promise> handle = promise.GetHandle();
+
+  std::string kind;
+  if (!input_event.Get("kind", &kind)) {
+    promise.RejectWithErrorMessage("Missing required option 'kind'");
+    return handle;
+  }
+
+  std::string input_event_id =
+      base::Uuid::GenerateRandomV4().AsLowercaseString();
+
+  if (kind == "key") {
+    auto maybe_event = CreateDispatchKeyEvent(input_event);
+    if (!maybe_event.has_value()) {
+      promise.RejectWithErrorMessage(maybe_event.error());
+      return handle;
+    }
+
+    auto* target_widget = GetFocusedRenderWidgetHost(web_contents());
+    if (!target_widget) {
+      promise.RejectWithErrorMessage("Unable to find a focused frame");
+      return handle;
+    }
+
+    input::NativeWebKeyboardEvent event = std::move(maybe_event).value();
+    auto* request = new InputDispatchRequest(GetWeakPtr(), std::move(promise),
+                                             std::move(input_event_id));
+    request->DispatchKeyboard(target_widget, event);
+    return handle;
+  }
+
+  if (kind == "mouse") {
+    auto maybe_event = CreateDispatchMouseEvent(
+        input_event, GetDispatchInputScaleFactor(web_contents()));
+    if (!maybe_event.has_value()) {
+      promise.RejectWithErrorMessage(maybe_event.error());
+      return handle;
+    }
+
+    auto* root_frame = web_contents()->GetPrimaryMainFrame();
+    auto* root_widget = root_frame ? content::RenderWidgetHostImpl::From(
+                                         root_frame->GetRenderWidgetHost())
+                                   : nullptr;
+    if (!root_widget || !root_widget->delegate() ||
+        !root_widget->delegate()->GetInputEventRouter() ||
+        !root_widget->GetView()) {
+      promise.RejectWithErrorMessage("Unable to find a target frame");
+      return handle;
+    }
+
+    auto event = std::move(maybe_event).value();
+    base::DictValue devtools_params =
+        CreateDevToolsMouseEventParams(input_event, *event);
+    auto* request = new InputDispatchRequest(GetWeakPtr(), std::move(promise),
+                                             std::move(input_event_id));
+    auto dispatch_after_visual_state = base::BindOnce(
+        [](base::WeakPtr<WebContents> owner,
+           base::WeakPtr<content::RenderWidgetHostImpl> root_widget,
+           InputDispatchRequest* request, base::DictValue devtools_params,
+           std::unique_ptr<blink::WebMouseEvent> event, bool success) {
+          if (!owner || !root_widget || !root_widget->delegate() ||
+              !root_widget->delegate()->GetInputEventRouter() ||
+              !root_widget->GetView()) {
+            request->RejectWithMessage("Unable to find a target frame");
+            return;
+          }
+
+          event->SetPositionInScreen(ConvertWidgetPointToScreenPoint(
+              *root_widget->GetView(), event->PositionInWidget()));
+
+          if (event->GetType() == blink::WebInputEvent::Type::kMouseWheel) {
+            request->RouteWheel(
+                owner->GetWebContents(), root_widget.get(),
+                *static_cast<blink::WebMouseWheelEvent*>(event.get()));
+          } else {
+            request->DispatchMouseViaDevTools(owner->GetWebContents(), *event,
+                                              std::move(devtools_params));
+          }
+        },
+        GetWeakPtr(), root_widget->GetWeakPtr(), request,
+        std::move(devtools_params), std::move(event));
+
+    root_widget->InsertVisualStateCallback(
+        std::move(dispatch_after_visual_state));
+    return handle;
+  }
+
+  if (kind == "touch") {
+    auto maybe_events = CreateDispatchTouchEvents(
+        this, input_event, GetDispatchInputScaleFactor(web_contents()));
+    if (!maybe_events.has_value()) {
+      promise.RejectWithErrorMessage(maybe_events.error());
+      return handle;
+    }
+
+    auto events = std::move(maybe_events).value();
+    if (events.empty()) {
+      auto dict = gin_helper::Dictionary::CreateEmpty(isolate);
+      dict.Set("inputEventId", input_event_id);
+      dict.Set("consumed", false);
+      dict.Set("ackState", std::string(InputAckStateToString(
+                               blink::mojom::InputEventResultState::kUnknown)));
+      dict.Set("ackSource",
+               std::string(InputAckSourceToString(
+                   blink::mojom::InputEventResultSource::kUnknown)));
+      promise.Resolve(dict);
+      return handle;
+    }
+
+    auto* root_frame = web_contents()->GetPrimaryMainFrame();
+    auto* root_widget = root_frame ? content::RenderWidgetHostImpl::From(
+                                         root_frame->GetRenderWidgetHost())
+                                   : nullptr;
+    if (!root_widget || !root_widget->delegate() ||
+        !root_widget->delegate()->GetInputEventRouter() ||
+        !root_widget->GetView()) {
+      promise.RejectWithErrorMessage("Unable to find a target frame");
+      return handle;
+    }
+
+    auto* request = new InputDispatchRequest(GetWeakPtr(), std::move(promise),
+                                             std::move(input_event_id));
+    root_widget->InsertVisualStateCallback(base::BindOnce(
+        [](base::WeakPtr<WebContents> owner,
+           base::WeakPtr<content::RenderWidgetHostImpl> root_widget,
+           InputDispatchRequest* request,
+           std::vector<blink::WebTouchEvent> events, bool success) {
+          if (!owner || !root_widget || !root_widget->delegate() ||
+              !root_widget->GetView()) {
+            request->RejectWithMessage("Unable to find a target frame");
+            return;
+          }
+
+          gfx::PointF point(events.front().touches[0].PositionInWidget());
+          root_widget->delegate()->GetRenderWidgetHostAtPointAsynchronously(
+              root_widget->GetView(), point,
+              base::BindOnce(
+                  [](InputDispatchRequest* request,
+                     std::vector<blink::WebTouchEvent> events,
+                     base::WeakPtr<content::RenderWidgetHostViewBase> target,
+                     std::optional<gfx::PointF> transformed) {
+                    if (!target || !transformed.has_value()) {
+                      request->RejectWithMessage(
+                          "Unable to find a target frame");
+                      return;
+                    }
+
+                    auto* target_widget = content::RenderWidgetHostImpl::From(
+                        target->GetRenderWidgetHost());
+                    if (!target_widget) {
+                      request->RejectWithMessage(
+                          "Unable to find a target frame");
+                      return;
+                    }
+
+                    gfx::PointF original(
+                        events.front().touches[0].PositionInWidget());
+                    gfx::Vector2dF delta = *transformed - original;
+                    for (auto& event : events) {
+                      event.dispatch_type =
+                          event.GetType() ==
+                                  blink::WebInputEvent::Type::kTouchCancel
+                              ? blink::WebInputEvent::DispatchType::
+                                    kEventNonBlocking
+                              : blink::WebInputEvent::DispatchType::kBlocking;
+                      event.moved_beyond_slop_region = true;
+                      event.unique_touch_event_id = ui::GetNextTouchEventId();
+                      for (unsigned j = 0; j < event.touches_length; ++j) {
+                        gfx::PointF point = event.touches[j].PositionInWidget();
+                        gfx::PointF position_in_widget(point.x() + delta.x(),
+                                                       point.y() + delta.y());
+                        event.touches[j].SetPositionInWidget(
+                            position_in_widget);
+                        event.touches[j].SetPositionInScreen(
+                            ConvertWidgetPointToScreenPoint(
+                                *target.get(), position_in_widget));
+                      }
+                    }
+
+                    request->DispatchTouchEvents(target_widget,
+                                                 std::move(events));
+                  },
+                  request, std::move(events)));
+        },
+        GetWeakPtr(), root_widget->GetWeakPtr(), request, std::move(events)));
+    return handle;
+  }
+
+  if (kind == "insertText") {
+    std::string text;
+    if (!input_event.Get("text", &text)) {
+      promise.RejectWithErrorMessage("Missing required option 'text'");
+      return handle;
+    }
+
+    auto* target_widget = GetFocusedRenderWidgetHost(web_contents());
+    if (!target_widget) {
+      promise.RejectWithErrorMessage("Unable to find a focused frame");
+      return handle;
+    }
+
+    auto* request = new InputDispatchRequest(GetWeakPtr(), std::move(promise),
+                                             std::move(input_event_id));
+    auto target_widget_weak = target_widget->GetWeakPtr();
+    target_widget->Focus();
+    target_widget->GetWidgetInputHandler()->ImeCommitText(
+        base::UTF8ToUTF16(text), std::vector<ui::ImeTextSpan>(),
+        gfx::Range::InvalidRange(), 0,
+        base::BindOnce(
+            [](InputDispatchRequest* request,
+               base::WeakPtr<content::RenderWidgetHostImpl> target_widget) {
+              request->ResolveSynthetic(target_widget.get());
+            },
+            request, target_widget_weak));
+    return handle;
+  }
+
+  if (kind == "imeSetComposition") {
+    std::string text;
+    int selection_start = 0;
+    int selection_end = 0;
+    if (!input_event.Get("text", &text) ||
+        !input_event.Get("selectionStart", &selection_start) ||
+        !input_event.Get("selectionEnd", &selection_end)) {
+      promise.RejectWithErrorMessage(
+          "'text', 'selectionStart', and 'selectionEnd' are required");
+      return handle;
+    }
+
+    if (selection_start < 0 || selection_end < 0) {
+      promise.RejectWithErrorMessage(
+          "'selectionStart' and 'selectionEnd' must be non-negative");
+      return handle;
+    }
+
+    gfx::Range replacement_range = gfx::Range::InvalidRange();
+    int replacement_start = 0;
+    int replacement_end = 0;
+    bool has_replacement_start =
+        input_event.Get("replacementStart", &replacement_start);
+    bool has_replacement_end =
+        input_event.Get("replacementEnd", &replacement_end);
+    if (has_replacement_start != has_replacement_end) {
+      promise.RejectWithErrorMessage(
+          "Either both replacementStart/replacementEnd are specified or "
+          "neither");
+      return handle;
+    }
+    if (has_replacement_start) {
