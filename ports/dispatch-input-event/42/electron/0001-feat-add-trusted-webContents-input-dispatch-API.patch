+content::RenderFrameHost* FindFrameForRenderWidgetHost(
+    content::WebContents* web_contents,
+    content::RenderWidgetHost* widget_host) {
+  if (!web_contents || !widget_host)
+    return nullptr;
+
+  content::RenderFrameHost* result = nullptr;
+  web_contents->ForEachRenderFrameHost([&](content::RenderFrameHost* rfh) {
+    if (!result && rfh->GetRenderWidgetHost() == widget_host)
+      result = rfh;
+  });
+  return result;
+}
+
+float GetDispatchInputScaleFactor(content::WebContents* web_contents) {
+  if (!web_contents || !web_contents->GetPrimaryMainFrame())
+    return 1.0f;
+
+  auto* web_contents_impl =
+      static_cast<content::WebContentsImpl*>(web_contents);
+  auto* widget_host_for_zoom = content::RenderWidgetHostImpl::From(
+      web_contents->GetPrimaryMainFrame()->GetRenderWidgetHost());
+  float scale_factor = blink::ZoomLevelToZoomFactor(
+      web_contents_impl->GetPendingZoomLevel(widget_host_for_zoom));
+  scale_factor *= web_contents_impl->GetPrimaryPage().GetPageScaleFactor();
+  return scale_factor;
+}
+
+content::RenderWidgetHostImpl* GetFocusedRenderWidgetHost(
+    content::WebContents* web_contents) {
+  if (auto* focused_frame = web_contents->GetFocusedFrame()) {
+    if (auto* focused_widget = content::RenderWidgetHostImpl::From(
+            focused_frame->GetRenderWidgetHost())) {
+      return focused_widget;
+    }
+  }
+
+  auto* main_frame = web_contents->GetPrimaryMainFrame();
+  if (!main_frame)
+    return nullptr;
+  auto* widget_host =
+      content::RenderWidgetHostImpl::From(main_frame->GetRenderWidgetHost());
+  if (!widget_host)
+    return nullptr;
+  if (widget_host->delegate()) {
+    if (auto* target_host =
+            widget_host->delegate()->GetFocusedRenderWidgetHost(widget_host)) {
+      widget_host = target_host;
+    }
+  }
+  return widget_host;
+}
