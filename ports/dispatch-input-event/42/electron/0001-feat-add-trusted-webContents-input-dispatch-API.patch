+    params.Set("force", force);
+
+  double tangential_pressure = 0;
+  if (dict.Get("tangentialPressure", &tangential_pressure))
+    params.Set("tangentialPressure", tangential_pressure);
+
+  double tilt_x = 0;
+  if (dict.Get("tiltX", &tilt_x))
+    params.Set("tiltX", tilt_x);
+
+  double tilt_y = 0;
+  if (dict.Get("tiltY", &tilt_y))
+    params.Set("tiltY", tilt_y);
+
+  int twist = 0;
+  if (dict.Get("twist", &twist))
+    params.Set("twist", twist);
+
+  double delta_x = 0;
+  if (dict.Get("deltaX", &delta_x))
+    params.Set("deltaX", delta_x);
+
+  double delta_y = 0;
+  if (dict.Get("deltaY", &delta_y))
+    params.Set("deltaY", delta_y);
+
+  std::string pointer_type;
+  if (dict.Get("pointerType", &pointer_type))
+    params.Set("pointerType", pointer_type);
+
+  return params;
+}
+
+class InputDispatchRequest
+    : public content::RenderWidgetHost::InputEventObserver {
+ public:
+  InputDispatchRequest(base::WeakPtr<WebContents> owner,
+                       gin_helper::Promise<gin_helper::Dictionary> promise,
+                       std::string input_event_id)
+      : owner_(std::move(owner)),
+        promise_(std::move(promise)),
+        input_event_id_(std::move(input_event_id)) {}
+
+  InputDispatchRequest(const InputDispatchRequest&) = delete;
+  InputDispatchRequest& operator=(const InputDispatchRequest&) = delete;
+
+  ~InputDispatchRequest() override { ClearObservers(); }
+
+  void DispatchKeyboard(content::RenderWidgetHostImpl* target_widget,
+                        const input::NativeWebKeyboardEvent& event) {
+    if (!StartObserving(target_widget, event)) {
+      ResolveUnknown();
+      return;
+    }
+
+    target_widget->Focus();
+    auto weak_this = weak_factory_.GetWeakPtr();
+    target_widget->ForwardKeyboardEvent(event);
+    if (!weak_this)
+      return;
+    ResolveIfNotQueued();
+  }
+
+  void DispatchMouse(content::RenderWidgetHostImpl* target_widget,
+                     const blink::WebMouseEvent& event) {
+    if (!StartObserving(target_widget, event)) {
+      ResolveUnknown();
+      return;
+    }
+
+    auto weak_this = weak_factory_.GetWeakPtr();
+    target_widget->ForwardMouseEvent(event);
+    if (!weak_this)
+      return;
+    ResolveIfNotQueued();
+  }
+
+  void RouteMouse(content::WebContents* web_contents,
+                  content::RenderWidgetHostImpl* root_widget,
+                  const blink::WebMouseEvent& event) {
+    if (!root_widget || !root_widget->delegate() ||
+        !root_widget->delegate()->GetInputEventRouter() ||
+        !root_widget->GetView()) {
+      ResolveUnknown();
+      return;
+    }
+    if (!StartObservingAll(web_contents, event)) {
+      ResolveUnknown();
+      return;
+    }
+
+    root_widget->delegate()->GetInputEventRouter()->RouteMouseEvent(
+        root_widget->GetView(), &event, ui::LatencyInfo());
+  }
+
+  void DispatchMouseViaDevTools(content::WebContents* web_contents,
+                                const blink::WebMouseEvent& event,
+                                base::DictValue params) {
+    if (!StartObservingAll(web_contents, event)) {
+      ResolveUnknown();
+      return;
+    }
+
+    GetDispatchInputDevToolsClient(web_contents)
+        ->SendCommand(
+            "Input.dispatchMouseEvent", std::move(params),
+            base::BindOnce(&InputDispatchRequest::OnDevToolsCommandResult,
+                           weak_factory_.GetWeakPtr()));
+  }
+
+  void DispatchWheel(content::RenderWidgetHostImpl* target_widget,
+                     blink::WebMouseWheelEvent event) {
+    if (!StartObserving(target_widget, event)) {
+      ResolveUnknown();
+      return;
+    }
+
+    auto weak_this = weak_factory_.GetWeakPtr();
+    target_widget->ForwardWheelEvent(event);
+    if (!weak_this)
+      return;
+    if (!input_queued_) {
+      ResolveUnknown();
+      return;
+    }
+
+    event.delta_x = 0;
+    event.delta_y = 0;
+    event.wheel_ticks_x = 0;
+    event.wheel_ticks_y = 0;
+    event.phase = blink::WebMouseWheelEvent::kPhaseEnded;
+    event.has_synthetic_phase = true;
+    event.dispatch_type = blink::WebInputEvent::DispatchType::kEventNonBlocking;
+    target_widget->ForwardWheelEvent(event);
+  }
+
+  void RouteWheel(content::WebContents* web_contents,
+                  content::RenderWidgetHostImpl* root_widget,
+                  blink::WebMouseWheelEvent event) {
+    if (!root_widget || !root_widget->delegate() ||
+        !root_widget->delegate()->GetInputEventRouter() ||
+        !root_widget->GetView()) {
+      ResolveUnknown();
+      return;
+    }
+    if (!StartObservingAll(web_contents, event)) {
+      ResolveUnknown();
+      return;
+    }
+
+    root_widget->delegate()->GetInputEventRouter()->RouteMouseWheelEvent(
+        root_widget->GetView(), &event, ui::LatencyInfo());
+    if (!input_queued_) {
+      return;
+    }
+
+    event.delta_x = 0;
+    event.delta_y = 0;
+    event.wheel_ticks_x = 0;
+    event.wheel_ticks_y = 0;
+    event.phase = blink::WebMouseWheelEvent::kPhaseEnded;
+    event.has_synthetic_phase = true;
+    event.dispatch_type = blink::WebInputEvent::DispatchType::kEventNonBlocking;
+    root_widget->delegate()->GetInputEventRouter()->RouteMouseWheelEvent(
+        root_widget->GetView(), &event, ui::LatencyInfo());
+  }
+
+  void DispatchTouchEvents(content::RenderWidgetHostImpl* target_widget,
+                           std::vector<blink::WebTouchEvent> events) {
+    if (events.empty()) {
+      ResolveUnknown();
+      return;
+    }
+    if (!StartObserving(target_widget, events.front())) {
+      ResolveUnknown();
+      return;
+    }
+
+    target_widget->GetTouchEmulator(/*create_if_necessary=*/true)
+        ->Enable(input::TouchEmulator::Mode::kInjectingTouchEvents,
+                 ui::GestureProviderConfigType::CURRENT_PLATFORM);
+
+    base::OnceClosure closure = base::BindOnce([] {});
+    for (size_t i = 0; i < events.size(); ++i) {
+      target_widget->GetTouchEmulator(/*create_if_necessary=*/true)
+          ->InjectTouchEvent(events[i], target_widget->GetView(),
+                             i == events.size() - 1 ? std::move(closure)
+                                                    : base::OnceClosure());
+    }
+  }
+
+  void ResolveSynthetic(content::RenderWidgetHostImpl* target_widget) {
+    if (target_widget) {
+      target_widget_ = target_widget->GetWeakPtr();
+    } else {
+      target_widget_ = base::WeakPtr<content::RenderWidgetHostImpl>();
+    }
+    Resolve(blink::mojom::InputEventResultSource::kUnknown,
+            blink::mojom::InputEventResultState::kUnknown);
+  }
+
+  void RejectWithMessage(std::string_view message) {
+    v8::HandleScope handle_scope(promise_.isolate());
+    v8::Context::Scope context_scope(promise_.GetContext());
+    promise_.RejectWithErrorMessage(message);
+    delete this;
+  }
+
+ private:
+  bool StartObserving(content::RenderWidgetHostImpl* target_widget,
+                      const blink::WebInputEvent& event) {
+    if (!target_widget)
+      return false;
+
+    target_widget_ = target_widget->GetWeakPtr();
+    SetExpectedEvent(event);
+    AddObservedWidget(target_widget);
+    if (observed_widgets_.empty())
+      return false;
+
+    StartTimeout();
+    return true;
+  }
+
+  bool StartObservingAll(content::WebContents* web_contents,
+                         const blink::WebInputEvent& event) {
+    if (!web_contents)
+      return false;
+
+    SetExpectedEvent(event);
+    web_contents->ForEachRenderFrameHost([&](content::RenderFrameHost* rfh) {
+      auto* widget =
+          content::RenderWidgetHostImpl::From(rfh->GetRenderWidgetHost());
+      AddObservedWidget(widget);
+    });
+
+    if (observed_widgets_.empty())
+      return false;
+
+    StartTimeout();
+    return true;
+  }
+
+  void SetExpectedEvent(const blink::WebInputEvent& event) {
+    expected_type_ = event.GetType();
+    expected_timestamp_ = event.TimeStamp();
+    input_queued_ = false;
+  }
+
+  void AddObservedWidget(content::RenderWidgetHostImpl* widget) {
+    if (!widget)
+      return;
+
+    for (const auto& observed_widget : observed_widgets_) {
+      if (observed_widget.get() == widget)
+        return;
+    }
+
+    widget->AddInputEventObserver(this);
+    observed_widgets_.push_back(widget->GetWeakPtr());
+  }
+
+  void StartTimeout() {
+    base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+        FROM_HERE,
+        base::BindOnce(&InputDispatchRequest::ResolveUnknownIfPending,
+                       weak_factory_.GetWeakPtr()),
+        base::Seconds(5));
+  }
+
+  void ClearObservers() {
+    for (auto& observed_widget : observed_widgets_) {
+      if (observed_widget)
+        observed_widget->RemoveInputEventObserver(this);
+    }
+    observed_widgets_.clear();
+  }
+
+  bool Matches(const content::RenderWidgetHost& widget,
+               const blink::WebInputEvent& event) const {
+    return FindObservedWidget(widget) &&
+           (event.GetModifiers() & blink::WebInputEvent::kFromDebugger) != 0 &&
+           event.GetType() == expected_type_ &&
+           event.TimeStamp() == expected_timestamp_;
+  }
+
+  content::RenderWidgetHostImpl* FindObservedWidget(
+      const content::RenderWidgetHost& widget) const {
+    for (const auto& observed_widget : observed_widgets_) {
+      if (observed_widget.get() == &widget)
+        return observed_widget.get();
+    }
+    return nullptr;
+  }
+
+  void OnInputEvent(const content::RenderWidgetHost& widget,
+                    const blink::WebInputEvent& event,
+                    input::InputEventSource source) override {
+    if (Matches(widget, event)) {
+      if (auto* widget_impl = FindObservedWidget(widget))
+        target_widget_ = widget_impl->GetWeakPtr();
+      input_queued_ = true;
+    }
+  }
+
+  void OnInputEventAck(const content::RenderWidgetHost& widget,
+                       blink::mojom::InputEventResultSource source,
+                       blink::mojom::InputEventResultState state,
+                       const blink::WebInputEvent& event) override {
+    if (!Matches(widget, event))
+      return;
+
+    if (auto* widget_impl = FindObservedWidget(widget))
+      target_widget_ = widget_impl->GetWeakPtr();
+
+    base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+        FROM_HERE, base::BindOnce(&InputDispatchRequest::Resolve,
+                                  weak_factory_.GetWeakPtr(), source, state));
+  }
+
+  void ResolveIfNotQueued() {
+    if (!input_queued_)
+      ResolveUnknown();
+  }
+
+  void ResolveUnknownIfPending() {
+    if (settled_)
+      return;
+    ResolveUnknown();
+  }
+
+  void OnDevToolsCommandResult(std::optional<std::string> error_message) {
+    if (settled_)
+      return;
+    if (error_message.has_value()) {
+      RejectWithMessage(*error_message);
+      return;
+    }
+    if (!input_queued_)
+      ResolveUnknown();
+  }
+
+  void ResolveUnknown() {
+    Resolve(blink::mojom::InputEventResultSource::kUnknown,
+            blink::mojom::InputEventResultState::kUnknown);
+  }
+
+  void Resolve(blink::mojom::InputEventResultSource source,
+               blink::mojom::InputEventResultState state) {
+    if (settled_)
+      return;
+    settled_ = true;
+
+    ClearObservers();
+
+    v8::HandleScope handle_scope(promise_.isolate());
+    v8::Context::Scope context_scope(promise_.GetContext());
+    auto dict = gin_helper::Dictionary::CreateEmpty(promise_.isolate());
+    dict.Set("inputEventId", input_event_id_);
+    dict.Set("consumed", InputAckStateIsConsumed(state));
+    dict.Set("ackState", std::string(InputAckStateToString(state)));
+    dict.Set("ackSource", std::string(InputAckSourceToString(source)));
+    if (owner_ && owner_->GetWebContents() && target_widget_) {
+      dict.Set("frame", FindFrameForRenderWidgetHost(owner_->GetWebContents(),
+                                                     target_widget_.get()));
+    }
+    promise_.Resolve(dict);
+    delete this;
+  }
+
+  base::WeakPtr<WebContents> owner_;
+  gin_helper::Promise<gin_helper::Dictionary> promise_;
+  std::string input_event_id_;
+  base::WeakPtr<content::RenderWidgetHostImpl> target_widget_;
+  std::vector<base::WeakPtr<content::RenderWidgetHostImpl>> observed_widgets_;
+  blink::WebInputEvent::Type expected_type_ =
+      blink::WebInputEvent::Type::kUndefined;
+  base::TimeTicks expected_timestamp_;
+  bool input_queued_ = false;
+  bool settled_ = false;
+  base::WeakPtrFactory<InputDispatchRequest> weak_factory_{this};
+};
