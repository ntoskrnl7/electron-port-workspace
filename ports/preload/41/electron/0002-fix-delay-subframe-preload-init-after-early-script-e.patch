From 983585bd9c9dc786df20e281d01fb095c9cd559b Mon Sep 17 00:00:00 2001
From: Jung-Kwang Lee <ntoskrnl7@gmail.com>
Date: Wed, 6 May 2026 00:28:22 +0900
Subject: [PATCH 2/3] fix: delay subframe preload init after early script
 execution

Avoid consuming Electron's subframe Node or preload initialization on the initial empty document when browser-side frame handlers synchronously execute JavaScript in a newly-created same-origin subframe. This lets DidClearWindowObject retry initialization after the real document commits.

diff --git a/shell/renderer/electron_render_frame_observer.cc b/shell/renderer/electron_render_frame_observer.cc
index e9f9cfd397..f13ad4ce5c 100644
--- a/shell/renderer/electron_render_frame_observer.cc
+++ b/shell/renderer/electron_render_frame_observer.cc
@@ -99,6 +99,24 @@ void ElectronRenderFrameObserver::DidInstallConditionalFeatures(
   // actual page has started to load.
   auto* web_frame =
       static_cast<blink::WebLocalFrameImpl*>(render_frame_->GetWebFrame());
+  auto prefs = render_frame_->GetBlinkPreferences();
+  bool allow_node_in_sub_frames = prefs.node_integration_in_sub_frames;
+  bool allow_preload_in_sub_frames =
+      base::CommandLine::ForCurrentProcess()->HasSwitch(
+          switches::kFramePreloadInSubFrames);
+
+  // Browser-side frame-created handlers can synchronously execute JavaScript in
+  // a newly-created same-origin subframe. That creates a main-world context for
+  // the initial empty document before the iframe's real navigation commits. Do
+  // not consume Electron's subframe preload or Node initialization on that
+  // throwaway document; DidClearWindowObject will retry once the frame has a
+  // real document.
+  if (!render_frame_->IsMainFrame() && web_frame->IsOnInitialEmptyDocument() &&
+      (allow_node_in_sub_frames || allow_preload_in_sub_frames)) {
+    has_delayed_node_initialization_ = true;
+    return;
+  }
+
   if (web_frame->Opener() && web_frame->IsOnInitialEmptyDocument()) {
     // FIXME(zcbenz): Chromium does not do any browser side navigation for
     // window.open('about:blank'), so there is no way to override WebPreferences
@@ -121,17 +139,12 @@ void ElectronRenderFrameObserver::DidInstallConditionalFeatures(
   if (ShouldNotifyClient(world_id))
     renderer_client_->DidCreateScriptContext(isolate, context, render_frame_);
 
-  auto prefs = render_frame_->GetBlinkPreferences();
   bool use_context_isolation = prefs.context_isolation;
   // This logic matches the EXPLAINED logic in electron_renderer_client.cc
   // to avoid explaining it twice go check that implementation in
   // DidCreateScriptContext();
   bool is_main_world = electron::is_main_world(world_id);
   bool is_main_frame = render_frame_->IsMainFrame();
-  bool allow_node_in_sub_frames = prefs.node_integration_in_sub_frames;
-  bool allow_preload_in_sub_frames =
-      base::CommandLine::ForCurrentProcess()->HasSwitch(
-          switches::kFramePreloadInSubFrames);
 
   bool should_create_isolated_context =
       use_context_isolation && is_main_world &&
