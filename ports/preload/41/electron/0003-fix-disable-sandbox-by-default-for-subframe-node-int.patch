diff --git a/spec/api-subframe-spec.ts b/spec/api-subframe-spec.ts
index b3b361ddb7..fd07dbc993 100644
--- a/spec/api-subframe-spec.ts
+++ b/spec/api-subframe-spec.ts
@@ -232,6 +232,112 @@ describe('subframe Node.js global exposure policy', () => {
     return frame!;
   };
 
+  const getNodeGlobals = async (target: Electron.WebFrameMain | Electron.WebContents) => {
+    return target.executeJavaScript(`({
+      process: typeof globalThis.process,
+      require: typeof globalThis.require,
+      fs: (() => {
+        try {
+          return typeof globalThis.require('fs').readFileSync;
+        } catch {
+          return 'unavailable';
+        }
+      })()
+    })`);
+  };
+
+  const expectNodeGlobals = (
+    actual: { process: string, require: string, fs: string },
+    enabled: boolean
+  ) => {
+    expect(actual).to.deep.equal(enabled
+      ? { process: 'object', require: 'function', fs: 'function' }
+      : { process: 'undefined', require: 'undefined', fs: 'unavailable' });
+  };
+
+  for (const { description, webPreferences, mainFrameNode, subFrameNode } of [
+    {
+      description: 'keeps Node.js globals out of all frames by default',
+      webPreferences: {
+        nodeIntegration: false,
+        nodeIntegrationInSubFrames: false,
+        contextIsolation: false
+      },
+      mainFrameNode: false,
+      subFrameNode: false
+    },
+    {
+      description: 'exposes Node.js globals only in the main frame when only nodeIntegration is enabled',
+      webPreferences: {
+        nodeIntegration: true,
+        nodeIntegrationInSubFrames: false,
+        contextIsolation: false
+      },
+      mainFrameNode: true,
+      subFrameNode: false
+    },
+    {
+      description: 'exposes Node.js globals only in subframes when only nodeIntegrationInSubFrames is enabled',
+      webPreferences: {
+        nodeIntegration: false,
+        nodeIntegrationInSubFrames: true,
+        contextIsolation: false
+      },
+      mainFrameNode: false,
+      subFrameNode: true
+    },
+    {
+      description: 'exposes Node.js globals in all frames when nodeIntegration and nodeIntegrationInSubFrames are enabled',
+      webPreferences: {
+        nodeIntegration: true,
+        nodeIntegrationInSubFrames: true,
+        contextIsolation: false
+      },
+      mainFrameNode: true,
+      subFrameNode: true
+    },
+    {
+      description: 'keeps explicit sandbox enabled when nodeIntegration and nodeIntegrationInSubFrames are enabled',
+      webPreferences: {
+        nodeIntegration: true,
+        nodeIntegrationInSubFrames: true,
+        contextIsolation: false,
+        sandbox: true
+      },
+      mainFrameNode: false,
+      subFrameNode: false
+    },
+    {
+      description: 'keeps explicit sandbox enabled when only nodeIntegrationInSubFrames is enabled',
+      webPreferences: {
+        nodeIntegration: false,
+        nodeIntegrationInSubFrames: true,
+        contextIsolation: false,
+        sandbox: true
+      },
+      mainFrameNode: false,
+      subFrameNode: false
+    },
+    {
+      description: 'uses explicit sandbox false for subframe Node.js globals',
+      webPreferences: {
+        nodeIntegration: false,
+        nodeIntegrationInSubFrames: true,
+        contextIsolation: false,
+        sandbox: false
+      },
+      mainFrameNode: false,
+      subFrameNode: true
+    }
+  ]) {
+    it(description, async () => {
+      const frame = await loadSameOriginFrame(webPreferences);
+
+      expectNodeGlobals(await getNodeGlobals(w.webContents), mainFrameNode);
+      expectNodeGlobals(await getNodeGlobals(frame), subFrameNode);
+    });
+  }
+
   it('does not expose Node.js globals in same-origin subframes when only main frame nodeIntegration is enabled', async () => {
     const frame = await loadSameOriginFrame({
       nodeIntegration: true,
@@ -254,8 +360,7 @@ describe('subframe Node.js global exposure policy', () => {
