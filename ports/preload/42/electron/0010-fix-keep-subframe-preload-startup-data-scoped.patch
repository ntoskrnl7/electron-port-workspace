+bool FramePreloadMatches(const PreloadScript& script,
+                         const FramePreloadOptions& options) {
+  DCHECK_EQ(script.script_type, PreloadScript::ScriptType::kWebFrame);
+
+  bool matches_scope = false;
+  if (!script.has_frame_scope) {
+    matches_scope =
+        options.is_main_frame || options.allow_legacy_subframe_preload;
+  } else {
+    switch (script.frame_scope) {
+      case PreloadScript::FrameScope::kMain:
+        matches_scope = options.is_main_frame;
+        break;
+      case PreloadScript::FrameScope::kSubFrames:
+        matches_scope = !options.is_main_frame;
+        break;
+      case PreloadScript::FrameScope::kAll:
+        matches_scope = true;
+        break;
+    }
+  }
+
+  if (!matches_scope)
+    return false;
+  if (options.is_initial_empty_document)
+    return script.run_in_initial_empty_document;
+  return true;
+}
+
 }  // namespace

