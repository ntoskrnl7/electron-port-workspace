+describe('sandboxed subframe initialization', () => {
+  let w: BrowserWindow;
+
+  afterEach(async () => {
+    await closeWindow(w);
+    w = null as unknown as BrowserWindow;
+  });
+
+  const loadSandboxedWindow = async () => {
+    w = new BrowserWindow({
+      show: false,
+      webPreferences: {
+        sandbox: true,
+        preload: path.resolve(__dirname, 'fixtures/empty-preload.js')
+      }
+    });
+    await w.loadURL('data:text/html,<html><body></body></html>');
+  };
+
+  const withoutRendererCrash = async <T>(action: () => Promise<T>) => {
+    return await new Promise<T>((resolve, reject) => {
+      const onRenderProcessGone = (
+        _event: Electron.Event,
+        details: Electron.RenderProcessGoneDetails
+      ) => {
+        reject(new Error(`renderer process gone: ${details.reason}, exitCode: ${details.exitCode}`));
+      };
+      w.webContents.once('render-process-gone', onRenderProcessGone);
+      action().then(resolve, reject).finally(() => {
+        w.webContents.removeListener('render-process-gone', onRenderProcessGone);
+      });
+    });
+  };
+
+  it('does not crash when appending a sandboxed allow-scripts iframe', async () => {
+    await loadSandboxedWindow();
+
+    const result = await withoutRendererCrash(() => w.webContents.executeJavaScript(`new Promise(resolve => {
+      const iframe = document.createElement('iframe');
+      iframe.setAttribute('sandbox', 'allow-scripts');
+      document.body.appendChild(iframe);
+      setTimeout(() => resolve({
+        frameCount: document.querySelectorAll('iframe').length
+      }), 1000);
+    })`));
+
+    expect(result).to.deep.equal({ frameCount: 1 });
+  });
+
+  it('does not crash when appending a sandboxed allow-scripts srcdoc iframe', async () => {
+    await loadSandboxedWindow();
+
+    const result = await withoutRendererCrash(() => w.webContents.executeJavaScript(`new Promise(resolve => {
+      const iframe = document.createElement('iframe');
+      iframe.setAttribute('sandbox', 'allow-scripts');
+      iframe.srcdoc = '<!doctype html><script>parent.postMessage("ready", "*")<\\/script>';
+      document.body.appendChild(iframe);
+      setTimeout(() => resolve({
+        frameCount: document.querySelectorAll('iframe').length
+      }), 1000);
+    })`));
+
+    expect(result).to.deep.equal({ frameCount: 1 });
+  });
+});
