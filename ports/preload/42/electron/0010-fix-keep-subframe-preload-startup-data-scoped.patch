+bool EnsureInitialEmptySubframeStartupData(content::RenderFrame* render_frame) {
+  auto* api_service = ElectronApiServiceImpl::Get(render_frame);
+  if (!api_service)
+    return false;
+  if (api_service->startup_data())
+    return true;
+
+  const bool is_initial_empty_subframe =
+      !render_frame->IsMainFrame() &&
+      GURL{render_frame->GetWebFrame()->GetDocument().Url()}.IsAboutBlank();
+  if (!is_initial_empty_subframe)
+    return false;
+
+  mojo::Remote<mojom::ElectronPreloadScriptLoader> loader;
+  blink::Platform::Current()->GetBrowserInterfaceBroker()->GetInterface(
+      loader.BindNewPipeAndPassReceiver());
+
+  mojom::RendererStartupDataPtr startup_data;
+  const auto prefs = render_frame->GetBlinkPreferences();
+  if (!loader->LoadPreloadScripts(
+          "frame", /*injection_point=*/"", render_frame->IsMainFrame(),
+          /*is_initial_empty_document=*/true,
+          prefs.node_integration_in_sub_frames,
+          &startup_data)) {
+    return false;
+  }
+  if (!startup_data)
+    return false;
+  if (startup_data->preload_scripts.empty())
+    return false;
+
+  api_service->SetStartupData(std::move(startup_data));
+  return true;
+}
+
 }  // namespace

