     ) => {
       const partition = `frame-preload-${scope ?? 'default'}-${crypto.randomUUID()}`;
       const ses = session.fromPartition(partition);
@@ -2171,8 +2172,11 @@ describe('session module', () => {
       ) => {
         details.push(eventDetails);
       };
-      ipcMain.on('frame-scope-preload-ran', listener);
+      let isListening = false;
       try {
