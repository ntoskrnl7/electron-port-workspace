       }
       return details;
     };
 
+    const expectRealSubframePreload = (details: Array<{ isMainFrame: boolean; href: string }>) => {
+      const subframeHrefs = details.filter(({ isMainFrame }) => !isMainFrame).map(({ href }) => href);
+      expect(subframeHrefs).to.have.lengthOf(1);
+      expect(subframeHrefs[0]).to.match(/\/frame\.html$/);
+    };
+
     it('runs frame preload scripts in main frames by default', async () => {
       const details = await collectFramePreloadEvents();
       expect(details.map(({ isMainFrame }) => isMainFrame)).to.deep.equal([true]);
@@ -2210,12 +2226,49 @@ describe('session module', () => {
     it('runs frame preload scripts in subframes with sub-frames scope', async () => {
       const details = await collectFramePreloadEvents('sub-frames');
       expect(details.map(({ isMainFrame }) => isMainFrame)).to.deep.equal([false]);
+      expectRealSubframePreload(details);
     });
 
     it('runs frame preload scripts in main frames and subframes with all scope', async () => {
       const details = await collectFramePreloadEvents('all');
       expect(details.map(({ isMainFrame }) => isMainFrame).sort())
         .to.deep.equal([false, true]);
+      expectRealSubframePreload(details);
+    });
+
+    it('runs all-scope frame preload in the real same-origin subframe after frame-created JavaScript', async () => {
+      const details = await collectFramePreloadEvents('all', false, (w) => {
+        w.webContents.on('frame-created', (_event, { frame }) => {
+          if (frame?.parent) {
+            void frame.executeJavaScript('document.hasFocus()').catch(() => {});
+          }
+        });
+      });
+
+      expect(details.map(({ isMainFrame }) => isMainFrame).sort())
+        .to.deep.equal([false, true]);
+      expectRealSubframePreload(details);
+    });
+
+    it('runs all-scope frame preload in the real same-origin subframe after CDP new-document access', async () => {
+      const details = await collectFramePreloadEvents('all', false, async (w) => {
+        await w.loadURL('about:blank');
+        w.webContents.debugger.attach('1.3');
+        await w.webContents.debugger.sendCommand('Page.enable');
+        await w.webContents.debugger.sendCommand('Page.addScriptToEvaluateOnNewDocument', {
