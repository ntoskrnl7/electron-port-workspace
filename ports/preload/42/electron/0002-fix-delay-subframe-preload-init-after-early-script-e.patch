+        ipcMain.on('frame-scope-preload-ran', listener);
+        isListening = true;
         await w.loadFile(path.join(fixtures, 'sub-frames', 'frame-container.html'));
         await w.webContents.executeJavaScript(`
           new Promise(resolve => {
@@ -2184,13 +2188,25 @@ describe('session module', () => {
             }
           })
         `);
-        await setTimeout(50);
+        const expectedEventCount = scope === 'all' || (!scope && nodeIntegrationInSubFrames) ? 2 : 1;
+        await waitUntil(() => details.length >= expectedEventCount, { timeout: 5000 });
       } finally {
-        ipcMain.removeListener('frame-scope-preload-ran', listener);
+        if (isListening) {
+          ipcMain.removeListener('frame-scope-preload-ran', listener);
+        }
+        if (!w.isDestroyed() && w.webContents.debugger.isAttached()) {
+          w.webContents.debugger.detach();
