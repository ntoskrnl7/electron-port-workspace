+          `
+        });
+      });
+
+      expect(details.map(({ isMainFrame }) => isMainFrame).sort())
+        .to.deep.equal([false, true]);
+      expectRealSubframePreload(details);
     });
 
     it('rejects scope for worker preload scripts', () => {
