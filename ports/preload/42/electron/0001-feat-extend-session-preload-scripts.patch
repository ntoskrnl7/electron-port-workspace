@@ -0,0 +1,106 @@
+import fs from 'node:fs';
+import path from 'node:path';
+
+const definitionsPath = path.resolve('electron.d.ts');
+let definitions = fs.readFileSync(definitionsPath, 'utf8');
+
+const frameScope = "('main' | 'sub-frames' | 'all')";
+const workerType = "('dedicated-worker' | 'shared-worker' | 'service-worker')";
+
+const preloadScript = `  type PreloadScript = ({
+
+    // Docs: https://electronjs.org/docs/api/structures/preload-script
+
+    /**
+     * Path of the script file. Must be an absolute path.
+     */
+    filePath: string;
+    /**
+     * Unique ID of preload script.
+     */
+    id: string;
+    /**
+     * Frame scope where the preload script will be executed. This is only set when
+     * \`type\` is \`frame\`.
+     */
+    scope?: ${frameScope};
+    /**
+     * Context type where the preload script will be executed.
+     */
+    type: 'frame';
+  } | {
+
+    // Docs: https://electronjs.org/docs/api/structures/preload-script
+
+    /**
+     * Path of the script file. Must be an absolute path.
+     */
+    filePath: string;
+    /**
+     * Unique ID of preload script.
+     */
+    id: string;
+    /**
+     * Context type where the preload script will be executed.
+     */
+    type: ${workerType};
+  });`;
+
+const preloadScriptRegistration = `  type PreloadScriptRegistration = ({
+
+    // Docs: https://electronjs.org/docs/api/structures/preload-script-registration
+
+    /**
+     * Path of the script file. Must be an absolute path.
+     */
+    filePath: string;
+    /**
+     * Unique ID of preload script. Defaults to a random UUID.
+     */
+    id?: string;
+    /**
+     * Frame scope where the preload script will be executed. This is only supported
+     * when \`type\` is \`frame\`. When omitted, Electron preserves the existing frame
+     * preload behavior: main frame injection, plus subframe injection when
+     * \`nodeIntegrationInSubFrames\` enables subframe preloads.
+     */
+    scope?: ${frameScope};
+    /**
+     * Context type where the preload script will be executed.
+     */
+    type: 'frame';
+  } | {
+
+    // Docs: https://electronjs.org/docs/api/structures/preload-script-registration
+
+    /**
+     * Path of the script file. Must be an absolute path.
+     */
+    filePath: string;
+    /**
+     * Unique ID of preload script. Defaults to a random UUID.
+     */
+    id?: string;
+    /**
+     * Context type where the preload script will be executed.
+     */
+    type: ${workerType};
+  });`;
+
+function replaceGeneratedInterface(source, name, replacement) {
+  const pattern = new RegExp(String.raw`^  interface ${name} \{[\s\S]*?^  \}`, 'm');
+  if (pattern.test(source)) {
+    return source.replace(pattern, replacement);
+  }
+
+  if (source.includes(`  type ${name} = (`)) {
+    return source;
+  }
+
+  throw new Error(`Could not find generated ${name} interface in ${definitionsPath}`);
+}
+
+definitions = replaceGeneratedInterface(definitions, 'PreloadScript', preloadScript);
+definitions = replaceGeneratedInterface(definitions, 'PreloadScriptRegistration', preloadScriptRegistration);
+
+fs.writeFileSync(definitionsPath, definitions);
