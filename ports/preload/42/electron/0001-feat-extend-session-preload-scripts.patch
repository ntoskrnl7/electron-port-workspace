+std::optional<PreloadScript::ScriptType> ParsePreloadScriptType(
+    const std::string& type) {
+  if (type == "frame")
+    return PreloadScript::ScriptType::kWebFrame;
+  if (type == "dedicated-worker")
+    return PreloadScript::ScriptType::kDedicatedWorker;
+  if (type == "shared-worker")
+    return PreloadScript::ScriptType::kSharedWorker;
+  if (type == "service-worker")
+    return PreloadScript::ScriptType::kServiceWorker;
+  return std::nullopt;
+}
+
+class ElectronPreloadScriptLoader : public mojom::ElectronPreloadScriptLoader {
+ public:
+  explicit ElectronPreloadScriptLoader(content::BrowserContext* browser_context)
+      : browser_context_(browser_context) {}
+
+  ElectronPreloadScriptLoader(const ElectronPreloadScriptLoader&) = delete;
+  ElectronPreloadScriptLoader& operator=(const ElectronPreloadScriptLoader&) =
+      delete;
+
+  void LoadPreloadScripts(const std::string& type,
+                          LoadPreloadScriptsCallback callback) override {
+    std::vector<mojom::PreloadScriptSourcePtr> sources;
+    std::optional<PreloadScript::ScriptType> script_type =
+        ParsePreloadScriptType(type);
+    auto* prefs = SessionPreferences::FromBrowserContext(browser_context_);
+    if (!script_type || !prefs) {
+      std::move(callback).Run(std::move(sources));
+      return;
+    }
+
+    for (const auto& script : prefs->preload_scripts()) {
+      if (script.script_type != *script_type)
+        continue;
+
+      auto source = mojom::PreloadScriptSource::New();
+      source->file_path = script.file_path.AsUTF8Unsafe();
+
+      if (!script.file_path.IsAbsolute()) {
+        source->error = "Preload script must have absolute path";
+      } else {
+        ScopedAllowBlockingForElectron allow_blocking;
+        if (!base::ReadFileToString(script.file_path, &source->contents))
+          source->error = "Unable to read preload script";
+      }
+
+      sources.push_back(std::move(source));
+    }
+
+    std::move(callback).Run(std::move(sources));
+  }
+
+ private:
+  raw_ptr<content::BrowserContext> browser_context_;
+};
+
+void BindPreloadScriptLoader(
+    content::BrowserContext* browser_context,
+    mojo::PendingReceiver<mojom::ElectronPreloadScriptLoader> receiver) {
+  mojo::MakeSelfOwnedReceiver(
+      std::make_unique<ElectronPreloadScriptLoader>(browser_context),
+      std::move(receiver));
+}
