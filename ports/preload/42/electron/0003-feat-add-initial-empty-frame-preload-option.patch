+
+v8::Local<v8::Context> GetInitializedScriptContext(
+    blink::WebLocalFrameImpl* web_frame,
+    v8::Isolate* isolate,
+    int world_id) {
+  blink::DOMWrapperWorld* world = nullptr;
+  if (world_id == WorldIDs::MAIN_WORLD_ID) {
+    world = &blink::DOMWrapperWorld::MainWorld(isolate);
+  } else {
+    world = blink::DOMWrapperWorld::EnsureIsolatedWorld(isolate, world_id);
+  }
+
+  auto* window_proxy = static_cast<blink::LocalWindowProxy*>(
+      web_frame->GetFrame()
+          ->GetWindowProxyManager()
+          ->GetWindowProxyMaybeUninitialized(*world));
+  return window_proxy->ContextIfInitialized();
+}
