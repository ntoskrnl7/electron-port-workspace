+bool SessionPreferences::HasFramePreloadScriptInInitialEmptyDocuments() {
+  const auto& preloads = preload_scripts();
+  auto it = std::find_if(
+      preloads.begin(), preloads.end(), [](const PreloadScript& script) {
+        return script.script_type == PreloadScript::ScriptType::kWebFrame &&
+               script.run_in_initial_empty_document && script.has_frame_scope &&
+               script.frame_scope != PreloadScript::FrameScope::kMain;
+      });
+  return it != preloads.end();
+}
+
 }  // namespace electron
