+void ElectronRenderFrameObserver::MaybeInitializeInitialEmptyDocument() {
+  auto* web_frame =
+      static_cast<blink::WebLocalFrameImpl*>(render_frame_->GetWebFrame());
+  if (render_frame_->IsMainFrame() || !web_frame->IsOnInitialEmptyDocument())
+    return;
+
+  const auto prefs = render_frame_->GetBlinkPreferences();
+  if (prefs.node_integration_in_sub_frames)
+    return;
+
+  auto* command_line = base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(switches::kFramePreloadInSubFrames) ||
+      !command_line->HasSwitch(switches::kFramePreloadInInitialEmptyDocuments))
+    return;
+
+  has_delayed_node_initialization_ = true;
+
+  v8::Isolate* isolate = web_frame->GetAgentGroupScheduler()->Isolate();
+  v8::HandleScope handle_scope{isolate};
+
+  if (prefs.context_isolation) {
+    web_frame->ExecuteScript(blink::WebScriptSource("void 0"));
+    if (initialized_initial_empty_document_)
+      return;
+
+    CreateIsolatedWorldContext();
+    if (initialized_initial_empty_document_)
+      return;
+
+    v8::Local<v8::Context> context =
+        GetInitializedScriptContext(web_frame, isolate,
+                                    WorldIDs::ISOLATED_WORLD_ID);
+    if (context.IsEmpty())
+      return;
+
+    v8::MicrotasksScope microtasks_scope(
+        context, v8::MicrotasksScope::kDoNotRunMicrotasks);
+    v8::Context::Scope context_scope(context);
+    DidInstallConditionalFeatures(context, WorldIDs::ISOLATED_WORLD_ID);
+  } else {
+    web_frame->ExecuteScript(blink::WebScriptSource("void 0"));
+    if (initialized_initial_empty_document_)
+      return;
+
+    v8::Local<v8::Context> context =
+        GetInitializedScriptContext(web_frame, isolate, WorldIDs::MAIN_WORLD_ID);
+    if (context.IsEmpty())
+      return;
+
+    v8::MicrotasksScope microtasks_scope(
+        context, v8::MicrotasksScope::kDoNotRunMicrotasks);
+    v8::Context::Scope context_scope(context);
+    DidInstallConditionalFeatures(context, WorldIDs::MAIN_WORLD_ID);
+  }
+}
