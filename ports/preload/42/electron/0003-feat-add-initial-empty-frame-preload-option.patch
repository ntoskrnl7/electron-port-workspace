+void SetIsInitialEmptyDocument(v8::Local<v8::Context> context,
+                               bool is_initial_empty_document) {
+  v8::Isolate* isolate = v8::Isolate::GetCurrent();
+  auto private_key = v8::Private::ForApi(
+      isolate, gin::StringToV8(isolate, "isInitialEmptyDocument"));
+  context->Global()
+      ->SetPrivate(context, private_key,
+                   v8::Boolean::New(isolate, is_initial_empty_document))
+      .ToChecked();
