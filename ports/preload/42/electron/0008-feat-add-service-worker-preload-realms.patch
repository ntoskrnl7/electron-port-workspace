-        return script.script_type == PreloadScript::ScriptType::kServiceWorker;
+        return ServiceWorkerTargetMatches(
+            script,
+            PreloadScript::ServiceWorkerTarget::kServiceWorkerGlobalScope);
       });
   return it != preloads.end();
 }
