 bool SessionPreferences::HasServiceWorkerPreloadScript() {
+  return HasServiceWorkerPreloadScriptInShadowRealm() ||
+         HasServiceWorkerPreloadScriptInServiceWorker();
+}
+
+namespace {
+
+bool ServiceWorkerTargetMatches(
+    const PreloadScript& script,
+    PreloadScript::ServiceWorkerTarget expected_target) {
+  if (script.script_type != PreloadScript::ScriptType::kServiceWorker)
+    return false;
+
+  const auto target = script.service_worker_target;
+  return target == expected_target ||
+         target == PreloadScript::ServiceWorkerTarget::kBoth;
+}
+
+}  // namespace
+
+bool SessionPreferences::HasServiceWorkerPreloadScriptInShadowRealm() {
+  const auto& preloads = preload_scripts();
+  auto it = std::find_if(
+      preloads.begin(), preloads.end(), [](const PreloadScript& script) {
+        return ServiceWorkerTargetMatches(
+            script,
+            PreloadScript::ServiceWorkerTarget::kShadowRealmGlobalScope);
+      });
+  return it != preloads.end();
+}
+
+bool SessionPreferences::HasServiceWorkerPreloadScriptInServiceWorker() {
   const auto& preloads = preload_scripts();
   auto it = std::find_if(
       preloads.begin(), preloads.end(), [](const PreloadScript& script) {
-        return script.script_type == PreloadScript::ScriptType::kServiceWorker;
+        return ServiceWorkerTargetMatches(
+            script,
+            PreloadScript::ServiceWorkerTarget::kServiceWorkerGlobalScope);
       });
   return it != preloads.end();
 }
