+bool ServiceWorkerTargetMatches(
+    const PreloadScript& script,
+    PreloadScript::ServiceWorkerTarget expected_target) {
+  if (script.script_type != PreloadScript::ScriptType::kServiceWorker)
+    return false;
+
+  const auto target = script.service_worker_target;
