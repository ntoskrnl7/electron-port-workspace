     preloadScripts: ElectronInternal.PreloadScript[];
     process: NodeJS.Process;
   };
+  serviceWorkerPreloadTarget?: 'shadow-realm-global-scope' | 'service-worker-global-scope';
 };
 
-const { preloadScripts, process: processProps } = binding.startupData;
+const { preloadScripts: startupPreloadScripts, process: processProps } = binding.startupData;
+const preloadScripts = binding.serviceWorkerPreloadTarget
+  ? startupPreloadScripts.filter((script) => {
+    if (script.type !== 'service-worker') return true;
+    const target = script.target ?? 'shadow-realm-global-scope';
+    return target === 'both' || target === binding.serviceWorkerPreloadTarget;
+  })
+  : startupPreloadScripts;
 
