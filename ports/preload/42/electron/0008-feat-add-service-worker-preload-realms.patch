+bool SessionPreferences::HasServiceWorkerPreloadScriptInShadowRealm() {
+  const auto& preloads = preload_scripts();
+  auto it = std::find_if(
+      preloads.begin(), preloads.end(), [](const PreloadScript& script) {
+        return ServiceWorkerTargetMatches(
+            script,
+            PreloadScript::ServiceWorkerTarget::kShadowRealmGlobalScope);
+      });
+  return it != preloads.end();
