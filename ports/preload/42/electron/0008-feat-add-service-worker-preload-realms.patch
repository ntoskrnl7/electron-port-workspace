+std::string PreloadScriptTypeToString(PreloadScript::ScriptType type) {
+  switch (type) {
+    case PreloadScript::ScriptType::kWebFrame:
+      return "frame";
+    case PreloadScript::ScriptType::kDedicatedWorker:
+      return "dedicated-worker";
+    case PreloadScript::ScriptType::kSharedWorker:
+      return "shared-worker";
+    case PreloadScript::ScriptType::kServiceWorker:
+      return "service-worker";
+  }
+}
+
+std::optional<std::string> ServiceWorkerTargetToString(
+    const PreloadScript& script) {
+  if (script.script_type != PreloadScript::ScriptType::kServiceWorker ||
+      !script.has_service_worker_target) {
+    return std::nullopt;
+  }
+
+  switch (script.service_worker_target) {
+    case PreloadScript::ServiceWorkerTarget::kShadowRealmGlobalScope:
+      return "shadow-realm-global-scope";
+    case PreloadScript::ServiceWorkerTarget::kServiceWorkerGlobalScope:
+      return "service-worker-global-scope";
+    case PreloadScript::ServiceWorkerTarget::kBoth:
+      return "both";
+  }
+}
+
