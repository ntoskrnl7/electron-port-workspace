From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Jung-Kwang Lee <ntoskrnl7@gmail.com>
Date: Mon, 11 May 2026 17:30:00 +0900
Subject: fix: disable DOM storage in PDF renderers

Chromium PDF renderer processes are not allowed to access origin data such as
localStorage. Match Chrome's renderer client behavior and disable DOM storage
for PDF renderer processes so the built-in PDF viewer sees localStorage as
unavailable instead of sending a storage Mojo request that the browser process
terminates as a bad message.

diff --git a/shell/renderer/renderer_client_base.cc b/shell/renderer/renderer_client_base.cc
index 882e5c9214..21c1396e03 100644
--- a/shell/renderer/renderer_client_base.cc
+++ b/shell/renderer/renderer_client_base.cc
@@ -503,6 +503,14 @@ bool RendererClientBase::IsPluginHandledExternally(
 #endif
 }
 
+bool RendererClientBase::IsDomStorageDisabled() const {
+#if BUILDFLAG(ENABLE_PDF_VIEWER)
+  return pdf::IsPdfRenderer();
+#else
+  return false;
+#endif  // BUILDFLAG(ENABLE_PDF_VIEWER)
+}
+
 v8::Local<v8::Object> RendererClientBase::GetScriptableObject(
     const blink::WebElement& plugin_element,
     v8::Isolate* isolate) {
diff --git a/shell/renderer/renderer_client_base.h b/shell/renderer/renderer_client_base.h
index 2731aca9ea..fe69b2473d 100644
--- a/shell/renderer/renderer_client_base.h
+++ b/shell/renderer/renderer_client_base.h
@@ -108,6 +108,7 @@ class RendererClientBase : public content::ContentRendererClient
                                  const blink::WebElement& plugin_element,
                                  const GURL& original_url,
                                  const std::string& mime_type) override;
+  bool IsDomStorageDisabled() const override;
   v8::Local<v8::Object> GetScriptableObject(
       const blink::WebElement& plugin_element,
       v8::Isolate* isolate) override;
