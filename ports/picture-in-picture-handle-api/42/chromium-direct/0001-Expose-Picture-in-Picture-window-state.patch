+
+std::optional<gfx::Rect>
+PictureInPictureBrowserFrameView::SetPictureInPictureWindowBounds(
+    const gfx::Rect& bounds) {
+  if (!GetWidget()) {
+    return std::nullopt;
+  }
+
+  gfx::Rect adjusted_bounds(bounds);
+  display::Display display =
+      display::Screen::Get()->GetDisplayMatching(adjusted_bounds);
+  if (!display.is_valid()) {
+    display = display::Screen::Get()->GetDisplayNearestWindow(
+        GetWidget()->GetNativeWindow());
+  }
+
+  gfx::Size adjusted_size = adjusted_bounds.size();
+  adjusted_size.SetToMax(GetMinimumSize());
+  adjusted_size.SetToMin(
+      PictureInPictureWindowManager::GetMaximumWindowSize(display));
+  adjusted_bounds.set_size(adjusted_size);
+  adjusted_bounds.AdjustToFit(display.work_area());
+
+  GetWidget()->SetBounds(adjusted_bounds);
+  if (is_tucking_forced_) {
+    EnforceTucking();
+  }
+  return GetWidget()->GetWindowBoundsInScreen();
+}
