diff --git a/lib/browser/picture-in-picture.ts b/lib/browser/picture-in-picture.ts
new file mode 100644
index 0000000000..39242471da
--- /dev/null
+++ b/lib/browser/picture-in-picture.ts
@@ -0,0 +1,167 @@
+const { nativeImage } = process._linkedBinding('electron_common_native_image');
+
+interface PictureInPictureDetails {
+  id: number;
+  type: 'video' | 'document';
+  sourceWebContents: Electron.WebContents;
+  pipWebContents?: Electron.WebContents;
+  bounds: Electron.Rectangle;
+  sourceId?: string;
+  videoSize?: Electron.Size;
+}
+
+type PictureInPictureApp = Electron.App & {
+  _getCurrentPictureInPictureDetails: () => PictureInPictureDetails | null;
+  _setCurrentPictureInPictureBounds: (id: number, bounds: Electron.Rectangle) => Electron.Rectangle | null;
+  _closeCurrentPictureInPicture: (id: number) => boolean;
+  _isCurrentPictureInPicture: (id: number) => boolean;
+};
+
+const getDesktopMediaWindowIdParts = (sourceId: string) => {
+  const [type, nativeWindowId, windowRegistryId] = sourceId.split(':');
+  if (type !== 'window') return null;
+
+  return {
+    nativeWindowId: nativeWindowId && nativeWindowId !== '0' ? nativeWindowId : null,
+    windowRegistryId: windowRegistryId && windowRegistryId !== '0' ? windowRegistryId : null
+  };
+};
+
+const getDetailsForId = (app: PictureInPictureApp, id: number) => {
+  const details = app._getCurrentPictureInPictureDetails();
+  return details?.id === id ? details : null;
+};
+
+const getSourceFromId = async (sourceId: string, options: Electron.PictureInPictureSourceOptions = {}) => {
+  const { getSources } = require('./api/desktop-capturer') as typeof import('./api/desktop-capturer');
+  const sources = await getSources({
+    types: ['window'],
+    thumbnailSize: options.thumbnailSize,
+    fetchWindowIcons: options.fetchWindowIcons
+  });
+
+  const targetWindowIdParts = getDesktopMediaWindowIdParts(sourceId);
+  const source =
+    sources.find((source) => {
+      if (source.id === sourceId) return true;
+
+      const sourceWindowIdParts = getDesktopMediaWindowIdParts(source.id);
+      return (
+        sourceWindowIdParts !== null &&
+        targetWindowIdParts !== null &&
+        ((targetWindowIdParts.nativeWindowId !== null &&
+          sourceWindowIdParts.nativeWindowId === targetWindowIdParts.nativeWindowId) ||
+          (targetWindowIdParts.windowRegistryId !== null &&
+            sourceWindowIdParts.windowRegistryId === targetWindowIdParts.windowRegistryId))
+      );
+    }) ?? null;
+  if (source) return source as Electron.DesktopCapturerSource;
+
+  return {
+    id: sourceId,
+    name: 'Picture-in-Picture',
+    thumbnail: nativeImage.createEmpty(),
+    appIcon: nativeImage.createEmpty(),
+    display_id: ''
+  };
+};
+
+export class PictureInPicture {
+  readonly id: number;
+  readonly type: 'video' | 'document';
+  readonly sourceWebContents: Electron.WebContents;
+
+  protected constructor(
+    protected readonly app: PictureInPictureApp,
+    details: PictureInPictureDetails
+  ) {
+    this.id = details.id;
+    this.type = details.type;
+    this.sourceWebContents = details.sourceWebContents;
+  }
+
+  getBounds() {
+    return getDetailsForId(this.app, this.id)?.bounds ?? null;
+  }
+
+  setBounds(bounds: Electron.Rectangle) {
+    return this.app._setCurrentPictureInPictureBounds(this.id, bounds);
+  }
+
+  getSize() {
+    const bounds = this.getBounds();
+    if (!bounds) return null;
+
+    return { width: bounds.width, height: bounds.height };
+  }
+
+  setSize(size: Electron.Size) {
+    const bounds = this.getBounds();
+    if (!bounds) return null;
+
+    const actualBounds = this.setBounds({ ...bounds, ...size });
+    if (!actualBounds) return null;
+
+    return { width: actualBounds.width, height: actualBounds.height };
+  }
+
+  getSourceId() {
+    return getDetailsForId(this.app, this.id)?.sourceId ?? null;
+  }
+
+  async getSource(options: Electron.PictureInPictureSourceOptions = {}) {
+    const sourceId = this.getSourceId();
+    if (!sourceId) return null;
+
+    return getSourceFromId(sourceId, options);
+  }
+
+  close() {
+    return this.app._closeCurrentPictureInPicture(this.id);
+  }
+
+  isDestroyed() {
+    return !this.app._isCurrentPictureInPicture(this.id);
+  }
+}
+
+export class VideoPictureInPicture extends PictureInPicture {
+  declare readonly type: 'video';
+  readonly videoSize: Electron.Size;
+
+  constructor(app: PictureInPictureApp, details: PictureInPictureDetails) {
+    super(app, details);
+    this.videoSize = details.videoSize ?? { width: 0, height: 0 };
+  }
+}
+
+export class DocumentPictureInPicture extends PictureInPicture {
+  declare readonly type: 'document';
+  readonly pipWebContents: Electron.WebContents;
+
+  constructor(app: PictureInPictureApp, details: PictureInPictureDetails) {
+    super(app, details);
+    this.pipWebContents = details.pipWebContents!;
+  }
+}
+
+export const createPictureInPicture = (app: PictureInPictureApp, details: PictureInPictureDetails) => {
+  if (details.type === 'document') {
+    return new DocumentPictureInPicture(app, details);
+  }
+
+  return new VideoPictureInPicture(app, details);
+};
+
+export const getCurrentPictureInPicture = (app: PictureInPictureApp) => {
+  const details = app._getCurrentPictureInPictureDetails();
+  return details ? createPictureInPicture(app, details) : null;
+};
+
+export const wrapPictureInPictureEvent = (app: PictureInPictureApp, eventName: string, args: any[]) => {
+  if ((eventName === 'enter-picture-in-picture' || eventName === 'leave-picture-in-picture') && args[1]?.id) {
+    return [args[0], createPictureInPicture(app, args[1]), ...args.slice(2)];
+  }
+
+  return args;
+};
