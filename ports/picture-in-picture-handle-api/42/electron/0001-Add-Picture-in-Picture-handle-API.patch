+void App::OnEnterPictureInPicture() {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Value> details = GetCurrentPictureInPictureDetails(isolate);
+  if (!details->IsNull()) {
+    gin_helper::Handle<WebContents> api_web_contents;
+    content::WebContents* source_web_contents =
+        PictureInPictureWindowManager::GetInstance()->GetWebContents();
+    if (source_web_contents) {
+      api_web_contents = WebContents::FromOrCreate(isolate, source_web_contents);
+    }
+
+    Emit("enter-picture-in-picture", details);
+    if (!api_web_contents.IsEmpty()) {
+      api_web_contents->Emit("enter-picture-in-picture", details);
+    }
+  }
+}
+
+void App::OnExitPictureInPicture() {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Value> details = GetCurrentPictureInPictureDetails(isolate);
+  if (!details->IsNull()) {
+    gin_helper::Handle<WebContents> api_web_contents;
+    content::WebContents* source_web_contents =
+        PictureInPictureWindowManager::GetInstance()->GetWebContents();
+    if (source_web_contents) {
+      api_web_contents = WebContents::FromOrCreate(isolate, source_web_contents);
+    }
+
+    Emit("leave-picture-in-picture", details);
+    if (!api_web_contents.IsEmpty()) {
+      api_web_contents->Emit("leave-picture-in-picture", details);
+    }
+  }
+}
+
 void App::BrowserChildProcessCrashedOrKilled(
     const content::ChildProcessData& data,
     const content::ChildProcessTerminationInfo& info) {
@@ -1269,6 +1310,70 @@ void App::SetAccessibilitySupportFeatures(
   Browser::Get()->OnAccessibilitySupportChanged();
 }
 
+v8::Local<v8::Value> App::GetCurrentPictureInPictureDetails(
+    v8::Isolate* isolate) {
+  auto* manager = PictureInPictureWindowManager::GetInstance();
+  int picture_in_picture_id = manager->GetPictureInPictureWindowId();
+  if (picture_in_picture_id == 0) {
+    return v8::Null(isolate);
+  }
+
+  content::WebContents* source_web_contents = manager->GetWebContents();
+  if (!source_web_contents) {
+    return v8::Null(isolate);
+  }
+
+  auto details = gin_helper::Dictionary::CreateEmpty(isolate);
+  content::WebContents* pip_web_contents = manager->GetChildWebContents();
+  details.Set("id", picture_in_picture_id);
+  details.Set("type", std::string(pip_web_contents ? "document" : "video"));
+  details.Set("sourceWebContents",
+              WebContents::FromOrCreate(isolate, source_web_contents));
+  if (pip_web_contents) {
+    details.Set("pipWebContents",
+                WebContents::FromOrCreate(isolate, pip_web_contents));
+  }
+
+  details.Set("bounds",
+              manager->GetPictureInPictureWindowBoundsInScreen().value_or(
+                  gfx::Rect()));
+  if (std::optional<std::string> source_id =
+          manager->GetPictureInPictureWindowSourceId()) {
+    details.Set("sourceId", *source_id);
+  }
+  if (std::optional<gfx::Size> video_size =
+          manager->GetVideoPictureInPictureSize()) {
+    details.Set("videoSize", *video_size);
+  }
+
+  return gin::ConvertToV8(isolate, details);
+}
+
+v8::Local<v8::Value> App::SetCurrentPictureInPictureBounds(
+    v8::Isolate* isolate,
+    int picture_in_picture_id,
+    const gfx::Rect& bounds) {
+  auto* manager = PictureInPictureWindowManager::GetInstance();
+  std::optional<gfx::Rect> actual_bounds =
+      manager->SetPictureInPictureWindowBoundsInScreen(picture_in_picture_id,
+                                                       bounds);
+  if (!actual_bounds) {
+    return v8::Null(isolate);
+  }
+
+  return gin::ConvertToV8(isolate, *actual_bounds);
+}
+
+bool App::CloseCurrentPictureInPicture(int picture_in_picture_id) {
+  return PictureInPictureWindowManager::GetInstance()
+      ->ClosePictureInPictureWindow(picture_in_picture_id);
+}
+
+bool App::IsCurrentPictureInPicture(int picture_in_picture_id) {
+  return PictureInPictureWindowManager::GetInstance()
+      ->IsPictureInPictureWindowIdCurrent(picture_in_picture_id);
+}
+
 void App::SetAccessibilitySupportEnabled(gin_helper::ErrorThrower thrower,
                                          bool enabled) {
   if (!Browser::Get()->is_ready()) {
@@ -2014,6 +2119,13 @@ gin::ObjectTemplateBuilder App::GetObjectTemplateBuilder(v8::Isolate* isolate) {
                  &App::SetAccessibilitySupportFeatures)
       .SetMethod("setAccessibilitySupportEnabled",
                  &App::SetAccessibilitySupportEnabled)
+      .SetMethod("_getCurrentPictureInPictureDetails",
+                 &App::GetCurrentPictureInPictureDetails)
+      .SetMethod("_setCurrentPictureInPictureBounds",
+                 &App::SetCurrentPictureInPictureBounds)
+      .SetMethod("_closeCurrentPictureInPicture",
+                 &App::CloseCurrentPictureInPicture)
+      .SetMethod("_isCurrentPictureInPicture", &App::IsCurrentPictureInPicture)
       .SetMethod("disableHardwareAcceleration",
