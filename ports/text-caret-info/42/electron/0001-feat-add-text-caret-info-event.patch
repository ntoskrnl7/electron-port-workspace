+class TextCaretFrameObserver : public base::SupportsUserData::Data,
+                               public content::WebContentsObserver,
+                               public content::TextInputManager::Observer {
+ public:
+  TextCaretFrameObserver(content::WebContents* web_contents,
+                         base::WeakPtr<WebContents> api_web_contents)
+      : content::WebContentsObserver(web_contents),
+        api_web_contents_(api_web_contents) {
+    auto* web_contents_impl =
+        static_cast<content::WebContentsImpl*>(web_contents);
+    text_input_manager_ = web_contents_impl->GetTextInputManager();
+    if (text_input_manager_)
+      text_input_manager_->AddObserver(this);
+  }
+
+  ~TextCaretFrameObserver() override { StopObservingTextInputManager(); }
+
+  static void CreateForWebContents(
+      content::WebContents* web_contents,
+      base::WeakPtr<WebContents> api_web_contents) {
+    if (!web_contents ||
+        web_contents->GetUserData(kTextCaretFrameObserverKey)) {
+      return;
+    }
+
+    web_contents->SetUserData(
+        kTextCaretFrameObserverKey,
+        std::make_unique<TextCaretFrameObserver>(web_contents,
+                                                 api_web_contents));
+  }
+
+  using content::WebContentsObserver::OnTextSelectionChanged;
+
+ private:
+  void WebContentsDestroyed() override {
+    StopObservingTextInputManager();
+    Observe(nullptr);
+  }
+
+  void OnUpdateTextInputStateCalled(
+      content::TextInputManager* text_input_manager,
+      content::RenderWidgetHostViewBase* updated_view,
+      bool did_update_state) override {
+    if (did_update_state)
+      EmitCaretInfoChanged(text_input_manager, updated_view, "focus");
+  }
+
+  void OnSelectionBoundsChanged(
+      content::TextInputManager* text_input_manager,
+      content::RenderWidgetHostViewBase* updated_view) override {
+    EmitCaretInfoChanged(text_input_manager, updated_view, "caret-move");
+  }
+
+  void OnTextSelectionChanged(
+      content::TextInputManager* text_input_manager,
+      content::RenderWidgetHostViewBase* updated_view) override {
+    EmitCaretInfoChanged(text_input_manager, updated_view, "caret-move");
+  }
+
+  void StopObservingTextInputManager() {
+    if (text_input_manager_ && text_input_manager_->HasObserver(this))
+      text_input_manager_->RemoveObserver(this);
+    text_input_manager_ = nullptr;
+  }
+
+  content::RenderFrameHost* GetRenderFrameHostForView(
+      content::RenderWidgetHostViewBase* view) {
+    content::WebContents* contents = web_contents();
+    if (!contents || !view)
+      return nullptr;
+
+    content::RenderWidgetHost* widget = view->GetRenderWidgetHost();
+    content::RenderFrameHost* focused_frame = contents->GetFocusedFrame();
+    if (focused_frame &&
+        (focused_frame->GetView() == view ||
+         focused_frame->GetRenderWidgetHost() == widget)) {
+      return focused_frame;
+    }
+
+    content::RenderFrameHost* result = nullptr;
+    contents->ForEachRenderFrameHostWithAction(
+        [view, widget, &result](content::RenderFrameHost* frame) {
+          if (frame->GetView() == view ||
+              frame->GetRenderWidgetHost() == widget) {
+            result = frame;
+            return content::RenderFrameHost::FrameIterationAction::kStop;
+          }
+          return content::RenderFrameHost::FrameIterationAction::kContinue;
+        });
+    return result;
+  }
+
+  void EmitCaretInfoChanged(content::TextInputManager* text_input_manager,
+                            content::RenderWidgetHostViewBase* updated_view,
+                            const char* reason) {
+    if (!api_web_contents_ || !text_input_manager || !updated_view ||
+        !text_input_manager->IsRegistered(updated_view)) {
+      return;
+    }
+
+    const ui::mojom::TextInputState* text_input_state =
+        text_input_manager->GetTextInputState();
+    if (!text_input_state ||
+        text_input_state->type == ui::TEXT_INPUT_TYPE_NONE) {
+      return;
+    }
+
+    const auto* region = text_input_manager->GetSelectionRegion(updated_view);
+    if (!region)
+      return;
+
+    gfx::Rect caret_bounds = RectFromSelectionBound(region->focus);
+    if (caret_bounds.IsEmpty())
+      caret_bounds = region->caret_rect;
+    if (caret_bounds.IsEmpty())
+      return;
+
+    content::RenderFrameHost* render_frame_host =
+        GetRenderFrameHostForView(updated_view);
+    if (!render_frame_host)
+      return;
+
+    v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+    v8::HandleScope handle_scope(isolate);
+
+    auto details = gin_helper::Dictionary::CreateEmpty(isolate);
+    details.SetGetter("frame", render_frame_host);
+    details.Set("url", render_frame_host->GetLastCommittedURL().spec());
+    details.Set("isMainFrame", render_frame_host->GetParent() == nullptr);
+    details.Set("inputType",
+                std::string(TextInputTypeToString(text_input_state->type)));
+    details.Set("inputMode",
+                std::string(TextInputModeToString(text_input_state->mode)));
+    details.Set("inputAction",
+                std::string(TextInputActionToString(text_input_state->action)));
+
+    auto caret = gin_helper::Dictionary::CreateEmpty(isolate);
+    caret.Set("visible", region->focus.type() != gfx::SelectionBound::EMPTY);
+    caret.Set("bounds", caret_bounds);
+
+    content::RenderWidgetHostView* root_view =
+        web_contents()->GetTopLevelRenderWidgetHostView();
+    if (root_view) {
+      gfx::Point screen_origin = caret_bounds.origin();
+      screen_origin += root_view->GetViewBounds().OffsetFromOrigin();
+      caret.Set("screenBounds", gfx::Rect(screen_origin, caret_bounds.size()));
+    }
+    details.Set("caret", caret);
+
+    if (text_input_state->selection.IsValid()) {
+      auto selection = gin_helper::Dictionary::CreateEmpty(isolate);
+      SetRangeDetails(&selection, text_input_state->selection);
+      details.Set("selection", selection);
+    }
+
+    const bool has_composition = text_input_state->composition &&
+                                 text_input_state->composition->IsValid();
+    auto composition = gin_helper::Dictionary::CreateEmpty(isolate);
+    composition.Set("isComposing", has_composition);
+    if (has_composition) {
+      composition.Set("start",
+                      static_cast<uint32_t>(
+                          text_input_state->composition->start()));
+      composition.Set("end",
+                      static_cast<uint32_t>(
+                          text_input_state->composition->end()));
+    }
+    details.Set("composition", composition);
+
+    details.Set("reason", std::string(reason));
+
+    api_web_contents_->Emit("text-caret-info-changed", details);
+  }
+
+  base::WeakPtr<WebContents> api_web_contents_;
+  raw_ptr<content::TextInputManager> text_input_manager_ = nullptr;
+};
