+gfx::Rect RectFromSelectionBound(const gfx::SelectionBound& bound) {
+  if (bound.type() == gfx::SelectionBound::EMPTY) {
+    return gfx::Rect();
+  }
+
+  const gfx::Point& start = bound.edge_start_rounded();
+  const gfx::Point& end = bound.edge_end_rounded();
+  const int left = std::min(start.x(), end.x());
+  const int top = std::min(start.y(), end.y());
+  const int width = std::max(1, std::abs(end.x() - start.x()));
+  const int height = std::max(1, std::abs(end.y() - start.y()));
+  return gfx::Rect(left, top, width, height);
+}
