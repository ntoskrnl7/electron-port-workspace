+  describe('text-caret-info-changed event', () => {
+    afterEach(closeAllWindows);
+
+    it('emits caret bounds and input state for a focused editable element', async () => {
+      const w = new BrowserWindow({ show: false, width: 400, height: 300 });
+      await w.loadURL(`data:text/html;charset=utf-8,${encodeURIComponent(`
+        <!DOCTYPE html>
+        <input
+          id="field"
+          type="search"
+          inputmode="email"
+          enterkeyhint="go"
+          value="hello"
+          style="font-size: 24px; margin: 20px;">
+      `)}`);
+
+      const caretInfoChanged = new Promise<Electron.TextCaretInfoChangedDetails>((resolve) => {
+        const listener = (_event: Electron.Event, details: Electron.TextCaretInfoChangedDetails) => {
+          if (details.selection?.start === 2 && details.selection.end === 2) {
+            w.webContents.off('text-caret-info-changed', listener);
+            resolve(details);
+          }
+        };
+        w.webContents.on('text-caret-info-changed', listener);
+      });
+
+      await w.webContents.executeJavaScript(`
+        const field = document.getElementById('field');
+        field.focus();
+        field.setSelectionRange(2, 2);
+      `);
+
+      const details = await caretInfoChanged;
+      expect(details.frame).to.equal(w.webContents.mainFrame);
+      expect(details.url).to.equal(w.webContents.mainFrame.url);
+      expect(details.isMainFrame).to.be.true();
+      expect(details.inputType).to.equal('search');
+      expect(details.inputMode).to.equal('email');
+      expect(details.inputAction).to.equal('go');
+      expect(details.reason).to.be.oneOf(['focus', 'caret-move']);
+      expect(details.caret.visible).to.be.true();
+      expect(details.caret.bounds.width).to.be.greaterThan(0);
+      expect(details.caret.bounds.height).to.be.greaterThan(0);
+      expect(details.selection).to.deep.equal({
+        isCollapsed: true,
+        start: 2,
+        end: 2
+      });
+      expect(details.composition).to.deep.equal({ isComposing: false });
+    });
+  });
+
