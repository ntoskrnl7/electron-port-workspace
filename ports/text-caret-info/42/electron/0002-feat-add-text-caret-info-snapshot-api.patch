+v8::Local<v8::Value> WebContents::GetTextCaretInfo(v8::Isolate* isolate) {
+  auto* web_contents_impl =
+      static_cast<content::WebContentsImpl*>(web_contents());
+  auto* text_input_manager = web_contents_impl->GetTextInputManager();
+  if (!text_input_manager)
+    return v8::Null(isolate);
+
+  content::RenderWidgetHostImpl* active_widget =
+      text_input_manager->GetActiveWidget();
+  content::RenderWidgetHostViewBase* active_view =
+      active_widget ? active_widget->GetView() : nullptr;
+  return CreateTextCaretInfo(isolate, web_contents(), text_input_manager,
+                             active_view, std::nullopt);
+}
