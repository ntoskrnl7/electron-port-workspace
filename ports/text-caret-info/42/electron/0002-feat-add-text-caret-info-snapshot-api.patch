+content::RenderFrameHost* GetRenderFrameHostForView(
+    content::WebContents* contents,
+    content::RenderWidgetHostViewBase* view) {
+  if (!contents || !view)
+    return nullptr;
+
+  content::RenderWidgetHost* widget = view->GetRenderWidgetHost();
+  content::RenderFrameHost* focused_frame = contents->GetFocusedFrame();
+  if (focused_frame && (focused_frame->GetView() == view ||
+                        focused_frame->GetRenderWidgetHost() == widget)) {
+    return focused_frame;
+  }
+
+  content::RenderFrameHost* result = nullptr;
+  contents->ForEachRenderFrameHostWithAction(
+      [view, widget, &result](content::RenderFrameHost* frame) {
+        if (frame->GetView() == view ||
+            frame->GetRenderWidgetHost() == widget) {
+          result = frame;
+          return content::RenderFrameHost::FrameIterationAction::kStop;
+        }
+        return content::RenderFrameHost::FrameIterationAction::kContinue;
+      });
+  return result;
+}
+
+v8::Local<v8::Value> CreateTextCaretInfo(
+    v8::Isolate* isolate,
+    content::WebContents* contents,
+    content::TextInputManager* text_input_manager,
+    content::RenderWidgetHostViewBase* view,
+    std::optional<std::string_view> reason) {
+  if (!contents || !text_input_manager || !view ||
+      !text_input_manager->IsRegistered(view)) {
+    return v8::Null(isolate);
+  }
+
+  const ui::mojom::TextInputState* text_input_state =
+      text_input_manager->GetTextInputState();
+  if (!text_input_state ||
+      text_input_state->type == ui::TEXT_INPUT_TYPE_NONE) {
+    return v8::Null(isolate);
+  }
+
+  const auto* region = text_input_manager->GetSelectionRegion(view);
+  if (!region)
+    return v8::Null(isolate);
+
+  gfx::Rect caret_bounds = RectFromSelectionBound(region->focus);
+  if (caret_bounds.IsEmpty())
+    caret_bounds = region->caret_rect;
+  if (caret_bounds.IsEmpty())
+    return v8::Null(isolate);
+
+  content::RenderFrameHost* render_frame_host =
+      GetRenderFrameHostForView(contents, view);
+  if (!render_frame_host)
+    return v8::Null(isolate);
+
+  auto details = gin_helper::Dictionary::CreateEmpty(isolate);
+  details.SetGetter("frame", render_frame_host);
+  details.Set("url", render_frame_host->GetLastCommittedURL().spec());
+  details.Set("isMainFrame", render_frame_host->GetParent() == nullptr);
+  details.Set("inputType",
+              std::string(TextInputTypeToString(text_input_state->type)));
+  details.Set("inputMode",
+              std::string(TextInputModeToString(text_input_state->mode)));
+  details.Set("inputAction",
+              std::string(TextInputActionToString(text_input_state->action)));
+
+  auto caret = gin_helper::Dictionary::CreateEmpty(isolate);
+  caret.Set("visible", region->focus.type() != gfx::SelectionBound::EMPTY);
+  caret.Set("bounds", caret_bounds);
+
+  content::RenderWidgetHostView* root_view =
+      contents->GetTopLevelRenderWidgetHostView();
+  if (root_view) {
+    gfx::Point screen_origin = caret_bounds.origin();
+    screen_origin += root_view->GetViewBounds().OffsetFromOrigin();
+    caret.Set("screenBounds", gfx::Rect(screen_origin, caret_bounds.size()));
+  }
+  details.Set("caret", caret);
+
+  if (text_input_state->selection.IsValid()) {
+    auto selection = gin_helper::Dictionary::CreateEmpty(isolate);
+    SetRangeDetails(&selection, text_input_state->selection);
+    details.Set("selection", selection);
+  }
+
+  const bool has_composition = text_input_state->composition &&
+                               text_input_state->composition->IsValid();
+  auto composition = gin_helper::Dictionary::CreateEmpty(isolate);
+  composition.Set("isComposing", has_composition);
+  if (has_composition) {
+    composition.Set(
+        "start", static_cast<uint32_t>(text_input_state->composition->start()));
+    composition.Set(
+        "end", static_cast<uint32_t>(text_input_state->composition->end()));
+  }
+  details.Set("composition", composition);
+
+  if (reason) {
+    details.Set("reason", std::string(*reason));
+  }
+
+  return details.GetHandle();
+}
