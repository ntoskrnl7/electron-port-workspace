+void WebContents::SetPrintRequestHandler(v8::Local<v8::Value> val,
+                                         gin::Arguments* args) {
+  if (val->IsNull()) {
+    print_request_handler_.reset();
+    return;
+  }
+
+  if (!val->IsFunction()) {
+    args->ThrowTypeError("Print request handler must be null or a function");
+    return;
+  }
+
+  print_request_handler_.emplace(args->isolate(), val);
+}
+
+void WebContents::RunPrintRequestHandler(
+    content::RenderFrameHost* rfh,
+    base::OnceCallback<void(bool)> callback) {
+  if (!print_request_handler_) {
+    std::move(callback).Run(true);
+    return;
+  }
+
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  gin_helper::Locker locker(isolate);
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Function> handler = print_request_handler_->NewHandle(isolate);
+  v8::Local<v8::Context> context = handler->GetCreationContextChecked(isolate);
+  v8::Context::Scope context_scope(context);
+
+  auto details = gin_helper::Dictionary::CreateEmpty(isolate);
+  details.SetGetter("frame", rfh);
+  details.Set("url", rfh->GetLastCommittedURL().spec());
+  details.Set("isMainFrame", rfh->GetParent() == nullptr);
+
+  auto callback_state = std::make_shared<PrintRequestHandlerState>(
+      rfh->GetGlobalId(), std::move(callback));
+  auto done = gin_helper::CreateFunctionFromTranslator(
+      isolate,
+      base::BindRepeating(
+          [](std::shared_ptr<PrintRequestHandlerState> callback_state,
+             gin::Arguments* args) {
+            if (!callback_state || callback_state->callback_called) {
+              args->ThrowTypeError("Print request callback was already called");
+              return;
+            }
+
+            callback_state->callback_called = true;
+
+            if (args->Length() == 0) {
+              if (callback_state->callback) {
+                std::move(callback_state->callback).Run(true);
+              } else {
+                args->ThrowTypeError(
+                    "Print request callback was called after the original "
+                    "print request was released; call request.handle(...) "
+                    "instead");
+              }
+              return;
+            }
+
+            v8::Local<v8::Value> value;
+            if (!args->GetNext(&value)) {
+              if (callback_state->callback) {
+                std::move(callback_state->callback).Run(true);
+              }
+              return;
+            }
+
+            if (value->IsBoolean() && !value.As<v8::Boolean>()->Value()) {
+              if (callback_state->callback) {
+                std::move(callback_state->callback).Run(false);
+              }
+              return;
+            }
+
+            if (value->IsFunction()) {
+              v8::Isolate* isolate = args->isolate();
+              gin_helper::Locker locker(isolate);
+              v8::HandleScope handle_scope(isolate);
+              auto context = isolate->GetCurrentContext();
+              auto prevent_default = std::make_shared<bool>(false);
+              auto* rfh =
+                  content::RenderFrameHost::FromID(callback_state->frame_id);
+              if (!rfh) {
+                if (callback_state->callback) {
+                  std::move(callback_state->callback).Run(false);
+                }
+                return;
+              }
+              v8::Local<v8::Object> request =
+                  CreatePrintRequestHandle(isolate, rfh, prevent_default);
+              v8::Local<v8::Value> argv[] = {request};
+              value.As<v8::Function>()
+                  ->Call(context, value, std::size(argv), argv)
+                  .IsEmpty();
+              if (callback_state->callback) {
+                std::move(callback_state->callback).Run(!*prevent_default);
+              }
+              return;
+            }
+
+            if (callback_state->callback) {
+              std::move(callback_state->callback).Run(true);
+            }
+          },
+          callback_state),
+      true);
+
+  v8::Local<v8::Value> argv[] = {details.GetHandle(), done};
+  if (handler->Call(context, handler, std::size(argv), argv).IsEmpty() &&
+      callback_state->callback) {
+    std::move(callback_state->callback).Run(true);
+    return;
+  }
+
+  if (callback_state->callback) {
+    std::move(callback_state->callback).Run(false);
+  }
+}
