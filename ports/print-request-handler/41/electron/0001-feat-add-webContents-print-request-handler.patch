+v8::Local<v8::Promise> PrintFrameToPDF(content::RenderFrameHost* rfh,
+                                       gin::Arguments* args) {
+  v8::Isolate* isolate = args->isolate();
+  gin_helper::Promise<v8::Local<v8::Value>> promise(isolate);
+  v8::Local<v8::Promise> handle = promise.GetHandle();
+
+  gin_helper::Dictionary options = gin_helper::Dictionary::CreateEmpty(isolate);
+  if (args->Length() >= 1 && !args->GetNext(&options)) {
+    promise.RejectWithErrorMessage("options must be an object when provided");
+    return handle;
+  }
+
+  std::optional<bool> landscape;
+  std::optional<bool> display_header_footer;
+  std::optional<bool> print_background;
+  std::optional<double> scale;
+  std::optional<double> paper_width;
+  std::optional<double> paper_height;
+  std::optional<double> margin_top;
+  std::optional<double> margin_bottom;
+  std::optional<double> margin_left;
+  std::optional<double> margin_right;
+  std::optional<std::string> header_template;
+  std::optional<std::string> footer_template;
+  std::optional<bool> prefer_css_page_size;
+  std::optional<bool> generate_tagged_pdf;
+  std::optional<bool> generate_document_outline;
+
+  options.GetOptional(kLandscape, &landscape);
+  options.GetOptional(kDisplayHeaderFooter, &display_header_footer);
+  options.GetOptional(kPrintBackground, &print_background);
+  options.GetOptional(kScale, &scale);
+  options.GetOptional(kPaperWidth, &paper_width);
+  options.GetOptional(kPaperHeight, &paper_height);
+  options.GetOptional(kMarginTop, &margin_top);
+  options.GetOptional(kMarginBottom, &margin_bottom);
+  options.GetOptional(kMarginLeft, &margin_left);
+  options.GetOptional(kMarginRight, &margin_right);
+  options.GetOptional(kHeaderTemplate, &header_template);
+  options.GetOptional(kFooterTemplate, &footer_template);
+  options.GetOptional(kPreferCSSPageSize, &prefer_css_page_size);
+  options.GetOptional(kGenerateTaggedPDF, &generate_tagged_pdf);
+  options.GetOptional(kGenerateDocumentOutline, &generate_document_outline);
+
+  absl::variant<printing::mojom::PrintPagesParamsPtr, std::string>
+      print_pages_params = print_to_pdf::GetPrintPagesParams(
+          rfh->GetLastCommittedURL(), landscape, display_header_footer,
+          print_background, scale, paper_width, paper_height, margin_top,
+          margin_bottom, margin_left, margin_right, header_template,
+          footer_template, prefer_css_page_size, generate_tagged_pdf,
+          generate_document_outline);
+
+  if (absl::holds_alternative<std::string>(print_pages_params)) {
+    promise.RejectWithErrorMessage("Invalid print parameters: " +
+                                   absl::get<std::string>(print_pages_params));
+    return handle;
+  }
+
+  std::string page_ranges;
+  options.Get(kPageRanges, &page_ranges);
+
+  auto* manager = PrintViewManagerElectron::FromWebContents(
+      content::WebContents::FromRenderFrameHost(rfh));
+  if (!manager) {
+    promise.RejectWithErrorMessage("Failed to find print manager");
+    return handle;
+  }
+
+  auto params = std::move(
+      absl::get<printing::mojom::PrintPagesParamsPtr>(print_pages_params));
+  manager->PrintToPdf(rfh, page_ranges, std::move(params),
+                      base::BindOnce(&OnPDFCreated, std::move(promise)));
+  return handle;
+}
+
+v8::Local<v8::Object> CreatePrintRequestHandle(
+    v8::Isolate* isolate,
+    content::RenderFrameHost* rfh,
+    std::shared_ptr<bool> prevent_default) {
+  auto request = gin_helper::Dictionary::CreateEmpty(isolate);
+  request.SetMethod("preventDefault",
+                    base::BindRepeating(
+                        [](std::shared_ptr<bool> prevent_default) {
+                          *prevent_default = true;
+                        },
+                        prevent_default));
+  request.SetMethod(
+      "_toPDF",
+      base::BindRepeating(
+          [](content::GlobalRenderFrameHostId rfh_id, gin::Arguments* args) {
+            auto* rfh = content::RenderFrameHost::FromID(rfh_id);
+            if (!rfh) {
+              gin_helper::Promise<v8::Local<v8::Value>> promise(
+                  args->isolate());
+              auto handle = promise.GetHandle();
