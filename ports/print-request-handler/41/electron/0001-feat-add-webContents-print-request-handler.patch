+      "_print",
+      base::BindRepeating(
+          [](content::GlobalRenderFrameHostId rfh_id, gin::Arguments* args) {
+            auto* rfh = content::RenderFrameHost::FromID(rfh_id);
+            if (!rfh) {
+              args->ThrowTypeError("Frame is no longer available");
+              return;
+            }
+
+            auto* api_web_contents = electron::api::WebContents::From(
+                content::WebContents::FromRenderFrameHost(rfh));
+            if (!api_web_contents) {
+              args->ThrowTypeError("Failed to find WebContents");
+              return;
+            }
