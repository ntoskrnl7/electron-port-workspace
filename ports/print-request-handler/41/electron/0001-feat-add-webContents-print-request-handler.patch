+
+interface NativePrintRequestHandlerJob {
+  preventDefault: () => void;
+  _toPDF: (options: any) => Promise<Buffer>;
+  _print: (options?: ElectronInternal.WebContentsPrintOptions, callback?: (success: boolean, failureReason?: string) => void) => void;
+}
+
+interface PrintRequestHandlerJob {
+  print: (options?: ElectronInternal.WebContentsPrintOptions) => Promise<void>;
+  toPDF: (options?: Electron.PrintToPDFOptions) => Promise<Buffer>;
+}
+
+interface PrintRequestHandlerRequest {
+  continue: () => void;
+  handle: (handler: (job: PrintRequestHandlerJob) => void | Promise<void>) => void;
+}
+
+const createPrintRequestHandlerJob = function (contents: Electron.WebContents, nativeJob: NativePrintRequestHandlerJob): PrintRequestHandlerJob {
+  return {
+    print: (options: ElectronInternal.WebContentsPrintOptions = {}) => {
+      return new Promise<void>((resolve, reject) => {
+        nativeJob._print(options, (success, failureReason) => {
+          if (success) {
+            resolve();
+          } else {
+            reject(new Error(failureReason || 'Print job failed'));
+          }
+        });
+      });
+    },
+    toPDF: (options = {}) => {
+      const printSettings = translatePrintToPDFOptions(options);
+      return queuePrintToPDF(contents, () => nativeJob._toPDF(printSettings));
+    }
+  };
+};
+
+WebContents.prototype.setPrintRequestHandler = function (handler) {
+  if (!this._setPrintRequestHandler) {
+    throw new Error('Printing feature is disabled');
+  }
+
+  if (handler === null) {
+    this._setPrintRequestHandler(null);
+    return;
+  }
+
+  if (typeof handler !== 'function') {
+    throw new TypeError('Print request handler must be null or a function');
+  }
+
+  this._setPrintRequestHandler((
+    details: Electron.PrintRequestHandlerDetails,
+    respond: (action?: ((job: NativePrintRequestHandlerJob) => void)) => void
+  ) => {
+    const request: PrintRequestHandlerRequest = {
+      continue: () => respond(),
+      handle: (handler: (job: PrintRequestHandlerJob) => void | Promise<void>) => {
+        if (typeof handler !== 'function') {
+          throw new TypeError('Print request handler must be a function');
+        }
+
+        respond(nativeJob => {
+          nativeJob.preventDefault();
+          const job = createPrintRequestHandlerJob(this, nativeJob);
+          Promise.resolve().then(() => handler(job));
+        });
+      }
+    };
+
+    handler(details, request);
+  });
+};
+
