+void AddHeader(network::mojom::WebSocketHandshakeResponsePtr& response,
+               std::string name,
+               std::string value) {
+  response->headers.push_back(network::mojom::HttpHeader::New(name, value));
+  base::StrAppend(&response->headers_text, {name, ": ", value, "\r\n"});
+}
