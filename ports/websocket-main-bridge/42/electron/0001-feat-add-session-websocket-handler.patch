+}
+
+bool WebSocketMain::EnsurePendingDecision(gin::Arguments* args) const {
+  if (destroyed_) {
+    args->ThrowTypeError("WebSocket has been destroyed");
+    return false;
+  }
+  if (decision_ != Decision::kPending) {
+    args->ThrowTypeError("WebSocket decision has already been made");
+    return false;
+  }
+  return true;
+}
+
+bool WebSocketMain::EnsureAccepted(gin::Arguments* args) const {
+  if (destroyed_) {
+    args->ThrowTypeError("WebSocket has been destroyed");
+    return false;
+  }
+  if (decision_ != Decision::kAccepted || !client_) {
+    args->ThrowTypeError("WebSocket is not open");
+    return false;
+  }
+  return true;
+}
+
+bool WebSocketMain::ParseOutgoingMessage(
+    gin::Arguments* args,
+    v8::Local<v8::Value> value,
+    network::mojom::WebSocketMessageType* type,
+    std::string* data) {
+  v8::Isolate* isolate = args->isolate();
+  if (value->IsString()) {
+    *type = network::mojom::WebSocketMessageType::TEXT;
+    return gin::ConvertFromV8(isolate, value, data);
+  }
+
+  if (node::Buffer::HasInstance(value)) {
+    *type = network::mojom::WebSocketMessageType::BINARY;
+    auto span = electron::Buffer::as_byte_span(value);
+    data->assign(reinterpret_cast<const char*>(span.data()), span.size());
+    return true;
+  }
+
+  gin_helper::Dictionary message;
+  if (!gin::ConvertFromV8(isolate, value, &message))
+    return false;
+
+  std::string message_type;
+  v8::Local<v8::Value> message_data;
+  if (!message.Get("type", &message_type) ||
+      !message.Get("data", &message_data)) {
+    return false;
+  }
+
+  *type = MessageTypeFromString(message_type);
+  if (*type == network::mojom::WebSocketMessageType::TEXT) {
+    return gin::ConvertFromV8(isolate, message_data, data);
+  }
+
+  if (!node::Buffer::HasInstance(message_data))
+    return false;
+  auto span = electron::Buffer::as_byte_span(message_data);
+  data->assign(reinterpret_cast<const char*>(span.data()), span.size());
+  return true;
+}
+
+void WebSocketMain::BindAcceptedConnection(
+    std::optional<std::string> protocol,
+    gin_helper::Dictionary response_headers) {
+  const MojoCreateDataPipeOptions data_pipe_options{
+      sizeof(MojoCreateDataPipeOptions), MOJO_CREATE_DATA_PIPE_FLAG_NONE, 1,
+      kWebSocketDataPipeCapacity};
+
+  mojo::ScopedDataPipeConsumerHandle readable;
+  MojoResult result = mojo::CreateDataPipe(&data_pipe_options,
+                                           browser_to_renderer_writable_,
+                                           readable);
+  if (result != MOJO_RESULT_OK) {
+    FailConnection("failed to create WebSocket data pipe");
+    return;
+  }
+
+  mojo::ScopedDataPipeProducerHandle writable;
+  result = mojo::CreateDataPipe(&data_pipe_options, writable,
+                                renderer_to_browser_readable_);
+  if (result != MOJO_RESULT_OK) {
+    FailConnection("failed to create WebSocket data pipe");
+    return;
+  }
+
+  writable_watcher_.Watch(
+      browser_to_renderer_writable_.get(), MOJO_HANDLE_SIGNAL_WRITABLE,
+      MOJO_WATCH_CONDITION_SATISFIED,
+      base::BindRepeating(&WebSocketMain::OnWritable, base::Unretained(this)));
+  readable_watcher_.Watch(
+      renderer_to_browser_readable_.get(), MOJO_HANDLE_SIGNAL_READABLE,
+      MOJO_WATCH_CONDITION_SATISFIED,
+      base::BindRepeating(&WebSocketMain::OnReadable, base::Unretained(this)));
+
+  decision_ = Decision::kAccepted;
+  auto response =
+      CreateHandshakeResponse(std::move(protocol), std::move(response_headers));
+  handshake_client_->OnConnectionEstablished(
+      receiver_as_websocket_.BindNewPipeAndPassRemote(),
+      client_.BindNewPipeAndPassReceiver(), std::move(response),
+      std::move(readable), std::move(writable));
+  handshake_client_.reset();
+
+  receiver_as_websocket_.set_disconnect_handler(
+      base::BindOnce(&WebSocketMain::Destroy, base::Unretained(this), true));
+  client_.set_disconnect_handler(
+      base::BindOnce(&WebSocketMain::Destroy, base::Unretained(this), true));
+}
+
+network::mojom::WebSocketHandshakeResponsePtr
+WebSocketMain::CreateHandshakeResponse(std::optional<std::string> protocol,
+                                       gin_helper::Dictionary response_headers) {
+  auto response = network::mojom::WebSocketHandshakeResponse::New();
+  response->url = url_;
+  response->http_version = net::HttpVersion(1, 1);
+  response->status_code = 101;
+  response->status_text = "Switching Protocols";
+  response->headers_text = "HTTP/1.1 101 Switching Protocols\r\n";
+  response->selected_protocol = protocol.value_or("");
+
+  AddHeader(response, "Upgrade", "websocket");
+  AddHeader(response, "Connection", "Upgrade");
+  if (protocol && !protocol->empty())
+    AddHeader(response, "Sec-WebSocket-Protocol", *protocol);
+
+  v8::Isolate* isolate = response_headers.isolate();
+  v8::Local<v8::Context> context = isolate->GetCurrentContext();
+  v8::Local<v8::Array> names;
+  if (response_headers.GetHandle()
+          ->GetOwnPropertyNames(context)
+          .ToLocal(&names)) {
+    for (uint32_t i = 0; i < names->Length(); ++i) {
+      v8::Local<v8::Value> key;
+      if (!names->Get(context, i).ToLocal(&key))
+        continue;
+      std::string name;
+      if (!gin::ConvertFromV8(isolate, key, &name))
+        continue;
+      v8::Local<v8::Value> value;
+      if (!response_headers.GetHandle()->Get(context, key).ToLocal(&value))
+        continue;
+      std::vector<std::string> values;
+      if (gin::ConvertFromV8(isolate, value, &values)) {
+        for (auto& header_value : values)
+          AddHeader(response, name, std::move(header_value));
+        continue;
+      }
+      std::string header_value;
+      if (gin::ConvertFromV8(isolate, value, &header_value))
+        AddHeader(response, name, std::move(header_value));
+    }
+  }
+
+  response->headers_text.append("\r\n");
+  return response;
+}
+
+void WebSocketMain::StartRawNetworkConnection() {
+  decision_ = Decision::kContinued;
+
+  std::move(continue_callback_).Run(handshake_client_.Unbind());
+  Destroy(false);
+}
+
+void WebSocketMain::FailConnection(const std::string& reason) {
+  if (destroyed_)
+    return;
+  if (decision_ == Decision::kPending && handshake_client_) {
+    decision_ = Decision::kFailed;
+    handshake_client_->OnFailure(reason, net::ERR_FAILED, -1);
+    Destroy(false);
+    return;
+  }
+  if (decision_ == Decision::kAccepted && client_) {
+    client_->OnDropChannel(false, net::kWebSocketErrorAbnormalClosure, reason);
+    Destroy(true);
+  }
+}
+
+void WebSocketMain::Destroy(bool emit_close) {
+  if (destroyed_)
+    return;
+
+  destroyed_ = true;
+  writable_watcher_.Cancel();
+  readable_watcher_.Cancel();
+  receiver_as_websocket_.reset();
+  client_.reset();
+  handshake_client_.reset();
+  browser_to_renderer_writable_.reset();
+  renderer_to_browser_readable_.reset();
+  RejectPendingSends("WebSocket has been destroyed");
+  if (emit_close) {
+    v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+    v8::HandleScope handle_scope(isolate);
+    gin_helper::Dictionary details =
+        gin_helper::Dictionary::CreateEmpty(isolate);
+    details.Set("code", static_cast<int>(net::kWebSocketErrorGoingAway));
+    details.Set("reason", "");
+    details.Set("wasClean", false);
+    EmitWithoutEvent("close", details);
+  }
+  Unpin();
+}
+
+void WebSocketMain::RejectPendingSends(const std::string& message) {
+  while (!outgoing_messages_.empty()) {
+    auto outgoing = std::move(outgoing_messages_.front());
+    outgoing_messages_.pop_front();
+    outgoing.promise.RejectWithErrorMessage(message);
+  }
+  buffered_amount_ = 0;
+}
+
+void WebSocketMain::SendMessage(network::mojom::WebSocketMessageType type,
+                                uint64_t data_length) {
+  if (destroyed_ || decision_ != Decision::kAccepted)
+    return;
+  if (type == network::mojom::WebSocketMessageType::CONTINUATION) {
+    FailConnection("WebSocket continuation frames are not supported");
+    return;
+  }
+  incoming_frames_.push_back({type, data_length, std::string()});
+  ProcessIncomingFrames();
+}
+
+void WebSocketMain::StartReceiving() {
+  ProcessIncomingFrames();
+}
+
+void WebSocketMain::StartClosingHandshake(uint16_t code,
+                                          const std::string& reason) {
+  if (destroyed_)
+    return;
+
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  gin_helper::Dictionary details =
+      gin_helper::Dictionary::CreateEmpty(isolate);
+  details.Set("code", static_cast<int>(code));
+  details.Set("reason", reason);
+  details.Set("wasClean", true);
+  EmitWithoutEvent("close", details);
+
+  if (client_)
+    client_->OnDropChannel(true, code, reason);
+  Destroy(false);
+}
+
+void WebSocketMain::ProcessIncomingFrames() {
+  if (destroyed_ || paused_ || !renderer_to_browser_readable_.is_valid())
+    return;
+
+  while (true) {
+    if (!current_incoming_frame_) {
+      if (incoming_frames_.empty())
+        return;
+      current_incoming_frame_ = std::move(incoming_frames_.front());
+      incoming_frames_.pop_front();
+      if (current_incoming_frame_->data_length >
+          std::numeric_limits<uint32_t>::max()) {
+        FailConnection("WebSocket message is too large");
+        return;
+      }
+      current_incoming_frame_->data.reserve(
+          static_cast<size_t>(current_incoming_frame_->data_length));
+    }
+
+    auto& frame = *current_incoming_frame_;
+    if (frame.data.size() == frame.data_length) {
+      EmitIncomingMessage(frame);
+      current_incoming_frame_.reset();
+      continue;
+    }
+
+    base::span<const uint8_t> read_buffer;
+    MojoResult result = renderer_to_browser_readable_->BeginReadData(
+        MOJO_READ_DATA_FLAG_NONE, read_buffer);
+    if (result == MOJO_RESULT_SHOULD_WAIT) {
+      readable_watcher_.ArmOrNotify();
+      return;
+    }
+    if (result != MOJO_RESULT_OK) {
+      FailConnection("failed to read WebSocket message");
+      return;
+    }
+    size_t num_bytes = std::min<size_t>(
+        frame.data_length - frame.data.size(), read_buffer.size());
+    frame.data.append(reinterpret_cast<const char*>(read_buffer.data()),
+                      num_bytes);
+    renderer_to_browser_readable_->EndReadData(num_bytes);
+  }
+}
+
+void WebSocketMain::OnReadable(MojoResult result,
+                               const mojo::HandleSignalsState& state) {
+  if (result != MOJO_RESULT_OK) {
+    Destroy(true);
+    return;
+  }
+  ProcessIncomingFrames();
+}
+
+void WebSocketMain::EmitIncomingMessage(const PendingIncomingFrame& frame) {
+  v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+  v8::HandleScope handle_scope(isolate);
+  gin_helper::Dictionary message = gin_helper::Dictionary::CreateEmpty(isolate);
+  message.Set("type", MessageTypeToString(frame.type));
+  if (frame.type == network::mojom::WebSocketMessageType::BINARY) {
+    auto buffer =
+        electron::Buffer::Copy(isolate, base::as_byte_span(frame.data))
+            .ToLocalChecked();
+    message.Set("data", buffer);
+  } else {
+    message.Set("data", frame.data);
+  }
+  EmitWithoutEvent("message", message);
+}
+
+void WebSocketMain::ProcessOutgoingMessages() {
+  if (destroyed_ || decision_ != Decision::kAccepted || !client_ ||
+      !browser_to_renderer_writable_.is_valid()) {
+    return;
+  }
+
+  while (!outgoing_messages_.empty()) {
+    auto& outgoing = outgoing_messages_.front();
+    while (outgoing.offset < outgoing.data.size()) {
+      base::span<uint8_t> write_buffer;
+      MojoResult result = browser_to_renderer_writable_->BeginWriteData(
+          outgoing.data.size() - outgoing.offset, MOJO_WRITE_DATA_FLAG_NONE,
+          write_buffer);
+      if (result == MOJO_RESULT_SHOULD_WAIT) {
+        writable_watcher_.ArmOrNotify();
+        return;
+      }
+      if (result != MOJO_RESULT_OK) {
+        Destroy(true);
+        return;
+      }
+      size_t num_bytes =
+          std::min(write_buffer.size(), outgoing.data.size() - outgoing.offset);
+      std::string_view remaining(outgoing.data);
+      remaining.remove_prefix(outgoing.offset);
+      write_buffer.first(num_bytes).copy_from(
+          base::as_byte_span(remaining.substr(0, num_bytes)));
+      browser_to_renderer_writable_->EndWriteData(num_bytes);
+      outgoing.offset += num_bytes;
+      buffered_amount_ -= num_bytes;
+    }
+
+    auto complete = std::move(outgoing_messages_.front());
+    outgoing_messages_.pop_front();
+    client_->OnDataFrame(true, complete.type, complete.data.size());
+    complete.promise.Resolve();
+  }
+}
+
+void WebSocketMain::OnWritable(MojoResult result,
+                               const mojo::HandleSignalsState& state) {
+  if (result != MOJO_RESULT_OK) {
+    Destroy(true);
+    return;
+  }
+  ProcessOutgoingMessages();
+}
+
+}  // namespace electron::api
