+
+void WebSocketMain::Accept(gin::Arguments* args) {
+  if (!EnsurePendingDecision(args))
+    return;
+
+  v8::Local<v8::Value> value;
+  std::optional<std::string> protocol;
+  gin_helper::Dictionary response_headers =
+      gin_helper::Dictionary::CreateEmpty(args->isolate());
+  if (args->GetNext(&value) && !value->IsNullOrUndefined()) {
+    gin_helper::Dictionary options;
+    if (!gin::ConvertFromV8(args->isolate(), value, &options)) {
+      args->ThrowTypeError("accept options must be an object");
+      return;
+    }
+    options.GetOptional("protocol", &protocol);
+    v8::Local<v8::Value> headers_value;
+    if (options.Get("responseHeaders", &headers_value) &&
+        !headers_value->IsNullOrUndefined() &&
+        !gin::ConvertFromV8(args->isolate(), headers_value,
+                            &response_headers)) {
+      args->ThrowTypeError("responseHeaders must be an object");
+      return;
+    }
+  }
+
+  if (protocol && !protocol->empty() &&
+      !std::ranges::contains(requested_protocols_, *protocol)) {
+    args->ThrowTypeError("protocol was not requested by the renderer");
+    return;
+  }
+
+  BindAcceptedConnection(std::move(protocol), std::move(response_headers));
+}
+
+void WebSocketMain::Fail(gin::Arguments* args) {
+  if (destroyed_)
+    return;
+
+  std::string reason = "WebSocket connection was rejected";
+  args->GetNext(&reason);
+
+  FailConnection(reason);
+}
+
+void WebSocketMain::Close(gin::Arguments* args) {
+  if (!EnsureAccepted(args))
+    return;
+
+  int code = 1000;
+  std::string reason;
+  args->GetNext(&code);
+  args->GetNext(&reason);
+  if (code < 0 || code > std::numeric_limits<uint16_t>::max() ||
+      !IsAcceptedStatusCode(static_cast<uint16_t>(code))) {
+    args->ThrowTypeError("invalid WebSocket close code");
+    return;
+  }
+  client_->OnDropChannel(true, static_cast<uint16_t>(code), reason);
+  Destroy(true);
+}
+
+v8::Local<v8::Promise> WebSocketMain::Send(gin::Arguments* args) {
+  v8::Isolate* isolate = args->isolate();
+  gin_helper::Promise<void> promise(isolate);
+  v8::Local<v8::Promise> handle = promise.GetHandle();
+
+  if (destroyed_ || decision_ != Decision::kAccepted || !client_) {
+    promise.RejectWithErrorMessage("WebSocket is not open");
+    return handle;
+  }
+
+  v8::Local<v8::Value> value;
+  if (!args->GetNext(&value)) {
+    promise.RejectWithErrorMessage("message is required");
+    return handle;
+  }
+
+  network::mojom::WebSocketMessageType type;
+  std::string data;
+  if (!ParseOutgoingMessage(args, value, &type, &data)) {
+    promise.RejectWithErrorMessage("invalid WebSocket message");
+    return handle;
+  }
+
+  if (buffered_amount_ + data.size() > kMaxBufferedAmount) {
+    promise.RejectWithErrorMessage("WebSocket send queue limit exceeded");
+    return handle;
+  }
+
+  buffered_amount_ += data.size();
+  outgoing_messages_.emplace_back(type, std::move(data), std::move(promise));
+  ProcessOutgoingMessages();
+  return handle;
+}
