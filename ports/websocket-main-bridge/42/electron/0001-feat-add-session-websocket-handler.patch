+class WebSocket final : public gin::Wrappable<WebSocket> {
+ public:
+  using WebSocketCreatorInfo =
+      content::ContentBrowserClient::WebSocketCreatorInfo;
+  using WebSocketFactory = content::ContentBrowserClient::WebSocketFactory;
+  using ContinueCallback = base::OnceCallback<void(
+      mojo::PendingRemote<network::mojom::WebSocketHandshakeClient>)>;
+
+  static WebSocket* FromOrCreate(v8::Isolate* isolate,
+                                 content::BrowserContext* browser_context);
+  static WebSocket* Create(v8::Isolate* isolate, base::PassKey<Session>);
+
+  explicit WebSocket(base::PassKey<Session>);
+  ~WebSocket() override;
+
+  static const char* GetClassName() { return "WebSocket"; }
+
+  static const gin::WrapperInfo kWrapperInfo;
+  void Trace(cppgc::Visitor*) const override;
+  const gin::WrapperInfo* wrapper_info() const override;
+  const char* GetHumanReadableName() const override;
+  gin::ObjectTemplateBuilder GetObjectTemplateBuilder(
+      v8::Isolate* isolate) override;
+
+  void SetHandler(gin::Arguments* args);
+  bool HasHandler() const;
+  bool MatchesURL(const GURL& url) const;
+  bool HandleConnection(
+      v8::Isolate* isolate,
+      content::BrowserContext* browser_context,
+      const WebSocketCreatorInfo& creator_info,
+      const std::vector<std::string>& requested_protocols,
+      ContinueCallback continue_callback,
+      const GURL& url,
+      const net::SiteForCookies& site_for_cookies,
+      const std::optional<std::string>& user_agent,
+      mojo::PendingRemote<network::mojom::WebSocketHandshakeClient>
+          handshake_client);
+
+ private:
+  using Handler = base::RepeatingCallback<void(v8::Local<v8::Value>)>;
+
+  class RequestFilter {
+   public:
+    RequestFilter();
+    RequestFilter(const RequestFilter&);
+    ~RequestFilter();
+
+    void AddUrlPattern(URLPattern pattern, bool is_match_pattern);
+    void AddUrlPatterns(const std::set<std::string>& filter_patterns,
+                        RequestFilter* filter,
+                        gin::Arguments* args,
+                        bool is_match_pattern = true);
+    bool MatchesURL(const GURL& url) const;
+
+   private:
+    bool MatchesURLSet(const GURL& url,
+                       const std::set<URLPattern>& patterns) const;
+
+    std::set<URLPattern> include_url_patterns_;
+    std::set<URLPattern> exclude_url_patterns_;
+  };
+
+  struct HandlerInfo {
+    HandlerInfo(RequestFilter filter, Handler handler);
+    HandlerInfo(HandlerInfo&&);
+    HandlerInfo& operator=(HandlerInfo&&);
+    ~HandlerInfo();
+
+    RequestFilter filter;
+    Handler handler;
+  };
+
+  std::optional<HandlerInfo> handler_info_;
+  uint64_t next_connection_id_ = 0;
+
+  gin::WeakCellFactory<WebSocket> weak_factory_{this};
+};
