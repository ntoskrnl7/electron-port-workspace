+std::string WebSocketMain::CreatorType() const {
+  switch (creator_info_.type) {
+    case WebSocketCreatorInfo::Type::kFrame:
+      return "frame";
+    case WebSocketCreatorInfo::Type::kDedicatedWorker:
+      return "dedicated-worker";
+    case WebSocketCreatorInfo::Type::kSharedWorker:
+      return "shared-worker";
+    case WebSocketCreatorInfo::Type::kServiceWorker:
+      return "service-worker";
+    case WebSocketCreatorInfo::Type::kUnknown:
+      return "unknown";
+  }
+}
+
+v8::Local<v8::Value> WebSocketMain::Creator(v8::Isolate* isolate) const {
+  if (destroyed_)
+    return v8::Null(isolate);
+
+  switch (creator_info_.type) {
+    case WebSocketCreatorInfo::Type::kFrame: {
+      auto* frame = content::RenderFrameHost::FromID(creator_info_.frame_id);
+      auto handle = WebFrameMain::From(isolate, frame);
+      return handle.IsEmpty() ? v8::Null(isolate) : handle.ToV8();
+    }
+    case WebSocketCreatorInfo::Type::kDedicatedWorker:
+      if (creator_info_.dedicated_worker_token) {
+        auto handle = DedicatedWorkerMain::FromToken(
+            isolate, *creator_info_.dedicated_worker_token);
+        return handle.IsEmpty() ? v8::Null(isolate) : handle.ToV8();
+      }
+      return v8::Null(isolate);
+    case WebSocketCreatorInfo::Type::kSharedWorker:
+      if (creator_info_.shared_worker_token) {
+        auto handle = SharedWorkerMain::FromToken(
+            isolate, *creator_info_.shared_worker_token);
+        return handle.IsEmpty() ? v8::Null(isolate) : handle.ToV8();
+      }
+      return v8::Null(isolate);
+    case WebSocketCreatorInfo::Type::kServiceWorker: {
+      if (!browser_context_ || creator_info_.service_worker_version_id < 0)
+        return v8::Null(isolate);
+      auto* session = Session::FromOrCreate(isolate, browser_context_);
+      if (!session)
+        return v8::Null(isolate);
+      auto handle = session->ServiceWorkerContext()
+                        ->GetWorkerFromVersionIDIfExists(
+                            isolate, creator_info_.service_worker_version_id);
+      return handle.IsEmpty() ? v8::Null(isolate) : handle.ToV8();
+    }
+    case WebSocketCreatorInfo::Type::kUnknown:
+      return v8::Null(isolate);
+  }
+}
