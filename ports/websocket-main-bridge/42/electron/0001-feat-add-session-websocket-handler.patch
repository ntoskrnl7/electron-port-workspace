+#include "shell/common/gin_helper/handle.h"
+#include "shell/common/node_util.h"
+#include "url/gurl.h"
+
+namespace electron::api {
+
+const gin::WrapperInfo WebSocket::kWrapperInfo = {{gin::kEmbedderNativeGin},
+                                                  gin::kElectronWebSocket};
+
+WebSocket::RequestFilter::RequestFilter() = default;
+WebSocket::RequestFilter::RequestFilter(const RequestFilter&) = default;
+WebSocket::RequestFilter::~RequestFilter() = default;
+
+WebSocket::HandlerInfo::HandlerInfo(RequestFilter filter, Handler handler)
+    : filter(std::move(filter)), handler(std::move(handler)) {}
+WebSocket::HandlerInfo::HandlerInfo(HandlerInfo&&) = default;
+WebSocket::HandlerInfo& WebSocket::HandlerInfo::operator=(HandlerInfo&&) =
+    default;
+WebSocket::HandlerInfo::~HandlerInfo() = default;
+
+void WebSocket::RequestFilter::AddUrlPattern(URLPattern pattern,
+                                             bool is_match_pattern) {
+  if (is_match_pattern) {
+    include_url_patterns_.emplace(std::move(pattern));
+  } else {
+    exclude_url_patterns_.emplace(std::move(pattern));
+  }
+}
+
+void WebSocket::RequestFilter::AddUrlPatterns(
+    const std::set<std::string>& filter_patterns,
+    RequestFilter* filter,
+    gin::Arguments* args,
+    bool is_match_pattern) {
+  for (const std::string& filter_pattern : filter_patterns) {
+    URLPattern pattern(URLPattern::SCHEME_ALL);
+    const URLPattern::ParseResult result = pattern.Parse(filter_pattern);
+    if (result == URLPattern::ParseResult::kSuccess) {
+      filter->AddUrlPattern(std::move(pattern), is_match_pattern);
+    } else {
+      const char* error_type = URLPattern::GetParseResultString(result);
+      args->ThrowTypeError("Invalid url pattern " + filter_pattern + ": " +
+                           error_type);
+      return;
+    }
+  }
+}
+
+bool WebSocket::RequestFilter::MatchesURLSet(
+    const GURL& url,
+    const std::set<URLPattern>& patterns) const {
+  if (patterns.empty())
+    return false;
+
+  for (const auto& pattern : patterns) {
+    if (pattern.MatchesURL(url))
+      return true;
+  }
+  return false;
+}
+
+bool WebSocket::RequestFilter::MatchesURL(const GURL& url) const {
+  return MatchesURLSet(url, include_url_patterns_) &&
+         !MatchesURLSet(url, exclude_url_patterns_);
+}
+
+WebSocket::WebSocket(base::PassKey<Session>) {}
+
+WebSocket::~WebSocket() = default;
+
+gin::ObjectTemplateBuilder WebSocket::GetObjectTemplateBuilder(
+    v8::Isolate* isolate) {
+  return gin::ObjectTemplateBuilder(isolate, GetClassName())
+      .SetMethod("setHandler", &WebSocket::SetHandler);
+}
+
+void WebSocket::Trace(cppgc::Visitor* visitor) const {
+  gin::Wrappable<WebSocket>::Trace(visitor);
+  visitor->Trace(weak_factory_);
+}
+
+const gin::WrapperInfo* WebSocket::wrapper_info() const {
+  return &kWrapperInfo;
+}
+
+const char* WebSocket::GetHumanReadableName() const {
+  return "Electron / WebSocket";
+}
+
+void WebSocket::SetHandler(gin::Arguments* args) {
+  v8::Local<v8::Value> arg;
+  std::set<std::string> include_patterns;
+  std::set<std::string> exclude_patterns;
+  RequestFilter filter;
+
+  gin::Dictionary dict(args->isolate());
+  if (args->GetNext(&arg) && !arg->IsFunction() && !arg->IsNull()) {
+    if (!gin::ConvertFromV8(args->isolate(), arg, &dict)) {
+      args->ThrowTypeError("filter must be an object");
+      return;
+    }
+    if (!dict.Get("urls", &include_patterns)) {
+      args->ThrowTypeError("Parameter 'filter' must have property 'urls'.");
+      return;
+    }
+    if (include_patterns.empty())
+      include_patterns.insert("<all_urls>");
+    dict.Get("excludeUrls", &exclude_patterns);
+    args->GetNext(&arg);
+  } else {
+    include_patterns.insert("<all_urls>");
+  }
+
+  filter.AddUrlPatterns(include_patterns, &filter, args);
+  filter.AddUrlPatterns(exclude_patterns, &filter, args, false);
+  if (args->isolate()->IsExecutionTerminating())
+    return;
+
+  Handler handler;
+  if (arg.IsEmpty() ||
+      !(gin::ConvertFromV8(args->isolate(), arg, &handler) || arg->IsNull())) {
+    args->ThrowTypeError("Must pass null or a Function");
+    return;
+  }
+
+  if (handler.is_null()) {
+    handler_info_.reset();
+  } else {
+    handler_info_ = HandlerInfo{std::move(filter), std::move(handler)};
+  }
+}
+
+bool WebSocket::HasHandler() const {
+  return handler_info_.has_value() && !handler_info_->handler.is_null();
+}
+
+bool WebSocket::MatchesURL(const GURL& url) const {
+  return HasHandler() && handler_info_->filter.MatchesURL(url);
+}
+
+bool WebSocket::HandleConnection(
+    v8::Isolate* isolate,
+    content::BrowserContext* browser_context,
+    const WebSocketCreatorInfo& creator_info,
+    const std::vector<std::string>& requested_protocols,
+    ContinueCallback continue_callback,
+    const GURL& url,
+    const net::SiteForCookies& site_for_cookies,
+    const std::optional<std::string>& user_agent,
+    mojo::PendingRemote<network::mojom::WebSocketHandshakeClient>
+        handshake_client) {
+  if (!MatchesURL(url))
+    return false;
+
+  v8::HandleScope handle_scope(isolate);
+  auto web_socket = WebSocketMain::Create(
+      isolate, base::NumberToString(++next_connection_id_), browser_context,
+      creator_info, std::move(continue_callback), url, requested_protocols,
+      site_for_cookies, user_agent, std::move(handshake_client));
+  if (web_socket.IsEmpty())
+    return false;
+
+  handler_info_->handler.Run(web_socket.ToV8());
+  return true;
+}
+
+// static
+WebSocket* WebSocket::FromOrCreate(v8::Isolate* isolate,
+                                   content::BrowserContext* browser_context) {
+  return Session::FromOrCreate(isolate, browser_context)->WebSocket(isolate);
+}
+
+// static
+WebSocket* WebSocket::Create(v8::Isolate* isolate,
+                             base::PassKey<Session> passkey) {
+  return cppgc::MakeGarbageCollected<WebSocket>(
+      isolate->GetCppHeap()->GetAllocationHandle(), std::move(passkey));
+}
+
+}  // namespace electron::api
