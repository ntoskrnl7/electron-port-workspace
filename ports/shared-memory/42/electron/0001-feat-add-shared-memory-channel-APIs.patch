+            ],
+            overflow: 'allocate'
+          }
+        });
+        const before = SharedMemory.getPoolStats(pool);
+        const first = SharedMemory.withAllocator(pool, () => {
+          const out = new Uint8Array(1500);
+          out[0] = 31;
+          out[1499] = 15;
+          return out.buffer;
+        }, { channel });
+        const firstDescriptor = SharedMemory.describe(first);
+        const firstSent = channel.send(first, 10);
+        const afterFirst = SharedMemory.getPoolStats(pool);
+        const second = SharedMemory.withAllocator(pool, () => {
+          const out = new Uint8Array(1400);
+          out[0] = 41;
+          out[1399] = 14;
+          return out.buffer;
+        }, { channel });
+        const secondDescriptor = SharedMemory.describe(second);
+        const secondSent = channel.send(second, 11);
