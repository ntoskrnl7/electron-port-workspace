+namespace electron::api::shared_memory {
+
+namespace {
+
+constexpr char kPoolIdKey[] = "id";
+constexpr char kPoolSizeKey[] = "size";
+constexpr char kPoolMaxAllocationSizeKey[] = "maxAllocationSize";
+constexpr char kDescriptorPoolIdKey[] = "poolId";
+constexpr char kDescriptorOffsetKey[] = "offset";
+constexpr char kDescriptorByteLengthKey[] = "byteLength";
+constexpr char kRingSlotSizeKey[] = "slotSize";
+constexpr char kRingSlotCountKey[] = "slotCount";
+constexpr char kRingMaxMetadataSizeKey[] = "maxTagSize";
+constexpr uint32_t kRingMagic = 0x5242534d;  // RBSM
+constexpr uint32_t kRingVersion = 1;
+constexpr uint32_t kSlotFree = 0;
+constexpr uint32_t kSlotReady = 1;
+constexpr uint32_t kSlotReading = 2;
+
+struct Pool {
+  Pool(base::UnsafeSharedMemoryRegion region,
+       uint64_t size,
+       uint64_t max_allocation_size)
+      : region(std::move(region)),
+        size(size),
+        max_allocation_size(max_allocation_size) {}
+
+  base::UnsafeSharedMemoryRegion region;
+  uint64_t size = 0;
+  uint64_t max_allocation_size = 0;
+  std::atomic<uint64_t> next_offset{0};
+  std::atomic<uint64_t> allocation_count{0};
+};
+
+using PoolMap = std::map<std::string, std::unique_ptr<Pool>>;
+
+struct RingHeader {
+  uint32_t magic = kRingMagic;
+  uint32_t version = kRingVersion;
+  uint32_t slot_size = 0;
+  uint32_t slot_count = 0;
+  uint32_t max_metadata_size = 0;
+  uint32_t reserved = 0;
+  std::atomic<uint64_t> write_sequence{0};
+  std::atomic<uint64_t> read_sequence{0};
+  std::atomic<uint64_t> dropped_count{0};
+};
+
+struct SlotHeader {
+  std::atomic<uint32_t> state{kSlotFree};
+  uint32_t byte_length = 0;
+  uint32_t metadata_length = 0;
+  uint32_t reserved = 0;
+  uint64_t sequence = 0;
+};
+
+struct RingMapping {
+  std::string key;
+  std::string pool_id;
+  uint64_t offset = 0;
+  uint64_t byte_length = 0;
+  uint32_t slot_size = 0;
+  uint32_t slot_count = 0;
+  uint32_t max_metadata_size = 0;
+  base::WritableSharedMemoryMapping mapping;
+};
+
+using RingMap = std::map<std::string, std::shared_ptr<RingMapping>>;
+
+base::Lock& GetPoolMapLock() {
+  static base::NoDestructor<base::Lock> lock;
+  return *lock;
+}
+
+PoolMap& GetPoolMap() {
+  static base::NoDestructor<PoolMap> pools;
+  return *pools;
+}
+
+base::Lock& GetRingMapLock() {
+  static base::NoDestructor<base::Lock> lock;
+  return *lock;
+}
+
+RingMap& GetRingMap() {
+  static base::NoDestructor<RingMap> rings;
+  return *rings;
+}
+
+uint64_t AlignAllocationSize(uint64_t size) {
+  return (size + 7u) & ~uint64_t{7u};
+}
+
+bool ParsePool(const gin_helper::Dictionary& pool,
+               std::string* id,
+               uint64_t* size,
+               uint64_t* max_allocation_size) {
+  if (!pool.Get(kPoolIdKey, id) || !pool.Get(kPoolSizeKey, size) ||
+      !pool.Get(kPoolMaxAllocationSizeKey, max_allocation_size)) {
+    return false;
+  }
+  return !id->empty() && *size > 0 && *max_allocation_size > 0;
+}
+
+bool ParseDescriptor(const gin_helper::Dictionary& descriptor,
+                     std::string* pool_id,
+                     uint64_t* offset,
+                     uint64_t* byte_length) {
+  if (!descriptor.Get(kDescriptorPoolIdKey, pool_id) ||
+      !descriptor.Get(kDescriptorOffsetKey, offset) ||
+      !descriptor.Get(kDescriptorByteLengthKey, byte_length)) {
+    return false;
+  }
+  return !pool_id->empty() && *byte_length > 0;
+}
+
+bool ParseRingDescriptor(const gin_helper::Dictionary& descriptor,
+                         std::string* pool_id,
+                         uint64_t* offset,
+                         uint64_t* byte_length,
+                         uint32_t* slot_size,
+                         uint32_t* slot_count,
+                         uint32_t* max_metadata_size) {
+  if (!ParseDescriptor(descriptor, pool_id, offset, byte_length) ||
+      !descriptor.Get(kRingSlotSizeKey, slot_size) ||
+      !descriptor.Get(kRingSlotCountKey, slot_count) ||
+      !descriptor.Get(kRingMaxMetadataSizeKey, max_metadata_size)) {
+    return false;
+  }
+  return *slot_size > 0 && *slot_count > 0;
+}
+
+std::string RingKey(const std::string& pool_id,
+                    uint64_t offset,
+                    uint64_t byte_length) {
+  std::ostringstream key;
+  key << pool_id << ':' << offset << ':' << byte_length;
+  return key.str();
+}
+
+uint64_t AlignToEight(uint64_t value) {
+  return (value + 7u) & ~uint64_t{7u};
+}
+
+bool CheckedAdd(uint64_t lhs, uint64_t rhs, uint64_t* out) {
+  if (lhs > std::numeric_limits<uint64_t>::max() - rhs)
+    return false;
+  *out = lhs + rhs;
+  return true;
+}
+
+bool CalculateRingByteLength(uint32_t slot_size,
+                             uint32_t slot_count,
+                             uint32_t max_metadata_size,
+                             uint64_t* byte_length) {
+  uint64_t slot_stride = 0;
+  if (!CheckedAdd(sizeof(SlotHeader), max_metadata_size, &slot_stride) ||
+      !CheckedAdd(slot_stride, slot_size, &slot_stride)) {
+    return false;
+  }
+  slot_stride = AlignToEight(slot_stride);
+  if (slot_count >
+      std::numeric_limits<uint64_t>::max() / slot_stride) {
+    return false;
+  }
+  uint64_t slots_size = slot_stride * slot_count;
+  return CheckedAdd(AlignToEight(sizeof(RingHeader)), slots_size, byte_length);
+}
+
+Pool* FindPool(const std::string& pool_id) {
+  base::AutoLock lock(GetPoolMapLock());
+  auto it = GetPoolMap().find(pool_id);
+  if (it == GetPoolMap().end())
+    return nullptr;
+  return it->second.get();
+}
+
+bool PoolMatches(const Pool* pool,
+                 uint64_t pool_size,
+                 uint64_t max_allocation_size) {
+  return pool && pool->size == pool_size &&
+         pool->max_allocation_size == max_allocation_size;
+}
+
+bool ReservePoolBytes(Pool* pool, uint64_t byte_length, uint64_t* offset) {
+  if (byte_length == 0 || byte_length > std::numeric_limits<uint64_t>::max() - 7u)
+    return false;
+  const uint64_t aligned_size = AlignAllocationSize(byte_length);
+
+  if (!pool)
+    return false;
+
+  uint64_t current = pool->next_offset.load(std::memory_order_relaxed);
+  for (;;) {
+    if (current > pool->size || aligned_size > pool->size - current)
+      return false;
+
+    if (pool->next_offset.compare_exchange_weak(
+            current, current + aligned_size, std::memory_order_acq_rel,
+            std::memory_order_relaxed)) {
+      *offset = current;
+      pool->allocation_count.fetch_add(1, std::memory_order_relaxed);
+      return true;
+    }
+  }
+}
+
+v8::Local<v8::ArrayBuffer> MapRegionToArrayBuffer(
+    v8::Isolate* isolate,
+    const base::UnsafeSharedMemoryRegion& region,
+    uint64_t offset,
+    uint64_t size) {
+  if (!region.IsValid() || size == 0 || offset > region.GetSize() ||
+      size > region.GetSize() - offset) {
+    return {};
+  }
+
+  base::WritableSharedMemoryMapping mapping =
+      region.MapAt(offset, base::checked_cast<size_t>(size),
+                   gin::GetSharedMemoryMapperForArrayBuffers());
+  if (!mapping.IsValid())
+    return {};
+
+  auto* mapping_ptr = new base::WritableSharedMemoryMapping(std::move(mapping));
+  size_t mapping_size = mapping_ptr->size();
+  auto* data = mapping_ptr->data();
+
+  auto backing_store = v8::ArrayBuffer::NewBackingStore(
+      data, mapping_size,
+      [](void*, size_t, void* arg) {
+        delete static_cast<base::WritableSharedMemoryMapping*>(arg);
+      },
+      mapping_ptr);
+  if (!backing_store) {
+    delete mapping_ptr;
+    return {};
+  }
+
+  return v8::ArrayBuffer::New(isolate, std::move(backing_store));
+}
+
+v8::Local<v8::Object> BuildDescriptor(v8::Isolate* isolate,
+                                      const std::string& pool_id,
+                                      uint64_t offset,
+                                      uint64_t byte_length) {
+  gin_helper::Dictionary descriptor{isolate, v8::Object::New(isolate)};
+  descriptor.Set(kDescriptorPoolIdKey, pool_id);
+  descriptor.Set(kDescriptorOffsetKey, offset);
+  descriptor.Set(kDescriptorByteLengthKey, byte_length);
+  return descriptor.GetHandle();
+}
+
+v8::Local<v8::Object> BuildRingDescriptor(v8::Isolate* isolate,
+                                          const std::string& pool_id,
+                                          uint64_t offset,
+                                          uint64_t byte_length,
+                                          uint32_t slot_size,
+                                          uint32_t slot_count,
+                                          uint32_t max_metadata_size) {
+  gin_helper::Dictionary descriptor{isolate, BuildDescriptor(isolate, pool_id,
+                                                             offset,
+                                                             byte_length)};
+  descriptor.Set(kRingSlotSizeKey, slot_size);
+  descriptor.Set(kRingSlotCountKey, slot_count);
+  descriptor.Set(kRingMaxMetadataSizeKey, max_metadata_size);
+  return descriptor.GetHandle();
+}
+
+RingHeader* GetRingHeader(const std::shared_ptr<RingMapping>& ring) {
+  return static_cast<RingHeader*>(ring->mapping.memory());
+}
+
+uint64_t SlotStride(const RingHeader* header) {
+  return AlignToEight(sizeof(SlotHeader) + header->max_metadata_size +
+                      header->slot_size);
+}
+
+SlotHeader* GetSlotHeader(const std::shared_ptr<RingMapping>& ring,
+                          uint64_t sequence) {
+  RingHeader* header = GetRingHeader(ring);
+  const uint64_t slot_index = sequence % header->slot_count;
+  auto* base = static_cast<uint8_t*>(ring->mapping.memory());
+  return UNSAFE_BUFFERS(reinterpret_cast<SlotHeader*>(
+      base + AlignToEight(sizeof(RingHeader)) + slot_index * SlotStride(header)));
+}
+
+char* GetSlotMetadata(const std::shared_ptr<RingMapping>& ring,
+                      SlotHeader* slot) {
+  auto* base = reinterpret_cast<uint8_t*>(slot);
+  return UNSAFE_BUFFERS(reinterpret_cast<char*>(base + sizeof(SlotHeader)));
+}
+
+uint8_t* GetSlotData(const std::shared_ptr<RingMapping>& ring,
+                     SlotHeader* slot) {
+  RingHeader* header = GetRingHeader(ring);
+  auto* base = reinterpret_cast<uint8_t*>(slot);
+  return UNSAFE_BUFFERS(base + sizeof(SlotHeader) + header->max_metadata_size);
+}
+
+std::shared_ptr<RingMapping> MapRing(const std::string& pool_id,
+                                     uint64_t offset,
+                                     uint64_t byte_length,
+                                     uint32_t slot_size,
+                                     uint32_t slot_count,
+                                     uint32_t max_metadata_size) {
+  const std::string key = RingKey(pool_id, offset, byte_length);
+  {
+    base::AutoLock lock(GetRingMapLock());
+    auto it = GetRingMap().find(key);
+    if (it != GetRingMap().end())
+      return it->second;
+  }
+
+  uint64_t expected_byte_length = 0;
+  if (!CalculateRingByteLength(slot_size, slot_count, max_metadata_size,
+                               &expected_byte_length) ||
+      expected_byte_length != byte_length) {
+    return {};
+  }
+
+  Pool* pool = FindPool(pool_id);
+  if (!pool || offset > pool->size || byte_length > pool->size - offset)
+    return {};
+
+  base::WritableSharedMemoryMapping mapping =
+      pool->region.MapAt(offset, base::checked_cast<size_t>(byte_length),
+                         gin::GetSharedMemoryMapperForArrayBuffers());
+  if (!mapping.IsValid())
+    return {};
+
+  auto ring = std::make_shared<RingMapping>();
+  ring->key = key;
+  ring->pool_id = pool_id;
+  ring->offset = offset;
+  ring->byte_length = byte_length;
+  ring->slot_size = slot_size;
+  ring->slot_count = slot_count;
+  ring->max_metadata_size = max_metadata_size;
+  ring->mapping = std::move(mapping);
+
+  RingHeader* header = GetRingHeader(ring);
+  if (header->magic != kRingMagic || header->version != kRingVersion ||
+      header->slot_size != slot_size || header->slot_count != slot_count ||
+      header->max_metadata_size != max_metadata_size) {
+    return {};
+  }
+
+  base::AutoLock lock(GetRingMapLock());
+  auto [it, inserted] = GetRingMap().emplace(key, ring);
+  return it->second;
+}
+
+bool GetRingFromDescriptor(gin_helper::Dictionary descriptor,
+                           std::shared_ptr<RingMapping>* ring) {
+  std::string pool_id;
+  uint64_t offset = 0;
+  uint64_t byte_length = 0;
+  uint32_t slot_size = 0;
+  uint32_t slot_count = 0;
+  uint32_t max_metadata_size = 0;
+  if (!ParseRingDescriptor(descriptor, &pool_id, &offset, &byte_length,
+                           &slot_size, &slot_count, &max_metadata_size)) {
+    return false;
+  }
+  *ring = MapRing(pool_id, offset, byte_length, slot_size, slot_count,
+                  max_metadata_size);
+  return !!*ring;
+}
+
+bool GetBytes(v8::Local<v8::Value> value, base::span<uint8_t>* bytes) {
+  if (value->IsArrayBufferView()) {
+    *bytes = electron::util::as_byte_span(value.As<v8::ArrayBufferView>());
+    return true;
+  }
+  if (value->IsArrayBuffer()) {
+    auto buffer = value.As<v8::ArrayBuffer>();
+    *bytes = UNSAFE_BUFFERS(base::span{
+        static_cast<uint8_t*>(buffer->Data()), buffer->ByteLength()});
+    return true;
+  }
+  return false;
+}
+
+v8::Local<v8::Value> BuildRingWriteResult(v8::Isolate* isolate,
+                                          bool ok,
+                                          uint64_t sequence,
+                                          const std::string& reason) {
+  gin_helper::Dictionary result{isolate, v8::Object::New(isolate)};
+  result.Set("ok", ok);
+  result.Set("sequence", sequence);
+  if (!reason.empty())
+    result.Set("reason", reason);
+  return result.GetHandle();
+}
+
+}  // namespace
+
+bool RegisterPool(const std::string& id,
+                  uint64_t size,
+                  uint64_t max_allocation_size,
+                  base::UnsafeSharedMemoryRegion region) {
+  if (id.empty() || size == 0 || max_allocation_size == 0 ||
+      !region.IsValid() || region.GetSize() != size) {
+    return false;
+  }
+
+  base::AutoLock lock(GetPoolMapLock());
+  auto pool =
+      std::make_unique<Pool>(std::move(region), size, max_allocation_size);
+  auto [it, inserted] = GetPoolMap().emplace(id, std::move(pool));
+  return inserted;
+}
+
+base::UnsafeSharedMemoryRegion DuplicatePoolRegion(const std::string& id,
+                                                   uint64_t size) {
+  Pool* pool = FindPool(id);
+  if (!pool || pool->size != size)
+    return {};
+  return pool->region.Duplicate();
+}
+
+v8::Local<v8::Value> GetPoolStats(v8::Isolate* isolate,
+                                  gin_helper::Dictionary pool) {
+  std::string pool_id;
+  uint64_t pool_size = 0;
+  uint64_t max_allocation_size = 0;
+  if (!ParsePool(pool, &pool_id, &pool_size, &max_allocation_size))
+    return v8::Null(isolate);
+
+  Pool* pool_entry = FindPool(pool_id);
+  if (!PoolMatches(pool_entry, pool_size, max_allocation_size))
+    return v8::Null(isolate);
+
+  const uint64_t used =
+      pool_entry->next_offset.load(std::memory_order_acquire);
+  gin_helper::Dictionary stats{isolate, v8::Object::New(isolate)};
+  stats.Set("id", pool_id);
+  stats.Set("size", pool_entry->size);
+  stats.Set("maxAllocationSize", pool_entry->max_allocation_size);
+  stats.Set("used", used);
+  stats.Set("remaining", used <= pool_entry->size ? pool_entry->size - used
+                                                  : uint64_t{0});
+  stats.Set("allocationCount",
+            pool_entry->allocation_count.load(std::memory_order_relaxed));
+  return stats.GetHandle();
+}
+
+bool Detach(v8::Isolate*, v8::Local<v8::Value> value) {
+  v8::Local<v8::ArrayBuffer> buffer;
+  if (value->IsArrayBuffer()) {
+    buffer = value.As<v8::ArrayBuffer>();
+  } else if (value->IsArrayBufferView()) {
+    buffer = value.As<v8::ArrayBufferView>()->Buffer();
+  } else {
+    return false;
+  }
+
+  if (buffer->WasDetached())
+    return true;
+  if (!buffer->IsDetachable())
+    return false;
+  return buffer->Detach(v8::Local<v8::Value>()).FromMaybe(false);
+}
+
+v8::Local<v8::Value> Allocate(v8::Isolate* isolate,
+                              gin_helper::Dictionary pool,
+                              uint64_t size) {
+  std::string pool_id;
+  uint64_t pool_size = 0;
+  uint64_t max_allocation_size = 0;
+  if (!ParsePool(pool, &pool_id, &pool_size, &max_allocation_size) ||
+      size == 0 || size > max_allocation_size) {
+    return v8::Null(isolate);
+  }
+
+  Pool* pool_entry = FindPool(pool_id);
+  if (!PoolMatches(pool_entry, pool_size, max_allocation_size))
+    return v8::Null(isolate);
+
+  uint64_t offset = 0;
+  if (!ReservePoolBytes(pool_entry, size, &offset))
+    return v8::Null(isolate);
+
+  v8::Local<v8::ArrayBuffer> buffer =
+      MapRegionToArrayBuffer(isolate, pool_entry->region, offset, size);
+  if (buffer.IsEmpty())
+    return v8::Null(isolate);
+
+  gin_helper::Dictionary result{isolate, v8::Object::New(isolate)};
+  result.Set("buffer", buffer);
+  result.Set("descriptor", BuildDescriptor(isolate, pool_id, offset, size));
+  return result.GetHandle();
+}
+
+v8::Local<v8::Value> CreateRing(v8::Isolate* isolate,
+                                gin_helper::Dictionary pool,
+                                gin_helper::Dictionary options) {
+  std::string pool_id;
+  uint64_t pool_size = 0;
+  uint64_t max_allocation_size = 0;
+  uint32_t slot_size = 0;
+  uint32_t slot_count = 0;
+  uint32_t max_metadata_size = 0;
+  if (!ParsePool(pool, &pool_id, &pool_size, &max_allocation_size) ||
+      !options.Get(kRingSlotSizeKey, &slot_size) ||
+      !options.Get(kRingSlotCountKey, &slot_count) ||
+      !options.Get(kRingMaxMetadataSizeKey, &max_metadata_size)) {
+    return v8::Null(isolate);
+  }
+
+  Pool* pool_entry = FindPool(pool_id);
+  if (!PoolMatches(pool_entry, pool_size, max_allocation_size))
+    return v8::Null(isolate);
+
+  uint64_t byte_length = 0;
+  if (!CalculateRingByteLength(slot_size, slot_count, max_metadata_size,
+                               &byte_length)) {
+    return v8::Null(isolate);
+  }
+
+  uint64_t offset = 0;
+  if (!ReservePoolBytes(pool_entry, byte_length, &offset)) {
+    return v8::Null(isolate);
+  }
+
+  base::WritableSharedMemoryMapping mapping =
+      pool_entry->region.MapAt(offset, base::checked_cast<size_t>(byte_length),
+                               gin::GetSharedMemoryMapperForArrayBuffers());
+  if (!mapping.IsValid())
+    return v8::Null(isolate);
+
+  std::ranges::fill(UNSAFE_BUFFERS(base::span(mapping.data(), mapping.size())),
+                    0);
+  auto* header = new (mapping.memory()) RingHeader();
+  header->slot_size = slot_size;
+  header->slot_count = slot_count;
+  header->max_metadata_size = max_metadata_size;
+
+  auto ring = std::make_shared<RingMapping>();
+  ring->key = RingKey(pool_id, offset, byte_length);
+  ring->pool_id = pool_id;
+  ring->offset = offset;
+  ring->byte_length = byte_length;
+  ring->slot_size = slot_size;
+  ring->slot_count = slot_count;
+  ring->max_metadata_size = max_metadata_size;
+  ring->mapping = std::move(mapping);
+
+  for (uint32_t i = 0; i < slot_count; ++i) {
+    new (GetSlotHeader(ring, i)) SlotHeader();
+  }
+
+  {
+    base::AutoLock lock(GetRingMapLock());
+    GetRingMap()[ring->key] = ring;
+  }
+
+  return BuildRingDescriptor(isolate, pool_id, offset, byte_length, slot_size,
+                             slot_count, max_metadata_size)
+      .As<v8::Value>();
+}
+
+bool OpenRing(gin_helper::Dictionary descriptor) {
+  std::shared_ptr<RingMapping> ring;
+  return GetRingFromDescriptor(descriptor, &ring);
+}
+
+v8::Local<v8::Value> RingWrite(v8::Isolate* isolate,
+                               gin_helper::Dictionary descriptor,
+                               v8::Local<v8::Value> data,
+                               std::string metadata,
+                               std::string overflow) {
+  std::shared_ptr<RingMapping> ring;
+  if (!GetRingFromDescriptor(descriptor, &ring))
+    return BuildRingWriteResult(isolate, false, 0, "closed");
+
+  base::span<uint8_t> bytes;
+  if (!GetBytes(data, &bytes))
+    return BuildRingWriteResult(isolate, false, 0, "invalid-data");
+
+  RingHeader* header = GetRingHeader(ring);
+  if (bytes.size() > header->slot_size)
+    return BuildRingWriteResult(isolate, false, 0, "oversized");
+  if (metadata.size() > header->max_metadata_size)
+    return BuildRingWriteResult(isolate, false, 0, "tag-too-large");
+
+  uint64_t sequence = header->write_sequence.load(std::memory_order_relaxed);
+  SlotHeader* slot = GetSlotHeader(ring, sequence);
+  uint32_t expected = kSlotFree;
+  if (!slot->state.compare_exchange_strong(expected, kSlotReading,
+                                           std::memory_order_acq_rel,
+                                           std::memory_order_acquire)) {
+    if (overflow == "drop-oldest") {
+      const uint64_t read_sequence =
+          header->read_sequence.load(std::memory_order_relaxed);
+      SlotHeader* dropped_slot = GetSlotHeader(ring, read_sequence);
+      dropped_slot->state.store(kSlotFree, std::memory_order_release);
+      header->read_sequence.store(read_sequence + 1, std::memory_order_release);
+      header->dropped_count.fetch_add(1, std::memory_order_relaxed);
+      expected = kSlotFree;
+      if (!slot->state.compare_exchange_strong(expected, kSlotReading,
+                                               std::memory_order_acq_rel,
+                                               std::memory_order_acquire)) {
+        return BuildRingWriteResult(isolate, false, sequence, "full");
+      }
+    } else if (overflow == "throw") {
+      return BuildRingWriteResult(isolate, false, sequence, "full");
+    } else {
+      return BuildRingWriteResult(isolate, false, sequence, "full");
+    }
+  }
+
+  slot->byte_length = base::checked_cast<uint32_t>(bytes.size());
+  slot->metadata_length = base::checked_cast<uint32_t>(metadata.size());
+  slot->sequence = sequence;
+  if (!metadata.empty()) {
+    UNSAFE_BUFFERS(
+        base::span(reinterpret_cast<uint8_t*>(GetSlotMetadata(ring, slot)),
+                   metadata.size()))
+        .copy_from(base::as_byte_span(metadata));
+  }
+  if (!bytes.empty()) {
+    UNSAFE_BUFFERS(base::span(GetSlotData(ring, slot), bytes.size()))
+        .copy_from(bytes);
+  }
+  slot->state.store(kSlotReady, std::memory_order_release);
+  header->write_sequence.store(sequence + 1, std::memory_order_release);
+  return BuildRingWriteResult(isolate, true, sequence, "");
+}
+
+v8::Local<v8::Value> RingRead(v8::Isolate* isolate,
+                              gin_helper::Dictionary descriptor) {
+  std::shared_ptr<RingMapping> ring;
+  if (!GetRingFromDescriptor(descriptor, &ring))
+    return v8::Null(isolate);
+
+  RingHeader* header = GetRingHeader(ring);
+  const uint64_t sequence =
+      header->read_sequence.load(std::memory_order_acquire);
+  SlotHeader* slot = GetSlotHeader(ring, sequence);
+  uint32_t expected = kSlotReady;
+  if (!slot->state.compare_exchange_strong(expected, kSlotReading,
+                                           std::memory_order_acq_rel,
+                                           std::memory_order_acquire)) {
+    return v8::Null(isolate);
+  }
+  if (slot->sequence != sequence) {
+    slot->state.store(kSlotFree, std::memory_order_release);
+    header->read_sequence.store(sequence + 1, std::memory_order_release);
+    return v8::Null(isolate);
+  }
+
+  auto* mapping_ref = new std::shared_ptr<RingMapping>(ring);
+  auto backing_store = v8::ArrayBuffer::NewBackingStore(
+      GetSlotData(ring, slot), slot->byte_length,
+      [](void*, size_t, void* arg) {
+        delete static_cast<std::shared_ptr<RingMapping>*>(arg);
+      },
+      mapping_ref);
+  if (!backing_store) {
+    delete mapping_ref;
+    slot->state.store(kSlotReady, std::memory_order_release);
+    return v8::Null(isolate);
+  }
+
+  v8::Local<v8::ArrayBuffer> buffer =
+      v8::ArrayBuffer::New(isolate, std::move(backing_store));
+  gin_helper::Dictionary result{isolate, v8::Object::New(isolate)};
+  result.Set("sequence", sequence);
+  result.Set("byteLength", slot->byte_length);
+  result.Set("tag", std::string(GetSlotMetadata(ring, slot),
+                                slot->metadata_length));
+  result.Set("buffer", buffer);
+  const auto slot_offset = static_cast<uint64_t>(
+      GetSlotData(ring, slot) - static_cast<uint8_t*>(ring->mapping.memory()));
+  result.Set("descriptor",
+             BuildDescriptor(isolate, ring->pool_id, ring->offset + slot_offset,
+                             slot->byte_length));
+  return result.GetHandle();
+}
+
+bool RingRelease(gin_helper::Dictionary descriptor, uint64_t sequence) {
+  std::shared_ptr<RingMapping> ring;
+  if (!GetRingFromDescriptor(descriptor, &ring))
+    return false;
+
+  RingHeader* header = GetRingHeader(ring);
+  SlotHeader* slot = GetSlotHeader(ring, sequence);
+  if (slot->sequence != sequence)
+    return false;
+  uint32_t expected = kSlotReading;
+  if (!slot->state.compare_exchange_strong(expected, kSlotFree,
+                                           std::memory_order_acq_rel,
+                                           std::memory_order_acquire)) {
+    return false;
+  }
+  header->read_sequence.store(sequence + 1, std::memory_order_release);
+  return true;
+}
+
+v8::Local<v8::Value> View(v8::Isolate* isolate,
+                          gin_helper::Dictionary descriptor) {
+  std::string pool_id;
+  uint64_t offset = 0;
+  uint64_t byte_length = 0;
+  if (!ParseDescriptor(descriptor, &pool_id, &offset, &byte_length))
+    return v8::Null(isolate);
+
+  Pool* pool = FindPool(pool_id);
+  if (!pool)
+    return v8::Null(isolate);
+
+  v8::Local<v8::ArrayBuffer> buffer =
+      MapRegionToArrayBuffer(isolate, pool->region, offset, byte_length);
+  if (buffer.IsEmpty())
+    return v8::Null(isolate);
+  return buffer.As<v8::Value>();
+}
+
+void Initialize(v8::Local<v8::Object> exports,
+                v8::Local<v8::Value> unused,
+                v8::Local<v8::Context> context,
+                void* priv) {
+  v8::Isolate* const isolate = v8::Isolate::GetCurrent();
+  gin_helper::Dictionary dict(isolate, exports);
+  dict.SetMethod("allocate", &Allocate);
+  dict.SetMethod("createRing", &CreateRing);
+  dict.SetMethod("detach", &Detach);
+  dict.SetMethod("getPoolStats", &GetPoolStats);
+  dict.SetMethod("openRing", &OpenRing);
+  dict.SetMethod("ringRead", &RingRead);
+  dict.SetMethod("ringRelease", &RingRelease);
+  dict.SetMethod("ringWrite", &RingWrite);
+  dict.SetMethod("view", &View);
+}
+
+}  // namespace electron::api::shared_memory
