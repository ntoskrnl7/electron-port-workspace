+  const receiveChannelMessage = (channel: any, handler: (message: any) => any) => {
+    return new Promise<any>((resolve, reject) => {
+      channel.setErrorHandler(reject);
+      channel.setMessageHandler((message: any) => {
+        try {
+          const result = handler(message);
+          channel.setMessageHandler(null);
+          resolve(result);
+        } catch (error) {
+          reject(error);
+        }
+      });
+    });
+  };
+
+  const collectChannelMessages = (channel: any, count: number, handler: (message: any, index: number) => any) => {
+    return new Promise<any[]>((resolve, reject) => {
+      const messages: any[] = [];
+      channel.setErrorHandler(reject);
+      channel.setMessageHandler((message: any) => {
+        try {
+          messages.push(handler(message, messages.length));
+          if (messages.length === count) {
+            channel.setMessageHandler(null);
+            resolve(messages);
+          }
+        } catch (error) {
+          reject(error);
+        }
+      });
+    });
+  };
