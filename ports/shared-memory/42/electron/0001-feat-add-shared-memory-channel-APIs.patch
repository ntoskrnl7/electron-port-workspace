+      id: pool.id,
+      size: 128,
+      maxAllocationSize: 64,
+      used: 0,
+      remaining: 128,
+      allocationCount: 0
+    });
+
+    SharedMemory.withAllocator(pool, () => {
+      const first = new Uint8Array(5);
