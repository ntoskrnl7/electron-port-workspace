+#include "services/service_manager/public/cpp/interface_provider.h"
+#include "shell/browser/api/electron_api_web_frame_main.h"
+#include "shell/common/api/api.mojom.h"
+#include "shell/common/api/electron_api_shared_memory.h"
+#include "shell/common/gin_helper/dictionary.h"
+#include "shell/common/gin_helper/handle.h"
+#include "shell/common/gin_helper/promise.h"
+#include "shell/common/node_includes.h"
+
+namespace {
+
+v8::Local<v8::Promise> CreatePool(
+    v8::Isolate* isolate,
+    gin_helper::Handle<electron::api::WebFrameMain> frame,
+    uint64_t size,
+    uint64_t max_allocation_size) {
+  gin_helper::Promise<std::string> promise(isolate);
+  v8::Local<v8::Promise> handle = promise.GetHandle();
+
+  if (frame.IsEmpty() || !frame->render_frame_host() ||
+      !frame->render_frame_host()->IsRenderFrameLive()) {
+    promise.RejectWithErrorMessage("Invalid target frame");
+    return handle;
+  }
+
+  if (size == 0) {
+    promise.RejectWithErrorMessage(
+        "SharedMemory pool size must be greater than zero");
+    return handle;
+  }
+
+  const uint64_t allocation_limit = max_allocation_size;
+  if (allocation_limit == 0 || allocation_limit > size) {
+    promise.RejectWithErrorMessage("Invalid maxAllocationSize");
+    return handle;
+  }
+
+  base::UnsafeSharedMemoryRegion region =
+      base::UnsafeSharedMemoryRegion::Create(size);
+  if (!region.IsValid()) {
+    promise.RejectWithErrorMessage("Failed to create shared memory region");
+    return handle;
+  }
+
+  base::UnsafeSharedMemoryRegion renderer_region = region.Duplicate();
+  if (!renderer_region.IsValid()) {
+    promise.RejectWithErrorMessage("Failed to duplicate shared memory region");
+    return handle;
+  }
+
+  const std::string id = base::UnguessableToken::Create().ToString();
+  if (!electron::api::shared_memory::RegisterPool(id, size, allocation_limit,
+                                                  std::move(region))) {
+    promise.RejectWithErrorMessage("Failed to register shared memory pool");
+    return handle;
+  }
+
+  auto electron_renderer =
+      std::make_unique<mojo::Remote<electron::mojom::ElectronRenderer>>();
+  frame->render_frame_host()->GetRemoteInterfaces()->GetInterface(
+      electron_renderer->BindNewPipeAndPassReceiver());
+  auto* raw_ptr = electron_renderer.get();
+  (*raw_ptr)->RegisterSharedMemoryPool(
+      id, std::move(renderer_region), size, allocation_limit,
+      base::BindOnce(
+          [](std::unique_ptr<mojo::Remote<electron::mojom::ElectronRenderer>>,
+             gin_helper::Promise<std::string> promise, std::string id,
+             bool success) {
+            if (success) {
+              promise.Resolve(id);
+            } else {
+              promise.RejectWithErrorMessage(
+                  "Failed to register shared memory pool in renderer");
+            }
+          },
+          std::move(electron_renderer), std::move(promise), id));
+
+  return handle;
+}
+
+void Initialize(v8::Local<v8::Object> exports,
+                v8::Local<v8::Value> unused,
+                v8::Local<v8::Context> context,
+                void* priv) {
+  v8::Isolate* const isolate = v8::Isolate::GetCurrent();
+  gin_helper::Dictionary dict(isolate, exports);
+  dict.SetMethod("createPool", &CreatePool);
+}
+
+}  // namespace
+
+NODE_LINKED_BINDING_CONTEXT_AWARE(electron_browser_shared_memory, Initialize)
