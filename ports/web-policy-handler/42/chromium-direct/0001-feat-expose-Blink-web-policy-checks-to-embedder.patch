+    case ContentSecurityPolicy::InlineType::kStyle:
+      return "style-src-elem";
+    case ContentSecurityPolicy::InlineType::kStyleAttribute:
+      return "style-src-attr";
+  }
+  NOTREACHED();
+  return "script-src";
