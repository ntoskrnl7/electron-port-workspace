+blink::WebPolicyDecision RendererBlinkPlatformImpl::CheckWebPolicy(
+    const blink::WebPolicyCheck& check) {
+  auto* content_client = GetContentClient();
+  if (!content_client)
+    return blink::WebPolicyDecision::kDefault;
+  auto* renderer_client = content_client->renderer();
+  if (!renderer_client)
+    return blink::WebPolicyDecision::kDefault;
+  return renderer_client->CheckWebPolicy(check);
+}
