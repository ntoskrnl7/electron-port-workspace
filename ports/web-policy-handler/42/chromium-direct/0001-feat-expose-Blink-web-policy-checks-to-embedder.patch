+std::string ToStdString(const String& value) {
+  return value.Utf8();
+}
+
+std::string ToStdString(const KURL& url) {
+  return url.IsNull() ? std::string() : url.GetString().Utf8();
+}
+
+std::string WebPolicyContextType(ExecutionContext* execution_context) {
+  if (!execution_context)
+    return "unknown";
+  if (execution_context->IsWindow())
+    return "frame";
+  if (execution_context->IsDedicatedWorkerGlobalScope())
+    return "dedicated-worker";
+  if (execution_context->IsSharedWorkerGlobalScope())
+    return "shared-worker";
+  if (execution_context->IsServiceWorkerGlobalScope())
+    return "service-worker";
+  return "unknown";
+}
+
+std::optional<LocalFrameToken> WebPolicyFrameToken(
+    ExecutionContext* execution_context) {
+  auto* window = DynamicTo<LocalDOMWindow>(execution_context);
+  if (!window)
+    return std::nullopt;
+  return window->GetLocalFrameToken();
+}
+
+WebPolicyDecision CheckXMLHttpRequestWebPolicy(ExecutionContext* context,
+                                               const char* name,
+                                               const KURL& resource_url,
+                                               const String& message) {
+  if (!context || !Platform::Current())
+    return WebPolicyDecision::kDefault;
+
+  WebPolicyCheck check;
+  check.policy = "browser-runtime";
+  check.name = name;
+  check.source = "runtime";
+  check.disposition = "enforce";
+  check.context_type = WebPolicyContextType(context);
+  check.document_url = ToStdString(context->Url());
+  check.document_origin = context->GetSecurityOrigin()
+                              ? context->GetSecurityOrigin()->ToString().Utf8()
+                              : std::string();
+  check.resource_url = ToStdString(resource_url);
+  check.message = ToStdString(message);
+  check.frame_token = WebPolicyFrameToken(context);
+  return Platform::Current()->CheckWebPolicy(check);
+}
