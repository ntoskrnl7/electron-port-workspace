+String WebPolicyContextType(ExecutionContext* execution_context) {
+  if (!execution_context)
+    return "unknown";
+  if (execution_context->IsWindow())
+    return "frame";
+  if (execution_context->IsDedicatedWorkerGlobalScope())
+    return "dedicated-worker";
+  if (execution_context->IsSharedWorkerGlobalScope())
+    return "shared-worker";
+  if (execution_context->IsServiceWorkerGlobalScope())
+    return "service-worker";
+  return "unknown";
+}
+
+std::optional<LocalFrameToken> WebPolicyFrameToken(
+    ExecutionContext* execution_context) {
+  auto* window = DynamicTo<LocalDOMWindow>(execution_context);
+  if (!window)
+    return std::nullopt;
+  return window->GetLocalFrameToken();
+}
+
+WebPolicyDecision CheckWebPolicy(ExecutionContext* execution_context,
+                                 const SecurityOrigin* security_origin,
+                                 std::string policy,
+                                 std::string name,
+                                 std::string disposition) {
+  if (!Platform::Current())
+    return WebPolicyDecision::kDefault;
+
+  WebPolicyCheck check;
+  check.policy = std::move(policy);
+  check.name = std::move(name);
+  check.source = "runtime";
+  check.disposition = std::move(disposition);
+  check.context_type = ToStdString(WebPolicyContextType(execution_context));
+  // Document and Permissions Policy checks can run while a frame's
+  // ExecutionContext is still being attached to its initial document. In that
+  // phase ExecutionContext::Url() is not safe to read yet, so leave the
+  // document URL empty rather than forcing an early dereference.
+  check.document_url = std::string();
+  check.document_origin =
+      security_origin ? security_origin->ToString().Utf8() : std::string();
+  check.frame_token = WebPolicyFrameToken(execution_context);
+  return Platform::Current()->CheckWebPolicy(check);
+}
+
