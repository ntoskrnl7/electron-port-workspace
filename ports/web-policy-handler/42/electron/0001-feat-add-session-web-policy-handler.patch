+class ElectronWebPolicyChecker : public mojom::ElectronWebPolicyChecker {
+ public:
+  ElectronWebPolicyChecker(content::BrowserContext* browser_context,
+                           int render_process_id)
+      : browser_context_(browser_context),
+        render_process_id_(render_process_id) {}
+
+  ElectronWebPolicyChecker(const ElectronWebPolicyChecker&) = delete;
+  ElectronWebPolicyChecker& operator=(const ElectronWebPolicyChecker&) =
+      delete;
+
+  void CheckWebPolicy(mojom::WebPolicyCheckDetailsPtr details,
+                      CheckWebPolicyCallback callback) override {
+    auto* session_cell = api::Session::FromBrowserContext(browser_context_);
+    if (!session_cell || !session_cell->Get()) {
+      std::move(callback).Run("default");
+      return;
+    }
+
+    v8::Isolate* isolate = JavascriptEnvironment::GetIsolate();
+    v8::HandleScope handle_scope(isolate);
+    auto details_object = gin_helper::Dictionary::CreateEmpty(isolate);
+    details_object.Set("policy", details->policy);
+    details_object.Set("name", details->name);
+    details_object.Set("source", details->source);
+    details_object.Set("disposition", details->disposition);
+    details_object.Set("contextType", details->context_type);
+    details_object.Set("documentUrl", details->document_url);
+    details_object.Set("documentOrigin", details->document_origin);
+    details_object.Set("resourceUrl", details->resource_url);
+    details_object.Set("message", details->message);
+
+    if (details->frame_token) {
+      auto frame_token = content::GlobalRenderFrameHostToken(
+          render_process_id_, *details->frame_token);
+      if (auto* rfh = content::RenderFrameHost::FromFrameToken(frame_token)) {
+        auto handle = api::WebFrameMain::From(isolate, rfh);
+        if (!handle.IsEmpty())
+          details_object.Set("frame", handle.ToV8());
+      }
+    }
+
+    std::move(callback).Run(
+        session_cell->Get()->HandleWebPolicy(details_object.GetHandle()));
+  }
+
+ private:
+  raw_ptr<content::BrowserContext> browser_context_;
+  int render_process_id_;
+};
+
+void BindWebPolicyChecker(
+    content::BrowserContext* browser_context,
+    int render_process_id,
+    mojo::PendingReceiver<mojom::ElectronWebPolicyChecker> receiver) {
+  mojo::MakeSelfOwnedReceiver(
+      std::make_unique<ElectronWebPolicyChecker>(browser_context,
+                                                 render_process_id),
+      std::move(receiver));
+}
