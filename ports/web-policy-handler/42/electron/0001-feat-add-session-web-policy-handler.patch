diff --git a/script/fix-web-policy-typescript-definitions.mjs b/script/fix-web-policy-typescript-definitions.mjs
new file mode 100644
index 0000000000..f2bc0a3ec5
--- /dev/null
+++ b/script/fix-web-policy-typescript-definitions.mjs
@@ -0,0 +1,217 @@
+import fs from 'node:fs';
+import path from 'node:path';
+
+const definitionsPath = path.resolve('electron.d.ts');
+let definitions = fs.readFileSync(definitionsPath, 'utf8');
+
+const cspDirectiveNames = [
+  'base-uri',
+  'block-all-mixed-content',
+  'child-src',
+  'connect-src',
+  'default-src',
+  'fenced-frame-src',
+  'font-src',
+  'form-action',
+  'frame-ancestors',
+  'frame-src',
+  'img-src',
+  'manifest-src',
+  'media-src',
+  'object-src',
+  'report-to',
+  'report-uri',
+  'require-trusted-types-for',
+  'sandbox',
+  'script-src',
+  'script-src-v2',
+  'script-src-attr',
+  'script-src-elem',
+  'style-src',
+  'style-src-attr',
+  'style-src-elem',
+  'treat-as-public-address',
+  'trusted-types',
+  'upgrade-insecure-requests',
+  'wasm-unsafe-eval',
+  'worker-src'
+];
+
+const documentPolicyNames = [
+  'force-load-at-top',
+  'js-profiling',
+  'sync-xhr',
+  'include-js-call-stacks-in-crash-reports',
+  'expect-no-linked-resources',
+  'network-efficiency-guardrails'
+];
+
+const browserRuntimePolicyNames = [
+  'sync-xhr',
+  'sync-xhr-page-dismissal'
+];
+
+function uniqueSorted(values) {
+  return [...new Set(values)].sort();
+}
+
+function stringUnion(values) {
+  return uniqueSorted(values).map(value => `'${value}'`).join(' | ');
+}
+
+function readPermissionsPolicyNames() {
+  const featureFile = path.resolve(
+    '..',
+    'services/network/public/cpp/permissions_policy/permissions_policy_features.json5'
+  );
+  if (!fs.existsSync(featureFile)) {
+    return [
+      'camera',
+      'fullscreen',
+      'geolocation',
+      'microphone',
+      'sync-xhr'
+    ];
+  }
+
+  const text = fs.readFileSync(featureFile, 'utf8');
+  const names = [];
+  const pattern = /permissions_policy_name:\s*"([^"]+)"/g;
+  let match;
+  while ((match = pattern.exec(text)) !== null) {
+    if (match[1] !== 'FEATURE_NAME')
+      names.push(match[1]);
+  }
+  return names;
+}
+
+function replaceGeneratedInterface(source, name, replacement) {
+  const marker = `  interface ${name} {`;
+  const start = source.indexOf(marker);
+  if (start === -1) {
+    throw new Error(`Unable to find generated ${name} interface in electron.d.ts`);
+  }
+
+  const candidates = [
+    source.indexOf('\n  interface ', start + marker.length),
+    source.indexOf('\n  class ', start + marker.length),
+    source.indexOf('\n  type ', start + marker.length)
+  ].filter(index => index !== -1);
+  if (candidates.length === 0) {
+    throw new Error(`Unable to find end of generated ${name} interface in electron.d.ts`);
+  }
+
+  const end = Math.min(...candidates);
+  return source.slice(0, start) + replacement + source.slice(end);
+}
+
+const detailsReplacement = `  type WebPolicyHandlerAction = 'default' | 'allow' | 'deny';
+  type WebPolicyKind = 'content-security-policy' | 'permissions-policy' | 'document-policy' | 'browser-runtime';
+  type WebPolicySource = 'runtime';
+  type WebPolicyDisposition = 'enforce' | 'report';
+  type WebPolicyContextType = 'frame' | 'dedicated-worker' | 'shared-worker' | 'service-worker' | 'unknown';
+  type ContentSecurityPolicyDirective = ${stringUnion(cspDirectiveNames)};
+  type PermissionsPolicyFeatureName = ${stringUnion(readPermissionsPolicyNames())};
+  type DocumentPolicyFeatureName = ${stringUnion(documentPolicyNames)};
+  type BrowserRuntimePolicyName = ${stringUnion(browserRuntimePolicyNames)};
+  type WebPolicyHandlerDetails = WebContentSecurityPolicyHandlerDetails | WebPermissionsPolicyHandlerDetails | WebDocumentPolicyHandlerDetails | WebBrowserRuntimePolicyHandlerDetails;
+
+  interface WebPolicyHandlerDetailsBase {
+
+    // Docs: https://electronjs.org/docs/api/structures/web-policy-handler-details
+
+    /**
+     * The policy family being checked.
+     */
+    policy: WebPolicyKind;
+    /**
+     * The policy directive, policy feature, or runtime policy name.
+     */
+    name: string;
+    /**
+     * Where the policy check was generated.
+     */
+    source: WebPolicySource;
+    /**
+     * Whether the check is for an enforcing policy or a report-only policy.
+     */
+    disposition: WebPolicyDisposition;
+    /**
+     * The JavaScript context type making the check.
+     */
+    contextType: WebPolicyContextType;
+    /**
+     * The URL of the document or worker context making the check, or an empty
+     * string when the URL is not available yet.
+     */
+    documentUrl: string;
+    /**
+     * The security origin of the document or worker context making the check.
+     */
+    documentOrigin: string;
+    /**
+     * The resource URL being checked, or an empty string when the policy check is
+     * not for a specific resource.
+     */
+    resourceUrl: string;
+    /**
+     * Additional context from the policy check, or an empty string when unavailable.
+     */
+    message: string;
+    /**
+     * The frame making the policy check. This is only present for frame-backed
+     * checks while the frame still exists.
+     */
+    frame?: WebFrameMain;
+  }
+
+  interface WebContentSecurityPolicyHandlerDetails extends WebPolicyHandlerDetailsBase {
+    policy: 'content-security-policy';
+    name: ContentSecurityPolicyDirective;
+  }
+
+  interface WebPermissionsPolicyHandlerDetails extends WebPolicyHandlerDetailsBase {
+    policy: 'permissions-policy';
+    name: PermissionsPolicyFeatureName;
+  }
+
+  interface WebDocumentPolicyHandlerDetails extends WebPolicyHandlerDetailsBase {
+    policy: 'document-policy';
+    name: DocumentPolicyFeatureName;
+  }
+
+  interface WebBrowserRuntimePolicyHandlerDetails extends WebPolicyHandlerDetailsBase {
+    policy: 'browser-runtime';
+    name: BrowserRuntimePolicyName;
+  }
+
+  interface WebPolicyHandlerResponse {
+
+    // Docs: https://electronjs.org/docs/api/structures/web-policy-handler-response
+
+    /**
+     * The action to take for the policy check.
+     */
+    action: WebPolicyHandlerAction;
+  }
+`;
+
+if (!definitions.includes('type WebPolicyHandlerAction =')) {
+  definitions = replaceGeneratedInterface(
+    definitions,
+    'WebPolicyHandlerResponse',
+    ''
+  );
+  definitions = replaceGeneratedInterface(
+    definitions,
+    'WebPolicyHandlerDetails',
+    detailsReplacement
+  );
+}
+
+definitions = definitions.replace(
+  /setWebPolicyHandler\(handler: [^\n]+?\): void;/,
+  'setWebPolicyHandler(handler: ((details: WebPolicyHandlerDetails) => (WebPolicyHandlerResponse) | (void)) | null): void;'
+);
+
+fs.writeFileSync(definitionsPath, definitions);
