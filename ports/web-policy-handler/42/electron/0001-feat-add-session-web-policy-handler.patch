+blink::WebPolicyDecision RendererClientBase::CheckWebPolicy(
+    const blink::WebPolicyCheck& check) const {
+  auto* broker = blink::Platform::Current()->GetBrowserInterfaceBroker();
+  if (!broker)
+    return blink::WebPolicyDecision::kDefault;
+
+  mojo::Remote<mojom::ElectronWebPolicyChecker> checker;
+  broker->GetInterface(checker.BindNewPipeAndPassReceiver());
+
+  auto details = mojom::WebPolicyCheckDetails::New();
+  details->policy = check.policy;
+  details->name = check.name;
+  details->source = check.source;
+  details->disposition = check.disposition;
+  details->context_type = check.context_type;
+  details->document_url = check.document_url;
+  details->document_origin = check.document_origin;
+  details->resource_url = check.resource_url;
+  details->message = check.message;
+  details->frame_token = check.frame_token;
+
+  std::string action;
+  if (!checker->CheckWebPolicy(std::move(details), &action))
+    return blink::WebPolicyDecision::kDefault;
+  if (action == "allow")
+    return blink::WebPolicyDecision::kAllow;
+  if (action == "deny")
+    return blink::WebPolicyDecision::kDeny;
+  return blink::WebPolicyDecision::kDefault;
+}
