+void Session::SetWebPolicyHandler(gin::Arguments* args) {
+  v8::Local<v8::Value> value;
+  WebPolicyHandler handler;
+  if (!args->GetNext(&value) ||
+      !(value->IsNull() ||
+        gin::ConvertFromV8(args->isolate(), value, &handler))) {
+    args->ThrowTypeError("Must pass null or function");
+    return;
+  }
+
+  web_policy_handler_ = std::move(handler);
+}
+
+std::string Session::HandleWebPolicy(v8::Local<v8::Value> details) {
+  if (web_policy_handler_.is_null())
+    return "default";
+
+  v8::Local<v8::Value> result = web_policy_handler_.Run(details);
+  if (result.IsEmpty() || !result->IsObject())
+    return "default";
+
+  gin_helper::Dictionary dict(isolate_, result.As<v8::Object>());
+  std::string action;
+  if (!dict.Get("action", &action))
+    return "default";
+  if (action == "allow" || action == "deny" || action == "default")
+    return action;
+  return "default";
+}
