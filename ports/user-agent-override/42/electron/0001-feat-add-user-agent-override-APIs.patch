+void Session::SetUserAgentOverride(gin_helper::ErrorThrower thrower,
+                                   const gin_helper::Dictionary& options) {
+  UserAgentOverrideOptions user_agent_override;
+  if (!ParseUserAgentOverrideOptions(thrower, options,
+                                     browser_context_->GetUserAgentMetadata(),
+                                     true, false, &user_agent_override)) {
+    return;
+  }
+
+  browser_context_->SetUserAgentOverride(
+      user_agent_override.user_agent, user_agent_override.user_agent_metadata);
+
+  auto* network_context =
+      browser_context_->GetDefaultStoragePartition()->GetNetworkContext();
+  network_context->SetUserAgent(user_agent_override.user_agent);
+  if (user_agent_override.accept_languages.has_value()) {
+    network_context->SetAcceptLanguage(
+        net::HttpUtil::GenerateAcceptLanguageHeader(
+            user_agent_override.accept_languages.value()));
+  }
+}
+
+void Session::ClearUserAgentOverride() {
+  browser_context_->ClearUserAgentOverride();
+
+  auto* network_context =
+      browser_context_->GetDefaultStoragePartition()->GetNetworkContext();
+  network_context->SetUserAgent(browser_context_->GetUserAgent());
+  network_context->SetAcceptLanguage(
+      net::HttpUtil::GenerateAcceptLanguageHeader(
+          ElectronBrowserClient::Get()->GetApplicationLocale()));
+}
+
 std::string Session::GetUserAgent() {
   return browser_context_->GetUserAgent();
 }
