diff --git a/shell/browser/user_agent_override.cc b/shell/browser/user_agent_override.cc
new file mode 100644
index 0000000000..229f11d99f
--- /dev/null
+++ b/shell/browser/user_agent_override.cc
@@ -0,0 +1,236 @@
+// Copyright (c) 2026 Electron Port Workspace contributors
+// Use of this source code is governed by the MIT license that can be
+// found in the LICENSE file.
+
+#include "shell/browser/user_agent_override.h"
+
+#include <string>
+#include <string_view>
+#include <utility>
+#include <vector>
+
+#include "base/strings/string_util.h"
+#include "base/values.h"
+#include "net/http/http_util.h"
+#include "shell/common/gin_converters/value_converter.h"
+#include "shell/common/gin_helper/dictionary.h"
+#include "shell/common/gin_helper/error_thrower.h"
+
+namespace electron {
+
+namespace {
+
+bool ValidateClientHintString(std::string_view value) {
+  for (const char c : value) {
+    if (!base::IsAsciiPrintable(c))
+      return false;
+  }
+  return true;
+}
+
+bool ReadClientHintString(const base::DictValue& dict,
+                          const char* key,
+                          std::string* out,
+                          std::string* error) {
+  const std::string* value = dict.FindString(key);
+  if (!value)
+    return true;
+  if (!ValidateClientHintString(*value)) {
+    *error = std::string("Invalid ") + key + " string";
+    return false;
+  }
+  *out = *value;
+  return true;
+}
+
+bool ReadBrandVersionList(const base::DictValue& dict,
+                          const char* key,
+                          blink::UserAgentBrandList* out,
+                          std::string* error) {
+  const base::ListValue* list = dict.FindList(key);
+  if (!list)
+    return true;
+
+  blink::UserAgentBrandList parsed;
+  for (const base::Value& item : *list) {
+    if (!item.is_dict()) {
+      *error = std::string(key) + " must be an array of objects";
+      return false;
+    }
+
+    const base::DictValue& brand_dict = item.GetDict();
+    const std::string* brand = brand_dict.FindString("brand");
+    const std::string* version = brand_dict.FindString("version");
+    if (!brand || !version) {
+      *error = std::string(key) + " entries must include brand and version";
+      return false;
+    }
+    if (!ValidateClientHintString(*brand)) {
+      *error = "Invalid brand string";
+      return false;
+    }
+    if (!ValidateClientHintString(*version)) {
+      *error = "Invalid brand version string";
+      return false;
+    }
+
+    parsed.emplace_back(*brand, *version);
+  }
+
+  *out = std::move(parsed);
+  return true;
+}
+
+bool ReadFormFactors(const base::DictValue& dict,
+                     blink::UserAgentMetadata* metadata,
+                     std::string* error) {
+  const base::ListValue* list = dict.FindList("formFactors");
+  if (!list)
+    return true;
+
+  std::vector<std::string> form_factors;
+  for (const base::Value& item : *list) {
+    if (!item.is_string()) {
+      *error = "formFactors must be an array of strings";
+      return false;
+    }
+
+    const std::string& form_factor = item.GetString();
+    if (!ValidateClientHintString(form_factor) ||
+        !blink::UserAgentMetadata::IsValidFormFactor(form_factor)) {
+      *error = "Invalid form factor string";
+      return false;
+    }
+    form_factors.push_back(form_factor);
+  }
+
+  metadata->form_factors = std::move(form_factors);
+  return true;
+}
+
+bool ParseUserAgentMetadata(const base::Value& value,
+                            const blink::UserAgentMetadata& default_metadata,
+                            blink::UserAgentMetadata* metadata,
+                            std::string* error) {
+  if (!value.is_dict()) {
+    *error = "userAgentMetadata must be an object";
+    return false;
+  }
+
+  const base::DictValue& dict = value.GetDict();
+  blink::UserAgentMetadata parsed = default_metadata;
+
+  if (!ReadBrandVersionList(dict, "brands", &parsed.brand_version_list, error))
+    return false;
+  if (!ReadBrandVersionList(dict, "fullVersionList",
+                            &parsed.brand_full_version_list, error)) {
+    return false;
+  }
+  if (!ReadClientHintString(dict, "fullVersion", &parsed.full_version, error))
+    return false;
+  if (!ReadClientHintString(dict, "platform", &parsed.platform, error))
+    return false;
+  if (!ReadClientHintString(dict, "platformVersion", &parsed.platform_version,
+                            error)) {
+    return false;
+  }
+  if (!ReadClientHintString(dict, "architecture", &parsed.architecture, error))
+    return false;
+  if (!ReadClientHintString(dict, "model", &parsed.model, error))
+    return false;
+  if (!ReadClientHintString(dict, "bitness", &parsed.bitness, error))
+    return false;
+
+  if (std::optional<bool> mobile = dict.FindBool("mobile"))
+    parsed.mobile = *mobile;
+  if (std::optional<bool> wow64 = dict.FindBool("wow64"))
+    parsed.wow64 = *wow64;
+
+  if (!ReadFormFactors(dict, &parsed, error))
+    return false;
+
+  *metadata = std::move(parsed);
+  return true;
+}
+
+}  // namespace
+
+UserAgentOverrideOptions::UserAgentOverrideOptions() = default;
+UserAgentOverrideOptions::UserAgentOverrideOptions(
+    const UserAgentOverrideOptions&) = default;
+UserAgentOverrideOptions::UserAgentOverrideOptions(
+    UserAgentOverrideOptions&&) noexcept = default;
+UserAgentOverrideOptions& UserAgentOverrideOptions::operator=(
+    const UserAgentOverrideOptions&) = default;
+UserAgentOverrideOptions& UserAgentOverrideOptions::operator=(
+    UserAgentOverrideOptions&&) noexcept = default;
+UserAgentOverrideOptions::~UserAgentOverrideOptions() = default;
+
+bool ParseUserAgentOverrideOptions(
+    gin_helper::ErrorThrower thrower,
+    const gin_helper::Dictionary& options,
+    const blink::UserAgentMetadata& default_metadata,
+    bool allow_accept_languages,
+    bool allow_inherit_to_new_windows,
+    UserAgentOverrideOptions* override_out) {
+  std::string user_agent;
+  if (!options.Get("userAgent", &user_agent) || user_agent.empty()) {
+    thrower.ThrowTypeError("userAgent must be a non-empty string");
+    return false;
+  }
+
+  if (!net::HttpUtil::IsValidHeaderValue(user_agent)) {
+    thrower.ThrowTypeError("Invalid characters found in userAgent");
+    return false;
+  }
+
+  base::Value metadata_value;
+  if (!options.Get("userAgentMetadata", &metadata_value)) {
+    thrower.ThrowTypeError("userAgentMetadata must be provided");
+    return false;
+  }
+
+  blink::UserAgentMetadata metadata;
+  std::string error;
+  if (!ParseUserAgentMetadata(metadata_value, default_metadata, &metadata,
+                              &error)) {
+    thrower.ThrowTypeError(error);
+    return false;
+  }
+
+  UserAgentOverrideOptions parsed;
+  parsed.user_agent = std::move(user_agent);
+  parsed.user_agent_metadata = std::move(metadata);
+
+  if (allow_accept_languages) {
+    std::string accept_languages;
+    if (options.Get("acceptLanguages", &accept_languages))
+      parsed.accept_languages = std::move(accept_languages);
+  }
+
+  if (allow_inherit_to_new_windows) {
+    parsed.inherit_to_new_windows =
+        options.ValueOrDefault("inheritToNewWindows", false);
+  }
+
+  *override_out = std::move(parsed);
+  return true;
+}
+
+blink::UserAgentOverride ToBlinkUserAgentOverride(
+    const std::string& user_agent,
+    const blink::UserAgentMetadata& user_agent_metadata) {
+  blink::UserAgentOverride override;
+  override.ua_string_override = user_agent;
+  if (!user_agent.empty())
+    override.ua_metadata_override = user_agent_metadata;
+  return override;
+}
+
+blink::UserAgentOverride ToBlinkUserAgentOverride(
+    const UserAgentOverrideOptions& options) {
+  return ToBlinkUserAgentOverride(options.user_agent,
+                                  options.user_agent_metadata);
+}
+
+}  // namespace electron
