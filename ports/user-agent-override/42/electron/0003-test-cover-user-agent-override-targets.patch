diff --git a/spec/lib/user-agent-override-helpers.ts b/spec/lib/user-agent-override-helpers.ts
new file mode 100644
index 0000000000..6ef549418a
--- /dev/null
+++ b/spec/lib/user-agent-override-helpers.ts
@@ -0,0 +1,158 @@
+import * as http from 'node:http';
+
+export interface UserAgentSnapshot {
+  userAgent: string;
+  brands?: Array<{ brand: string; version: string }>;
+  mobile?: boolean;
+  platform?: string;
+}
+
+export type UserAgentTargetSnapshots = Record<
+  'mainFrame' | 'subframe' | 'dedicatedWorker' | 'sharedWorker' | 'serviceWorker',
+  UserAgentSnapshot
+>;
+
+const snapshotScript = `
+function readUserAgentSnapshot() {
+  const snapshot = {
+    userAgent: navigator.userAgent
+  };
+  if (navigator.userAgentData) {
+    snapshot.brands = navigator.userAgentData.brands.map(brand => ({
+      brand: brand.brand,
+      version: brand.version
+    }));
+    snapshot.mobile = navigator.userAgentData.mobile;
+    snapshot.platform = navigator.userAgentData.platform;
+  }
+  return snapshot;
+}
+`;
+
+export function createUserAgentOverrideTestServer() {
+  const requests: Record<string, http.IncomingHttpHeaders> = {};
+  const server = http.createServer((req, res) => {
+    const requestPath = (req.url ?? '/').split('?')[0];
+    requests[requestPath] = req.headers;
+
+    if (requestPath === '/subframe.html') {
+      res.setHeader('Content-Type', 'text/html');
+      res.end(`<!DOCTYPE html><script>
+        ${snapshotScript}
+        parent.postMessage({
+          type: 'user-agent-snapshot',
+          snapshot: readUserAgentSnapshot()
+        }, '*');
+      </script>`);
+      return;
+    }
+
+    if (requestPath === '/dedicated-worker.js') {
+      res.setHeader('Content-Type', 'text/javascript');
+      res.end(`
+        ${snapshotScript}
+        postMessage(readUserAgentSnapshot());
+      `);
+      return;
+    }
+
+    if (requestPath === '/shared-worker.js') {
+      res.setHeader('Content-Type', 'text/javascript');
+      res.end(`
+        ${snapshotScript}
+        onconnect = event => {
+          event.ports[0].postMessage(readUserAgentSnapshot());
+        };
+      `);
+      return;
+    }
+
+    if (requestPath === '/service-worker.js') {
+      res.setHeader('Content-Type', 'text/javascript');
+      res.end(`
+        ${snapshotScript}
+        self.addEventListener('message', event => {
+          event.ports[0].postMessage(readUserAgentSnapshot());
+        });
+      `);
+      return;
+    }
+
+    res.setHeader('Content-Type', 'text/html');
+    res.end('<!DOCTYPE html>');
+  });
+
+  return { server, requests };
+}
+
+export async function collectUserAgentOverrideTargetSnapshots(webContents: Electron.WebContents) {
+  const mainFrame = await webContents.executeJavaScript(`(() => {
+    ${snapshotScript}
+    return readUserAgentSnapshot();
+  })()`);
+
+  const subframe = await webContents.executeJavaScript(`
+    new Promise((resolve, reject) => {
+      const timeout = setTimeout(() => reject(new Error('subframe timed out')), 5000);
+      window.addEventListener('message', event => {
+        if (event.data?.type !== 'user-agent-snapshot') return;
+        clearTimeout(timeout);
+        resolve(event.data.snapshot);
+      }, { once: true });
+
+      const frame = document.createElement('iframe');
+      frame.src = '/subframe.html';
+      document.body.appendChild(frame);
+    })
+  `);
+
+  const dedicatedWorker = await webContents.executeJavaScript(`
+    new Promise((resolve, reject) => {
+      const worker = new Worker('/dedicated-worker.js');
+      worker.onerror = event => reject(event.message);
+      worker.onmessage = event => {
+        worker.terminate();
+        resolve(event.data);
+      };
+    })
+  `);
+
+  const sharedWorker = await webContents.executeJavaScript(`
+    new Promise((resolve, reject) => {
+      const worker = new SharedWorker('/shared-worker.js');
+      worker.onerror = event => reject(event.message);
+      worker.port.onmessage = event => {
+        worker.port.close();
+        resolve(event.data);
+      };
+      worker.port.start();
+    })
+  `);
+
+  const serviceWorker = await webContents.executeJavaScript(`
+    (async () => {
+      const registration = await navigator.serviceWorker.register('/service-worker.js');
+      const readyRegistration = await navigator.serviceWorker.ready;
+      const worker = readyRegistration.active || registration.active ||
+        registration.waiting || registration.installing;
+      if (!worker) throw new Error('service worker is not available');
+
+      const snapshot = await new Promise((resolve, reject) => {
+        const channel = new MessageChannel();
+        channel.port1.onmessage = event => resolve(event.data);
+        channel.port1.onmessageerror = event => reject(event);
+        worker.postMessage('user-agent', [channel.port2]);
+      });
+      await registration.unregister();
+      return snapshot;
+    })()
+  `);
+
+  return {
+    mainFrame,
+    subframe,
+    dedicatedWorker,
+    sharedWorker,
+    serviceWorker
+  } as UserAgentTargetSnapshots;
+}
